---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  schemaData?: object | object[];
  keywords?: string;
  preloadImage?: string;
  ogType?: string;
  noindex?: boolean;
  hreflang?: { lang: string; href: string }[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://jraftcreative.com/images/og-image.jpg',
  schemaData,
  keywords,
  preloadImage,
  ogType = 'website',
  noindex = false,
  hreflang = [],
} = Astro.props;

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  {keywords && <meta name="keywords" content={keywords}>}
  <meta name="author" content="Jraft Creative">
  <link rel="canonical" href={canonical}>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={ogTitle || title}>
  <meta property="og:description" content={ogDescription || description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:site_name" content="Jraft Creative">
  <meta property="og:image" content={ogImage}>
  <meta property="og:locale" content="en_SG">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle || title}>
  <meta name="twitter:description" content={ogDescription || description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Geo targeting -->
  <meta name="geo.region" content="SG">
  <meta name="geo.placename" content="Singapore">
  {noindex ? <meta name="robots" content="noindex, nofollow"> : <meta name="robots" content="index, follow">}
  {hreflang.map(h => <link rel="alternate" hreflang={h.lang} href={h.href} />)}

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=2">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2">
  <link rel="manifest" href="/site.webmanifest">

  <!-- LLM-readable site summary (GEO) -->
  <link rel="alternate" type="text/plain" href="https://jraftcreative.com/llms.txt" title="LLM site summary">

  <!-- RSS feed -->
  <link rel="alternate" type="application/rss+xml" href="https://jraftcreative.com/rss.xml" title="Jraft Creative Blog">

  <!-- Preload critical assets -->
  {preloadImage && <link rel="preload" href={preloadImage} as="image" fetchpriority="high">}

  <!-- Font preload -->
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Schema.org Structured Data -->
  {schemaData && (
    Array.isArray(schemaData)
      ? schemaData.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
      : <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  )}
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P7XX5KDQ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- Capture first-seen landing page for conversion attribution -->
  <script is:inline>
    (function() {
      try {
        if (!sessionStorage.getItem('jraft_landing_page')) {
          sessionStorage.setItem('jraft_landing_page', window.location.pathname + window.location.search);
        }
        if (!sessionStorage.getItem('jraft_landing_referrer')) {
          sessionStorage.setItem('jraft_landing_referrer', document.referrer || 'direct');
        }
      } catch (e) { /* sessionStorage unavailable */ }
    })();
  </script>

  <!-- Capture gclid (Google Ads click ID) for offline conversion import -->
  <script is:inline>
    (function() {
      // Step 1: Capture gclid from URL on landing
      try {
        var params = new URLSearchParams(window.location.search);
        var gclid = params.get('gclid');
        if (gclid) {
          localStorage.setItem('jraft_gclid', gclid);
          localStorage.setItem('jraft_gclid_ts', Date.now().toString());
        }
      } catch (e) { /* localStorage or URLSearchParams unavailable */ }

      // Step 2: Inject [ref:GCLID] into all wa.me link text params (90-day window)
      function injectRef() {
        try {
          var ts = parseInt(localStorage.getItem('jraft_gclid_ts') || '0', 10);
          var ninetyDays = 90 * 24 * 60 * 60 * 1000;
          if (!ts || (Date.now() - ts) >= ninetyDays) return;
          var stored = localStorage.getItem('jraft_gclid');
          if (!stored) return;
          var refTag = ' [ref:' + stored + ']';
          var links = document.querySelectorAll('a[href*="wa.me/"]');
          links.forEach(function(a) {
            try {
              var url = new URL(a.href);
              var text = url.searchParams.get('text') || '';
              if (text.indexOf('[ref:') === -1) {
                url.searchParams.set('text', text + refTag);
                a.href = url.toString();
              }
            } catch (e) { /* skip malformed link */ }
          });
        } catch (e) { /* localStorage unavailable */ }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', injectRef);
      } else {
        injectRef();
      }
    })();
  </script>

  <!-- Animated background -->
  <div class="animated-bg" aria-hidden="true">
    <div class="animated-bg__orb animated-bg__orb--1"></div>
    <div class="animated-bg__orb animated-bg__orb--2"></div>
    <div class="animated-bg__orb animated-bg__orb--3"></div>
    <div class="animated-bg__grid"></div>
  </div>

  <!-- Skip to content link for keyboard/screen reader users -->
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <Nav currentPath={currentPath} />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- Back to Top -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  <slot name="after-footer" />

  <!-- Google Tag Manager -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-P7XX5KDQ');
  </script>

  <!-- Google Ads Conversion Tracking -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-17551276654"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-17551276654');
  </script>

  <!-- Common JS -->
  <script is:inline>
    // Lazy-load background images
    var bgObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.backgroundImage = 'url(' + entry.target.dataset.bg + ')';
          bgObserver.unobserve(entry.target);
        }
      });
    }, { rootMargin: '200px' });
    document.querySelectorAll('[data-bg]').forEach(function(el) { bgObserver.observe(el); });

    // Mobile nav toggle with accessibility
    var navToggle = document.getElementById('navToggle');
    var navLinks = document.getElementById('navLinks');

    navToggle.addEventListener('click', function () {
      var isActive = navLinks.classList.toggle('active');
      navToggle.setAttribute('aria-expanded', isActive ? 'true' : 'false');
      navToggle.setAttribute('aria-label', isActive ? 'Close navigation menu' : 'Open navigation menu');
    });

    // Dropdown toggle on mobile with accessibility
    var dropdownWraps = document.querySelectorAll('.nav-dropdown-wrap');
    dropdownWraps.forEach(function(wrap) {
      var toggle = wrap.querySelector('.nav-dropdown-toggle');
      if (toggle) {
        toggle.addEventListener('click', function(e) {
          if (window.innerWidth <= 640) {
            e.preventDefault();
            // Close other open dropdowns
            dropdownWraps.forEach(function(otherWrap) {
              if (otherWrap !== wrap && otherWrap.classList.contains('open')) {
                otherWrap.classList.remove('open');
                var otherToggle = otherWrap.querySelector('.nav-dropdown-toggle');
                if (otherToggle) otherToggle.setAttribute('aria-expanded', 'false');
              }
            });
            var isOpen = wrap.classList.toggle('open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          }
        });
      }
    });

    document.querySelectorAll('.nav-links a:not(.nav-dropdown-toggle)').forEach(function (link) {
      link.addEventListener('click', function () {
        navLinks.classList.remove('active');
        navToggle.setAttribute('aria-expanded', 'false');
        navToggle.setAttribute('aria-label', 'Open navigation menu');
        dropdownWraps.forEach(function(wrap) {
          wrap.classList.remove('open');
          var toggle = wrap.querySelector('.nav-dropdown-toggle');
          if (toggle) toggle.setAttribute('aria-expanded', 'false');
        });
      });
    });

    // Navbar scroll effect + back to top visibility
    var nav = document.getElementById('nav');
    var backToTop = document.getElementById('backToTop');
    window.addEventListener('scroll', function () {
      nav.classList.toggle('scrolled', window.scrollY > 20);
      backToTop.classList.toggle('visible', window.scrollY > 600);
    });

    backToTop.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Scroll reveal.
    // threshold 0 + positive bottom rootMargin: any element that touches the
    // viewport (or sits just below it) reveals immediately — including content
    // already on screen at initial load. Previously threshold 0.1 with a
    // negative bottom margin left near-fold content stuck at opacity:0 (a blank
    // void) until the user scrolled. Surfaced site-wide once heroes were slimmed.
    var revealObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px 10% 0px' });

    document.querySelectorAll('.reveal').forEach(function (el) {
      revealObserver.observe(el);
    });

    // Safety net: if anything is still hidden after load (e.g. observer
    // edge cases), reveal everything within the first viewport immediately so
    // there is never a blank void on screen.
    window.addEventListener('load', function () {
      document.querySelectorAll('.reveal:not(.visible)').forEach(function (el) {
        if (el.getBoundingClientRect().top < window.innerHeight) {
          el.classList.add('visible');
        }
      });
    });
  </script>
</body>
</html>
