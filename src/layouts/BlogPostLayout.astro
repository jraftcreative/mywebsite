---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category: string;
  image: string;
  imageAlt: string;
  keywords: string[];
  slug: string;
}

const { title, description, date, author, category, image, imageAlt, keywords, slug } = Astro.props;

const canonical = `https://jraftcreative.com/blog/${slug}/`;
const ogImage = `https://jraftcreative.com${image}`;
const formattedDate = date.toLocaleDateString('en-SG', { year: 'numeric', month: 'long', day: 'numeric' });
const isoDate = date.toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: ogImage,
  datePublished: isoDate,
  dateModified: isoDate,
  author: {
    '@type': 'Organization',
    name: 'Jraft Creative',
    url: 'https://jraftcreative.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Jraft Creative',
    url: 'https://jraftcreative.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://jraftcreative.com/images/logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  keywords: keywords.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jraftcreative.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://jraftcreative.com/blog/' },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---

<BaseLayout
  title={`${title} | Jraft Creative Blog`}
  description={description}
  canonical={canonical}
  ogTitle={title}
  ogDescription={description}
  ogImage={ogImage}
  ogType="article"
  keywords={keywords.join(', ')}
  schemaData={[articleSchema, breadcrumbSchema]}
>
  <article class="blog-post">
    <div class="blog-post-hero">
      <div class="container">
        <nav class="blog-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/blog/">Blog</a>
          <span aria-hidden="true">/</span>
          <span>{title}</span>
        </nav>
        <div class="blog-post-meta">
          <span class="blog-post-category">{category}</span>
          <time datetime={isoDate}>{formattedDate}</time>
        </div>
        <h1>{title}</h1>
        <p class="blog-post-description">{description}</p>
      </div>
    </div>
    <div class="blog-post-image">
      <img src={image} alt={imageAlt} width="1200" height="630" loading="eager">
    </div>
    <div class="container blog-post-content">
      <slot />
    </div>
  </article>

  <!-- WhatsApp Button -->
  <a href={`https://wa.me/6582234578?text=${encodeURIComponent(`Hi, I just read your blog post "${title}" and have a question.`)}`} class="whatsapp-btn" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" slot="after-footer">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="#fff" aria-hidden="true"><path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.13 6.742 3.05 9.378L1.054 31.29l6.118-1.962A15.91 15.91 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.302 22.602c-.39 1.1-2.276 2.106-3.156 2.17-.796.058-1.78.082-2.872-.278a26.3 26.3 0 0 1-2.6-1.074c-4.576-2.186-7.566-6.826-7.796-7.142-.222-.316-1.836-2.478-1.836-4.726 0-2.248 1.162-3.356 1.574-3.814.39-.434.858-.542 1.144-.542.286 0 .572.004.82.014.264.012.618-.1.966.738.39.938 1.294 3.224 1.408 3.458.112.234.19.508.038.82-.15.316-.226.512-.448.79-.222.278-.468.62-.668.832-.222.234-.454.49-.196.962.26.47 1.154 1.906 2.478 3.088 1.702 1.52 3.136 1.99 3.582 2.214.448.222.708.19.968-.114.26-.306 1.118-1.302 1.416-1.75.298-.448.596-.37.998-.222.404.148 2.566 1.21 3.006 1.432.44.222.734.334.844.518.112.186.112 1.074-.278 2.174z"/></svg>
  </a>
</BaseLayout>
