---
/**
 * MarketingFunnelBlock
 * ----------------------------------------------------------------------------
 * In-content block that funnels visitors from website-design landing pages
 * (transactional "I want a website") to the matching marketing-service sibling
 * page ("I want growth / leads / patients / bookings"). Solves keyword
 * cannibalisation between [industry]-website-singapore and
 * [industry]-marketing-singapore pages by giving each one a clear handoff
 * to the other.
 *
 * Inserted at the BOTTOM of the slot on industry website pages, just above
 * the page's final contact CTA section.
 *
 * Brand: #49b889 accent on the site's dark palette — mirrors the colour
 * vocabulary of GrowthBundleCTA (--bg-alt / --accent / muted-light text)
 * so it reads as a quieter sibling-page funnel rather than a primary
 * product CTA.
 */
interface Props {
  industry: string;        // displayed in-copy, e.g. "clinic", "law firm"
  marketingHref: string;   // target URL, e.g. "/clinic-marketing-singapore/"
  outcomeLine: string;     // outcome promise, e.g. "See how we'd fill your appointment book"
  ctaText: string;         // anchor text, e.g. "Clinic Marketing Singapore"
  eyebrow?: string;        // override eyebrow line for non-website parent pages
  leadInLine?: string;     // override lead-in sentence; defaults to website-context wording
}
const {
  industry,
  marketingHref,
  outcomeLine,
  ctaText,
  eyebrow,
  leadInLine,
} = Astro.props;
const eyebrowText = eyebrow ?? `Already have a ${industry} website?`;
const leadIn = leadInLine ?? `A website doesn't grow a ${industry} — marketing does.`;
---
<aside class="marketing-funnel-block">
  <div class="mfb-inner">
    <p class="mfb-eyebrow">{eyebrowText}</p>
    <p class="mfb-line">
      {leadIn} {outcomeLine}
    </p>
    <a href={marketingHref} class="mfb-cta">
      → {ctaText}
    </a>
  </div>
</aside>

<style>
.marketing-funnel-block {
  background: var(--bg-alt, rgba(13, 13, 20, 0.6));
  border-left: 4px solid var(--accent, #49b889);
  border-top: 1px solid var(--border, rgba(255, 255, 255, 0.06));
  border-right: 1px solid var(--border, rgba(255, 255, 255, 0.06));
  border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.06));
  padding: 1.5rem 1.75rem;
  margin: 2.5rem auto;
  border-radius: 4px;
  max-width: 760px;
}
.mfb-eyebrow {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text, #ffffff);
  margin: 0 0 0.5rem;
  letter-spacing: 0.01em;
}
.mfb-line {
  font-size: 1rem;
  line-height: 1.55;
  color: var(--text-secondary, rgba(255, 255, 255, 0.75));
  margin: 0 0 1rem;
}
.mfb-cta {
  display: inline-block;
  font-weight: 600;
  color: var(--accent, #49b889);
  text-decoration: none;
  font-size: 1rem;
  transition: color 0.15s;
}
.mfb-cta:hover { color: var(--text, #ffffff); }
</style>
