---
/**
 * MarketingFunnelBlock
 * ----------------------------------------------------------------------------
 * In-content block that funnels visitors from website-design landing pages
 * (transactional "I want a website") to the matching marketing-service sibling
 * page ("I want growth / leads / patients / bookings"). Solves keyword
 * cannibalisation between [industry]-website-singapore and
 * [industry]-marketing-singapore pages by giving each one a clear handoff
 * to the other.
 *
 * Inserted at the BOTTOM of the slot on industry website pages, just above
 * the page's final contact CTA section.
 *
 * Brand: #39BB9D accent on light-background callout (deliberately quieter
 * than the GrowthBundleCTA midpage card — this is a sibling-page funnel,
 * not a primary product CTA).
 */
interface Props {
  industry: string;        // displayed in-copy, e.g. "clinic", "law firm"
  marketingHref: string;   // target URL, e.g. "/clinic-marketing-singapore/"
  outcomeLine: string;     // outcome promise, e.g. "See how we'd fill your appointment book"
  ctaText: string;         // anchor text, e.g. "Clinic Marketing Singapore"
}
const { industry, marketingHref, outcomeLine, ctaText } = Astro.props;
---
<aside class="marketing-funnel-block">
  <div class="mfb-inner">
    <p class="mfb-eyebrow">Already have a {industry} website?</p>
    <p class="mfb-line">
      A website doesn't grow a {industry} — marketing does. {outcomeLine}.
    </p>
    <a href={marketingHref} class="mfb-cta">
      → {ctaText}
    </a>
  </div>
</aside>

<style>
.marketing-funnel-block {
  background: #f8f9fa;
  border-left: 4px solid #39BB9D;
  padding: 1.5rem 1.75rem;
  margin: 2.5rem auto;
  border-radius: 4px;
  max-width: 760px;
}
.mfb-eyebrow {
  font-size: 0.875rem;
  font-weight: 600;
  color: #1F1F1F;
  margin: 0 0 0.5rem;
  letter-spacing: 0.01em;
}
.mfb-line {
  font-size: 1rem;
  line-height: 1.55;
  color: #4a4a4a;
  margin: 0 0 1rem;
}
.mfb-cta {
  display: inline-block;
  font-weight: 600;
  color: #39BB9D;
  text-decoration: none;
  font-size: 1rem;
  transition: color 0.15s;
}
.mfb-cta:hover { color: #1F1F1F; }
</style>
