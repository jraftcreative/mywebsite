const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "ChatGPT Optimisation Singapore",
    "description": "Get your brand recommended by ChatGPT in Singapore. Specialist ChatGPT optimisation to ensure AI names your business when users ask for recommendations. From S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "ChatGPT Optimisation",
    "offers": [
      { "@type": "Offer", "name": "GEO Essentials", "price": "3000", "priceCurrency": "SGD", "description": "AI visibility audit, schema markup, content optimisation (5 pages/mo), llms.txt setup, monthly reporting" },
      { "@type": "Offer", "name": "GEO Growth", "price": "5000", "priceCurrency": "SGD", "description": "Everything in Essentials plus 20 pages/mo, authority building, answer engine content, bi-weekly reporting, dedicated strategist" },
      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do I get my brand recommended by ChatGPT?", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPT recommends brands it can verify through structured data, third-party citations, and authoritative content. We optimise your entity signals, build citation-ready content, and strengthen your presence on the sources ChatGPT trusts so it confidently names your brand in answers." } },
      { "@type": "Question", "name": "Why doesn't ChatGPT mention my brand?", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPT relies on patterns from its training data and real-time browsing sources. If your brand lacks structured data, has thin third-party mentions, or doesn't appear on the sites ChatGPT references, it simply won't have enough signal to recommend you. Most businesses have near-zero ChatGPT visibility without deliberate optimisation." } },
      { "@type": "Question", "name": "How does ChatGPT decide which brands to recommend?", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPT evaluates entity clarity, consistency of brand information across the web, third-party authority signals like reviews and directory listings, and content that directly answers user queries. Brands with strong structured data and widespread credible mentions get cited far more often." } },
      { "@type": "Question", "name": "How much does ChatGPT optimisation cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Our ChatGPT optimisation plans start at $3,000 SGD/month for the Essentials package, which covers AI audits, schema markup, and content optimisation. Growth plans at $5,000/month include authority building and a dedicated strategist. Enterprise plans from $10,000/month deliver full-service AI visibility across all platforms." } },
      { "@type": "Question", "name": "How long does it take to appear in ChatGPT recommendations?", "acceptedAnswer": { "@type": "Answer", "text": "Technical foundations like schema markup and llms.txt can influence ChatGPT visibility within weeks. Broader citation growth through authority building and content optimisation typically shows measurable results within 60 to 90 days, with compounding improvements as your brand signals strengthen over time." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "ChatGPT Optimisation Singapore", "item": "https://jraftcreative.com/chatgpt-optimisation-singapore/" }
    ]
