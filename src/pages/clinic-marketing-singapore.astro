---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Clinic Marketing Singapore",
    "description": "Digital marketing for GP, family medicine and specialist medical clinics in Singapore (non-aesthetic). Google Ads, neighbourhood social content, GBP management and CHAS-aware messaging — every asset MOH-reviewed. From S$2,999/month with the Growth Bundle.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Medical Clinic Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Growth Bundle for Medical Clinics", "price": "2999", "priceCurrency": "SGD", "description": "Paid ads (Google + Meta), 12 social content pieces per month, GBP management, and one consolidated monthly report — MOH-reviewed before every publish." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your clinic ads follow MOH advertising rules?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, caption and content piece is reviewed against the MOH Private Hospitals and Medical Clinics Act advertising rules and the Singapore Medical Council ethical code before publication. That means no superlatives like 'best clinic', no treatment outcome claims, no patient testimonials phrased as endorsements, and no comparative claims naming other clinics. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "What does GP and clinic marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our Growth Bundle for medical clinics is $2,999 SGD/month, no lock-in. It covers paid ads on Google and Meta, 12 social posts a month, Google Business Profile management, and one consolidated monthly report. Multi-doctor practices or specialist clinics adding video, KOL doctor content or multi-language campaigns typically sit between $5,500 and $10,000/month." } },
      { "@type": "Question", "name": "Can you help us compete with HDB-block walk-ins and chain clinics?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The chain clinics and high-traffic HDB-block GPs aren't winning on medicine, they're winning on convenience and visibility. We close that gap with neighbourhood-level Google Ads, a properly managed GBP that shows up in the local map pack, and social content that gives residents a reason to choose your clinic over the walk-in two blocks away." } },
      { "@type": "Question", "name": "Can you handle CHAS, Medisave and MediShield messaging?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. CHAS Blue, Orange, Green and Pioneer/Merdeka Generation eligibility, Medisave-claimable procedures, MediShield Life integration for specialist clinics, and chronic disease management programmes are all common targeting and creative angles. We frame them as factual operational details, which keeps them MOH-compliant — they're patient access information, not promotional claims." } },
      { "@type": "Question", "name": "Can you run content in Mandarin, Malay or Tamil?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. For clinics serving HDB estates with strong Mandarin, Malay or Tamil-speaking populations, we run dual-language ad creative and social content. Our copywriter handles English and Mandarin in-house, and we work with vetted Malay and Tamil reviewers for those languages. All non-English content goes through the same MOH-compliance check before publication." } },
      { "@type": "Question", "name": "How do we compete with telemedicine apps like Doctor Anywhere or WhiteCoat?", "acceptedAnswer": { "@type": "Answer", "text": "You don't beat telemedicine on convenience — you beat it on the things telemedicine can't do. Same-day in-person appointments, physical examinations, vaccinations, chronic disease monitoring, paediatric care, and continuity with a doctor who knows the family. The marketing job is making those advantages obvious in ads and content. We've found this works better than trying to out-discount the apps on consultation price." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Clinic Marketing Singapore", "item": "https://jraftcreative.com/clinic-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Patient Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Clinic Marketing in Singapore — GP & Specialist Practice Ads"
  description="Digital marketing for SG GP, family practice and specialist clinics. Google Ads, neighbourhood content, CHAS angles, multi-language, MOH-reviewed. From $2,999/mo."
  canonical="https://jraftcreative.com/clinic-marketing-singapore/"
  ogTitle="Clinic Marketing in Singapore — GP & Specialist Practice Ads"
  ogDescription="Digital marketing for SG GP, family practice and specialist clinics. Google Ads, neighbourhood content, CHAS angles, multi-language, MOH-reviewed. From $2,999/mo."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="clinic marketing singapore, gp marketing singapore, medical clinic marketing, family clinic marketing singapore, specialist clinic marketing, gp google ads singapore, clinic social media singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Clinic Marketing"
  heroTitle='Marketing for <span class="highlight">GP &amp; Medical Clinics in Singapore</span>'
  heroSubtitle="Built for how SG patients actually find a doctor — Google Maps, GBP, and a clear shortlist. We run the ads, social content and Google Business Profile work that puts your practice in front of patients searching tonight. Every asset MOH-reviewed before it goes live."
  heroImage="/images/service-clinic.webp"
  heroImageAlt="GP and family medical clinic in Singapore — clinic marketing"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20medical%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my medical clinic in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at where your patients are coming from"
  ctaDescription="Tell us your clinic's location, what kind of practice you run, and what your current new-patient mix looks like. We'll come back inside 24 hours with where we'd start."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20medical%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why GP and medical clinics need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best Doctor</span> in the Estate Still Loses Patients to the <span class="highlight">Clinic That's Easier to Find</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has more than 1,800 GP clinics, a wall of telemedicine apps, and hospital outpatient teams running paid campaigns against you every day. The clinics holding steady patient volume aren't necessarily delivering better care — they're being seen at the moments that matter, and they're doing it inside MOH's advertising rules.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Compliance Line</h3>
            <p>Clinic advertising is governed by MOH rules under the Healthcare Services Act (HCSA) and the Singapore Medical Council ethical code — no superlatives, no outcome claims, no testimonials as endorsements. Generalist agencies don't know these limits, and one careless post creates real regulatory exposure for your practice.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Validation Step</h3>
            <p>Before a patient calls, they read your Google reviews, check your hours, scan your doctor credentials, and decide whether you look like a practice they can trust. A thin, abandoned Google Business Profile and a silent social feed quietly send that patient to the clinic that looks more cared-for.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Clinic Near Me" Moment</h3>
            <p>Most clinic demand is local and immediate — "clinic near me", "GP [estate]", "paediatrician [area]" — searched on a phone, often the same day. The GP on the ground floor of the next block wins by geography. If you're not in the map pack and the neighbourhood ads, residents don't know you exist.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for medical clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Clinic <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for GP, family and specialist clinics — combining local SEO, AI search optimisation (GEO), paid search, neighbourhood social content, branding, and conversion-focused web design, all reviewed against Singapore's healthcare advertising rules before anything goes live.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO &amp; Google Business Profile</a></h3>
            <p>Rank for "clinic near me", "GP [estate]" and treatment searches across your real catchment. Actively managed GBP — weekly posts, photo refresh, review responses, accurate holiday hours — so you show up in the local map pack instead of an abandoned listing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/clinic-ai-search-optimisation-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when patients ask ChatGPT, Gemini, Perplexity or Google AI Mode for "family clinic in [estate]" or "GP open now near me." AI-friendly schema and the same citation playbook we use for our own agency, kept factual and MOH-compliant.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google &amp; Meta Ads</a></h3>
            <p>Search ads on the queries patients type when they need a clinic that day, with the geo-radius tightened to your real catchment — not a Singapore-wide blast. Meta ads layered on for awareness in the same postal codes, with conversion tracking from click to enquiry.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Clinics</a></h3>
            <p>Doctor introductions, what to expect at a first visit, vaccination schedules, chronic disease and CHAS explainers across Instagram, TikTok and Facebook. Factual, useful content that builds neighbourhood familiarity — no outcome claims, no testimonial-as-results language.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Clinics</a></h3>
            <p>Clinic identity, doctor positioning, and a consistent look across signage, GBP, ads and social — the trust signals that tell a researching patient your practice is established and credible, not a faceless name on a directory listing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/clinic-website-design-singapore/">Websites for Clinics</a></h3>
            <p>Service pages, doctor profiles, clear hours and location, CHAS and panel information, and a single-step enquiry path — built mobile-first and fast, so the patient who found you on their phone actually books.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for clinic marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">SG Patients</span> Actually <span class="highlight">Choose a Clinic</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching clinics are generalists who don't understand MOH advertising rules or the way Singapore patients pick a doctor. We are the opposite — full-service, compliance-aware, and built around real catchment behaviour: Google Maps, reviews, CHAS and panel eligibility, and the neighbourhood-tight visibility that actually moves new-patient flow.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>MOH-Reviewed Before Publish</h3>
            <p>Every ad, caption and post is checked against MOH advertising rules and the SMC ethical code before it goes live — no superlatives, no outcome claims, no testimonials as endorsements. You build authority without putting your clinic's standing at risk, and the compliance log sits inside your monthly report.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, Meta, social, branding and websites under one roof — plus CHAS, Medisave and Mandarin/Malay/Tamil angles handled properly. No coordinating between three vendors; every channel carries the same compliant positioning.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enquiries, Not Vanity Metrics</h3>
            <p>We report calls, form fills and enquiries by channel and the cost per enquiry — not likes. One page a month, no lock-in, no 40-slide deck. Clinics stay for the patient pipeline, not because they're trapped in a contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PATIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Patient Funnel — how Singapore patients decide on a clinic">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Patient Funnel</p>
        <h2>How <span class="highlight">Singapore Patients</span> Actually <span class="highlight">Choose a Clinic</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first "clinic near me" search to a regular family doctor, every patient in Singapore moves through the same five stages. We build compliant marketing that shows up at each one — from discovery through to the return visit that builds a loyal patient base.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google Maps, "clinic near me", GBP, referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, doctor credentials, hours, CHAS panel</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist nearby clinics — convenience &amp; trust</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Call, WhatsApp, form, or simply walk in</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Repeat visits, chronic care, family &amp; referrals</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Clinic marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Clinic Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Clinics of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card featured reveal reveal-d1">
            <h3>Growth Bundle</h3>
            <div class="price">$2,999 <span>SGD/mo</span></div>
            <p class="pricing-desc">For solo GP and family practices building consistent new-patient flow.</p>
            <ul class="pricing-features">
              <li>Paid ads (Google + Meta)</li>
              <li>12 social content pieces / month</li>
              <li>Google Business Profile management</li>
              <li>One consolidated monthly report</li>
              <li>MOH-reviewed before every publish</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d2">
            <h3>Multi-Doctor</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For 2–5 doctor clinics and specialist practices scaling enquiries.</p>
            <ul class="pricing-features">
              <li>Everything in the Growth Bundle</li>
              <li>Multi-doctor &amp; specialist content</li>
              <li>Video content production</li>
              <li>Dual-language campaigns (Mandarin / Malay / Tamil)</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Group / Specialist</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For specialist clinics and small clinic groups across multiple locations.</p>
            <ul class="pricing-features">
              <li>Everything in Multi-Doctor</li>
              <li>KOL doctor content</li>
              <li>Multi-location GBP &amp; per-branch ad geos</li>
              <li>Dedicated account strategist</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about clinic marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions clinic owners actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your clinic ads follow MOH advertising rules?</summary>
          <div class="faq-answer"><p>Yes. Every ad, caption and content piece is reviewed against the MOH Private Hospitals and Medical Clinics Act advertising rules and the Singapore Medical Council ethical code before publication. That means no superlatives like "best clinic", no treatment outcome claims, no patient testimonials phrased as endorsements, and no comparative claims naming other clinics. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What does GP and clinic marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>Our Growth Bundle for medical clinics is $2,999 SGD/month, no lock-in. It covers paid ads on Google and Meta, 12 social posts a month, Google Business Profile management, and one consolidated monthly report. Multi-doctor practices or specialist clinics adding video, KOL doctor content or multi-language campaigns typically sit between $5,500 and $10,000/month.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you help us compete with HDB-block walk-ins and chain clinics?</summary>
          <div class="faq-answer"><p>Yes. The chain clinics and high-traffic HDB-block GPs aren't winning on medicine, they're winning on convenience and visibility. We close that gap with neighbourhood-level Google Ads, a properly managed GBP that shows up in the local map pack, and social content that gives residents a reason to choose your clinic over the walk-in two blocks away.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you handle CHAS, Medisave and MediShield messaging?</summary>
          <div class="faq-answer"><p>Yes. CHAS Blue, Orange, Green and Pioneer/Merdeka Generation eligibility, Medisave-claimable procedures, MediShield Life integration for specialist clinics, and chronic disease management programmes are all common targeting and creative angles. We frame them as factual operational details, which keeps them MOH-compliant — they're patient access information, not promotional claims.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you run content in Mandarin, Malay or Tamil?</summary>
          <div class="faq-answer"><p>Yes. For clinics serving HDB estates with strong Mandarin, Malay or Tamil-speaking populations, we run dual-language ad creative and social content. Our copywriter handles English and Mandarin in-house, and we work with vetted Malay and Tamil reviewers for those languages. All non-English content goes through the same MOH-compliance check before publication.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do we compete with telemedicine apps like Doctor Anywhere or WhiteCoat?</summary>
          <div class="faq-answer"><p>You don't beat telemedicine on convenience — you beat it on the things telemedicine can't do. Same-day in-person appointments, physical examinations, vaccinations, chronic disease monitoring, paediatric care, and continuity with a doctor who knows the family. The marketing job is making those advantages obvious in ads and content. We've found this works better than trying to out-discount the apps on consultation price.</p></div>
        </details>
