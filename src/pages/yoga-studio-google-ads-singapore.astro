---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Yoga Studio Google Ads Singapore",
    "description": "Google Ads management for yoga studios in Singapore — trial class campaigns, membership promotions, class-specific targeting, and conversion tracking. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for Yoga Studios",
    "offers": [
      { "@type": "Offer", "name": "Starter Yoga Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, yoga keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Yoga Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, landing page optimisation, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Yoga Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should yoga studios budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most yoga studios start with a monthly ad spend of $1,000–$3,000 on top of management fees. Keywords like 'yoga class Singapore' typically cost $1.50–$5 per click, while more specific terms like 'hot yoga Tanjong Pagar' cost less due to lower competition. We recommend starting lean, then scaling based on cost-per-trial data." } },
      { "@type": "Question", "name": "Which yoga keywords convert best in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "High-intent keywords like 'yoga trial class Singapore', 'beginner yoga near me', and class-specific terms like 'prenatal yoga Singapore' or 'hot yoga CBD' tend to convert best. We also target neighbourhood-level queries — 'yoga studio Tiong Bahru' or 'yoga class Tanjong Pagar' — to capture students near your studio." } },
      { "@type": "Question", "name": "Can Google Ads promote trial class offers for yoga studios?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Trial class campaigns are among the highest-converting ad types for yoga studios. We create dedicated campaigns with ad copy highlighting your trial offer — whether it is a free first class, $10 trial, or intro week pass — paired with a landing page designed to capture bookings instantly." } },
      { "@type": "Question", "name": "How do you track whether Google Ads lead to actual memberships?", "acceptedAnswer": { "@type": "Answer", "text": "We set up conversion tracking across form submissions, booking widget completions, phone calls, and WhatsApp messages. Each conversion is attributed to the specific keyword and ad that generated it. Over time, we can map the full journey from ad click to trial booking to paid membership sign-up." } },
      { "@type": "Question", "name": "How long before Google Ads campaigns deliver consistent leads for a yoga studio?", "acceptedAnswer": { "@type": "Answer", "text": "You can expect initial enquiries within the first week. However, it takes 4–6 weeks for campaigns to gather enough data for proper optimisation — refining keyword bids, testing ad copy, and improving landing page conversion rates. Most studios see stable, cost-effective lead flow from month two onwards." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Yoga Studio Google Ads Singapore", "item": "https://jraftcreative.com/yoga-studio-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Yoga Studio Google Ads Singapore — PPC for Yoga Studios | Jraft Creative"
  description="Google Ads management for yoga studios in Singapore. Trial class campaigns, membership promotions, class-specific targeting, and full conversion tracking. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/yoga-studio-google-ads-singapore/"
  ogTitle="Yoga Studio Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for yoga studios in Singapore. Fill trial classes, drive memberships, and target students by class type and location. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="yoga studio google ads singapore, yoga studio advertising singapore, google ads for yoga studios, ppc yoga singapore, yoga marketing singapore, yoga studio digital advertising, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Yoga Studio Google Ads Singapore"
  heroTitle='Google Ads for Yoga Studios <span class="highlight">in Singapore</span>'
  heroSubtitle="Students are searching for yoga classes right now — hot yoga, vinyasa, Yin, prenatal, and everything in between. We build Google Ads campaigns that put your studio at the top of search results, fill trial classes, and convert first-timers into long-term members."
  heroImage="/images/service-yoga.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my yoga studio in Singapore."
  ctaLabel="Grow Your Studio"
  ctaTitle="Get a Free Yoga Studio Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll review your local competition, identify the highest-value keywords for your class types and location, and map out a Google Ads strategy to fill your studio. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20yoga%20studio%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for yoga studios">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Losing New Students to Studios That Show Up First?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has over 300 yoga studios competing for a health-conscious audience that keeps growing. When someone searches "yoga class near me" or "hot yoga Singapore", they see a page of paid ads and map results. If your studio isn't visible, that potential student books a trial at the studio that is — often a competitor less than two MRT stops away.</p>
        <p>Without structured Google Ads, yoga studios waste budget on broad keywords that attract casual browsers, send traffic to a homepage that doesn't mention the specific class being searched, and have no tracking to know which campaigns actually drive trial bookings. Meanwhile, studios with optimised campaigns are filling mats at a fraction of the cost.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for yoga studios">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Yoga Studio Ad Services</p>
        <h2>Google Ads Strategy Built for Yoga Studios</h2>
      </div>
      <div class="section-content reveal">
        <p>We build Google Ads campaigns specifically for yoga studios in Singapore — targeting the exact class types students search for, in the neighbourhoods where your studio operates. Whether you run hot yoga in the CBD, prenatal classes in the East, or vinyasa in Bukit Timah, every campaign is designed to drive trial bookings and membership sign-ups.</p>
        <p>Our approach covers class-specific keywords, location targeting around your studio, and seasonal campaigns for New Year resolutions, corporate wellness partnerships, and workshop promotions — ensuring your ad budget captures students with real intent to practise.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Trial Class &amp; Intro Offer Campaigns</h3>
            <p>Dedicated campaigns promoting your trial classes, first-class-free offers, or intro week passes. Ad copy and landing pages designed to reduce friction and get students booked — targeting high-intent keywords like "yoga trial class Singapore" and "beginner yoga near me".</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Class-Specific &amp; Location Targeting</h3>
            <p>Separate campaigns for each class type — hot yoga, Yin, vinyasa, Ashtanga, prenatal — combined with neighbourhood-level targeting. Reach students searching for the specific style of yoga you teach, within walking or commuting distance of your studio.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Membership Conversion Tracking</h3>
            <p>Full tracking setup across booking widget completions, form submissions, phone calls, and WhatsApp messages. Every trial booking and membership enquiry is attributed to the keyword and ad that generated it — so you know your true cost per new member.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Seasonal &amp; Promo Campaigns</h3>
            <p>Timed campaigns for peak interest periods — January fitness resolutions, post-holiday wellness, teacher training sign-ups, and workshop promotions. Capture surge demand when it happens with ready-to-launch ad sets and landing pages.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for yoga studio Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>We Understand What Fills Yoga Studios</h2>
      </div>
      <div class="section-content reveal">
        <p>We've run ad campaigns for fitness and wellness businesses across Singapore and understand how yoga students search, compare, and book. Here's why studios choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Yoga &amp; Wellness Market Knowledge</h3>
            <p>We know which class types have the highest search volume in Singapore, how students compare studios, and which keywords signal a student ready to book versus one still browsing. That knowledge shapes every campaign we build.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each trial booking and membership enquiry costs.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that scale with your studio. Ramp up before peak seasons, pause during quieter months — no penalties, no minimum commitments, no long-term lock-ins.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Trial-to-Member Optimisation</h3>
            <p>We don't just drive trial bookings — we optimise the entire funnel from ad click to trial attendance to paid membership. Continuous testing, bid adjustments, and landing page improvements lower your cost per member over time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Yoga studio Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Yoga Ads Pricing</p>
        <h2>Google Ads Plans for Yoga Studios</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For yoga studios launching their first Google Ads campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Yoga keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For studios scaling across multiple class types and locations.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; ad copy optimisation</li>
              <li>Landing page optimisation</li>
              <li>Competitor ad analysis</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-location yoga businesses maximising reach island-wide.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for yoga studios">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Yoga Studio Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should yoga studios budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Most yoga studios start with a monthly ad spend of $1,000–$3,000 on top of management fees. Keywords like "yoga class Singapore" typically cost $1.50–$5 per click, while more specific terms like "hot yoga Tanjong Pagar" cost less due to lower competition. We recommend starting lean, then scaling based on cost-per-trial data.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which yoga keywords convert best in Singapore?</summary>
          <div class="faq-answer"><p>High-intent keywords like "yoga trial class Singapore", "beginner yoga near me", and class-specific terms like "prenatal yoga Singapore" or "hot yoga CBD" tend to convert best. We also target neighbourhood-level queries — "yoga studio Tiong Bahru" or "yoga class Tanjong Pagar" — to capture students near your studio.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can Google Ads promote trial class offers for yoga studios?</summary>
          <div class="faq-answer"><p>Yes. Trial class campaigns are among the highest-converting ad types for yoga studios. We create dedicated campaigns with ad copy highlighting your trial offer — whether it is a free first class, $10 trial, or intro week pass — paired with a landing page designed to capture bookings instantly.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you track whether Google Ads lead to actual memberships?</summary>
          <div class="faq-answer"><p>We set up conversion tracking across form submissions, booking widget completions, phone calls, and WhatsApp messages. Each conversion is attributed to the specific keyword and ad that generated it. Over time, we can map the full journey from ad click to trial booking to paid membership sign-up.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before Google Ads campaigns deliver consistent leads for a yoga studio?</summary>
          <div class="faq-answer"><p>You can expect initial enquiries within the first week. However, it takes 4–6 weeks for campaigns to gather enough data for proper optimisation — refining keyword bids, testing ad copy, and improving landing page conversion rates. Most studios see stable, cost-effective lead flow from month two onwards.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
