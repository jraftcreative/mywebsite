---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Restaurant Marketing Singapore",
    "description": "Full-service marketing agency for restaurants in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, and AI search — built for dine-in, delivery, and multi-outlet operators. From S$1,800/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Restaurant Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Restaurant Marketing", "price": "1800", "priceCurrency": "SGD", "description": "Single-channel focus (SEO + GBP or Social), Google Business Profile optimisation, review-velocity playbook, monthly content, and reporting for single-outlet restaurants" },
      { "@type": "Offer", "name": "Growth Restaurant Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Multi-channel: SEO + Google Ads + IG/TikTok, food photography direction, reservation and delivery tracking, and bi-weekly reporting for established restaurants and small chains" },
      { "@type": "Offer", "name": "Enterprise Restaurant Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Full-service across all 6 channels, dedicated strategist, video production for Reels and TikTok, brand refresh, in-store collateral, and weekly reporting for multi-outlet restaurant groups" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does restaurant marketing cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Restaurant marketing in Singapore starts at S$1,800/month for essential single-channel work (typically Google Business Profile plus SEO or social content). Growth packages at S$3,000/month combine SEO, Google Ads, and IG/TikTok with food photography direction. Enterprise packages at S$5,500+/month add video production, brand refresh, and a dedicated strategist for multi-outlet restaurant groups. Single-outlet restaurants typically start at Essential, while small chains running 2-5 outlets fit the Growth tier." } },
      { "@type": "Question", "name": "Why is Google Business Profile so important for restaurants in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Diners searching 'best dim sum Chinatown' or 'Italian restaurant Tanjong Pagar' decide based on the Google Maps three-pack — the top three results that appear on the map. Google Business Profile signals (review count, recency, photos, posts, response rate, and category accuracy) decide which restaurants land in that three-pack. Most restaurants leave GBP underbuilt, which means even outlets with great food lose covers to weaker competitors with better-optimised profiles." } },
      { "@type": "Question", "name": "What's the buyer journey for a restaurant diner in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Singapore restaurant diners move through five stages: Discover (IG/TikTok scrolling, friend recommendations, food blogger content) → Choose (Google Maps three-pack, reviews, ChatGPT/AI search, Burpple/Chope listings) → First Visit (decision based on menu, photos, reviews) → Return (loyalty driven by experience, follow-up content, IG/TikTok presence) → Advocate (UGC posts, Google reviews, word-of-mouth). Marketing for restaurants needs to show up at every stage — not just the bottom-of-funnel reservation form." } },
      { "@type": "Question", "name": "Can restaurant marketing reduce my dependence on delivery platforms?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Delivery platforms like GrabFood, Foodpanda, and Deliveroo charge 25-30% commission per order. By ranking on Google for 'food delivery [neighbourhood]' and cuisine-specific delivery searches, building a strong Google Business Profile, and running direct-response IG/TikTok content, you drive orders to your own website and reservation flow — keeping the full margin instead of bleeding it to platforms. Over 12-18 months this typically becomes one of the highest-ROI channels for established restaurants." } },
      { "@type": "Question", "name": "How long before restaurant marketing brings more covers and orders?", "acceptedAnswer": { "@type": "Answer", "text": "Google Business Profile work and Google Ads can lift discovery and bookings within the first 2-4 weeks. Social media content cadence compounds over 8-12 weeks as branded content builds following and UGC. SEO and AI search citations typically show ranking improvements within 3-6 months for neighbourhood and cuisine-specific keywords. Most restaurants see measurable reservation and online-order lift inside the first quarter once GBP, reviews, and social are running together." } },
      { "@type": "Question", "name": "Do you work with restaurants that have multiple outlets?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Multi-outlet restaurant marketing is a core strength. Each outlet gets its own Google Business Profile, location-specific catchment SEO, geo-targeted ads, and localised social content — while the master brand stays consistent across the chain. We handle franchise rollouts, new outlet launches, and existing-chain consolidation under one strategy." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Restaurant Marketing Singapore", "item": "https://jraftcreative.com/restaurant-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Restaurant Buyer Funnel — 5-stage horizontal flow with green accents */
  .fnb-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .fnb-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .fnb-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Restaurant Marketing Singapore | Jraft Creative"
  description="Full-service restaurant marketing agency in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, AI search — for dine-in, delivery, and multi-outlet operators. From $1,800/mo."
  canonical="https://jraftcreative.com/restaurant-marketing-singapore/"
  ogTitle="Restaurant Marketing Singapore | Jraft Creative"
  ogDescription="Full-service restaurant marketing agency in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, AI search — from $1,800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="restaurant marketing singapore, restaurant digital marketing singapore, restaurant marketing agency singapore, dine-in marketing singapore, restaurant seo singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Restaurant Marketing Singapore"
  heroTitle='Marketing Agency for <span class="highlight">Restaurants in Singapore</span>'
  heroSubtitle="Singapore diners decide where to eat on the Google Maps three-pack, IG Reels, and increasingly ChatGPT — long before they pick up the phone. We build full-service marketing strategies (Google Business Profile, SEO, GEO, Google Ads, IG/TikTok, branding, websites) designed for how dine-in, delivery, and multi-outlet restaurants actually win covers in Singapore."
  heroImage="/images/service-restaurant.webp"
  heroImageAlt="Singapore restaurant interior — restaurant marketing agency"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20a%20restaurant%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I run a restaurant in Singapore and need marketing help."
  ctaLabel="Ready to Get Started?"
  ctaTitle='Let Us <span class="highlight">Fill</span> Your <span class="highlight">Tables</span>'
  ctaDescription="Book a free consultation and tell us about your restaurant — concept, catchment, outlet count, current marketing. We'll get back to you within 24 hours with a tailored, channel-by-channel marketing plan."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20a%20restaurant%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why restaurants need specialised marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Restaurants Are Still <span class="highlight">Losing Covers</span> to Operators with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore restaurant diners decide on the Google Maps three-pack, the IG Reels feed, and the food blogger they trust — long before they decide on the food. The restaurants winning covers are not always the ones with the best chefs. They are the ones showing up where diners actually decide.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Three-Pack Decides</h3>
            <p>When diners search "Italian restaurant Tanjong Pagar" or "dim sum Chinatown," the Google Maps three-pack drives the bookings. Review count, recency, photos, and category signals decide which restaurants surface — and most operators leave Google Business Profile half-built.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Delivery Commission Drag</h3>
            <p>GrabFood, Foodpanda, and Deliveroo charge 25-30% per order. Restaurants without their own SEO, Google Ads, and ordering flow effectively rent their customer base from the aggregators — paying that 25-30% every month forever.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Content Treadmill</h3>
            <p>Restaurant IG and TikTok are saturated. Winning operators are not the ones with the prettiest hero shot — they are the ones running a branded content cadence, on-brand UGC, and creator collaborations as a monthly system, not a hopeful post.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for restaurants in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Restaurant <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for restaurants — combining Google Business Profile and catchment SEO, AI search optimisation, paid search, social content, branding, and conversion-focused restaurant websites.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-seo-singapore/">SEO for Restaurants</a></h3>
            <p>Rank for "best [cuisine] [neighbourhood]" and delivery-intent searches across every SG catchment. Google Business Profile optimisation plus a review-velocity playbook engineered to land the three-pack.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-google-ads-singapore/">Google Ads for Restaurants</a></h3>
            <p>Neighbourhood-radius Search campaigns and Performance Max built for reservations, delivery orders, and event nights. GCLID tracking from click to booked cover. Industry benchmark CPL: S$8-S$25.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-social-media-singapore/">Social Media for Restaurants</a></h3>
            <p>IG and TikTok content cadence with food photography direction, UGC frameworks, and creator collaborations. Reels formats built for SG diner scroll behaviour — not template content recycled from US chains.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-meta-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-facebook-ads-singapore/">Facebook &amp; Instagram Ads</a></h3>
            <p>Meta campaigns for event nights, set lunches, weekend brunch, and reservations. Catchment-radius targeting, retargeting site visitors, and creator-style ad formats built for Singapore audiences.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-branding-singapore/">Restaurant Branding</a></h3>
            <p>Visual identity, menu design, signage, and in-store collateral that travels from the storefront into every diner photo. Built so your brand stays consistent from menu card to IG grid to delivery packaging.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/restaurant-ai-search-optimisation-singapore/">AI Search (GEO) for Restaurants</a></h3>
            <p>Get cited when diners ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best Italian in Tanjong Pagar" or "where to take parents for dim sum." Same GEO playbook we run for our own agency.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for restaurant marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Singapore Diners</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching restaurants are content shops producing pretty grids without measuring covers, or PR-led generalists chasing press placements nobody reads. We are the opposite — full-service, performance-led, and built around the Singapore diner journey. We work across dine-in restaurants, delivery-first concepts, cloud kitchens, multi-outlet chains, and premium fine-dining brands in every SG catchment.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>GBP, SEO, GEO, Google Ads, Meta, IG, TikTok, branding, websites — under one roof. No bolting six agencies together for what should be one operator. Every channel delivers consistent positioning, design, and measurement.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>You Own Every Asset From Day One</h3>
            <p>Your Business Manager, your Pixel, your ad account, your GBP, your domain — set up in your name from day one. No agency lock-in. If you ever leave, you take the whole marketing engine with you.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>GEO and AI-Search Ready</h3>
            <p>Very few SG agencies are competent on AI search yet. We run the GEO playbook for our own brand and ship it for clients — a real differentiator for any restaurant playing for the next 24 months of diner-decision behaviour.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== RESTAURANT BUYER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Restaurant Buyer Funnel — how Singapore diners decide where to eat">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Buyer Funnel</p>
        <h2>How <span class="highlight">Singapore Diners</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From scroll to repeat visit, every Singapore restaurant diner moves through the same five stages. We build marketing campaigns that show up at each one — from a first IG impression through to an advocate posting their meal to their stories.</p>
      </div>
      <ol class="fnb-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>IG Reels, TikTok, friend recs, food bloggers</p>
        </li>
        <li class="funnel-stage">
          <h3>Choose</h3>
          <p>Google Maps three-pack, reviews, AI search, Chope</p>
        </li>
        <li class="funnel-stage">
          <h3>First Visit</h3>
          <p>Menu, photos, reviews convert intent to booking</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Experience, follow-up content, loyalty triggers</p>
        </li>
        <li class="funnel-stage">
          <h3>Advocate</h3>
          <p>UGC posts, Google reviews, word-of-mouth</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Restaurant marketing pricing Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Restaurant Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Restaurants of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$1,800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-outlet restaurants building visibility.</p>
            <ul class="pricing-features">
              <li>Single-channel focus (SEO + GBP or Social)</li>
              <li>Google Business Profile optimisation</li>
              <li>Review-velocity playbook</li>
              <li>4 pieces of content/month</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For established restaurants and small chains.</p>
            <ul class="pricing-features">
              <li>SEO + Google Ads + IG/TikTok</li>
              <li>Food photography direction</li>
              <li>GCLID reservation and delivery tracking</li>
              <li>Catchment-area landing pages</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$5,500+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-outlet restaurant groups.</p>
            <ul class="pricing-features">
              <li>Full 6-channel coverage</li>
              <li>Dedicated strategist</li>
              <li>Video production for Reels &amp; TikTok</li>
              <li>Brand refresh / in-store collateral</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about restaurant marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Restaurant</span> Marketing — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does restaurant marketing cost in Singapore?</summary>
          <div class="faq-answer"><p>Restaurant marketing in Singapore starts at S$1,800/month for essential single-channel work (typically Google Business Profile plus SEO or social content). Growth packages at S$3,000/month combine SEO, Google Ads, and IG/TikTok with food photography direction. Enterprise packages at S$5,500+/month add video production, brand refresh, and a dedicated strategist for multi-outlet restaurant groups.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Why is Google Business Profile so important for restaurants?</summary>
          <div class="faq-answer"><p>Diners searching "best dim sum Chinatown" or "Italian restaurant Tanjong Pagar" decide based on the Google Maps three-pack — the top three results on the map. GBP signals (review count, recency, photos, posts, response rate, category accuracy) decide which restaurants surface. Most operators leave GBP underbuilt, losing covers to weaker competitors with better-optimised profiles.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What's the buyer journey for a restaurant diner in Singapore?</summary>
          <div class="faq-answer"><p>Five stages: Discover (IG/TikTok scrolling, friend recs, food blogger content) → Choose (Google Maps three-pack, reviews, ChatGPT/AI search, Chope) → First Visit (menu, photos, reviews convert intent) → Return (loyalty driven by experience and content) → Advocate (UGC posts, Google reviews, word-of-mouth). Marketing has to show up at every stage — not just the reservation form.</p></div>
        </details>
