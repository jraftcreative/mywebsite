---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Google Ads Agency Singapore",
    "description": "Expert Google Ads management in Singapore — search ads, display ads, remarketing, and campaign optimisation. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management",
    "offers": [
      { "@type": "Offer", "name": "Starter PPC", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth PPC", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, landing page recommendations, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale PPC", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How long until my Google Ads start getting leads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "First clicks within 24 hours of launch. First qualified leads within 1-2 weeks for most categories. Stable cost-per-lead (the number we plan against) takes 4-8 weeks — Google Ads needs ~30 conversions for its algorithm to optimise effectively. SG benchmark for typical SME categories: aesthetic clinics S$80-S$180/lead, F&B S$40-S$80/lead, tuition centres S$60-S$120/lead, B2B services S$150-S$400/lead. Wildly cheaper than that on month 1 usually means low-quality leads." } },
      { "@type": "Question", "name": "How much does a Google Ads agency in Singapore cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our management fees: Starter PPC at S$1,000/month (1 platform, up to S$3K ad spend, monthly reporting), Growth PPC at S$2,500/month (2 platforms, up to S$10K ad spend, A/B testing, bi-weekly reporting), Scale PPC at S$5,000/month (all platforms, unlimited spend, dedicated strategist, CRO, weekly reporting). Ad spend goes directly to Google — we don't mark it up. SG market range for agency management is S$800-S$6,000/month. Below S$800 you're typically getting a freelancer or an automated tool." } },
      { "@type": "Question", "name": "How much ad spend do I need to start?", "acceptedAnswer": { "@type": "Answer", "text": "For most SG SME categories: S$1,500-S$3,000/month minimum to generate enough conversion data for Google's algorithm to optimise. Below S$1,000/month, you're spending in patches — not enough data for the system to learn what's working. The S$1,000/month management fee + S$1,500 minimum ad spend = S$2,500/month total floor. For high-CPC categories (legal, aesthetic medical, mortgage), the floor is closer to S$3,000-S$5,000 in ad spend." } },
      { "@type": "Question", "name": "What's the difference between Google Ads and SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads is paid — you bid for keywords and pay per click (S$2-S$30 per click in SG depending on category). Results start immediately, stop the moment you stop spending. SEO is organic — you optimise your site and content to rank without paying for clicks. Takes 3-6 months to show meaningful results, lasts long after you stop active work. Most SG SMEs need both: Ads for immediate lead flow while SEO builds the long-term cheaper-per-lead channel. We run both." } },
      { "@type": "Question", "name": "Do you guarantee Google Ads results?", "acceptedAnswer": { "@type": "Answer", "text": "No, and avoid any agency that does. Anyone guaranteeing a specific number of leads is either over-promising or planning to pad numbers with low-quality conversions (form spam, accidental clicks, irrelevant calls). What we commit to: structured campaign builds, weekly or bi-weekly optimisation, conversion tracking that actually fires, transparent reporting, and a 90-day plan with stated CPL targets you can hold us to. If we miss targets by month 3, we audit, adjust, and tell you honestly what changed." } },
      { "@type": "Question", "name": "What's a good cost-per-lead in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Depends on category. Rough SG benchmarks from accounts we've run or audited: F&B (delivery, reservations) S$30-S$80, fitness/gym memberships S$50-S$120, beauty/hair salons S$40-S$100, aesthetic clinics S$80-S$200, preschools/childcare S$60-S$150, tuition centres S$60-S$120, dental S$80-S$180, professional services (law, accounting) S$150-S$400, B2B SaaS S$200-S$600. The right CPL depends on your customer lifetime value — if a tuition centre customer is worth S$3,000, a S$150 lead is excellent." } },
      { "@type": "Question", "name": "Can I run Google Ads myself instead of hiring an agency?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, if you have 6-10 hours per week to learn and manage it, and S$2K+/month in ad spend to make the learning curve worth it. Google's Smart Campaigns and Performance Max can run on autopilot but typically deliver 30-50% worse cost-per-lead than properly structured manual campaigns. The agency value is in negative keyword work, conversion tracking accuracy, audience segmentation, and weekly bid adjustments — none of which Performance Max does well alone. We've audited dozens of self-managed accounts; the same fix shows up: weak negative keyword lists burning 20-40% of spend on irrelevant clicks." } },
      { "@type": "Question", "name": "What's Performance Max and should I use it?", "acceptedAnswer": { "@type": "Answer", "text": "Performance Max is Google's AI-driven campaign type that runs across Search, Display, YouTube, Gmail, and Discover simultaneously. Strengths: easy setup, broad reach, good for e-commerce. Weaknesses: black-box reporting (you can't see where spend goes), poor performance for lead-gen B2B, and tends to burn budget on irrelevant placements without strong audience signals. We use Performance Max for some e-commerce and lead-gen clients with strong conversion data — but only with audience signals, asset groups, and brand exclusions properly configured." } },
      { "@type": "Question", "name": "Should I run Google Ads or Meta (Facebook + Instagram) Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Both, usually, but order them by intent. Google Ads captures active demand — someone typing \"aesthetic clinic Orchard\" is ready to book. Meta creates demand — showing your service to people who weren't looking yet. For most SG SMEs we recommend starting Google Ads first (faster ROI, immediate qualified leads) then layering Meta for retargeting and demand generation in months 2-3. Industry exceptions: visual product categories (beauty, F&B, fashion) often do better leading with Meta." } },
      { "@type": "Question", "name": "How do you track conversions for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Three layers: (1) Google Ads conversion tags for form submissions, calls, and purchases — fired through Google Tag Manager or Cloudflare Zaraz; (2) GA4 conversion events as a secondary check; (3) offline conversion uploads using GCLID matching — when a lead becomes a booking or sale in your CRM, we push that back to Google Ads so the algorithm optimises for revenue, not just form fills. Layer 3 is what separates an agency that gets you leads from one that gets you customers." } },
      { "@type": "Question", "name": "What's a free Google Ads strategy session and what do I get?", "acceptedAnswer": { "@type": "Answer", "text": "A 45-minute call with a strategist where we audit your current Google Ads account (if you have one), review your competitors' ad presence, identify your highest-intent keywords, project realistic monthly spend and CPL targets for your category, and walk through what a working campaign would look like. No deck. No pitch. If we're not the right fit, we'll say so. We do these because most SG SMEs are running Ads built by someone who left, an in-house person who never learned the platform properly, or Performance Max on autopilot. Free hour, honest assessment." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Google Ads Agency Singapore", "item": "https://jraftcreative.com/google-ads-agency-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Google Ads Singapore — Lead-Gen Specialists | Jraft"
  description="Expert Google Ads management in Singapore — search ads, display ads, remarketing, and campaign optimisation. Plans from S$1,000/month. Free ad strategy session."
  canonical="https://jraftcreative.com/google-ads-agency-singapore/"
  ogTitle="Google Ads Singapore — Lead-Gen Specialists | Jraft"
  ogDescription="Expert Google Ads and PPC management in Singapore. Search ads, display ads, remarketing, and campaign optimisation. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-ads.jpg"
  keywords="google ads agency singapore, ppc management singapore, google ads management singapore, sem agency singapore, paid search singapore, google advertising singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Google Ads Agency Singapore"
  heroTitle='Google Ads &amp; PPC Management <span class="highlight">in Singapore</span>'
  heroSubtitle="Last month our own Google Ads dashboard said our cost-per-lead was S$50. The real number was S$237.73. Nineteen reported conversions. Four real leads. The other fifteen were job seekers tapping the WhatsApp button on our contact page — Google logged each one as a conversion and the bidding algorithm spent the budget optimising for more of them. If you're running Google Ads in Singapore and you've never reconciled your reported leads against actual booked customers, your CPL is almost certainly higher than you think. We fix it for ourselves and for the businesses we run ads for — same approach, same tracking, same numbers we'd want to see if we were the client."
  heroImage="/images/service-ads.webp"
  heroButtons={[
    { text: "Get a Free Google Ads Audit", href: "/contact/", class: "btn btn-primary" },
    { text: 'DM "AUDIT" on WhatsApp', href: "https://wa.me/6582234578?text=AUDIT", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your Google Ads management services."
  ctaLabel="Get the audit"
  ctaTitle="Get a real-CPL audit of your current Google Ads account"
  ctaDescription="Send us your account access. We'll run a 30-minute audit looking at: which conversion actions are firing fake conversions, where your wasted spend is going (the negative keyword gaps), what your real CPL probably is once we reconcile reported vs actual, and the three highest-impact fixes. You get a written 1-page snapshot back within the week. No call required unless you want one."
  ctaButtons={[
    { text: "Book a 15-min discovery call", href: "/contact/", class: "btn btn-primary" },
    { text: 'DM "AUDIT" on WhatsApp', href: "https://wa.me/6582234578?text=AUDIT", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== SECTION 2 — THE ACTUAL PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Why SG Google Ads dashboards under-report CPL">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Why most SG Google Ads accounts report CPLs that are mathematically impossible</h2>
      </div>
      <div class="pillar-prose reveal">
        <p>The pattern shows up in nearly every account we audit. Reported CPL on the Google Ads dashboard: S$30-50. Reported conversion rate: 8-12%. The owner is convinced the account is performing.</p>
        <p>Then we ask: how many of those conversions became actual customers? Half the time the answer is "I don&rsquo;t know — I never matched them back". The other half it&rsquo;s "fewer than half — most of the form fills are spam, most of the WhatsApp clicks go nowhere".</p>
        <p>We hit this on our own account in April. Reported CPL S$50.05 across 19 conversions. We ran the reconciliation: matched every reported conversion against actual contacts who reached out, replied to us, and entered the sales process. Four were real leads. Fifteen were noise — mostly job seekers tapping our WhatsApp button after seeing the contact page. Real CPL: S$237.73. The bidding algorithm had been optimising the wrong signal for weeks.</p>
        <p>The phantom-conversion problem is endemic in SG because of how local SME accounts are structured: WhatsApp-first contact, multi-step lead qualification, no offline conversion upload. Most Google Ads agencies don&rsquo;t fix this because the broken numbers look good on the monthly report. <strong>Reported CPL S$50 is easier to send to a client than real CPL S$237.</strong></p>
        <p>The fix is technical and unglamorous: demote noisy conversion actions, install GCLID-to-WhatsApp tracking so every ad-driven WhatsApp lead carries a click ID, upload offline conversions weekly so Google&rsquo;s algorithm learns what an actual customer looks like. We built this system on our own account in May. Five weeks later the algorithm started filtering job-seeker traffic on its own.</p>
        <p>If your agency hasn&rsquo;t done this for you, your campaign is bidding against a fake metric. The traffic is real, the spend is real, but the conversion signal training the bidding is contaminated. Every dollar you spend reinforces the wrong patterns.</p>
        <p>That&rsquo;s the fix we mean when we say we run Google Ads properly for SG SMEs. The fix. Not the report.</p>
      </div>

      <aside class="pillar-reconcile reveal" aria-label="Reported vs real cost-per-lead reconciliation">
        <p class="pillar-reconcile__label">April 2026 &mdash; Jraft Creative own Google Ads account</p>

        <div class="pillar-reconcile__rows">
          <div class="pillar-reconcile__row">
            <div class="pillar-reconcile__side pillar-reconcile__side--before">
              <span class="pillar-reconcile__side-label">Reported CPL</span>
              <span class="pillar-reconcile__side-number">S$50<span class="pillar-reconcile__cents">.05</span></span>
            </div>
            <span class="pillar-reconcile__arrow" aria-hidden="true">&rarr;</span>
            <div class="pillar-reconcile__side pillar-reconcile__side--after">
              <span class="pillar-reconcile__side-label">Real CPL after reconciliation</span>
              <span class="pillar-reconcile__side-number">S$237<span class="pillar-reconcile__cents">.73</span></span>
            </div>
          </div>

          <div class="pillar-reconcile__row pillar-reconcile__row--mini">
            <div class="pillar-reconcile__side pillar-reconcile__side--before">
              <span class="pillar-reconcile__side-label">Reported conversions</span>
              <span class="pillar-reconcile__side-number pillar-reconcile__side-number--small">19</span>
            </div>
            <span class="pillar-reconcile__arrow" aria-hidden="true">&rarr;</span>
            <div class="pillar-reconcile__side pillar-reconcile__side--after">
              <span class="pillar-reconcile__side-label">Real leads</span>
              <span class="pillar-reconcile__side-number pillar-reconcile__side-number--small">4</span>
            </div>
          </div>
        </div>

        <footer class="pillar-reconcile__foot">
          <span class="pillar-reconcile__pct">79<span class="pillar-reconcile__pct-mark">%</span></span>
          <span class="pillar-reconcile__pct-text">of reported conversions were phantom &mdash; job seekers tapping WhatsApp, form spam, accidental clicks. The bidding algorithm was optimising for the noise.</span>
        </footer>
      </aside>
    </div>
  </section>

  <!-- ========== SECTION 3 — HOW WE SOLVE IT ========== -->
  <section class="section" id="sub-services" aria-label="What Jraft does differently as a Google Ads agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>What Jraft does differently as a Google Ads agency</h2>
      </div>
      <div class="pillar-prose reveal">
        <p>The work that separates a Google Ads agency that gets you leads from one that gets you customers is the boring layer: tracking, conversion hygiene, and the weekly discipline of feeding the algorithm clean data. Here is what we actually do.</p>

        <h3><span class="pillar-step">01</span>Audit your conversion actions before touching bids</h3>
        <p>The first thing we do on a new account is open the Conversions tab and look at what Google is calling a "conversion". On nearly every audit we find at least one conversion action that&rsquo;s quietly burning budget — a "WhatsApp Click" action firing every time anyone taps the button, a Google-managed "Lead form - Submit" that double-counts, or a "Page Visit" left over from a past agency that&rsquo;s polluting the bidding signal.</p>
        <p>We demote everything noisy to secondary. We turn off everything fake. Only verified primary actions remain.</p>

        <h3><span class="pillar-step">02</span>Install GCLID-to-WhatsApp tracking on day one</h3>
        <p>Three of every four real ad-driven leads in Singapore reach out via WhatsApp, not the form. If your Google Ads account isn&rsquo;t capturing the click ID and passing it through to your WhatsApp messages, you can&rsquo;t attribute a real customer back to the ad that earned them. We install an inline script that captures <code>gclid</code> on landing, stores it for 90 days, and appends a <code>[ref:GCLID]</code> tag to every <code>wa.me/</code> link on the site. Real ad-driven leads arrive in your WhatsApp inbox with the click ID attached.</p>

        <h3><span class="pillar-step">03</span>Upload offline conversions weekly</h3>
        <p>When a lead becomes an actual customer in your CRM or contact log, we push that back to Google Ads with the original GCLID. The bidding algorithm now optimises for customers, not form fills. This is the single highest-impact thing you can do for a Google Ads account in Singapore. Almost no agency does it because it requires a weekly operational discipline.</p>

        <h3><span class="pillar-step">04</span>Negative keyword work weekly, not quarterly</h3>
        <p>Most self-managed accounts and most agency-managed accounts in Singapore have 20-40% of spend going to irrelevant clicks because the negative keyword list hasn&rsquo;t been touched since campaign launch. We review the search terms report every week, push new negatives, prune over-blocking ones, and refine match-type strategy. On a typical account we recover 25-35% of wasted spend in the first month from this work alone.</p>

        <p><strong>The pattern:</strong> clean tracking &rarr; clean conversion signal &rarr; clean bidding &rarr; clean negative keyword work &rarr; real customers. Skip any layer and the next one breaks.</p>
      </div>
    </div>
  </section>

  <!-- ========== SECTION 4 — COMPARISON TABLE: DIY vs FREELANCER vs JRAFT ========== -->
  <section class="section" id="vs-comparison" style="background: var(--bg-alt);" aria-label="DIY vs freelancer vs Jraft-managed Google Ads comparison">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What You Actually Get</p>
        <h2>Self-managed vs freelancer vs Jraft-managed &mdash; what you actually get for each</h2>
      </div>
      <p class="pillar-section-intro reveal">The Google Ads management market in Singapore spans a wide range. Below S$500/month you&rsquo;re typically buying automation (Performance Max running unattended). At S$500-S$1,500/month you&rsquo;re typically buying a freelancer with three accounts and limited time. Above S$1,500/month you should be buying weekly optimisation, real tracking, and offline conversion uploads. Most accounts don&rsquo;t get the third even at agency price.</p>

      <div class="pillar-compare pillar-compare--three reveal" data-pillar="google-ads" role="region" aria-label="DIY versus freelancer versus agency-managed Google Ads comparison">
        <header class="pillar-compare__head">
          <div class="pillar-compare__col-label pillar-compare__col-label--a">DIY (you run it)</div>
          <div class="pillar-compare__col-label pillar-compare__col-label--mid">Freelancer / cheap agency</div>
          <div class="pillar-compare__col-label pillar-compare__col-label--b">Jraft-managed</div>
        </header>

        <div class="pillar-compare__rows">
          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Monthly cost</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Just ad spend &mdash; no mgmt fee.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">S$300&ndash;S$800/mo + ad spend.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">S$1,000&ndash;S$5,000/mo + ad spend.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Time you spend per week</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">6&ndash;10 hours to do it properly.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Under 1 hour.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">30 min review, monthly call.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Campaign structure</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Often Performance Max on autopilot.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Smart Campaigns or PMax + basic Search.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Search + PMax + Display + remarketing, structured by intent stage.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Conversion tracking</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Whatever Google suggests at setup.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Form + WhatsApp click both fire as &ldquo;conversions&rdquo; &mdash; noisy.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Verified primary actions only. GCLID-to-WhatsApp. GA4 cross-check.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Offline conversion upload</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">No.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Almost never.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Weekly, every Friday.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Negative keyword work</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Once at launch, rarely touched.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Quarterly.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Weekly search-terms review.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">A/B testing on ad copy</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Sometimes.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Rarely.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Every 2&ndash;3 weeks on rotation.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Landing page input</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">None.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Generic recommendations.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Specific changes ranked by impact.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Reporting</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">Dashboard self-serve.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Templated PDF monthly.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Real-CPL reconciliation, monthly written analysis.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">Typical real CPL outcome</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">30&ndash;50% worse than properly managed.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">20&ndash;30% worse.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">The real number &mdash; what you plan the business against, not what flatters the report.</div>
          </article>

          <article class="pillar-compare__row">
            <p class="pillar-compare__dimension">What you learn from the engagement</p>
            <div class="pillar-compare__cell pillar-compare__cell--a">A lot, slowly, expensively.</div>
            <div class="pillar-compare__cell pillar-compare__cell--mid">Little &mdash; it&rsquo;s a service contract.</div>
            <div class="pillar-compare__cell pillar-compare__cell--b">Account becomes a forecasting tool for the business.</div>
          </article>
        </div>
      </div>

      <aside class="pillar-callout pillar-callout--single reveal" aria-label="Cheap agency market warning">
        <div class="pillar-callout__stat">
          <span class="pillar-callout__number">S$300<span style="font-size: 0.55em; color: var(--text-muted); font-weight: 700;">&ndash;800</span></span>
          <span class="pillar-callout__unit">monthly</span>
        </div>
        <div class="pillar-callout__body">
          <p class="pillar-callout__lede">is the most common SG agency price point &mdash; and where the phantom-conversion problem lives.</p>
          <p class="pillar-callout__support">The agency benefits from reported CPL looking better than real CPL. The owner doesn&rsquo;t notice because nobody reconciles dashboard numbers against actual customers.</p>
        </div>
      </aside>

      <!-- TODO: when /blog/meta-ads-vs-google-ads-singapore-sme/ ships (4 Jun 2026), wrap the title below in an <a href> link. -->
      <p class="pillar-companion-tease reveal">Want the deeper comparison &mdash; Google Ads vs Meta Ads, real CPL benchmarks by vertical, and our decision flowchart for which platform to start with? Read the full essay &mdash; <strong>Meta Ads vs Google Ads: Which Should a Singapore SME Start With?</strong> (companion essay, shipping early June 2026).</p>
    </div>
  </section>

  <!-- ========== SECTION 5 — PRICING ========== -->
  <section class="section" id="pricing" aria-label="Google Ads management pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">PPC Pricing</p>
        <h2>Google Ads management pricing &mdash; published in full</h2>
      </div>
      <div class="pillar-prose reveal">
        <p>We publish our fees. The numbers below are real, are what we charge, and reflect the hours the work actually takes.</p>
        <p>Below S$800/month you&rsquo;re typically getting a freelancer with three accounts and limited weekly time. The SG market range for proper agency management is S$800-S$6,000/month plus ad spend. We don&rsquo;t mark up media spend — every dollar of ad budget goes directly to Google through your own account. Your monthly fee is for the management, the tracking, and the offline conversion work.</p>
      </div>
