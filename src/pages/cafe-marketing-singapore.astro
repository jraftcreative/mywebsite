---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Cafe Marketing Singapore",
    "description": "Full-service marketing agency for cafes and coffee shops in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, and AI search — built for specialty coffee, brunch, and aesthetic-led cafe concepts. From S$1,800/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Cafe Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Cafe Marketing", "price": "1800", "priceCurrency": "SGD", "description": "Single-channel focus (SEO + GBP or Social), Google Business Profile optimisation, review-velocity playbook, monthly content, and reporting for single-outlet cafes" },
      { "@type": "Offer", "name": "Growth Cafe Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Multi-channel: SEO + Google Ads + IG/TikTok, coffee and food photography direction, UGC frameworks, and bi-weekly reporting for established cafes and small chains" },
      { "@type": "Offer", "name": "Enterprise Cafe Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Full-service across all 6 channels, dedicated strategist, video production for Reels and TikTok, brand refresh, in-store collateral, and weekly reporting for multi-outlet cafe groups" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does cafe marketing cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Cafe marketing in Singapore starts at S$1,800/month for essential single-channel work (typically Google Business Profile plus SEO or social content). Growth packages at S$3,000/month combine SEO, Google Ads, and IG/TikTok with coffee and food photography direction. Enterprise packages at S$5,500+/month add video production, brand refresh, and a dedicated strategist for multi-outlet cafe groups. Single-outlet specialty cafes typically start at Essential, while small chains running 2-5 outlets fit the Growth tier." } },
      { "@type": "Question", "name": "Why is Instagram so important for cafe marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Singapore cafe-goers — especially the brunch and specialty coffee crowd — discover most new spots on IG Reels and TikTok before ever Googling. Aesthetic interior, latte art, and signature dish content drive the first visit. The cafes filling tables aren't necessarily the ones with the best espresso — they're the ones with consistent branded social content and UGC the audience actually shares." } },
      { "@type": "Question", "name": "What's the buyer journey for a cafe-goer in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Singapore cafe-goers move through five stages: Discover (IG Reels, TikTok, cafe-hopping blogs, friend recommendations) → Choose (Google Maps three-pack, reviews, ChatGPT/AI search, Burpple) → First Visit (decision based on photos, vibe, menu) → Return (loyalty driven by experience, content, weekly regulars) → Advocate (UGC posts, Google reviews, IG stories). Cafe marketing needs to show up at every stage — especially Discover and Choose, where most cafes lose to better-photographed competitors." } },
      { "@type": "Question", "name": "Which marketing channels work best for cafes in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Six channels in priority order for most cafes: (1) IG and TikTok content cadence with branded coffee/food/interior photography, (2) Google Business Profile plus catchment SEO for 'best cafe [neighbourhood]' and 'brunch [area]' searches, (3) Google Ads for neighbourhood-radius and weekend brunch campaigns, (4) AI search (GEO) optimisation for ChatGPT and Perplexity citations, (5) the website as menu, reservation, and gift card hub, (6) branding and in-store collateral that travels into every customer photo. We build cross-channel plans based on your concept and outlet count." } },
      { "@type": "Question", "name": "How long before cafe marketing brings more foot traffic?", "acceptedAnswer": { "@type": "Answer", "text": "Google Business Profile work and Google Ads can lift discovery and walk-ins within 2-4 weeks. Social media content cadence compounds over 8-12 weeks as branded content builds following and UGC. SEO and AI search citations typically show ranking improvements within 3-6 months for neighbourhood and concept-specific keywords. Most cafes see measurable weekend foot-traffic lift inside the first quarter once GBP, reviews, and IG/TikTok are running together." } },
      { "@type": "Question", "name": "Do you handle coffee and food photography content?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Growth and Enterprise tiers include coffee, food, and interior photography direction plus video production for Reels and TikTok. We coordinate the shoot brief, frame dishes and latte art for menu and social formats, write captions and voiceover scripts, and brief UGC creators where relevant. Most cafes have a phone full of inconsistent dish photos — we replace that with a branded asset library that fuels social, the website, GBP, and ads in parallel." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Cafe Marketing Singapore", "item": "https://jraftcreative.com/cafe-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  .service-cta-section { background: var(--bg-alt) !important; }

  /* Cafe Buyer Funnel — 5-stage horizontal flow */
  .fnb-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .fnb-funnel { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .funnel-stage:nth-child(2n)::after, .funnel-stage:last-child::after { display: none; }
    .funnel-stage:nth-child(2n-1)::after { right: -22px; }
  }
  @media (max-width: 600px) {
    .fnb-funnel { grid-template-columns: 1fr; gap: 20px; }
    .funnel-stage::after { display: none; }
  }
</style>

<ServiceLayout
  title="Cafe Marketing Singapore | Jraft Creative"
  description="Full-service cafe marketing agency in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, AI search — for specialty coffee, brunch, and aesthetic-led cafes. From $1,800/mo."
  canonical="https://jraftcreative.com/cafe-marketing-singapore/"
  ogTitle="Cafe Marketing Singapore | Jraft Creative"
  ogDescription="Full-service cafe marketing agency in Singapore. SEO, Google Ads, IG/TikTok, branding, websites, AI search — from $1,800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="cafe marketing singapore, cafe digital marketing singapore, cafe marketing agency singapore, coffee shop marketing singapore, brunch cafe marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Cafe Marketing Singapore"
  heroTitle='Marketing Agency for <span class="highlight">Cafes &amp; Coffee Shops in Singapore</span>'
  heroSubtitle="Singapore cafe-goers find their next brunch on IG Reels and TikTok before they ever open Google Maps. The cafes filling weekend tables are not always the ones with the best espresso — they are the ones showing up where the brunch crowd actually scrolls. We build full-service marketing strategies (IG/TikTok, Google Business Profile, SEO, GEO, Google Ads, branding, websites) designed for how Singapore cafe-goers actually decide."
  heroImage="/images/service-cafe.webp"
  heroImageAlt="Singapore specialty cafe interior — cafe marketing agency"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20a%20cafe%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I run a cafe in Singapore and need marketing help."
  ctaLabel="Ready to Get Started?"
  ctaTitle='Let Us <span class="highlight">Grow</span> Your <span class="highlight">Cafe Pipeline</span>'
  ctaDescription="Book a free consultation and tell us about your cafe — your concept, your catchment, your current marketing. We'll get back to you within 24 hours with a tailored, channel-by-channel marketing plan."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20a%20cafe%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why cafes need specialised marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Cafes Are Still <span class="highlight">Losing the Weekend Crowd</span> to Operators with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore opens new specialty cafes almost every week. Cafe-goers decide on IG Reels, TikTok cafe-hopping content, and the Google Maps three-pack — usually before they ever set foot inside. Cafes winning the weekend brunch crowd are not always the ones with the best beans. They are the ones showing up where the audience actually scrolls.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The IG-First Discovery</h3>
            <p>Brunch and specialty coffee audiences discover new cafes on IG Reels and TikTok before Google. Without a branded content cadence — interior shots, latte art, signature dishes — even great cafes stay invisible to the audience most likely to walk in on Saturday morning.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Three-Pack Decides Walk-Ins</h3>
            <p>When someone searches "cafe Tiong Bahru" or "best brunch Holland Village," the Google Maps three-pack drives the walk-in. Review count, recency, photos, and category accuracy decide who shows up — and most cafes leave Google Business Profile half-built.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Aesthetic-Commodity Problem</h3>
            <p>Plain wood, white tiles, minimalist menu — the Singapore aesthetic cafe template has been copied for a decade. Cafes that stand out have differentiated brand systems, distinctive photography direction, and content that does not look like every other neighbourhood cafe.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for cafes in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Cafe <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for cafes — combining IG and TikTok content, Google Business Profile and catchment SEO, paid search, AI search optimisation, branding, and conversion-focused cafe websites.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/cafe-social-media-singapore/">Social Media for Cafes</a></h3>
            <p>IG and TikTok content cadence with coffee, food, and interior photography direction. UGC frameworks and creator collaborations built for the SG brunch and specialty coffee crowd — not generic cafe content templates.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/cafe-seo-singapore/">SEO for Cafes</a></h3>
            <p>Rank for "best cafe [neighbourhood]" and "brunch [area]" searches across Tiong Bahru, Holland Village, Bukit Timah, and every SG catchment. Google Business Profile optimisation plus a review-velocity playbook engineered for the three-pack.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3>Google Ads for Cafes</h3>
            <p>Neighbourhood-radius Search and Performance Max campaigns built for weekend walk-ins, event bookings, and seasonal launches. GCLID tracking from click to walk-in event. Industry benchmark CPL: S$5-S$20.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/cafe-website-design-singapore/">Cafe Websites</a></h3>
            <p>Menu, online ordering, reservations, event bookings, and gift card flow — mobile-first design built for the cafe-goer who already decided yours is the next stop. Photography-led to match your IG grid.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/fnb-branding-singapore/">Cafe Branding</a></h3>
            <p>Visual identity, menu design, packaging, cup sleeves, signage, and in-store collateral that travels from the storefront into every diner photo. Built to differentiate from the white-tile-wood-counter aesthetic template.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">AI Search (GEO) for Cafes</a></h3>
            <p>Get cited when cafe-goers ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best brunch Holland Village" or "specialty coffee Tiong Bahru." Same GEO playbook we run for our own agency.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for cafe marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Singapore Cafe-Goers</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching cafes either lean PR-led (press placements nobody acts on) or treat cafes as smaller restaurants and apply restaurant tactics. We are the opposite — full-service, content-and-aesthetic-led where the category needs it, performance-led on Google where the category rewards it. We work across specialty coffee, brunch, dessert cafes, bubble tea brands, and small chain cafe groups in every SG catchment.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>IG, TikTok, GBP, SEO, GEO, Google Ads, branding, websites — under one roof. No bolting six agencies together for what should be one operator. Every channel delivers consistent positioning, design, and measurement.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>You Own Every Asset From Day One</h3>
            <p>Your Business Manager, your Pixel, your ad account, your GBP, your domain — set up in your name from day one. No agency lock-in. If you ever leave, you take the whole marketing engine with you.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>GEO and AI-Search Ready</h3>
            <p>Very few SG agencies are competent on AI search yet. We run the GEO playbook for our own brand and ship it for clients — a real differentiator for any cafe playing for the next 24 months of cafe-goer decision behaviour.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CAFE BUYER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Cafe Buyer Funnel — how Singapore cafe-goers decide where to brunch">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Buyer Funnel</p>
        <h2>How <span class="highlight">Singapore Cafe-Goers</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From scroll to weekly regular, every Singapore cafe-goer moves through the same five stages. We build marketing campaigns that show up at each one — from a first IG Reel through to a regular posting their flat white to their stories.</p>
      </div>
      <ol class="fnb-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>IG Reels, TikTok, cafe-hopping blogs, friend recs</p>
        </li>
        <li class="funnel-stage">
          <h3>Choose</h3>
          <p>Google Maps three-pack, reviews, AI search, Burpple</p>
        </li>
        <li class="funnel-stage">
          <h3>First Visit</h3>
          <p>Photos, vibe, menu convert intent to walk-in</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Experience, content, weekly-regular triggers</p>
        </li>
        <li class="funnel-stage">
          <h3>Advocate</h3>
          <p>UGC posts, Google reviews, IG stories</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Cafe marketing pricing Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Cafe Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Cafes of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$1,800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-outlet specialty cafes building visibility.</p>
