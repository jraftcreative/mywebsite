---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Tuition Centre Marketing Singapore",
    "description": "Full-service digital marketing for tuition centres in Singapore — website design, SEO, Google Ads, social media, and content marketing. Enrolment-focused strategies from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Tuition Centre Marketing",
    "offers": [
      { "@type": "Offer", "name": "Tuition Centre Marketing", "priceCurrency": "SGD", "description": "Full-service marketing for tuition centres in Singapore — website, SEO, Google Ads, social media, and content marketing. Custom-quoted to your enrolment goals and centre size." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a tuition centre spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most tuition centres in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your centre's size, number of branches, and enrolment targets. We'll quote a custom retainer based on your situation." } },
      { "@type": "Question", "name": "How long before marketing generates enrolments for my tuition centre?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate parent enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness over 2–3 months. Most clients see a meaningful increase in trial lesson bookings within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "What marketing channels work best for tuition centres in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search (both organic and ads) is the highest-intent channel — parents actively searching for tuition are ready to enrol. Facebook and Instagram work well for awareness and retargeting. WhatsApp is increasingly important for parent communication. A well-designed website ties everything together as your conversion hub." } },
      { "@type": "Question", "name": "Do you handle all marketing or just specific services?", "acceptedAnswer": { "@type": "Answer", "text": "We are a full-service agency — website design, SEO, Google Ads, Facebook Ads, social media content, and email marketing all handled by one team. You can start with specific services and expand over time, or go all-in with an integrated strategy from day one. Every channel is managed in-house with no outsourcing." } },
      { "@type": "Question", "name": "Can you help during peak enrolment seasons like year-end and January?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We plan seasonal campaigns around Singapore's key enrolment periods — year-end registration, January intake, mid-year transfers, and exam result release dates. This includes ramping up ad budgets, launching targeted landing pages, scheduling open house promotions, and running lead nurturing sequences timed to parent decision cycles." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tuition Centre Marketing Singapore", "item": "https://jraftcreative.com/tuition-centre-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Tuition Centre Marketing Singapore — Jraft Creative"
  description="Full-service digital marketing for tuition centres in Singapore — website, SEO, Google Ads, social media, and content marketing."
  canonical="https://jraftcreative.com/tuition-centre-marketing-singapore/"
  ogTitle="Tuition Centre Marketing Singapore — Jraft Creative"
  ogDescription="Full-service marketing for tuition centres in Singapore. Website, SEO, Google Ads, social media — one agency, one strategy, more enrolments."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="tuition centre marketing singapore, tuition marketing agency, tuition centre advertising singapore, tuition centre digital marketing, tuition centre promotion singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Tuition Centre Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">Tuition Centres in Singapore</span>'
  heroSubtitle="Website, SEO, Google Ads, social media, and content — managed by one agency with one goal: filling your classrooms. Stop piecing together freelancers and start running a unified enrolment strategy."
  heroImage="/images/service-tuition.webp"
  heroImageAlt="Singapore tuition classroom — tuition centre marketing agency"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20tuition%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my tuition centre in Singapore."
  ctaLabel="Ready to Fill Your Classrooms?"
  ctaTitle="Get Your Free Tuition Centre Marketing Audit"
  ctaDescription="Book a free consultation and we'll review your current marketing, identify gaps, and recommend a strategy tailored to your centre's enrolment goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20tuition%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why tuition centres need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Word-of-Mouth Alone <span class="highlight">Won't Fill</span> Your <span class="highlight">Classrooms</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has over 800 registered tuition centres, plus thousands of freelance tutors, all chasing the same parent shortlist. The centres filling their classrooms aren't always the strongest teachers — they're the ones parents actually find, trust, and shortlist first.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>A Saturated PSLE &amp; O-Level Market</h3>
            <p>From PSLE maths to O-Level chemistry and A-Level econs, every subject and level is crowded with brand chains and independent centres. If you're not visible for the exact subject, level, and neighbourhood parents are searching, you're invisible at the moment they choose.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Parents Validate Before They Enquire</h3>
            <p>Parents don't enrol on a flyer. They cross-check Google reviews, scan your Instagram and Facebook, look for exam-result proof, and ask other parents — all before booking a trial. Centres without those trust signals lose the booking even when their teaching is stronger.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Tuition Near Me" Search Wins</h3>
            <p>A parent searching "PSLE maths tuition Tampines" or "tuition near me" won't reach you through word-of-mouth — they enrol with whoever ranks on page one and owns the Maps pack. Referrals stay valuable, but they don't scale predictably the way local search does.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for tuition centres in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Tuition Centre <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for tuition centres — combining catchment-area SEO, AI search optimisation (GEO), high-intent paid search, parent-focused social content, brand positioning, and enrolment-focused web design.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-seo-singapore/">SEO for Tuition Centres</a></h3>
            <p>Rank for parent searches like "PSLE maths tuition Tampines" and "O-Level chemistry tuition near me." Subject-, level-, and neighbourhood-specific landing pages plus Google Business Profile optimisation to win the local Maps pack.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-ai-search-optimisation-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when parents ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best PSLE maths tuition near Bishan" or "good A-Level econs tutor Singapore." The same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-google-ads-singapore/">Google Ads for Tuition Centres</a></h3>
            <p>High-intent campaigns timed to year-end registration, January intake, and post-exam result windows. GCLID tracking from click to signed enrolment, with budgets managed to a healthy cost-per-enquiry.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-social-media-singapore/">Social Media for Tuition Centres</a></h3>
            <p>Teacher-led Reels, student achievement stories, exam tips, and classroom culture on Instagram, Facebook, and TikTok. The parent-trust content that keeps your centre top-of-mind through the enrolment decision.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-branding-singapore/">Branding for Tuition Centres</a></h3>
            <p>The brand system that lifts you above the dozens of centres in your catchment. Logo, palette, parent-pack template, and teacher photo direction — positioned by subject niche and teaching approach, not price alone.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tuition-centre-website-singapore/">Websites for Tuition Centres</a></h3>
            <p>The site that closes the trial booking. Subject and level pages, tutor profiles, transparent fees, branch locations, and a single-field enquiry form — fast on mobile for parents shortlisting on their phone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for tuition centre marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A Marketing Partner That <span class="highlight">Understands</span> Singapore <span class="highlight">Tuition</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We work with tuition centres, enrichment programmes, and education businesses across Singapore. We understand the enrolment cycle, the parent decision-making process, and the competitive dynamics of the local tuition market — MOE curriculum levels, PSLE/O-Level/A-Level exam cycles, and seasonal intake peaks. Your strategy is built on that industry knowledge, not a generic template.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Education Sector Expertise</h3>
            <p>We know the Singapore tuition market — MOE curriculum levels, PSLE/O-Level/A-Level exam cycles, parent search behaviour, and enrolment seasonality. Every campaign is built around how parents actually shortlist a centre for their child.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>Website, SEO, GEO, Google Ads, IG, TikTok, Facebook, and branding — all under one roof. No coordinating between separate vendors. Every channel reinforces the same positioning and parent-trust signals for the same audience.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enrolment-Focused Reporting</h3>
            <p>We measure enquiries, trial bookings, cost per lead, and channel performance — not vanity metrics. GCLID offline tracking ties each ad click to the enquiry and trial it produced, so spend connects to classroom occupancy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ENROLMENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Enrolment Funnel — how Singapore parents decide on a tuition centre">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Enrolment Funnel</p>
        <h2>How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first Google search to a signed term, every parent enrolling a child in tuition moves through the same five stages. We build marketing campaigns that show up at each one — from discovery scrolling through to a confirmed enrolment.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, IG, TikTok, parent Facebook groups, AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, exam results, teacher credibility</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 centres on fit, fees &amp; location</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>WhatsApp, call, or trial-lesson booking</p>
        </li>
        <li class="funnel-stage">
          <h3>Enrol</h3>
          <p>Sign for the term &amp; secure the slot</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Tuition centre marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Tuition Centre Marketing Pricing</p>
        <h2><span class="highlight">Custom-Quoted</span> to Your <span class="highlight">Enrolment Goals</span></h2>
        <p>Monthly retainers. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid" style="grid-template-columns: minmax(280px, 460px); justify-content: center;">
          <div class="pricing-card featured reveal reveal-d1">
            <h3>Full-Service Retainer</h3>
            <div class="price">From $3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">Most tuition centres invest between $2,500 and $8,000/month — quoted to your centre size, branches, and enrolment targets.</p>
            <ul class="pricing-features">
              <li>Website, SEO, Google Ads &amp; social media</li>
              <li>Google Business Profile optimisation</li>
              <li>Seasonal intake &amp; exam-period campaigns</li>
              <li>Conversion &amp; enquiry tracking</li>
              <li>Enrolment-focused performance reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get a Custom Quote</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about tuition centre marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Tuition Centre Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a tuition centre spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most tuition centres in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your centre's size, number of branches, and enrolment targets. We quote each retainer custom based on your situation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates enrolments for my tuition centre?</summary>
          <div class="faq-answer"><p>Paid channels like <a href="/tuition-centre-google-ads-singapore/">Google Ads</a> can generate parent enquiries within the first week. <a href="/tuition-centre-seo-singapore/">SEO</a> typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness over 2–3 months. Most clients see a meaningful increase in trial lesson bookings within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for tuition centres in Singapore?</summary>
          <div class="faq-answer"><p>Google Search — both organic and ads — is the highest-intent channel because parents actively searching for tuition are ready to enrol. Facebook and Instagram work well for awareness and retargeting. WhatsApp is increasingly important for parent communication. A well-designed <a href="/tuition-centre-website-singapore/">website</a> ties everything together as your conversion hub.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you handle all marketing or just specific services?</summary>
          <div class="faq-answer"><p>We are a full-service agency — <a href="/services/website-development/">website design</a>, <a href="/services/seo-performance/">SEO</a>, <a href="/services/paid-ads/">Google Ads</a>, Facebook Ads, <a href="/services/social-media/">social media content</a>, and email marketing all handled by one team. You can start with specific services and expand over time, or go all-in with an integrated strategy from day one. Every channel is managed in-house with no outsourcing.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you help during peak enrolment seasons like year-end and January?</summary>
          <div class="faq-answer"><p>Yes. We plan seasonal campaigns around Singapore's key enrolment periods — year-end registration, January intake, mid-year transfers, and exam result release dates. This includes ramping up ad budgets, launching targeted landing pages, scheduling open house promotions, and running lead nurturing sequences timed to parent decision cycles.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Tuition Centre Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/tuition-centre-website-singapore/" class="related-service-link">Tuition Centre Website Design</a>
          <a href="/tuition-centre-seo-singapore/" class="related-service-link">Tuition Centre SEO</a>
          <a href="/tuition-centre-social-media-singapore/" class="related-service-link">Tuition Centre Social Media</a>
          <a href="/tuition-centre-google-ads-singapore/" class="related-service-link">Tuition Centre Google Ads</a>
          <a href="/tuition-centre-facebook-ads-singapore/" class="related-service-link">Tuition Centre Facebook Ads</a>
          <a href="/tuition-centre-branding-singapore/" class="related-service-link">Tuition Centre Branding</a>
          <a href="/tuition-centre-content-marketing-singapore/" class="related-service-link">Tuition Centre Content Marketing</a>
      </div>
    </div>
  </section>
</ServiceLayout>
