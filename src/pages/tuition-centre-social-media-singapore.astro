---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Tuition Centre Social Media Marketing Singapore",
    "description": "Social media marketing for tuition centres in Singapore. Parent engagement on Facebook and Instagram, student success stories, exam tips content, and trust-building through strategic social media.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Tuition Centre Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting for tuition centres" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting for tuition centres" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting for tuition centres" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost for tuition centres in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing for tuition centres in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, video production, and community management." } },
      { "@type": "Question", "name": "Which social media platforms work best for tuition centres in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Facebook and Instagram are the most effective platforms for tuition centres in Singapore. Facebook excels at reaching parents through community groups and targeted ads, while Instagram is ideal for showcasing student achievements and learning environments through visual content and Reels." } },
      { "@type": "Question", "name": "What kind of content do you create for tuition centres?", "acceptedAnswer": { "@type": "Answer", "text": "We create exam tips and study guides, student success stories and testimonials, behind-the-scenes classroom content, tutor introductions, programme highlights, and enrolment campaign posts. Every piece of content is designed to build trust with parents and position your centre as a credible educational partner." } },
      { "@type": "Question", "name": "How do you help tuition centres build trust with parents online?", "acceptedAnswer": { "@type": "Answer", "text": "We build trust through consistent, value-driven content — real student results, parent testimonials, transparent communication about teaching methods, and educational tips parents can use at home. This positions your centre as an authority and makes parents feel confident choosing you over competitors." } },
      { "@type": "Question", "name": "Can social media marketing help my tuition centre get more enrolments?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Strategic social media marketing drives awareness, builds credibility, and generates enquiries from parents actively looking for tuition in Singapore. We combine organic content with targeted campaigns around peak enrolment periods like post-PSLE, mid-year, and year-end registration windows." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" },
      { "@type": "ListItem", "position": 3, "name": "Tuition Centre Social Media", "item": "https://jraftcreative.com/tuition-centre-social-media-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Tuition Centre Social Media Singapore — Social Media Marketing | Jraft Creative"
  description="Social media marketing for tuition centres in Singapore. Parent engagement, student success stories, exam tips content, and enrolment campaigns. Monthly plans from S$2,500."
  canonical="https://jraftcreative.com/tuition-centre-social-media-singapore/"
  ogTitle="Tuition Centre Social Media Singapore — Jraft Creative"
  ogDescription="Social media marketing built for tuition centres in Singapore. Content that builds trust with parents and drives enrolments. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="tuition centre social media singapore, tuition centre marketing singapore, social media for tuition centres, tuition centre instagram, tuition centre facebook marketing, tuition centre digital marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Tuition Centre Social Media"
  heroTitle='Social Media for <span class="highlight">Tuition Centres</span> in Singapore'
  heroSubtitle="Content strategy, parent engagement, and enrolment campaigns built specifically for tuition centres. We help you build trust with parents and turn your social media presence into a consistent source of new student sign-ups."
  heroImage="/images/service-tuition.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need social media marketing for my tuition centre in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Tuition Centre with Social Media"
  ctaDescription="Book a free consultation and tell us about your tuition centre. We'll get back to you within 24 hours with a tailored social media strategy."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20social%20media%20marketing%20for%20my%20tuition%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for tuition centres in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Searching — But Are They Finding Your Centre?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore parents are some of the most research-driven in the world when it comes to education. Before committing to a tuition centre, they scroll through Instagram pages, read Facebook reviews, and compare centres based on what they see online. If your social media looks inactive or generic, parents move on to the next option — even if your teaching quality is excellent.</p>
        <p>The tuition industry in Singapore is fiercely competitive. From Orchard to Tampines, centres are fighting for the same pool of parents preparing their children for PSLE, O-Levels, and A-Levels. Without a consistent social media presence that showcases real results, shares valuable study tips, and builds trust through testimonials, you're invisible to the parents who matter most. Posting once a month with a stock image and a "registration open" caption is not a strategy — it's a missed opportunity.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media services for tuition centres">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services Built for Tuition Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>We handle your tuition centre's entire social media presence — from content planning to community engagement. Every post is crafted to resonate with Singaporean parents and position your centre as a trusted educational partner that delivers real academic results.</p>
        <p>Our team creates content around exam preparation tips, student achievement spotlights, tutor profiles, and programme launches. We time campaigns around key Singapore education milestones — PSLE registration, mid-year enrolment drives, and holiday intensive sign-ups — so your content lands when parents are actively searching.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Student Success Reels</h3>
            <p>Short-form video content featuring grade improvements, student testimonials, and exam preparation tips that parents share and engage with across Instagram and TikTok.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Parent Community Engagement</h3>
            <p>Active management of comments, DMs, and parent enquiries. We respond promptly, answer questions about programmes, and nurture leads from first contact to enrolment.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Exam Tips &amp; Study Guides</h3>
            <p>Branded carousel posts and infographics with practical study tips for PSLE, O-Level, and A-Level subjects that position your centre as a knowledgeable authority parents trust.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Enrolment Campaigns</h3>
            <p>Targeted social media campaigns timed around Singapore's academic calendar — term breaks, post-exam periods, and year-end registration drives that convert interest into sign-ups.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for tuition centre social media">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A Social Media Partner That Understands Education</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with tuition centres across Singapore and understand what parents look for when evaluating their options online. Our content is built to build credibility, answer parent concerns, and drive enrolment enquiries.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Education Sector Experience</h3>
            <p>We know the Singapore education landscape — from MOE syllabus changes to peak enrolment seasons. Your content reflects what parents actually care about, not generic marketing fluff.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Parent-First Content</h3>
            <p>Every post is written for the decision-maker: the parent. We create content that addresses their concerns about academic results, teaching quality, and learning environment.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Approval Before Publishing</h3>
            <p>You review and approve every post, caption, and design before it goes live. Full content calendar delivered in advance so nothing is published without your sign-off.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans with no binding agreements. Stay because your enrolments are growing and the content is working — not because of a contract clause.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Tuition centre social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Tuition Centres of Every Size</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For centres building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing centres ready to scale enrolments.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For established centres that want a complete social team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about tuition centre social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Tuition Centre Social Media — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost for tuition centres in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing for tuition centres in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, video production, and community management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which social media platforms work best for tuition centres in Singapore?</summary>
          <div class="faq-answer"><p>Facebook and Instagram are the most effective platforms for tuition centres in Singapore. Facebook excels at reaching parents through community groups and targeted ads, while Instagram is ideal for showcasing student achievements and learning environments through visual content and Reels.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What kind of content do you create for tuition centres?</summary>
          <div class="faq-answer"><p>We create exam tips and study guides, student success stories and testimonials, behind-the-scenes classroom content, tutor introductions, programme highlights, and enrolment campaign posts. Every piece of content is designed to build trust with parents and position your centre as a credible educational partner.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you help tuition centres build trust with parents online?</summary>
          <div class="faq-answer"><p>We build trust through consistent, value-driven content — real student results, parent testimonials, transparent communication about teaching methods, and educational tips parents can use at home. This positions your centre as an authority and makes parents feel confident choosing you over competitors.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can social media marketing help my tuition centre get more enrolments?</summary>
          <div class="faq-answer"><p>Yes. Strategic social media marketing drives awareness, builds credibility, and generates enquiries from parents actively looking for tuition in Singapore. We combine organic content with targeted campaigns around peak enrolment periods like post-PSLE, mid-year, and year-end registration windows.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
