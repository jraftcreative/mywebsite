---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Enrichment Centre Social Media Marketing Singapore",
    "description": "Social media marketing for enrichment centres in Singapore. Class highlights, student achievements, parent testimonials, and programme launches across Instagram and Facebook.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Enrichment Centre Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting for enrichment centres" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting for enrichment centres" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting for enrichment centres" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost for enrichment centres in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing for enrichment centres in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, Reels production, and active community management." } },
      { "@type": "Question", "name": "What type of social media content works best for enrichment centres?", "acceptedAnswer": { "@type": "Answer", "text": "The highest-performing content for enrichment centres includes class activity highlights, student project showcases, parent testimonials, programme launch announcements, and behind-the-scenes Reels showing what children actually experience. Visual content that captures fun, learning moments consistently drives the strongest engagement from parents." } },
      { "@type": "Question", "name": "How do you promote new enrichment programmes on social media?", "acceptedAnswer": { "@type": "Answer", "text": "We build launch campaigns with teaser content, countdown posts, early-bird offers, and highlight Reels. Campaigns are timed around school holidays and term breaks when parents are actively searching for enrichment activities. We also run retargeting strategies for parents who engaged with your previous content." } },
      { "@type": "Question", "name": "Can you manage social media for enrichment centres with multiple locations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create location-specific content strategies while maintaining brand consistency across all branches. Each location can have tailored posts highlighting its unique programmes, instructors, and community events, all managed through a single content calendar and approval workflow." } },
      { "@type": "Question", "name": "How long before we see results from social media marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Most enrichment centres see measurable improvements in engagement and enquiries within the first 60 to 90 days. Follower growth and brand awareness build steadily, while targeted campaigns around programme launches and school holidays can generate immediate enrolment interest." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" },
      { "@type": "ListItem", "position": 3, "name": "Enrichment Centre Social Media", "item": "https://jraftcreative.com/enrichment-centre-social-media-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Enrichment Centre Social Media Singapore — Social Media Marketing | Jraft Creative"
  description="Social media marketing for enrichment centres in Singapore. Class highlights, student achievements, parent testimonials, and programme launch campaigns. Monthly plans from S$2,500."
  canonical="https://jraftcreative.com/enrichment-centre-social-media-singapore/"
  ogTitle="Enrichment Centre Social Media Singapore — Jraft Creative"
  ogDescription="Social media marketing for enrichment centres in Singapore. Content that showcases your programmes and drives enrolments. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="enrichment centre social media singapore, enrichment centre marketing singapore, social media for enrichment centres, enrichment centre instagram, enrichment programme marketing singapore, enrichment class marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Enrichment Centre Social Media"
  heroTitle='Social Media for <span class="highlight">Enrichment Centres</span> in Singapore'
  heroSubtitle="Content creation, programme promotion, and parent engagement designed specifically for enrichment centres. We showcase what makes your programmes special and turn browsing parents into enrolled families."
  heroImage="/images/service-enrichment.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need social media marketing for my enrichment centre in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Enrichment Centre with Social Media"
  ctaDescription="Book a free consultation and tell us about your enrichment programmes. We'll get back to you within 24 hours with a tailored social media strategy."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20social%20media%20marketing%20for%20my%20enrichment%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for enrichment centres in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Great Programmes, but Parents Don't Know You Exist</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has hundreds of enrichment centres offering everything from coding and robotics to art, speech and drama, and creative writing. Parents are overwhelmed with choices, and they default to the centres that show up in their social feeds with polished, engaging content. If your Instagram looks like an afterthought or your Facebook page hasn't been updated since last term, you're losing prospective families to competitors who invest in their online presence.</p>
        <p>The real problem isn't your programme quality — it's visibility. Parents in Bukit Timah, Marine Parade, and Jurong are scrolling through Instagram Stories and Facebook groups looking for enrichment options for their children. They compare class photos, read reviews, and check how active your page is before they ever call to ask about schedules. A dormant social media profile signals an inactive business, regardless of how full your classes actually are.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media services for enrichment centres">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services for Enrichment Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>We manage your enrichment centre's social media from strategy to publishing. Every post is designed to highlight your unique programmes, celebrate student achievements, and give parents the confidence to enrol their children with you.</p>
        <p>Our content revolves around what parents want to see — children actively engaged in learning, real outcomes from your programmes, and the personality behind your brand. We plan campaigns around school holidays, term breaks, and programme launches to capture interest when parents are making decisions.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Class Highlight Reels</h3>
            <p>Engaging short-form videos capturing the energy of your classes — from robotics builds to art sessions — edited for Instagram Reels and TikTok to attract parent attention and shares.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Parent Engagement &amp; Enquiry Management</h3>
            <p>Prompt responses to comments, DMs, and programme enquiries. We nurture interested parents from their first interaction through to trial class booking and enrolment.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Programme Launch Graphics</h3>
            <p>Branded visual content for new programme announcements, holiday workshops, and seasonal promotions — designed to stand out in crowded parent feeds and drive registrations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Seasonal Campaign Strategy</h3>
            <p>Data-driven campaigns timed around June and December school holidays, term breaks, and key registration windows to maximise enrolment during peak decision-making periods.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for enrichment centre social media">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>We Know What Enrichment Centre Parents Want to See</h2>
      </div>
      <div class="section-content reveal">
        <p>We don't create generic social media content and hope it works. Our team understands the enrichment industry in Singapore and builds content strategies that resonate with parents who are comparing options and looking for the right fit for their child.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Enrichment Industry Knowledge</h3>
            <p>We understand the competitive landscape of enrichment programmes in Singapore — from STEAM to language classes. Your content reflects what makes your centre different, not just what you offer.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Visual-First Approach</h3>
            <p>Enrichment is inherently visual. We capture and present your classes in ways that make parents wish their child was already enrolled — real moments, real engagement, real learning.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Full Content Approval</h3>
            <p>Every post, caption, and visual is shared with you for approval before it goes live. You maintain complete control over your brand while we handle the creative and strategy work.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Flexible Monthly Plans</h3>
            <p>No lock-in contracts. Our month-to-month plans let you scale up during peak seasons and adjust during quieter periods. You stay because the results justify the investment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Enrichment centre social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Enrichment Centres of Every Size</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For centres building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing centres ready to fill more classes.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For established centres that want a complete social team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about enrichment centre social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Enrichment Centre Social Media — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost for enrichment centres in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing for enrichment centres in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, Reels production, and active community management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What type of social media content works best for enrichment centres?</summary>
          <div class="faq-answer"><p>The highest-performing content for enrichment centres includes class activity highlights, student project showcases, parent testimonials, programme launch announcements, and behind-the-scenes Reels showing what children actually experience. Visual content that captures fun, learning moments consistently drives the strongest engagement from parents.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you promote new enrichment programmes on social media?</summary>
          <div class="faq-answer"><p>We build launch campaigns with teaser content, countdown posts, early-bird offers, and highlight Reels. Campaigns are timed around school holidays and term breaks when parents are actively searching for enrichment activities. We also run retargeting strategies for parents who engaged with your previous content.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you manage social media for enrichment centres with multiple locations?</summary>
          <div class="faq-answer"><p>Yes. We create location-specific content strategies while maintaining brand consistency across all branches. Each location can have tailored posts highlighting its unique programmes, instructors, and community events, all managed through a single content calendar and approval workflow.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before we see results from social media marketing?</summary>
          <div class="faq-answer"><p>Most enrichment centres see measurable improvements in engagement and enquiries within the first 60 to 90 days. Follower growth and brand awareness build steadily, while targeted campaigns around programme launches and school holidays can generate immediate enrolment interest.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
