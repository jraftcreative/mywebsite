---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Marketing Agency for Interior Designers Singapore",
    "description": "Full-service marketing agency for interior designers in Singapore. SEO, Google Ads, social, branding, websites — built for renovation firms. From S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Interior Designer Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential ID Firm Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Single-channel focus (SEO or Social), Qanvast/Houzz profile setup, monthly content, and reporting for solo and boutique ID firms" },
      { "@type": "Offer", "name": "Growth ID Firm Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Multi-channel: SEO + Google Ads + IG/TikTok, before-after content production, GCLID lead tracking, bi-weekly reporting for established renovation firms" },
      { "@type": "Offer", "name": "Enterprise ID Firm Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service across all 5 channels, dedicated strategist, video production for walkthrough Reels, brand refresh, and weekly reporting for multi-location ID firms" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does marketing cost for an interior designer in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Interior designer marketing in Singapore starts at S$3,000 per month for essential single-channel work (typically SEO or social media). Growth packages at S$5,500/month combine SEO, Google Ads, and IG/TikTok with lead tracking. Enterprise packages at S$10,000+/month add video production, brand refresh, and a dedicated strategist. Renovation firms with multiple branches or premium positioning typically need the Growth tier minimum to compete with Qanvast and Renonation aggregator listings." } },
      { "@type": "Question", "name": "Why can't I just rely on Qanvast and Renonation for leads?", "acceptedAnswer": { "@type": "Answer", "text": "Aggregator platforms like Qanvast and Renonation send high-volume but low-margin leads — homeowners are typically comparing 5-8 firms simultaneously, and you pay per lead or per quote. Direct-to-firm marketing (SEO, Google Ads, IG, TikTok) builds a brand that homeowners search for by name, reducing lead cost over time and capturing higher-value clients who skip aggregator shortlists entirely." } },
      { "@type": "Question", "name": "What's the buyer journey for an HDB or condo renovation in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "HDB and condo renovation buyers research online for 3-6 months before shortlisting. The journey is: Inspiration (Pinterest, IG Reels, TikTok walkthroughs) → Shortlist (Qanvast/Renonation, Google searches like 'interior designer Punggol', AI tools like ChatGPT) → Quote (3-5 firm consultations) → Site Visit → Sign. Marketing for ID firms needs to show up at every stage — not just the bottom-of-funnel lead form." } },
      { "@type": "Question", "name": "Which marketing channels work best for interior designers in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Five channels in priority order for most ID firms: (1) SEO for HDB/condo catchment searches ('interior designer Punggol', 'BTO renovation Sengkang'), (2) Google Ads for high-intent terms during BTO key collection seasons, (3) Instagram Reels for completed project walkthroughs, (4) TikTok for behind-the-scenes and design-trend content, (5) a portfolio website that converts visits into quote enquiries. We build cross-channel plans based on your firm's stage and budget." } },
      { "@type": "Question", "name": "How long before marketing brings renovation leads?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads can generate quote requests within the first 7-14 days once tracking is set up. Social media content compounds over 8-12 weeks. SEO and GEO typically show ranking and AI-citation improvements within 3-6 months for catchment-area keywords. Renovation buyers research for months before signing, so a multi-channel presence shortens the consideration window meaningfully and gets your firm into the shortlist earlier in the journey." } },
      { "@type": "Question", "name": "Do you handle before-and-after content production?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Growth and Enterprise tiers include before-after photo and video production rights handover from completed projects. We coordinate the shoot brief, frame the walkthrough for IG Reels and TikTok formats, and write the captions/voiceover scripts. Most ID firms have a portfolio sitting on a hard drive — we turn that into rankable, citable content that fuels both organic and paid channels." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Marketing Agency for Interior Designers Singapore", "item": "https://jraftcreative.com/interior-designer-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Renovation Buyer Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Marketing Agency for Interior Designers Singapore | Jraft"
  description="Full-service marketing agency for interior designers in Singapore. SEO, Google Ads, social, branding, websites — built for renovation firms. From $3,000/mo."
  canonical="https://jraftcreative.com/interior-designer-marketing-singapore/"
  ogTitle="Marketing Agency for Interior Designers Singapore | Jraft"
  ogDescription="Full-service marketing agency for interior designers in Singapore. SEO, Google Ads, social, branding, websites — built for renovation firms. From $3,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="marketing agency for interior designers singapore, interior design digital marketing singapore, interior designer lead generation singapore, marketing for renovation firms singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Marketing for Interior Designers"
  heroTitle='Marketing Agency for <span class="highlight">Interior Designers in Singapore</span>'
  heroSubtitle="HDB and condo renovation buyers research online for 3 to 6 months before shortlisting an ID firm — and most ID firms are invisible during those months. We build full-service marketing strategies (SEO, GEO, Google Ads, IG/TikTok, branding, websites) designed for how Singapore homeowners actually choose who renovates their home."
  heroImage="/images/service-interior.webp"
  heroImageAlt="Modern Singapore HDB or condo interior — interior designer marketing"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20an%20interior%20design%20firm%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I run an interior design firm in Singapore and need marketing help."
  ctaLabel="Ready to Get Started?"
  ctaTitle='Let Us <span class="highlight">Grow</span> Your <span class="highlight">Renovation Pipeline</span>'
  ctaDescription="Book a free consultation and tell us about your ID firm — your niche, your project mix, your current marketing. We'll get back to you within 24 hours with a tailored, channel-by-channel marketing plan."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20an%20interior%20design%20firm%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why interior design firms need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> ID Firms Are Still <span class="highlight">Losing Quotes</span> to Firms with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>By the time a homeowner calls your firm, they've already spent 3-6 months deciding who's worth a quote. Most ID firms are invisible during that window — and the firms winning higher-margin projects know exactly why.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Shortlist Window</h3>
            <p>Homeowners spend 3-6 months on Google, Instagram, TikTok, Facebook, and increasingly AI tools before reaching out to a single firm. By then they've already shortlisted 3-5 firms. If you're not showing up on the platforms where they're searching, you're not getting the quote.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Aggregator Trap</h3>
            <p>Qanvast and Renonation own the discovery layer. Firms relying on aggregator leads pay per quote, compete on price against four other firms in every enquiry, and never build the brand recognition that drives direct enquiries.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Higher-Margin Gap</h3>
            <p>Firms winning landed renovations, boutique condos, and design-led HDBs aren't the ones with the most aggregator leads. They're the ones showing up directly in Google, dominating IG Reels in their catchment, getting cited in AI tools, and closing the visit with a strong portfolio site.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for interior designers in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every ID Firm <span class="highlight">Needs</span></h2>
