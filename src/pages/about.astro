---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Jraft Creative",
    "description": "Jraft Creative is a full-service marketing agency in Singapore helping businesses grow through website development, SEO, paid ads, social media, and AI search optimisation.",
    "url": "https://jraftcreative.com/about/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "legalName": "Jraft Creative Pte. Ltd.",
      "url": "https://jraftcreative.com/",
      "foundingDate": "2025",
      "foundingLocation": { "@type": "Place", "name": "Singapore" },
      "email": "contact@jraftcreative.com",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      },
      "areaServed": { "@type": "Country", "name": "Singapore" },
      "sameAs": [
        "https://www.instagram.com/jraftcreative",
        "https://www.linkedin.com/company/jraftcreative",
        "https://www.tiktok.com/@jraftcreative"
      ],
      "employee": [
        { "@id": "https://jraftcreative.com/about/#jeremy-cheong" },
        { "@id": "https://jraftcreative.com/about/#jeevan-aurol" }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://jraftcreative.com/about/#jeremy-cheong",
    "name": "Jeremy Cheong",
    "jobTitle": "Founder & Managing Director",
    "worksFor": {
      "@type": "Organization",
      "name": "Jraft Creative Pte. Ltd.",
      "url": "https://jraftcreative.com/"
    },
    "url": "https://jraftcreative.com/about/jeremy/",
    "mainEntityOfPage": "https://jraftcreative.com/about/",
    "image": "https://jraftcreative.com/images/founder.webp",
    "description": "Jeremy founded Jraft Creative in 2025 after spending years in sales and marketing roles across Singapore — managing over $1 million in ad spend and helping grow a business unit from zero to $2 million ARR in under a year.",
    "knowsAbout": [
      "Digital Marketing Strategy",
      "Search Engine Optimisation",
      "Google Ads",
      "Meta Ads",
      "Web Design",
      "AI Search Optimisation",
      "Generative Engine Optimisation"
    ],
    "sameAs": [
      "https://www.linkedin.com/in/jeremycheong"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://jraftcreative.com/about/#jeevan-aurol",
    "name": "Jeevan Aurol",
    "jobTitle": "Account Director",
    "worksFor": {
      "@type": "Organization",
      "name": "Jraft Creative Pte. Ltd.",
      "url": "https://jraftcreative.com/"
    },
    "url": "https://jraftcreative.com/about/",
    "mainEntityOfPage": "https://jraftcreative.com/about/",
    "image": "https://jraftcreative.com/images/jeevan.webp",
    "description": "Jeevan brings 15 years of marketing leadership built on one conviction: the best campaigns come from understanding the commercial reality behind them — the pricing decisions, the channel trade-offs, and the P&L pressures that determine whether a strategy actually ships.",
    "knowsAbout": [
      "Account Management",
      "Go-to-Market Strategy",
      "Brand Marketing",
      "Performance Marketing",
      "Product Launches",
      "Paid Media",
      "Content Strategy"
    ],
    "sameAs": [
      "https://www.linkedin.com/in/jeevan-aurol-ba69b213/"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "About", "item": "https://jraftcreative.com/about/" }
    ]
  }
];
---

<BaseLayout
  title="About Jraft Creative — Marketing Agency Singapore"
  description="Learn about Jraft Creative — a full-service marketing agency in Singapore. We help businesses grow through web design, SEO, paid ads, social media."
  canonical="https://jraftcreative.com/about/"
  ogTitle="About Jraft Creative — Marketing Agency Singapore"
  ogDescription="Full-service marketing agency in Singapore. Web design, SEO, paid ads, social media, and AI search optimisation — all under one roof."
  keywords="about Jraft Creative, marketing agency Singapore, digital agency Singapore, who we are, Jraft Creative team"
  schemaData={schemaData}
>

  <!-- ========== HERO ========== -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__content reveal">
        <p class="section-label">About Jraft Creative</p>
        <h1>Jraft Creative is the <span class="highlight">marketing team</span> that puts your <span class="highlight">strategy and business goals</span> before anything else.</h1>
        <p class="about-hero__subtitle">That sounds obvious until you&rsquo;ve worked with an agency that runs the same playbook on every client. We don&rsquo;t. The work starts with your numbers, your market, and what you&rsquo;re actually trying to build &mdash; and the campaigns, content, and channels come after that. Jeremy started Jraft Creative in 2025 after years inside Singapore sales and marketing teams &mdash; managing more than $1 million in ad spend along the way, and helping take one company from zero to $2M ARR. The team has grown around the same idea: do the strategy work first, then earn the result.</p>
      </div>
    </div>
  </section>

  <!-- ========== FOUNDERS STRIP ========== -->
  <section class="section founders-strip" aria-label="The people behind your business's winning strategy">
    <div class="container">
      <div class="founders-strip__header reveal">
        <h2>The <span class="highlight">people</span> behind your business's <span class="highlight">winning strategy</span>.</h2>
      </div>

      <div class="founders-grid">

        <!-- Jeremy -->
        <div class="founder-col reveal">
          <div class="founder-photo">
            <img src="/images/founder.webp" alt="Jeremy Cheong, Founder of Jraft Creative" width="800" height="1000" loading="lazy" decoding="async" />
          </div>
          <blockquote class="founder-pullquote">
            &ldquo;If marketing isn&rsquo;t tied to the business under it, it&rsquo;s just decoration.&rdquo;
          </blockquote>
          <div class="founder-identity">
            <p class="founder-name">Jeremy Cheong</p>
            <p class="founder-title">Founder & Managing Director</p>
          </div>
          <div class="founder-bio">
            <p>Jeremy founded Jraft Creative in 2025 after spending years in sales and marketing roles across Singapore &mdash; the kind of work where you&rsquo;re personally on the hook for the pipeline every quarter, and the number at the end of it is yours to defend. Two chapters stand out: managing over $1 million in ad spend across paid search and social, and helping grow a business unit from zero to $2 million ARR in under a year. That&rsquo;s where the conviction came from. He&rsquo;d seen, up close, what marketing looks like when it&rsquo;s actually accountable to revenue &mdash; and what it looks like when it&rsquo;s a deck full of impressions.</p>
            <p>He started the agency because he kept seeing the same gap. Small businesses were getting outgunned by competitors with bigger budgets and dedicated teams, while the agencies they could afford were either selling cookie-cutter templates, or charging enterprise rates for work no senior person was actually touching from one month to the next.</p>
            <p>So he built Jraft Creative to close that gap. Senior strategy, real ownership, no lock-in, no junior handoff. He runs strategy across every account here, sits in the WhatsApp chat with most of our clients directly, and is the one you call when something needs a real decision.</p>
          </div>
        </div>

        <!-- Jeevan -->
        <div class="founder-col reveal reveal-d1">
          <div class="founder-photo">
            <img src="/images/jeevan.webp" alt="Jeevan Aurol, Account Director at Jraft Creative" width="800" height="1000" loading="lazy" decoding="async" />
          </div>
          <blockquote class="founder-pullquote">
            &ldquo;Good marketing doesn&rsquo;t start with a campaign &mdash; it starts with understanding how business actually works.&rdquo;
          </blockquote>
          <div class="founder-identity">
            <p class="founder-name">Jeevan Aurol</p>
            <p class="founder-title">Account Director</p>
          </div>
          <div class="founder-bio">
            <p>Jeevan brings 15 years of marketing leadership built on one conviction: the best campaigns come from understanding the commercial reality behind them &mdash; the pricing decisions, the channel trade-offs, the P&amp;L pressures, and the stakeholder dynamics that determine whether a strategy actually ships.</p>
            <p>His career spans global product launches at Razer, where he scaled a category from zero to US$8M in profit within a year, managed a US$1.2M GTM budget, and led campaigns across US, Europe, APAC, and China. He has sat in the room where pricing gets decided, where retail margins get negotiated, and where marketing has to justify itself in numbers &mdash; not just impressions.</p>
            <p>Before and alongside that, he has worked agency-side &mdash; diagnosing client business challenges, pitching tailored strategies, and delivering performance campaigns for SME clients across paid, organic, and content channels.</p>
            <p>For clients, this means working with someone who thinks like a business owner first and a marketer second &mdash; and who builds campaigns designed to move the needle, not just the needle on a dashboard.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== OUR STORY ========== -->
  <section class="section about-story-section" aria-label="Our story">
    <div class="container">
      <div class="about-story-centered reveal">
        <p class="section-label"><span class="highlight">Our Story</span></p>
        <h2>Started With a <span class="highlight">Simple Belief</span></h2>
        <p>Too many Singapore businesses were getting overcharged for underwhelming work &mdash; bloated WordPress sites, cookie-cutter social media, and SEO reports full of jargon but no results.</p>
        <p>Jraft Creative was founded in 2025 to do things differently. We believe that great marketing shouldn&rsquo;t require a six-figure budget. Every business &mdash; from a one-person startup to an established SME &mdash; deserves a team that actually cares about their growth.</p>
        <p>Today, we work with businesses across Singapore to build websites that convert, run campaigns that perform, and create content that resonates. No fluff, no vanity metrics &mdash; just measurable results.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DO ========== -->
  <section class="section" style="background: rgba(13, 13, 20, 0.6); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);" aria-label="What we do">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Full-Service, <span class="highlight">One Team</span></h2>
        <p>Everything your business needs to grow online &mdash; handled by one agency with one point of contact.</p>
      </div>
      <div class="about-services-grid">
        <div class="about-service-card reveal reveal-d1">
          <div class="about-service-card__media">
            <img src="/images/service-webdev.webp" alt="Hand-coded business website on a laptop screen — bespoke website development by Jraft Creative" loading="lazy" decoding="async" width="800" height="450" />
          </div>
          <div class="about-service-card__body">
            <h3>Website Development</h3>
            <p>Custom websites, ecommerce stores, and web applications &mdash; hand-coded for speed, SEO, and conversions. No templates, no page builders.</p>
            <a href="/services/website-development" class="about-service-link">Learn more</a>
          </div>
        </div>
        <div class="about-service-card reveal reveal-d2">
          <div class="about-service-card__media">
            <img src="/images/service-seo.webp" alt="Search engine results page with high-ranking organic listings — SEO and performance services by Jraft Creative" loading="lazy" decoding="async" width="800" height="450" />
          </div>
          <div class="about-service-card__body">
            <h3>SEO &amp; Performance</h3>
            <p>Technical audits, on-page optimisation, local SEO, and performance tuning to get you found on Google and keep visitors on your site.</p>
            <a href="/services/seo-performance" class="about-service-link">Learn more</a>
          </div>
        </div>
        <div class="about-service-card reveal reveal-d3">
          <div class="about-service-card__media">
            <img src="/images/service-ads.webp" alt="Google and Meta ad campaign performance dashboard — paid advertising management by Jraft Creative" loading="lazy" decoding="async" width="800" height="450" />
          </div>
          <div class="about-service-card__body">
            <h3>Paid Ads</h3>
            <p>Google Ads, Meta Ads, TikTok, and YouTube &mdash; we manage your ad spend to deliver qualified leads and measurable ROI.</p>
            <a href="/services/paid-ads" class="about-service-link">Learn more</a>
          </div>
        </div>
        <div class="about-service-card reveal reveal-d4">
          <div class="about-service-card__media">
            <img src="/images/service-social.webp" alt="Social media content grid across Instagram, TikTok and Facebook — social media services by Jraft Creative" loading="lazy" decoding="async" width="800" height="450" />
          </div>
          <div class="about-service-card__body">
            <h3>Social Media</h3>
            <p>Content creation, Reels, TikToks, community management, and growth strategy for Instagram, TikTok, Facebook, and LinkedIn.</p>
            <a href="/services/social-media" class="about-service-link">Learn more</a>
          </div>
        </div>
        <div class="about-service-card about-service-card--accent reveal reveal-d1">
          <div class="about-service-card__media">
            <img src="/images/service-seo.webp" alt="AI assistants recommending brands in chat answers — AI search optimisation (GEO) by Jraft Creative" loading="lazy" decoding="async" width="800" height="450" />
          </div>
          <div class="about-service-card__body">
            <h3>AI Search Optimisation</h3>
            <p>Get your brand recommended by ChatGPT, Gemini, and Perplexity. We optimise your digital presence so AI engines cite and recommend you.</p>
            <a href="/services/ai-search-optimisation" class="about-service-link">Learn more</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" aria-label="Why choose us">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>What Makes Us <span class="highlight">Different</span></h2>
      </div>
      <div class="about-why-grid">
        <div class="about-why-item reveal reveal-d1">
          <h3>Transparent Pricing</h3>
          <p>No hidden fees, no surprise invoices. We publish our prices and quote upfront. The price we quote is the price you pay &mdash; always.</p>
        </div>
        <div class="about-why-item reveal reveal-d2">
          <h3>No Lock-in Contracts</h3>
          <p>We earn your business every month. No 12-month lock-ins, no cancellation penalties. Stay because of results, not because of a contract.</p>
        </div>
        <div class="about-why-item reveal reveal-d3">
          <h3>Fast Turnaround</h3>
          <p>Most websites launch within 2 weeks. Campaigns go live within days. We move quickly because your time matters.</p>
        </div>
        <div class="about-why-item reveal reveal-d1">
          <h3>Hand-Coded Quality</h3>
          <p>We don&rsquo;t use bloated WordPress themes or page builders. Every site is hand-coded for speed, scoring 90+ on Google PageSpeed out of the box.</p>
        </div>
        <div class="about-why-item reveal reveal-d2">
          <h3>Singapore-Focused</h3>
          <p>We understand local consumer behaviour, industry regulations, and the competitive landscape. Your project is handled by people who know Singapore.</p>
        </div>
        <div class="about-why-item reveal reveal-d3">
          <h3>Results Over Vanity</h3>
          <p>We don&rsquo;t chase likes &mdash; we chase leads, conversions, and revenue. Every decision is guided by data and your business goals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW WE WORK ========== -->
  <section class="section" style="background: rgba(13, 13, 20, 0.6); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);" aria-label="How we work">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">How We Work</p>
        <h2>Simple, <span class="highlight">Transparent Process</span></h2>
        <p>From first call to launch in as fast as 2 weeks.</p>
      </div>
      <div class="about-process-grid">
        <div class="about-process-step reveal reveal-d1">
          <div class="about-process-number">01</div>
          <h3>Discovery</h3>
          <p>Free consultation to understand your business, goals, and audience. We define the project scope and provide a transparent quote.</p>
        </div>
        <div class="about-process-step reveal reveal-d2">
          <div class="about-process-number">02</div>
          <h3>Design</h3>
          <p>Custom mockups tailored to your brand. We iterate based on your feedback until every detail is right.</p>
        </div>
        <div class="about-process-step reveal reveal-d3">
          <div class="about-process-number">03</div>
          <h3>Build</h3>
          <p>Hand-coded, mobile-responsive, and SEO-optimised. We test across all devices and browsers before launch.</p>
        </div>
        <div class="about-process-step reveal reveal-d4">
          <div class="about-process-number">04</div>
          <h3>Launch &amp; Support</h3>
          <p>We deploy, configure analytics, and provide training. Every project includes 30 days of free post-launch support.</p>
        </div>
      </div>
      <div class="section-cta reveal" style="text-align: center; margin-top: 40px;">
        <a href="/process/" class="btn btn-secondary">View Our Full Process</a>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="section cta-section" aria-label="Get started">
    <div class="container">
      <div class="cta-box reveal">
        <p class="section-label">Ready to Get Started?</p>
        <h2>Let&rsquo;s Build Something Great Together</h2>
        <p>Book a free consultation and tell us about your project. No obligations &mdash; just a conversation about how we can help your business grow.</p>
        <div class="cta-buttons">
          <a href="/contact/" class="btn btn-primary">Book Your Consultation</a>
          <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20more%20about%20your%20agency." class="btn btn-secondary" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WhatsApp Button -->
  <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20marketing%20services%20for%20my%20business." class="whatsapp-btn" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" slot="after-footer">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="#fff" aria-hidden="true"><path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.13 6.742 3.05 9.378L1.054 31.29l6.118-1.962A15.91 15.91 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.302 22.602c-.39 1.1-2.276 2.106-3.156 2.17-.796.058-1.78.082-2.872-.278a26.3 26.3 0 0 1-2.6-1.074c-4.576-2.186-7.566-6.826-7.796-7.142-.222-.316-1.836-2.478-1.836-4.726 0-2.248 1.162-3.356 1.574-3.814.39-.434.858-.542 1.144-.542.286 0 .572.004.82.014.264.012.618-.1.966.738.39.938 1.294 3.224 1.408 3.458.112.234.19.508.038.82-.15.316-.226.512-.448.79-.222.278-.468.62-.668.832-.222.234-.454.49-.196.962.26.47 1.154 1.906 2.478 3.088 1.702 1.52 3.136 1.99 3.582 2.214.448.222.708.19.968-.114.26-.306 1.118-1.302 1.416-1.75.298-.448.596-.37.998-.222.404.148 2.566 1.21 3.006 1.432.44.222.734.334.844.518.112.186.112 1.074-.278 2.174z"/></svg>
  </a>

</BaseLayout>

<!-- Hide global grid bg on About page, per locked design pattern -->
<style is:global>
  .animated-bg__grid { display: none; }
</style>

<style>
  /* --- About Hero (editorial; matches site type system) --- */
  .about-hero {
    padding: 160px 0 64px;
    background: transparent;
  }

  .about-hero__content {
    max-width: 880px;
  }

  .about-hero h1 {
    font-size: clamp(2.2rem, 4.6vw, 3.4rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 16px 0 24px;
  }

  /* Brand-green highlight phrases — global .highlight rule is scoped to
     .hero / .section-header only, so we re-apply here for .about-hero and
     .founders-strip headers. Gradient text-fill matches the rest of the site. */
  .about-hero h1 .highlight,
  .founders-strip h2 .highlight,
  .about-story-centered .highlight,
  .about-story-centered h2 .highlight,
  .about-story-centered .section-label .highlight {
    background: linear-gradient(135deg, var(--accent) 0%, #7adeb5 50%, var(--accent) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: var(--accent); /* fallback for browsers w/o background-clip:text */
  }

  .about-hero__subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 720px;
  }

  /* --- Founders strip --- */
  .founders-strip {
    padding-top: 72px;
    padding-bottom: 96px;
  }

  .founders-strip__header {
    max-width: 760px;
    margin-bottom: 56px;
  }

  .founders-strip__header h2 {
    font-size: clamp(1.8rem, 3.2vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 12px 0 16px;
  }

  .founders-strip__intro {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.55;
    max-width: 560px;
  }

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  /* --- Founder column (editorial — no card, no shadow) --- */
  .founder-col {
    max-width: 560px;
  }

  .founder-photo {
    width: 100%;
    max-width: 260px;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin: 0 auto 28px;
  }

  .founder-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .founder-photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.015));
    border: 1px dashed rgba(255, 255, 255, 0.14);
  }

  .founder-photo__caption {
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .founder-pullquote {
    margin: 0 0 20px;
    padding: 4px 0 4px 14px;
    border-left: 2px solid #39BB9D;
    font-style: italic;
    font-size: 1.08rem;
    line-height: 1.55;
    color: var(--text);
    max-width: 520px;
  }

  .founder-identity {
    margin-bottom: 20px;
  }

  .founder-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 4px;
    letter-spacing: -0.005em;
  }

  .founder-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: #39BB9D;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .founder-bio {
    max-width: 520px;
  }

  .founder-bio p {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.75;
    margin: 0 0 18px;
  }

  .founder-bio p:last-child {
    margin-bottom: 0;
  }

  /* --- Our Story (centered) --- */
  /* Tighten top spacing so Our Story sits closer to the Founders strip above.
     Global .section default is 120px 0 — reduce top by ~40%. */
  .about-story-section {
    padding-top: 72px;
  }

  .about-story-centered {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .about-story-centered h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-align: center;
  }

  .about-story-centered p {
