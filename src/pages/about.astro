---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Jraft Creative",
    "description": "Jraft Creative is a full-service marketing agency in Singapore helping businesses grow through website development, SEO, paid ads, social media, and AI search optimisation.",
    "url": "https://jraftcreative.com/about/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "legalName": "Jraft Creative Pte. Ltd.",
      "url": "https://jraftcreative.com/",
      "foundingDate": "2025",
      "foundingLocation": { "@type": "Place", "name": "Singapore" },
      "email": "contact@jraftcreative.com",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      },
      "areaServed": { "@type": "Country", "name": "Singapore" },
      "sameAs": [
        "https://www.instagram.com/jraftcreative",
        "https://www.linkedin.com/company/jraftcreative",
        "https://www.tiktok.com/@jraftcreative"
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "About", "item": "https://jraftcreative.com/about/" }
    ]
  }
];
---

<BaseLayout
  title="About Us | Jraft Creative — Marketing Agency Singapore"
  description="Learn about Jraft Creative — a full-service marketing agency in Singapore. We help businesses grow through web design, SEO, paid ads, social media."
  canonical="https://jraftcreative.com/about/"
  ogTitle="About Jraft Creative — Marketing Agency Singapore"
  ogDescription="Full-service marketing agency in Singapore. Web design, SEO, paid ads, social media, and AI search optimisation — all under one roof."
  keywords="about Jraft Creative, marketing agency Singapore, digital agency Singapore, who we are, Jraft Creative team"
  schemaData={schemaData}
>

  <!-- ========== HERO ========== -->
  <section class="about-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">/</span> <span>About</span>
      </nav>
      <div class="about-hero__content reveal">
        <p class="section-label">About Us</p>
        <h1>We <span class="highlight">Build Brands</span> That Actually Grow</h1>
        <p class="about-hero__subtitle">Jraft Creative is a full-service marketing agency in Singapore. We combine strategy, design, and technology to help businesses launch, scale, and stand out in a crowded market.</p>
      </div>
    </div>
  </section>

  <!-- ========== OUR STORY ========== -->
  <section class="section" aria-label="Our story">
    <div class="container">
      <div class="about-story-grid">
        <div class="about-story-content reveal">
          <p class="section-label">Our Story</p>
          <h2>Started With a Simple Belief</h2>
          <p>Too many Singapore businesses were getting overcharged for underwhelming work — bloated WordPress sites, cookie-cutter social media, and SEO reports full of jargon but no results.</p>
          <p>Jraft Creative was founded in 2025 to do things differently. We believe that great marketing shouldn't require a six-figure budget. Every business — from a one-person startup to an established SME — deserves a team that actually cares about their growth.</p>
          <p>Today, we work with businesses across Singapore to build websites that convert, run campaigns that perform, and create content that resonates. No fluff, no vanity metrics — just measurable results.</p>
        </div>
        <div class="about-story-stats reveal reveal-d1">
          <div class="about-stat">
            <span class="about-stat__number">15+</span>
            <span class="about-stat__label">Projects Delivered</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__number">6</span>
            <span class="about-stat__label">Industries Served</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__number">100%</span>
            <span class="about-stat__label">Client Satisfaction</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__number">2 wks</span>
            <span class="about-stat__label">Avg. Turnaround</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FOUNDER ========== -->
  <section class="section" style="background: rgba(13, 13, 20, 0.6); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);" aria-label="Meet the founder">
    <div class="container">
      <div class="about-founder-grid reveal">
        <div class="about-founder-col">
          <div class="about-founder-photo">
            <img src="/images/founder.webp" alt="Jeremy Cheong, Co-Founder of Jraft Creative" width="800" height="1200" loading="lazy">
          </div>
          <div class="about-founder-name">
            <a href="/about/jeremy/" style="text-decoration: none; color: inherit;"><strong>Jeremy Cheong</strong></a>
            <span>Co-Founder</span>
          </div>
        </div>
        <div class="about-founder-content">
          <p class="section-label">Meet the Founder</p>
          <h2>Built on Real-World <span class="highlight">Sales &amp; Marketing Experience</span></h2>
          <p>Jraft Creative wasn't born in a classroom — it was built on years of hands-on experience in sales and marketing across multiple industries in Singapore.</p>
          <p>Before starting Jraft Creative, our founder spent years in high-growth sales and marketing roles, working closely with businesses to drive revenue, build pipelines, and scale operations. One of the most defining chapters: helping a company grow a business unit from zero to $2 million ARR in under a year.</p>
          <p>But throughout that journey, one pattern kept showing up. Small businesses were constantly outgunned by bigger competitors with deeper pockets and dedicated marketing teams. And most business owners — stretched thin between operations, hiring, and cash flow — kept putting marketing off for "later." Later turned into months. Months turned into missed opportunities.</p>
          <p>Jraft Creative was founded to close that gap. To give smaller businesses access to the same calibre of strategy, design, and execution that larger companies take for granted — without the enterprise price tag or the 12-month lock-in.</p>
          <p>Today, Jraft Creative brings that same growth mindset to every client engagement — whether it's launching a new website, running paid campaigns, or getting your brand recommended by AI search engines.</p>
          <a href="/about/jeremy/" class="about-service-link">More about Jeremy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DO ========== -->
  <section class="section" style="background: rgba(13, 13, 20, 0.6); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);" aria-label="What we do">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Full-Service, <span class="highlight">One Team</span></h2>
        <p>Everything your business needs to grow online — handled by one agency with one point of contact.</p>
      </div>
      <div class="about-services-grid">
        <div class="about-service-card reveal reveal-d1">
          <div class="about-service-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>Website Development</h3>
          <p>Custom websites, ecommerce stores, and web applications — hand-coded for speed, SEO, and conversions. No templates, no page builders.</p>
          <a href="/services/website-development" class="about-service-link">Learn more</a>
        </div>
        <div class="about-service-card reveal reveal-d2">
          <div class="about-service-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h3>SEO &amp; Performance</h3>
          <p>Technical audits, on-page optimisation, local SEO, and performance tuning to get you found on Google and keep visitors on your site.</p>
          <a href="/services/seo-performance" class="about-service-link">Learn more</a>
        </div>
        <div class="about-service-card reveal reveal-d3">
          <div class="about-service-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <h3>Paid Ads</h3>
          <p>Google Ads, Meta Ads, TikTok, and YouTube — we manage your ad spend to deliver qualified leads and measurable ROI.</p>
          <a href="/services/paid-ads" class="about-service-link">Learn more</a>
        </div>
        <div class="about-service-card reveal reveal-d4">
          <div class="about-service-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2H7a5 5 0 0 0-5 5v10a5 5 0 0 0 5 5h10a5 5 0 0 0 5-5V7a5 5 0 0 0-5-5z"/><line x1="16" y1="11.37" x2="16" y2="11.37"/><circle cx="12" cy="12" r="4"/></svg>
          </div>
          <h3>Social Media</h3>
          <p>Content creation, Reels, TikToks, community management, and growth strategy for Instagram, TikTok, Facebook, and LinkedIn.</p>
          <a href="/services/social-media" class="about-service-link">Learn more</a>
        </div>
        <div class="about-service-card about-service-card--accent reveal reveal-d1">
          <div class="about-service-icon">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 3-2 5.5-4 7.5L12 20l-3-3.5C7 14.5 5 12 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2"/></svg>
          </div>
          <h3>AI Search Optimisation</h3>
          <p>Get your brand recommended by ChatGPT, Gemini, and Perplexity. We optimise your digital presence so AI engines cite and recommend you.</p>
          <a href="/services/ai-search-optimisation" class="about-service-link">Learn more</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" aria-label="Why choose us">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>What Makes Us <span class="highlight">Different</span></h2>
      </div>
      <div class="about-why-grid">
        <div class="about-why-item reveal reveal-d1">
          <h3>Transparent Pricing</h3>
          <p>No hidden fees, no surprise invoices. We publish our prices and quote upfront. The price we quote is the price you pay — always.</p>
        </div>
        <div class="about-why-item reveal reveal-d2">
          <h3>No Lock-in Contracts</h3>
          <p>We earn your business every month. No 12-month lock-ins, no cancellation penalties. Stay because of results, not because of a contract.</p>
        </div>
        <div class="about-why-item reveal reveal-d3">
          <h3>Fast Turnaround</h3>
          <p>Most websites launch within 2 weeks. Campaigns go live within days. We move quickly because your time matters.</p>
        </div>
        <div class="about-why-item reveal reveal-d1">
          <h3>Hand-Coded Quality</h3>
          <p>We don't use bloated WordPress themes or page builders. Every site is hand-coded for speed, scoring 90+ on Google PageSpeed out of the box.</p>
        </div>
        <div class="about-why-item reveal reveal-d2">
          <h3>Singapore-Focused</h3>
          <p>We understand local consumer behaviour, industry regulations, and the competitive landscape. Your project is handled by people who know Singapore.</p>
        </div>
        <div class="about-why-item reveal reveal-d3">
          <h3>Results Over Vanity</h3>
          <p>We don't chase likes — we chase leads, conversions, and revenue. Every decision is guided by data and your business goals.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW WE WORK ========== -->
  <section class="section" style="background: rgba(13, 13, 20, 0.6); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);" aria-label="How we work">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">How We Work</p>
        <h2>Simple, <span class="highlight">Transparent Process</span></h2>
        <p>From first call to launch in as fast as 2 weeks.</p>
      </div>
      <div class="about-process-grid">
        <div class="about-process-step reveal reveal-d1">
          <div class="about-process-number">01</div>
          <h3>Discovery</h3>
          <p>Free consultation to understand your business, goals, and audience. We define the project scope and provide a transparent quote.</p>
        </div>
        <div class="about-process-step reveal reveal-d2">
          <div class="about-process-number">02</div>
          <h3>Design</h3>
          <p>Custom mockups tailored to your brand. We iterate based on your feedback until every detail is right.</p>
        </div>
        <div class="about-process-step reveal reveal-d3">
          <div class="about-process-number">03</div>
          <h3>Build</h3>
          <p>Hand-coded, mobile-responsive, and SEO-optimised. We test across all devices and browsers before launch.</p>
        </div>
        <div class="about-process-step reveal reveal-d4">
          <div class="about-process-number">04</div>
          <h3>Launch &amp; Support</h3>
          <p>We deploy, configure analytics, and provide training. Every project includes 30 days of free post-launch support.</p>
        </div>
      </div>
      <div class="section-cta reveal" style="text-align: center; margin-top: 40px;">
        <a href="/process/" class="btn btn-secondary">View Our Full Process</a>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="section cta-section" aria-label="Get started">
    <div class="container">
      <div class="cta-box reveal">
        <p class="section-label">Ready to Get Started?</p>
        <h2>Let's Build Something Great Together</h2>
        <p>Book a free consultation and tell us about your project. No obligations — just a conversation about how we can help your business grow.</p>
        <div class="cta-buttons">
          <a href="/contact/" class="btn btn-primary">Get a Free Quote</a>
          <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20more%20about%20your%20agency." class="btn btn-secondary" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WhatsApp Button -->
  <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20services." class="whatsapp-btn" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" slot="after-footer">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="#fff" aria-hidden="true"><path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.13 6.742 3.05 9.378L1.054 31.29l6.118-1.962A15.91 15.91 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.302 22.602c-.39 1.1-2.276 2.106-3.156 2.17-.796.058-1.78.082-2.872-.278a26.3 26.3 0 0 1-2.6-1.074c-4.576-2.186-7.566-6.826-7.796-7.142-.222-.316-1.836-2.478-1.836-4.726 0-2.248 1.162-3.356 1.574-3.814.39-.434.858-.542 1.144-.542.286 0 .572.004.82.014.264.012.618-.1.966.738.39.938 1.294 3.224 1.408 3.458.112.234.19.508.038.82-.15.316-.226.512-.448.79-.222.278-.468.62-.668.832-.222.234-.454.49-.196.962.26.47 1.154 1.906 2.478 3.088 1.702 1.52 3.136 1.99 3.582 2.214.448.222.708.19.968-.114.26-.306 1.118-1.302 1.416-1.75.298-.448.596-.37.998-.222.404.148 2.566 1.21 3.006 1.432.44.222.734.334.844.518.112.186.112 1.074-.278 2.174z"/></svg>
  </a>

</BaseLayout>

<style>
  /* --- About Hero --- */
  .about-hero {
    padding: 160px 0 60px;
    background: transparent;
  }

  .about-hero .breadcrumb {
    margin-bottom: 32px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .about-hero .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .about-hero .breadcrumb a:hover {
    color: var(--accent);
  }

  .about-hero .breadcrumb span {
    margin: 0 8px;
  }

  .about-hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .about-hero__subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
  }

  /* --- Story Section --- */
  .about-story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about-story-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .about-story-content p {
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .about-story-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    padding-top: 20px;
  }

  .about-stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: center;
    transition: all var(--transition);
  }

  .about-stat:hover {
    border-color: var(--border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .about-stat__number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }

  .about-stat__label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }

  /* --- Founder Section --- */
  .about-founder-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 56px;
    align-items: center;
  }

  .about-founder-col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .about-founder-photo {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--bg-card);
    border: 1px solid var(--border);
    width: 100%;
  }

  .about-founder-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-founder-name {
    padding: 20px 0 0;
    text-align: center;
    width: 100%;
  }

  .about-founder-name strong {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .about-founder-name span {
    display: block;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
    margin-top: 4px;
  }

  .about-founder-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .about-founder-content p {
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  /* --- Services Grid --- */
  .about-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .about-service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 28px;
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
  }

  .about-service-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .about-service-card--accent {
    border-color: var(--border-accent);
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.04), rgba(73, 184, 137, 0.01));
  }

  .about-service-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: var(--accent-dim);
    color: var(--accent);
    margin-bottom: 20px;
  }

  .about-service-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .about-service-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 16px;
    flex: 1;
  }

  .about-service-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--transition);
  }

  .about-service-link:hover {
    color: var(--accent-hover);
  }

  .about-service-link::after {
    content: ' \2192';
  }

  /* --- Why Us Grid --- */
  .about-why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .about-why-item {
    padding: 32px 28px;
    border-left: 3px solid var(--accent);
    background: var(--bg-card);
    border-radius: 0 var(--radius) var(--radius) 0;
    transition: all var(--transition);
  }

  .about-why-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .about-why-item h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .about-why-item p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* --- Process Grid --- */
  .about-process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .about-process-step {
    text-align: center;
    padding: 32px 20px;
  }

  .about-process-number {
    font-size: 2.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }

  .about-process-step h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .about-process-step p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .about-story-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .about-founder-grid {
      grid-template-columns: 240px 1fr;
