---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Law Firm AI Search Optimisation Singapore",
    "description": "AI search optimisation for law firms in Singapore — get your firm recommended by ChatGPT, Google Gemini, Perplexity, and AI Overviews when clients search for legal services. From S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Law Firm AI Search Optimisation (GEO)",
    "offers": [
      { "@type": "Offer", "name": "GEO Essentials", "price": "3000", "priceCurrency": "SGD", "description": "AI visibility audit, schema markup, content optimisation (5 pages/mo), llms.txt setup, monthly reporting" },
      { "@type": "Offer", "name": "GEO Growth", "price": "5000", "priceCurrency": "SGD", "description": "Everything in Essentials plus 20 pages/mo, authority building, answer engine content, bi-weekly reporting, dedicated strategist" },
      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Why does my law firm need AI search optimisation?", "acceptedAnswer": { "@type": "Answer", "text": "Prospective clients increasingly ask ChatGPT and Gemini for law firm recommendations before contacting anyone. Legal queries are high-value — a single AI referral for corporate law or litigation can be worth thousands in billable hours. If AI doesn't recommend your firm, you're losing high-value clients to competitors." } },
      { "@type": "Question", "name": "Which AI platforms recommend law firms in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "The main platforms are ChatGPT, Google Gemini, Google AI Overviews, Perplexity, and Microsoft Copilot. Each pulls from different sources when making legal recommendations, so a multi-platform strategy is essential for comprehensive visibility." } },
      { "@type": "Question", "name": "How is GEO different from SEO for law firms?", "acceptedAnswer": { "@type": "Answer", "text": "SEO helps your law firm rank in Google search results. GEO ensures AI platforms name your firm when clients ask for recommendations. The overlap between Google rankings and AI citations is below 20%, meaning a top Google ranking doesn't guarantee AI will recommend you." } },
      { "@type": "Question", "name": "How long before my law firm appears in AI recommendations?", "acceptedAnswer": { "@type": "Answer", "text": "Most law firms see measurable changes in AI citation rates within 30 to 90 days. Schema markup and llms.txt implementation can deliver quick wins within weeks. Building authority signals and legal directory presence compounds over time for sustained visibility." } },
      { "@type": "Question", "name": "How much does law firm AI search optimisation cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Our GEO plans for law firms start at $3,000 SGD/month for the Essentials package covering AI audits, schema markup, and content optimisation. Growth plans at $5,000/month add authority building and a dedicated strategist. Enterprise plans from $10,000/month deliver full-service AI search domination." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Law Firm AI Search Optimisation Singapore", "item": "https://jraftcreative.com/law-firm-ai-search-optimisation-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Law Firm AI Search Optimisation — Jraft Creative"
  description="Get your law firm recommended by ChatGPT and Gemini when clients search for legal services in Singapore — from S$3,000/mo."
  canonical="https://jraftcreative.com/law-firm-ai-search-optimisation-singapore/"
  ogTitle="Law Firm AI Search Optimisation — Jraft Creative"
  ogDescription="Get your law firm recommended by ChatGPT, Gemini, and Perplexity. Specialist AI search optimisation for law firms in Singapore."
  ogImage="https://jraftcreative.com/images/og-seo.jpg"
  keywords="law firm ai search optimisation singapore, law firm geo singapore, legal ai visibility, law firm chatgpt optimisation, legal generative engine optimisation, lawyer ai search singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Law Firm GEO"
  heroTitle='Law Firm AI Search Optimisation in <span class="highlight">Singapore</span>'
  heroSubtitle="Clients ask ChatGPT 'best corporate lawyer in Singapore' or 'recommended divorce lawyer near me' before they ever contact a firm. Legal queries are high-value — one AI referral can be worth thousands in billable hours. With 60.9% of Singapore using AI to search, your firm needs to be the one AI recommends."
  heroImage="/images/service-seo.webp"
  heroImageAlt="Singapore law firm partners — law firm AI search optimisation"
  heroButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View GEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to learn about AI search optimisation for my law firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Law Firm Into AI Answers"
  ctaDescription="Book a free AI visibility audit and we'll show you exactly how your firm appears — and where it's missing — across ChatGPT, Gemini, Perplexity, and Google AI Overviews. We'll respond within 24 hours."
  ctaButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20about%20AI%20search%20optimisation%20for%20my%20law%20firm.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why law firms need AI search optimisation in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Clients Now Ask <span class="highlight">AI</span> Which Lawyer to <span class="highlight">Hire</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Before they ever call a firm, prospective clients ask ChatGPT, Gemini, Perplexity, and Google AI Mode "best corporate lawyer in Singapore" or "recommended divorce lawyer near me". AI replies with a short, curated shortlist — and if your firm isn't named, you never enter the consideration set. Legal matters carry high client lifetime value, so each missed AI recommendation is a high-value client lost to a competitor.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Clients Ask AI First</h3>
            <p>"Best corporate lawyer Singapore", "recommended divorce lawyer near me", "IP law firm for startups" — increasingly typed into ChatGPT, Gemini, Perplexity, and Google AI Mode, not Google search. AI returns three or four named firms with a rationale for each. That shortlist is now the first impression, and it forms before anyone visits your website.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Invisible to AI, Off the Shortlist</h3>
            <p>The overlap between Google rankings and AI citations is below 20%. A firm that ranks page one for "corporate law firm Singapore" can be completely absent from ChatGPT's answer. AI picks firms on practice-area authority, reviews, directory presence, and structured data — not search position. Invisible to AI means off the shortlist, every time.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Compliance Still Applies</h3>
            <p>The Legal Profession (Professional Conduct) Rules govern how Singapore firms may publicise their services — and those rules apply to AI-surfaced content exactly as they do to a website or brochure. Practice-area content, reviews handling, and claims of expertise must stay accurate and non-misleading. We build AI visibility within those guardrails, never around them.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="AI search optimisation services for law firms">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of Law Firm <span class="highlight">GEO</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Generative Engine Optimisation for law firms isn't traditional SEO. AI recommends firms on a distinct set of signals — structured data about your practice areas and lawyers, citation-ready answer content, third-party authority, and reputation. We build every signal AI weighs when it decides which firm to name, all within the Legal Profession (Professional Conduct) Rules.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>AI-Friendly Content &amp; Schema</h3>
            <p>JSON-LD markup that tells AI exactly what your firm practises — LegalService, Attorney, FAQ, and Speakable schemas plus an llms.txt file — paired with cleanly structured pages AI can extract. The machine-readable foundation that lets ChatGPT and Gemini parse your practice areas, lawyers, and jurisdictions accurately.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Entity &amp; Authority Signals</h3>
            <p>AI recommends firms it recognises as established entities. We strengthen the signals that build that recognition — consistent firm and lawyer entities across the web, thought-leadership in outlets like Singapore Law Watch and LinkedIn, and recognition in rankings such as Chambers &amp; Partners and Asian Legal Business.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Citation &amp; Directory Presence</h3>
            <p>AI verifies firms against the Law Society of Singapore registry and trusted legal directories before citing them. We ensure your firm and lawyers appear with complete, specific, up-to-date practice-area information across the directories AI references — a baseline trust signal that makes AI cite you with confidence.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Review &amp; Reputation Signals</h3>
            <p>AI treats Google Reviews as unfiltered social proof — a firm with 50+ reviews averaging 4.5 stars sends a far stronger signal than one with none. We build a compliant review-generation process and manage your reputation across the platforms AI reads, so client sentiment reinforces every recommendation.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-campaign-analytics.webp');">
          <div class="service-detail-card__content">
            <h3>Practice-Area Answer Content</h3>
            <p>Each practice area generates its own prompts — "how long does a divorce take in Singapore", "rights if terminated without notice". We build detailed, individual practice-area pages and legal FAQs that answer those questions clearly, giving AI the authoritative, citable content it needs to recommend you for the exact matter a client asks about.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>AI-Visibility Monitoring</h3>
            <p>We track a set of legal prompts across ChatGPT, Gemini, Perplexity, and Copilot over time — where your firm appears, where it doesn't, and which competitors AI favours. A transparent report shows citation rates by practice area so you can see AI visibility improving and where to focus next.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for law firm AI search optimisation">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">GEO Agency</span> Built for <span class="highlight">Law Firms</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We combine how AI search actually selects firms with how legal clients evaluate and choose representation. We know the prompts prospective clients use, the signals AI relies on for legal recommendations, and the Legal Profession (Professional Conduct) Rules that govern everything a firm publishes — and we turn AI visibility into real consultations and retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Legal Industry Understanding</h3>
            <p>We understand how legal clients search — from in-house counsel sourcing external firms to individuals seeking representation. Our strategies target the specific AI prompts legal consumers use, accounting for the nuance of practice area, jurisdiction, and matter complexity.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Practice-Area Targeting</h3>
            <p>Corporate, family, IP, criminal, employment, real estate — each practice area generates distinct AI prompts. We optimise your firm's visibility for every area you serve, so AI recommends you whether someone asks for a mergers lawyer or a tenancy-dispute specialist.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Compliance-First Authority</h3>
            <p>Legal clients demand credibility, and Singapore's conduct rules demand accuracy. We strengthen the directory, review, peer-endorsement, and thought-leadership signals AI weighs — while keeping every claim accurate and non-misleading under the Professional Conduct Rules.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — where GEO fits the client journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>Where <span class="highlight">GEO</span> Fits the <span class="highlight">Client Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every prospective legal client moves through the same five stages before engaging a firm. GEO owns the first one — being recommended by the AI tool the moment a client asks — and feeds trust signals into every stage after it.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Asks ChatGPT, Gemini or Perplexity for firms</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>AI names 3–4 firms for the matter</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, directory, practice-area pages</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>Consultation request or call</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Retainer signed, refers &amp; returns</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Law firm AI search optimisation pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">GEO Pricing</p>
        <h2>AI Search Optimisation Plans for Law Firms</h2>
        <p>Monthly retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essentials</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
