---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Wellness Marketing Agency Singapore",
    "description": "Full-service digital marketing agency for wellness businesses in Singapore — website design, SEO, Google Ads, social media, and content marketing across all health and fitness sub-industries. From $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Wellness Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for wellness businesses" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, client-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-location campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a wellness business spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most wellness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business's size, number of locations, and growth targets. Our Essential plan at $3,000/month is a strong starting point for single-location wellness businesses." } },
      { "@type": "Question", "name": "What types of wellness businesses do you work with?", "acceptedAnswer": { "@type": "Answer", "text": "We work with all segments of Singapore's wellness industry — yoga studios, pilates studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, spas, nutrition consultancies, personal trainers, chiropractic clinics, and holistic health practitioners. Each segment has its own audience, competitive dynamics, and marketing approach, and we tailor every strategy accordingly." } },
      { "@type": "Question", "name": "How is a wellness-specialist agency different from a general marketing agency?", "acceptedAnswer": { "@type": "Answer", "text": "A general agency treats every client the same — generic templates, generic strategies, generic results. We specialise in wellness because the industry has unique characteristics: the trust required for healthcare marketing, the community dynamics of fitness, the seasonality of wellness trends, and the specific search behaviour of health-conscious Singaporeans. This specialisation means faster results because we already know what works in your industry." } },
      { "@type": "Question", "name": "How long before marketing generates results for my wellness business?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate client enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most wellness business clients see a meaningful increase in bookings and enquiries within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "Do you handle everything in-house or outsource to freelancers?", "acceptedAnswer": { "@type": "Answer", "text": "Everything is handled in-house — website design and development, SEO, Google Ads, Facebook Ads, social media content creation, content writing, and analytics. No outsourcing, no subcontractors, no white-labelling. One team manages your entire marketing strategy, which means complete alignment across channels and a single point of accountability for results." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Wellness Marketing Agency Singapore", "item": "https://jraftcreative.com/wellness-marketing-agency-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Beauty Booking Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Wellness Marketing Agency Singapore — Jraft Creative"
  description="Full-service digital marketing agency for wellness businesses in Singapore — website, SEO, Google Ads, social media, and content marketing across all."
  canonical="https://jraftcreative.com/wellness-marketing-agency-singapore/"
  ogTitle="Wellness Marketing Agency Singapore — Jraft Creative"
  ogDescription="Full-service marketing agency for wellness businesses in Singapore. Website, SEO, Google Ads, social media — one agency specialising in health and fitness."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="wellness marketing agency singapore, health marketing agency, fitness marketing agency singapore, wellness digital marketing, health and wellness marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Wellness Marketing Agency"
  heroTitle='The <span class="highlight">Wellness Marketing Agency</span> Singapore Trusts'
  heroSubtitle="We are a full-service digital marketing agency that specialises in health, wellness, and fitness businesses in Singapore. Website, SEO, Google Ads, social media, and content — all managed by one team that knows your industry."
  heroImage="/images/service-wellness.webp"
  heroImageAlt="Wellness studio in Singapore — wellness marketing agency"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my wellness business in Singapore."
  ctaLabel="Ready to Grow Your Wellness Business?"
  ctaTitle="Get Your Free Wellness Marketing Audit"
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your wellness business's growth goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20wellness%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why wellness businesses need a specialist marketing agency in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Generic Agencies Don't Understand How <span class="highlight">Wellness Clients</span> Actually <span class="highlight">Choose</span></h2>
      </div>
      <div class="section-content reveal">
        <p>From yoga studios and pilates centres to physiotherapy, TCM, and mental health clinics, Singapore's wellness market is crowded — and health-conscious Singaporeans research, compare, and book online before they ever walk in. Most wellness businesses are invisible during that window, and most agencies treat them like any other client.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Saturated Market</h3>
            <p>Every neighbourhood, mall, and HDB cluster has a studio, clinic, or practice competing for the same health-conscious clients. Walk-ins and word-of-mouth alone can't fill the schedule when there are comparable options within a few minutes of your door.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trust-Led Decision</h3>
            <p>Wellness is a credibility category. Clients vet you on Google reviews, before-and-after proof, practitioner credentials, and content cadence before they commit. Generic agencies don't grasp the trust and compliance sensitivity that healthcare and fitness marketing demand.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Fragmented Marketing</h3>
            <p>One vendor for SEO, another for ads, a freelancer for social, and a separate web team — none of them talking to each other. The budget spreads thin, the messaging drifts, and nobody ties a single enquiry back to a campaign that actually worked.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Wellness marketing services in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Wellness Brand <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for wellness businesses — combining local SEO, AI search optimisation (GEO), paid search, social content, branding, and conversion-focused web design that turns a search into a booked session.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/wellness-seo-singapore/">SEO for Wellness Businesses</a></h3>
            <p>Rank for service-plus-neighbourhood searches like "physiotherapy Tanjong Pagar" or "yoga classes near me." Google Business Profile and map-pack optimisation that drives bookings from the nearest MRT exit.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when clients ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best physiotherapy clinic Singapore" or "pilates studio near me." AI-friendly schema and the same playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/wellness-google-ads-singapore/">Google Ads for Wellness Businesses</a></h3>
            <p>High-intent paid search with neighbourhood geo-targeting that captures clients the moment they search for your service. GCLID tracking from click to booked appointment, so every dollar maps to a real enquiry.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/wellness-social-media-marketing-singapore/">Social Media for Wellness Businesses</a></h3>
            <p>Instagram and TikTok built around educational health content, treatment and class walkthroughs, practitioner thought leadership, and client success stories — the trust-building proof engine the wellness category runs on.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/wellness-branding-agency-singapore/">Branding for Wellness Businesses</a></h3>
            <p>Visual identity, service-menu design, and collateral that signals credibility and care — separating you from the other studios and clinics nearby, and lifting you out of price-only comparisons.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/website-development/">Websites for Wellness Businesses</a></h3>
            <p>Booking integration, service menus, condition and class pages, consultation forms, and mobile-first speed — the conversion architecture that turns a search or an Instagram tap into a booked session.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative as your wellness marketing agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Wellness Clients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We built our agency around a single focus: helping health, wellness, and fitness businesses in Singapore grow through strategic digital marketing. Strategy built on real wellness business models, trust dynamics, and seasonality — not generic templates or vanity-metric retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Wellness Industry Specialisation</h3>
            <p>We work with yoga studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, and holistic health providers. We understand the audience, compliance needs, and competitive dynamics of each vertical — no learning curve, no generic templates.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, social, branding, and websites under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, design, and measurement as part of a single, coherent strategy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Bookings, Not Vanity Metrics</h3>
            <p>We measure bookings, enquiries, and cost per acquisition — not impressions and likes. GCLID offline tracking and WhatsApp-routed enquiries prove which click became which booking. Month-to-month retainers, no lock-in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WELLNESS BOOKING FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Booking Funnel — how Singapore wellness clients decide">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Booking Funnel</p>
        <h2>How <span class="highlight">Singapore Wellness Clients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first search to a repeat booking, every Singapore wellness client moves through the same five stages. We build marketing that shows up at each one — from discovery through to the rebook that turns a first visit into lifetime value.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, Instagram, TikTok, friend referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Google reviews, credentials, content, results</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 providers, price &amp; service match</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Online form, booking app, WhatsApp, or phone</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Rebook, subscribe, refer friends</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Wellness marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for Wellness Businesses</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location wellness businesses building a foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For wellness businesses scaling across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Vertical-specific content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-location wellness brands.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-location campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Brand strategy &amp; positioning</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about wellness marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Wellness Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a wellness business spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most wellness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business's size, number of locations, and growth targets. Our Essential plan at $3,000/month is a strong starting point for single-location wellness businesses.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What types of wellness businesses do you work with?</summary>
          <div class="faq-answer"><p>We work with all segments of Singapore's wellness industry — yoga studios, pilates studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, spas, nutrition consultancies, personal trainers, chiropractic clinics, and holistic health practitioners. Each segment has its own audience, competitive dynamics, and marketing approach, and we tailor every strategy accordingly.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How is a wellness-specialist agency different from a general marketing agency?</summary>
          <div class="faq-answer"><p>A general agency treats every client the same — generic templates, generic strategies, generic results. We specialise in wellness because the industry has unique characteristics: the trust required for healthcare marketing, the community dynamics of fitness, the seasonality of wellness trends, and the specific search behaviour of health-conscious Singaporeans. This specialisation means faster results because we already know what works in your industry.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How long before marketing generates results for my wellness business?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate client enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most wellness business clients see a meaningful increase in bookings and enquiries within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you handle everything in-house or outsource to freelancers?</summary>
          <div class="faq-answer"><p>Everything is handled in-house — website design and development, SEO, Google Ads, Facebook Ads, social media content creation, content writing, and analytics. No outsourcing, no subcontractors, no white-labelling. One team manages your entire marketing strategy, which means complete alignment across channels and a single point of accountability for results.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="general" />

</ServiceLayout>
