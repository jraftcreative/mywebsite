---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Wellness Marketing Agency Singapore",
    "description": "Full-service digital marketing agency for wellness businesses in Singapore — website design, SEO, Google Ads, social media, and content marketing across all health and fitness sub-industries. From $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Wellness Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for wellness businesses" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, client-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-location campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a wellness business spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most wellness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business's size, number of locations, and growth targets. Our Essential plan at $3,000/month is a strong starting point for single-location wellness businesses." } },
      { "@type": "Question", "name": "What types of wellness businesses do you work with?", "acceptedAnswer": { "@type": "Answer", "text": "We work with all segments of Singapore's wellness industry — yoga studios, pilates studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, spas, nutrition consultancies, personal trainers, chiropractic clinics, and holistic health practitioners. Each segment has its own audience, competitive dynamics, and marketing approach, and we tailor every strategy accordingly." } },
      { "@type": "Question", "name": "How is a wellness-specialist agency different from a general marketing agency?", "acceptedAnswer": { "@type": "Answer", "text": "A general agency treats every client the same — generic templates, generic strategies, generic results. We specialise in wellness because the industry has unique characteristics: the trust required for healthcare marketing, the community dynamics of fitness, the seasonality of wellness trends, and the specific search behaviour of health-conscious Singaporeans. This specialisation means faster results because we already know what works in your industry." } },
      { "@type": "Question", "name": "How long before marketing generates results for my wellness business?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate client enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most wellness business clients see a meaningful increase in bookings and enquiries within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "Do you handle everything in-house or outsource to freelancers?", "acceptedAnswer": { "@type": "Answer", "text": "Everything is handled in-house — website design and development, SEO, Google Ads, Facebook Ads, social media content creation, content writing, and analytics. No outsourcing, no subcontractors, no white-labelling. One team manages your entire marketing strategy, which means complete alignment across channels and a single point of accountability for results." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Wellness Marketing Agency Singapore", "item": "https://jraftcreative.com/wellness-marketing-agency-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Wellness Marketing Agency Singapore — Full-Service | Jraft Creative"
  description="Full-service digital marketing agency for wellness businesses in Singapore — website, SEO, Google Ads, social media, and content marketing across all health and fitness sub-industries. From $3,000/mo SGD."
  canonical="https://jraftcreative.com/wellness-marketing-agency-singapore/"
  ogTitle="Wellness Marketing Agency Singapore — Jraft Creative"
  ogDescription="Full-service marketing agency for wellness businesses in Singapore. Website, SEO, Google Ads, social media — one agency specialising in health and fitness."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="wellness marketing agency singapore, health marketing agency, fitness marketing agency singapore, wellness digital marketing, health and wellness marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Wellness Marketing Agency"
  heroTitle='The <span class="highlight">Wellness Marketing Agency</span> Singapore Trusts'
  heroSubtitle="We are a full-service digital marketing agency that specialises in health, wellness, and fitness businesses in Singapore. Website, SEO, Google Ads, social media, and content — all managed by one team that knows your industry."
  heroImage="/images/service-wellness.webp"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my wellness business in Singapore."
  ctaLabel="Ready to Grow Your Wellness Business?"
  ctaTitle="Get Your Free Wellness Marketing Audit"
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your wellness business's growth goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20wellness%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why wellness businesses need a specialist marketing agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Generic Marketing Agencies Do Not Understand Wellness</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's wellness industry is projected to reach $3.5 billion by 2027. From yoga studios and pilates centres to physiotherapy clinics and mental health practices, the market is expanding rapidly — and so is competition. Every wellness business is fighting for visibility among health-conscious Singaporeans who increasingly research, compare, and book online.</p>
        <p>Many wellness businesses hire general marketing agencies that treat them the same as an e-commerce store or a restaurant. These agencies do not understand the trust requirements of healthcare marketing, the community dynamics of fitness businesses, the seasonal patterns of wellness trends, or the specific search behaviour of people seeking health and fitness services in Singapore. The result is generic campaigns that waste budget and produce mediocre results.</p>
        <p>Jraft Creative is different. We specialise in the wellness industry. We understand that a physiotherapy clinic requires different marketing sensitivity than a gym. That a yoga studio's member acquisition differs from a mental health practice's client journey. That TCM marketing needs to bridge traditional medicine with modern accessibility. This specialisation means faster results, less wasted spend, and marketing that actually resonates with your target clients.</p>
      </div>
    </div>
  </section>

  <!-- ========== SUB-SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Wellness marketing services overview">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Services</p>
        <h2>Full-Service Marketing for Every Wellness Vertical</h2>
      </div>
      <div class="section-content reveal">
        <p>We handle every aspect of your wellness business's marketing in-house. Whether you run a yoga studio, a physiotherapy clinic, a gym, or a mental health practice, we build and execute a comprehensive marketing strategy tailored to your specific vertical, audience, and growth goals. No outsourcing, no subcontractors. One team, one strategy, measurable results.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Website Design &amp; Development</h3>
            <p>Professional, mobile-responsive websites tailored to your wellness vertical — booking-integrated studio sites, condition-specific healthcare clinic sites, member-focused gym platforms. Every website is designed for how your specific audience evaluates and chooses a wellness provider in Singapore.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>SEO &amp; Local Search</h3>
            <p>Rank on Google for the services, conditions, and locations your business covers. Google Business Profile optimisation with review management, local citations, and vertical-specific content. We target the exact search terms that drive bookings in your wellness segment — from "yoga classes near me" to "physiotherapy for back pain Singapore."</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Google Ads &amp; Paid Social</h3>
            <p>Targeted ad campaigns on Google, Instagram, Facebook, and TikTok tailored to your wellness vertical. We understand the different conversion paths — urgent healthcare searches vs considered fitness decisions — and build campaigns that match your audience's intent, timing, and platform behaviour.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Social Media &amp; Content Marketing</h3>
            <p>Platform-specific social media strategies and content marketing programmes for wellness businesses. Educational health content, community-building fitness posts, practitioner thought leadership, and client success stories — all calibrated to the tone, compliance requirements, and audience expectations of your specific wellness vertical.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative as your wellness marketing agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Singapore's Specialist Wellness Marketing Agency</h2>
      </div>
      <div class="section-content reveal">
        <p>We built our agency around a single focus: helping health, wellness, and fitness businesses in Singapore grow through strategic digital marketing. Here is what that specialisation delivers for you:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Wellness Industry Specialisation</h3>
            <p>We work with yoga studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, and holistic health providers across Singapore. We understand the unique audience, compliance needs, seasonal patterns, and competitive dynamics of each vertical — no learning curve, no generic templates.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Full-Service, In-House</h3>
            <p>Website, SEO, ads, content, and social media all managed by one team. No outsourcing to freelancers. No subcontractors. One team that understands your industry manages every touchpoint, ensuring consistent messaging and efficient budget allocation across channels.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Results-Focused Reporting</h3>
            <p>We do not report on vanity metrics. You get clear data on bookings, memberships, patient enquiries, cost per acquisition, and channel performance — the numbers that directly impact your revenue. Every report is contextualised with wellness industry benchmarks.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month retainers on all plans. You stay because the results justify it — not because of a 12-month commitment. We earn your business every month through transparent reporting and measurable outcomes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Wellness marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for Wellness Businesses</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location wellness businesses building a foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>4 social media posts/month</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For wellness businesses scaling across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Instagram &amp; Facebook Ads</li>
              <li>8 social media posts/month</li>
              <li>Vertical-specific content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-location wellness brands.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-location campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Brand strategy &amp; positioning</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about wellness marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Wellness Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a wellness business spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most wellness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business's size, number of locations, and growth targets. Our Essential plan at $3,000/month is a strong starting point for single-location wellness businesses.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What types of wellness businesses do you work with?</summary>
          <div class="faq-answer"><p>We work with all segments of Singapore's wellness industry — yoga studios, pilates studios, gyms, physiotherapy clinics, TCM practices, mental health clinics, veterinary clinics, spas, nutrition consultancies, personal trainers, chiropractic clinics, and holistic health practitioners. Each segment has its own audience, competitive dynamics, and marketing approach, and we tailor every strategy accordingly.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How is a wellness-specialist agency different from a general marketing agency?</summary>
          <div class="faq-answer"><p>A general agency treats every client the same — generic templates, generic strategies, generic results. We specialise in wellness because the industry has unique characteristics: the trust required for healthcare marketing, the community dynamics of fitness, the seasonality of wellness trends, and the specific search behaviour of health-conscious Singaporeans. This specialisation means faster results because we already know what works in your industry.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How long before marketing generates results for my wellness business?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate client enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most wellness business clients see a meaningful increase in bookings and enquiries within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you handle everything in-house or outsource to freelancers?</summary>
          <div class="faq-answer"><p>Everything is handled in-house — website design and development, SEO, Google Ads, Facebook Ads, social media content creation, content writing, and analytics. No outsourcing, no subcontractors, no white-labelling. One team manages your entire marketing strategy, which means complete alignment across channels and a single point of accountability for results.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
