---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Church Website Design Singapore",
    "description": "Professional website design for churches and religious organisations in Singapore. Sermon archives, event calendars, online giving, and ministry pages — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Church Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Church Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page church website with service times, contact form, Google Maps, mobile-responsive design, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Church Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with sermon archive, event calendar, online giving integration, ministry pages, and advanced SEO" },
      { "@type": "Offer", "name": "Premium Church Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with live streaming, member portal, multi-campus support, donation management, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a church website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional church website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service times, contact form, and mobile-responsive design. Business and Premium packages add sermon archives, event calendars, online giving, member portals, and multi-campus support." } },
      { "@type": "Question", "name": "Can you add online giving and donations to the church website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online giving integration. We set up secure donation pages that support one-time and recurring giving via credit card, PayNow, or bank transfer — making it easy for members to tithe and give offerings from any device." } },
      { "@type": "Question", "name": "Will the website include a sermon archive?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build sermon archive pages that organise recordings by date, speaker, series, or Scripture reference. Members can listen to audio, watch video, and download sermon notes. Our Business package includes the full sermon archive system, and Premium adds live streaming integration." } },
      { "@type": "Question", "name": "Can you build an event calendar with registration?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We create event calendar pages where your church can list upcoming services, retreats, camps, prayer meetings, and community events. Members can view event details and register online — reducing manual sign-ups and giving your admin team a clear attendee list." } },
      { "@type": "Question", "name": "How long does it take to build a church website?", "acceptedAnswer": { "@type": "Answer", "text": "Most church websites go live within 2–3 weeks. A straightforward 5-page site can be ready in as little as 2 weeks, while larger projects with sermon archives, online giving, event registration, or multi-campus features may take 3–4 weeks. We provide a clear timeline before starting work." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Church Website Design Singapore", "item": "https://jraftcreative.com/church-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Church Website Design Singapore — Websites for Churches &amp; Ministries | Jraft Creative"
  description="Professional website design for churches and religious organisations in Singapore. Sermon archives, event calendars, online giving, and ministry pages — from S$2,500."
  canonical="https://jraftcreative.com/church-website-design-singapore/"
  ogTitle="Church Website Design Singapore — Jraft Creative"
  ogDescription="Website design for churches, ministries, and places of worship in Singapore. Sermon archives, online giving, event calendars — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="church website design singapore, church web design singapore, ministry website singapore, religious organisation website, online giving church singapore, sermon archive website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Church Website Design"
  heroTitle='Website Design for <span class="highlight">Churches in Singapore</span>'
  heroSubtitle="Your congregation deserves more than a Facebook group. We build purposeful websites for churches, ministries, and places of worship — with sermon archives, event calendars, online giving, and ministry pages that keep your community connected."
  heroImage="/images/service-church.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my church in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Bring Your Church Online"
  ctaDescription="Book a free consultation and tell us about your church. We'll get back to you within 24 hours with a tailored proposal — whether you're a local church plant, an established congregation, or a multi-campus ministry."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20church%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why churches in Singapore need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Members Are Looking Online — What Do They Find?</h2>
      </div>
      <div class="section-content reveal">
        <p>Too many churches in Singapore still rely on Facebook groups and WhatsApp broadcasts as their primary digital presence. New visitors searching "church near Jurong" or "Sunday service times Singapore" land on outdated directory listings or social media pages with no clear information. When someone is looking for a place of worship, a scattered online presence makes it harder for them to take that first step through your doors.</p>
        <p>Then there is the practical side. Members want to re-watch last week's sermon, sign up for a retreat, or give their tithes online — but without a proper website, each of these tasks becomes a separate chain of messages to the church office. Volunteers spend hours fielding the same questions about service times, event details, and giving instructions that a well-built website could answer in seconds.</p>
        <p>Churches also face unique communication needs. You are not selling a product — you are building a community. Your website needs to reflect your church's heart and mission while making it genuinely easy for newcomers to learn about your beliefs, find a service, and connect with a ministry. A generic business template will not do that justice. Your church needs a website built with purpose.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Church website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Churches &amp; Ministries</h2>
      </div>
      <div class="section-content reveal">
        <p>Every church website we deliver is designed around the way congregations actually operate in Singapore. We go beyond generic templates — your site will have sermon archives, event registration, online giving, and ministry pages that help your church stay connected throughout the week, not just on Sunday.</p>
        <p>We also know that churches need more than a website alone. Pair your new site with <a href="/services/seo-performance/">SEO services</a> so visitors searching for churches in your area can find you, <a href="/services/social-media/">social media marketing</a> to share sermon highlights and community stories, and <a href="/services/paid-ads/">paid ads management</a> to reach new families in your neighbourhood.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Sermon Archives &amp; Media</h3>
            <p>Give your congregation access to past sermons organised by date, speaker, series, or Scripture reference. We build media pages that support audio playback, video embeds, and downloadable sermon notes — so members can revisit teachings anytime.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Event Calendar &amp; Registration</h3>
            <p>List upcoming services, retreats, prayer meetings, camps, and community events in one central calendar. Members can view details and register online — cutting down on manual sign-ups and giving your admin team a clear headcount.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Online Giving &amp; Donations</h3>
            <p>Make tithing and offerings simple with secure online giving pages. We integrate payment options including credit card, PayNow, and bank transfer — with support for one-time gifts, recurring giving, and designated funds for missions or building projects.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Ministry &amp; Community Pages</h3>
            <p>Showcase your church's ministries — youth, children, worship, small groups, missions — with dedicated pages that explain what each ministry does, when they meet, and how to get involved. Help newcomers find their place in your community.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for church website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Church Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand that a church website is not a commercial storefront — it is a digital extension of your ministry. Every design decision we make is guided by the goal of helping your church welcome visitors, serve members, and communicate your mission clearly online.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>We Understand Church Needs</h3>
            <p>Churches operate differently from businesses. We design around the rhythms of church life — weekly services, seasonal events, ministry sign-ups, and giving campaigns — so your website works the way your church actually runs.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most church websites go live within 2 weeks of kickoff. Whether you are launching a new church plant or replacing an outdated site, we deliver on time without rushing the details that matter to your congregation.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Easy for Your Team to Update</h3>
            <p>Your church staff and volunteers should not need a developer to post a new sermon or update event details. We build sites that are straightforward to maintain, with clear content areas your team can manage independently.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so your church leadership can focus on shepherding the congregation instead of managing marketing channels.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Church website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Church Website Pricing</p>
        <h2>Website Packages for Churches</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For churches getting their first professional website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Service times &amp; location page</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For churches ready to engage their congregation online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Sermon archive with audio &amp; video</li>
              <li>Event calendar &amp; registration</li>
              <li>Online giving integration</li>
              <li>Ministry &amp; small group pages</li>
              <li>Advanced SEO &amp; church schema</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-campus churches or large ministries.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-campus support</li>
              <li>Live streaming integration</li>
              <li>Member portal &amp; directory</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about church website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Church Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a church website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional church website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service times, contact form, and mobile-responsive design. Business and Premium packages add sermon archives, event calendars, online giving, member portals, and multi-campus support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add online giving and donations to the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online giving integration. We set up secure donation pages that support one-time and recurring giving via credit card, PayNow, or bank transfer — making it easy for members to tithe and give offerings from any device.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Will the website include a sermon archive?</summary>
          <div class="faq-answer"><p>Yes. We build sermon archive pages that organise recordings by date, speaker, series, or Scripture reference. Members can listen to audio, watch video, and download sermon notes. Our Business package includes the full sermon archive system, and Premium adds live streaming integration.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you build an event calendar with registration?</summary>
          <div class="faq-answer"><p>Absolutely. We create event calendar pages where your church can list upcoming services, retreats, camps, prayer meetings, and community events. Members can view event details and register online — reducing manual sign-ups and giving your admin team a clear attendee list.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a church website?</summary>
          <div class="faq-answer"><p>Most church websites go live within 2-3 weeks. A straightforward 5-page site can be ready in as little as 2 weeks, while larger projects with sermon archives, online giving, event registration, or multi-campus features may take 3-4 weeks. We provide a clear timeline before starting work.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
