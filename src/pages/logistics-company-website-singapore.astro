---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Logistics Company Website Design Singapore",
    "description": "Professional website design for logistics companies in Singapore. Fleet showcases, shipment tracking integration, and quote request forms — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Logistics Company Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Logistics Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page logistics company website with service overview, fleet showcase, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Logistics Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with shipment tracking integration, quote request forms, blog, advanced SEO, and Google Business Profile setup" },
      { "@type": "Offer", "name": "Premium Logistics Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with real-time tracking portal, client login, multi-language support, API integrations, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a logistics company website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional logistics company website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service overview, fleet showcase, and contact form. Business and Premium packages add tracking integration, quote request systems, and client portals." } },
      { "@type": "Question", "name": "Can you integrate shipment tracking into the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include shipment tracking integration. We can embed tracking widgets from major carriers, connect to your TMS or WMS via API, or build a custom tracking page where clients enter an AWB or container number to check status in real time." } },
      { "@type": "Question", "name": "Do you build websites for freight forwarders and 3PL companies?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build websites for freight forwarders, third-party logistics (3PL) providers, warehousing companies, customs brokers, and supply chain management firms across Singapore. Each site is tailored to the specific services and workflows of your logistics niche." } },
      { "@type": "Question", "name": "Will the website help my logistics company rank on Google in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with keyword targeting for searches like 'logistics company Singapore', 'freight forwarder Singapore', or 'warehouse services Singapore'. We also set up Google Business Profile and logistics-specific schema markup." } },
      { "@type": "Question", "name": "How long does it take to build a logistics company website?", "acceptedAnswer": { "@type": "Answer", "text": "Most logistics company websites go live within 2-3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with tracking integration or client portals may take 3-4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Logistics Company Website Singapore", "item": "https://jraftcreative.com/logistics-company-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Logistics Company Website Singapore — Freight & Supply Chain Web Design | Jraft Creative"
  description="Professional website design for logistics companies in Singapore. Fleet showcases, shipment tracking integration, and quote request forms — from S$2,500."
  canonical="https://jraftcreative.com/logistics-company-website-singapore/"
  ogTitle="Logistics Company Website Singapore — Jraft Creative"
  ogDescription="Website design for logistics companies in Singapore. Fleet showcases, tracking integration, quote forms — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="logistics company website singapore, freight forwarder website design, logistics web design singapore, supply chain website singapore, warehouse company website, 3PL website design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Logistics Websites"
  heroTitle='Website Design for <span class="highlight">Logistics Companies in Singapore</span>'
  heroSubtitle="Singapore is one of the world's top logistics hubs — your website should reflect that. We build professional, mobile-friendly websites for logistics firms with fleet showcases, shipment tracking, and quote request forms built in."
  heroImage="/images/service-logistics.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my logistics company in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Logistics Business Online"
  ctaDescription="Book a free consultation and tell us about your logistics company. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20logistics%20company%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why logistics companies need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Logistics Companies Are Losing Contracts Without a Digital Presence</h2>
      </div>
      <div class="section-content reveal">
        <p>Procurement managers, supply chain directors, and operations teams research logistics providers online before requesting quotes or scheduling warehouse visits. If your company doesn't have a website — or relies on a dated one with no service details — you're invisible to the businesses making sourcing decisions. Competitors with a professional web presence and documented capabilities get shortlisted instead.</p>
        <p>Without a proper website, your fleet capacity, warehouse facilities, trade lane coverage, and years of operational experience sit buried in email attachments and PDF capability decks. Potential clients can't verify your service scope, review your infrastructure, or submit quote requests outside of office hours. That friction costs you contracts — especially when competing firms display their capabilities, certifications, and client testimonials front and centre online.</p>
        <p>Singapore handles over 37 million TEUs annually through PSA terminals and processes billions in airfreight through Changi. As a global supply chain hub, the market is fiercely competitive. Freight forwarders, 3PL providers, and warehousing firms alike need a digital presence that communicates scale, reliability, and operational excellence at first glance. A well-built website turns your fleet, facilities, and track record into a 24/7 business development tool that generates leads even when your team is managing shipments.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Logistics website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Logistics Companies</h2>
      </div>
      <div class="section-content reveal">
        <p>Every logistics website we deliver is purpose-built for the freight, warehousing, and supply chain industry. We go beyond a generic template — your site will feature structured service pages, fleet and warehouse showcases, shipment tracking integration, and quote request forms that convert visitors into qualified leads.</p>
        <p>We understand that logistics firms in Singapore need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/" class="inline-link">SEO services</a> to rank for logistics searches, <a href="/services/social-media/" class="inline-link">social media marketing</a> to showcase operations and milestones, and <a href="/services/paid-ads/" class="inline-link">paid ads management</a> for targeted B2B lead generation campaigns.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Service Capabilities &amp; Trade Lanes</h3>
            <p>Dedicated pages for each service your company offers — sea freight, air freight, land transport, cross-border, customs brokerage, or project cargo. Each page is structured for SEO with trade lane maps, transit times, and clear descriptions that help procurement teams evaluate your coverage at a glance.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Fleet &amp; Warehouse Showcases</h3>
            <p>Visual galleries of your truck fleet, container yard, warehouse facilities, and cold chain infrastructure. Include specifications, capacity figures, and certifications such as GDP, TAPA, or HACCP to give potential clients the operational detail they need before requesting a quote.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Quote Request &amp; Enquiry Forms</h3>
            <p>Structured forms where shippers and importers can submit shipment details — origin, destination, cargo type, weight, and dimensions — and request a quotation directly through your website. Captures qualified leads around the clock and streamlines your sales pipeline.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Shipment Tracking Integration</h3>
            <p>Embed tracking widgets from major carriers or connect to your TMS and WMS via API. Clients can enter an AWB, container number, or booking reference to check shipment status in real time — reducing support calls and improving the customer experience.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for logistics website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Logistics Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've worked with logistics companies, freight forwarders, and supply chain firms across Singapore. We know what procurement teams and operations managers look for when evaluating logistics providers online, and we build websites that communicate your capabilities and reliability clearly.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Logistics Industry Experience</h3>
            <p>We understand the logistics sector — from freight forwarding workflows and warehouse operations to how procurement teams shortlist providers. Your website will speak the language of the industry, not generic marketing copy.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most logistics company websites go live within 2 weeks of kickoff. We know time matters when you're responding to RFQs or onboarding new trade lanes.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Every site is designed for mobile first. Fast load times, clean navigation, and tap-to-call buttons so clients and operations managers can reach your team directly from the warehouse floor or port terminal.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so your team can focus on moving cargo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Logistics website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Logistics Website Pricing</p>
        <h2>Website Packages for Logistics Companies</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new logistics firms getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Service overview pages</li>
              <li>Fleet &amp; facility gallery</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established logistics firms ready to win more contracts.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Shipment tracking integration</li>
              <li>Quote request forms</li>
              <li>Trade lane &amp; service detail pages</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For large logistics operations and 3PL providers.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Client login &amp; tracking portal</li>
              <li>API &amp; TMS/WMS integration</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about logistics website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Logistics Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a logistics company website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional logistics company website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service overview, fleet showcase, and contact form. Business and Premium packages add tracking integration, quote request systems, and client portals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you integrate shipment tracking into the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include shipment tracking integration. We can embed tracking widgets from major carriers, connect to your TMS or WMS via API, or build a custom tracking page where clients enter an AWB or container number to check status in real time.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build websites for freight forwarders and 3PL companies?</summary>
          <div class="faq-answer"><p>Yes. We build websites for freight forwarders, third-party logistics (3PL) providers, warehousing companies, customs brokers, and supply chain management firms across Singapore. Each site is tailored to the specific services and workflows of your logistics niche.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will the website help my logistics company rank on Google in Singapore?</summary>
          <div class="faq-answer"><p>Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with keyword targeting for searches like "logistics company Singapore", "freight forwarder Singapore", or "warehouse services Singapore". We also set up Google Business Profile and logistics-specific schema markup.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a logistics company website?</summary>
          <div class="faq-answer"><p>Most logistics company websites go live within 2-3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with tracking integration or client portals may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
