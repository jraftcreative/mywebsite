  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <style>
    @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400 800; font-display: swap; src: url('/fonts/inter-latin.woff2') format('woff2'); }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { min-height: 100vh; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: #0a0a0a; color: #e0e0e0; padding: 48px 24px; }
    .container { max-width: 720px; margin: 0 auto; }
    .header { text-align: center; margin-bottom: 48px; }
    .logo { display: inline-block; margin-bottom: 32px; }
    .logo img { width: 56px; height: 56px; border-radius: 12px; }
    .code { font-size: 5rem; font-weight: 800; color: #49b889; line-height: 1; letter-spacing: -0.03em; }
    h1 { font-size: 1.75rem; margin: 16px 0 12px; font-weight: 700; }
    .lead { color: #999; font-size: 1.05rem; line-height: 1.6; max-width: 520px; margin: 0 auto 32px; }
    .cta-group { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 64px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; text-decoration: none; font-weight: 600; border-radius: 10px; transition: all 0.2s; min-height: 48px; font-size: 0.95rem; }
    .btn-primary { background: #49b889; color: #0a0a0a; }
    .btn-primary:hover { background: #3aa377; transform: translateY(-1px); }
    .btn-secondary { background: transparent; border: 1px solid rgba(255,255,255,0.15); color: #e0e0e0; }
    .btn-secondary:hover { border-color: #49b889; color: #49b889; }
    .btn:focus-visible { outline: 3px solid #49b889; outline-offset: 3px; }

    .section-label { color: #49b889; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
    .section-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 20px; color: #fff; }

    .links-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; margin-bottom: 48px; }
    .link-card { display: block; padding: 18px 20px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; text-decoration: none; color: #e0e0e0; transition: all 0.2s; }
    .link-card:hover { background: rgba(73, 184, 137, 0.08); border-color: #49b889; transform: translateY(-1px); }
    .link-card strong { display: block; color: #fff; font-size: 0.95rem; margin-bottom: 4px; font-weight: 600; }
    .link-card span { color: #888; font-size: 0.82rem; line-height: 1.5; }

    .divider { border: 0; height: 1px; background: rgba(255,255,255,0.08); margin: 48px 0; }

    .blog-list { display: flex; flex-direction: column; gap: 10px; }
    .blog-list a { display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; text-decoration: none; color: #e0e0e0; font-size: 0.9rem; transition: all 0.2s; }
    .blog-list a:hover { background: rgba(73, 184, 137, 0.06); border-color: rgba(73, 184, 137, 0.3); }
    .blog-list a::before { content: "→"; color: #49b889; font-weight: 700; }

    .footer-links { text-align: center; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.06); }
    .footer-links a { color: #888; text-decoration: none; font-size: 0.85rem; margin: 0 12px; transition: color 0.2s; }
    .footer-links a:hover { color: #49b889; }

    @media (max-width: 600px) {
      .code { font-size: 4rem; }
      h1 { font-size: 1.4rem; }
      .lead { font-size: 0.95rem; }
      body { padding: 32px 20px; }
    }
  </style>
</head>
