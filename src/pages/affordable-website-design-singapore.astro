---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Affordable Website Design Singapore",
    "description": "Affordable website design in Singapore for SMEs and small businesses. Professional websites with full SEO setup, mobile-responsive design, and transparent pricing. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Affordable Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page professional website with mobile-responsive design, basic SEO setup, contact form integration, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with CMS integration, advanced SEO and schema markup, Google Analytics setup, and custom design" },
      { "@type": "Offer", "name": "Premium Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with unlimited pages, ecommerce or booking systems, third-party integrations, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an affordable website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Our affordable website packages start from S$2,500 for a 5-page professional website. This includes mobile-responsive design, basic SEO setup, a contact form, and hosting guidance. Business packages start at S$5,500 for growing companies that need more pages and features, while Premium packages from S$10,000 cover advanced requirements like ecommerce and custom integrations." } },
      { "@type": "Question", "name": "What is included in your affordable web design packages?", "acceptedAnswer": { "@type": "Answer", "text": "Every package includes a professionally designed, mobile-responsive website with SEO fundamentals built in from day one. You get a custom layout tailored to your brand, a contact form, fast page load speeds, Google-friendly structure, and full ownership of your website files. There are no hidden fees, no monthly lock-in contracts, and no surprise charges after delivery." } },
      { "@type": "Question", "name": "Is cheap web design the same as affordable web design?", "acceptedAnswer": { "@type": "Answer", "text": "No. Cheap web design usually means template-based sites with no SEO, poor performance, and no support after launch. Affordable web design means you get a professionally built, custom website at a fair price. Our sites are coded for speed, structured for Google rankings, and designed to convert visitors into customers — without the inflated price tags that large agencies charge." } },
      { "@type": "Question", "name": "Do I own my website after the project is complete?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. You own 100% of your website files, content, and design. We do not lock you into proprietary platforms or ongoing contracts. Once the project is delivered, everything belongs to you. If you ever want to move to a different hosting provider or work with another developer, you are free to do so without any restrictions or transfer fees." } },
      { "@type": "Question", "name": "How long does it take to build an affordable website?", "acceptedAnswer": { "@type": "Answer", "text": "Our Starter websites are typically delivered within 2 weeks from the time we receive your content and brand assets. Business packages take 3 to 4 weeks, and Premium projects with advanced features take 4 to 8 weeks. We provide a clear timeline during our initial consultation so you know exactly when to expect your site to go live." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Affordable Website Design Singapore", "item": "https://jraftcreative.com/affordable-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Affordable Website Design Singapore — Quality Sites from $2,500 | Jraft Creative"
  description="Affordable website design in Singapore for SMEs and small businesses. Professional, mobile-responsive websites with full SEO setup and transparent pricing. From S$2,500."
  canonical="https://jraftcreative.com/affordable-website-design-singapore/"
  ogTitle="Affordable Website Design Singapore — Jraft Creative"
  ogDescription="Professional website design for Singapore SMEs at fair prices. Mobile-responsive, SEO-ready websites from S$2,500. No hidden costs or lock-in contracts."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="affordable website design singapore, cheap website design singapore, budget website singapore, affordable web design, SME website singapore, small business website singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Affordable Website Design"
  heroTitle='Affordable Website Design <span class="highlight">in Singapore</span>'
  heroSubtitle="Professional websites for SMEs and small businesses at fair, transparent prices. No inflated agency fees, no hidden costs, no lock-in contracts. Just quality web design that works for your budget."
  heroImage="/images/service-affordable.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need an affordable website for my business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get a Professional Website Without the Premium Price Tag"
  ctaDescription="Book a free consultation and we will scope your project with transparent pricing. We will get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20an%20affordable%20website%20for%20my%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why SMEs struggle to find affordable web design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Quality Web Design Should Not Break the Bank</h2>
      </div>
      <div class="section-content reveal">
        <p>Too many Singapore SMEs are priced out of professional web design. Large agencies charge $10,000 or more for a basic business website, padding proposals with unnecessary features and ongoing retainer fees that drain your budget month after month. For a small business trying to establish an online presence, those numbers are simply out of reach.</p>
        <p>The alternative — DIY website builders — creates a different problem. Template-based sites look generic, load slowly, and lack the SEO foundations needed to rank on Google. Your visitors can tell the difference between a professionally designed website and one assembled from drag-and-drop blocks, and that perception directly affects whether they trust your business enough to enquire or buy.</p>
        <p>What SMEs actually need is a middle ground: a professionally designed, mobile-responsive website built with proper SEO structure and fast load times — at a price that reflects the real cost of the work, not inflated agency overheads. That is exactly what we deliver at Jraft Creative.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Affordable web design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What You Get</p>
        <h2>Affordable Web Design That Does Not Cut Corners</h2>
      </div>
      <div class="section-content reveal">
        <p>Every affordable website we build includes the same professional standards we apply to premium projects — clean code, fast performance, and Google-ready structure. The difference is scope, not quality. We right-size the project to match your business needs and budget.</p>
        <p>Need more than just a website? Pair your new site with our <a href="/services/seo-performance/">SEO services</a> to drive organic traffic, <a href="/services/paid-ads/">paid advertising</a> to generate leads from day one, or <a href="/services/social-media/">social media marketing</a> to build your brand presence across platforms.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Professional Design at Fair Prices</h3>
            <p>Custom layouts designed around your brand — not cookie-cutter templates. You get a website that looks and feels professional, built to the same standards as sites costing three times more. Quality design should be accessible to every business.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Full SEO Setup Included</h3>
            <p>Every page is built with proper title tags, meta descriptions, heading structure, schema markup, and sitemap generation. Your site is ready for Google from the moment it goes live — no additional SEO package required to get started.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Mobile-Responsive as Standard</h3>
            <p>Every website we build is fully responsive across phones, tablets, and desktops. Mobile-first design is not a premium add-on — it is included in every package because over 70% of your visitors in Singapore are browsing on their phones.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>No Hidden Costs or Lock-ins</h3>
            <p>Our pricing is transparent and final. No surprise invoices after delivery, no mandatory monthly retainers, and no proprietary platform lock-in. You own your website files outright and can host them wherever you choose.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for affordable web design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Affordable Does Not Mean Compromise</h2>
      </div>
      <div class="section-content reveal">
        <p>We keep our prices fair by running lean and focusing on what matters — delivering high-quality websites without the overhead of a large agency. Here is what sets us apart from budget builders and overpriced firms:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Transparent Fixed Pricing</h3>
            <p>You know exactly what you are paying before we start. Our packages have clear scopes and fixed prices — no hourly billing surprises, no scope creep charges, and no hidden fees added after the project begins.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Built for Performance</h3>
            <p>Affordable does not mean slow. Every site is optimised for Core Web Vitals — fast load times, stable layouts, and responsive interactions. Your visitors get a premium experience regardless of your budget tier.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Full Ownership, No Lock-in</h3>
            <p>You own every file, every line of code, and every design asset. We do not hold your website hostage on proprietary systems. Move hosts, change developers, or manage it yourself — the choice is always yours.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Singapore-Focused Expertise</h3>
            <p>We understand the Singapore market — local search behaviour, mobile usage patterns, and what SME customers expect from a business website. Your site is designed for the audience that matters to your business.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Affordable website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Affordable Pricing</p>
        <h2>Website Packages That Fit Your Budget</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new businesses &amp; sole proprietors.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Custom responsive design</li>
              <li>Contact form integration</li>
              <li>Basic SEO setup</li>
              <li>Mobile-friendly layout</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing SMEs that need more.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>CMS / blog integration</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Analytics setup</li>
              <li>Custom design &amp; branding</li>
              <li>3-4 week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For businesses with advanced needs.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Ecommerce / booking systems</li>
              <li>Third-party integrations</li>
              <li>Fully custom functionality</li>
              <li>Priority support</li>
              <li>Performance monitoring</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about affordable website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Affordable Web Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an affordable website cost in Singapore?</summary>
          <div class="faq-answer"><p>Our affordable website packages start from S$2,500 for a 5-page professional website. This includes mobile-responsive design, basic SEO setup, a contact form, and hosting guidance. Business packages start at S$5,500 for growing companies that need more pages and features, while Premium packages from S$10,000 cover advanced requirements like ecommerce and custom integrations.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What is included in your affordable web design packages?</summary>
          <div class="faq-answer"><p>Every package includes a professionally designed, mobile-responsive website with SEO fundamentals built in from day one. You get a custom layout tailored to your brand, a contact form, fast page load speeds, Google-friendly structure, and full ownership of your website files. There are no hidden fees, no monthly lock-in contracts, and no surprise charges after delivery.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Is cheap web design the same as affordable web design?</summary>
          <div class="faq-answer"><p>No. Cheap web design usually means template-based sites with no SEO, poor performance, and no support after launch. Affordable web design means you get a professionally built, custom website at a fair price. Our sites are coded for speed, structured for Google rankings, and designed to convert visitors into customers — without the inflated price tags that large agencies charge.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do I own my website after the project is complete?</summary>
          <div class="faq-answer"><p>Yes. You own 100% of your website files, content, and design. We do not lock you into proprietary platforms or ongoing contracts. Once the project is delivered, everything belongs to you. If you ever want to move to a different hosting provider or work with another developer, you are free to do so without any restrictions or transfer fees.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an affordable website?</summary>
          <div class="faq-answer"><p>Our Starter websites are typically delivered within 2 weeks from the time we receive your content and brand assets. Business packages take 3 to 4 weeks, and Premium projects with advanced features take 4 to 8 weeks. We provide a clear timeline during our initial consultation so you know exactly when to expect your site to go live.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
