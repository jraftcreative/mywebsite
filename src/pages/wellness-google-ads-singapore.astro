---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Wellness Google Ads Singapore",
    "description": "Google Ads management for wellness businesses in Singapore — multi-vertical strategy across fitness, healthcare, beauty, and wellbeing. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for Wellness Businesses",
    "offers": [
      { "@type": "Offer", "name": "Starter Wellness Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, wellness keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Wellness Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, landing page optimisation, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Wellness Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should wellness businesses budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Budgets vary by wellness vertical. Most businesses start with $1,000–$4,000 monthly ad spend on top of management fees. Fitness keywords cost $1.50–$5 per click, healthcare terms $3–$10, and beauty and spa keywords $2–$6. We set your budget based on your specific vertical, service mix, and growth objectives." } },
      { "@type": "Question", "name": "Can one Google Ads agency manage campaigns across different wellness verticals?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — and there are advantages to working with one agency across verticals. We understand how fitness, healthcare, beauty, and wellbeing audiences overlap and differ, which prevents budget waste from cross-targeting. A single agency also enables consistent tracking, unified reporting, and strategic coordination across all your wellness marketing." } },
      { "@type": "Question", "name": "Which wellness services convert best through Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Services with high search intent and immediate need convert best — physiotherapy appointments, dental check-ups, spa treatments, gym memberships, and beauty treatments. We also see strong results from trial offers, first-visit promotions, and package deals that lower the barrier for new clients to try your service." } },
      { "@type": "Question", "name": "Do you handle healthcare advertising compliance for wellness ads?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. For any wellness service that falls under healthcare advertising regulations — physiotherapy, TCM, mental health, medical aesthetics — we ensure full compliance with Google's healthcare advertiser policies and Singapore's PHMC guidelines. Non-healthcare verticals like fitness and beauty follow standard ad policies." } },
      { "@type": "Question", "name": "How do you measure success across different wellness services?", "acceptedAnswer": { "@type": "Answer", "text": "We set up vertical-specific tracking — appointment bookings for healthcare, trial sign-ups for fitness, treatment reservations for beauty, and consultation requests for holistic services. Each vertical has its own KPIs and benchmarks, so you see clear performance data for every part of your wellness business." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Wellness Google Ads Singapore", "item": "https://jraftcreative.com/wellness-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Wellness Google Ads Singapore — PPC for Wellness Businesses | Jraft Creative"
  description="Google Ads management for wellness businesses in Singapore. Multi-vertical strategy across fitness, healthcare, beauty, and wellbeing. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/wellness-google-ads-singapore/"
  ogTitle="Wellness Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for wellness businesses in Singapore. Multi-vertical campaigns across fitness, healthcare, beauty, and wellbeing. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="wellness google ads singapore, wellness advertising singapore, google ads for wellness businesses, ppc wellness singapore, wellness marketing singapore, health and wellness ads singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Wellness Google Ads Singapore"
  heroTitle='Google Ads for Wellness Businesses <span class="highlight">in Singapore</span>'
  heroSubtitle="Whether you run a fitness studio, healthcare clinic, beauty spa, or holistic wellness centre — we build Google Ads campaigns that reach clients across every wellness vertical. Multi-service strategy, cross-channel targeting, and unified tracking that grows your entire wellness business."
  heroImage="/images/service-wellness.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my wellness business in Singapore."
  ctaLabel="Grow Your Wellness Business"
  ctaTitle="Get a Free Wellness Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll analyse your wellness verticals, review competitor ad activity, and map out a Google Ads strategy that covers every service in your business. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20wellness%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for wellness businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Running a Multi-Service Wellness Business Without a Unified Ad Strategy?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's wellness industry spans fitness, healthcare, beauty, and holistic wellbeing — and many businesses operate across multiple verticals. You might offer physiotherapy and pilates under one roof, or run a wellness centre that combines TCM, massage, and nutritional coaching. Each service has its own audience, its own keywords, and its own competitive landscape.</p>
        <p>Without a coordinated Google Ads strategy, multi-service wellness businesses either spread their budget too thin across too many campaigns, or focus on one vertical while neglecting others. Generic wellness keywords attract broad but unfocused traffic, and without vertical-specific tracking, you can't tell which services generate the best return. The result is wasted ad spend and missed opportunities across your entire business.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for wellness businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Wellness Ad Services</p>
        <h2>Multi-Vertical Google Ads for Wellness Businesses</h2>
      </div>
      <div class="section-content reveal">
        <p>We build Google Ads campaigns that cover every vertical of your wellness business — fitness, healthcare, beauty, and holistic wellbeing — with separate strategies for each service and unified tracking across all of them. Whether you operate a single wellness centre with multiple services or manage several brands across the wellness spectrum, every campaign is designed to drive bookings.</p>
        <p>Our approach covers vertical-specific keyword targeting, cross-service audience strategies, compliance handling for healthcare verticals, and landing pages tailored to each service. Budget allocation is optimised across verticals based on performance data — shifting spend towards the services generating the best return.</p>
        <p>Explore our specialist pages for <a href="/yoga-studio-google-ads-singapore/">yoga studio</a>, <a href="/gym-google-ads-singapore/">gym</a>, <a href="/physiotherapy-google-ads-singapore/">physiotherapy</a>, <a href="/tcm-clinic-google-ads-singapore/">TCM clinic</a>, and <a href="/mental-health-google-ads-singapore/">mental health</a> Google Ads.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Multi-Vertical Campaign Architecture</h3>
            <p>Structured campaigns for each wellness vertical — fitness memberships, healthcare appointments, beauty treatments, and holistic services — with separate keyword strategies, budgets, and performance targets that prevent cross-vertical budget waste.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Cross-Service Audience Strategy</h3>
            <p>Identify audience overlaps across your wellness services and build remarketing campaigns that cross-sell. A physiotherapy patient could become a pilates member. A gym-goer might book a sports massage. We structure campaigns to capture these cross-vertical opportunities.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Unified Tracking &amp; Attribution</h3>
            <p>A single tracking framework across all wellness verticals — each with its own conversion goals and KPIs. See which services drive the most revenue, which keywords have the lowest cost per acquisition, and where to shift budget for maximum return.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Vertical-Specific Landing Pages</h3>
            <p>Dedicated landing pages for each service within your wellness business — tailored messaging, relevant imagery, and booking flows that match each vertical's audience expectations and conversion patterns.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for wellness Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Wellness Advertising Across Every Vertical</h2>
      </div>
      <div class="section-content reveal">
        <p>We've managed ad campaigns across every wellness vertical in Singapore — fitness, healthcare, beauty, and holistic wellbeing. Here's why wellness businesses choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Cross-Vertical Expertise</h3>
            <p>We understand how fitness, healthcare, beauty, and wellbeing audiences search, compare, and book differently. That knowledge shapes campaign architecture that works for each vertical while maintaining efficiency across your entire wellness business.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each booking costs across every service vertical.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that scale with your business. Add new wellness verticals, shift budgets seasonally, launch new services — no penalties, no minimum terms, no rigid structures.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Compliance Where It Matters</h3>
            <p>Healthcare verticals get full advertising compliance — Google certification, PHMC guidelines, proper disclaimers. Non-healthcare verticals run standard campaigns. We handle the complexity so you don't have to.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Wellness Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Wellness Ads Pricing</p>
        <h2>Google Ads Plans for Wellness Businesses</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For wellness businesses launching their first Google Ads campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Wellness keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For wellness businesses scaling across multiple service verticals.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; ad copy optimisation</li>
              <li>Landing page optimisation</li>
              <li>Cross-vertical audience strategy</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-vertical wellness groups maximising reach and revenue.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for wellness businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Wellness Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should wellness businesses budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Budgets vary by wellness vertical. Most businesses start with $1,000–$4,000 monthly ad spend on top of management fees. Fitness keywords cost $1.50–$5 per click, healthcare terms $3–$10, and beauty and spa keywords $2–$6. We set your budget based on your specific vertical, service mix, and growth objectives.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can one Google Ads agency manage campaigns across different wellness verticals?</summary>
          <div class="faq-answer"><p>Yes — and there are advantages to working with one agency across verticals. We understand how fitness, healthcare, beauty, and wellbeing audiences overlap and differ, which prevents budget waste from cross-targeting. A single agency also enables consistent tracking, unified reporting, and strategic coordination across all your wellness marketing.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Which wellness services convert best through Google Ads?</summary>
          <div class="faq-answer"><p>Services with high search intent and immediate need convert best — physiotherapy appointments, dental check-ups, spa treatments, gym memberships, and beauty treatments. We also see strong results from trial offers, first-visit promotions, and package deals that lower the barrier for new clients to try your service.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you handle healthcare advertising compliance for wellness ads?</summary>
          <div class="faq-answer"><p>Yes. For any wellness service that falls under healthcare advertising regulations — physiotherapy, TCM, mental health, medical aesthetics — we ensure full compliance with Google's healthcare advertiser policies and Singapore's PHMC guidelines. Non-healthcare verticals like fitness and beauty follow standard ad policies.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you measure success across different wellness services?</summary>
          <div class="faq-answer"><p>We set up vertical-specific tracking — appointment bookings for healthcare, trial sign-ups for fitness, treatment reservations for beauty, and consultation requests for holistic services. Each vertical has its own KPIs and benchmarks, so you see clear performance data for every part of your wellness business.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
