---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Fitness Marketing Singapore",
    "description": "Full-service digital marketing for fitness businesses in Singapore — gyms, studios, personal trainers, and boutique fitness. Website design, SEO, Google Ads, social media, and content marketing from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Fitness Industry Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for fitness businesses" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, membership-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-location campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a fitness business spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most fitness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business format — a personal trainer may start at $2,500/mo while a multi-location gym chain could invest $10,000+/mo. Our Essential plan at $3,000/month suits most single-location fitness businesses." } },
      { "@type": "Question", "name": "How long before marketing generates new clients for my fitness business?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads and Instagram Ads can generate trial bookings and enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most fitness business clients see a meaningful increase in trial sign-ups or membership enquiries within the first 60 days." } },
      { "@type": "Question", "name": "What types of fitness businesses do you work with?", "acceptedAnswer": { "@type": "Answer", "text": "We work with the full spectrum of Singapore's fitness industry — commercial gyms, boutique fitness studios, CrossFit boxes, yoga studios, pilates studios, personal trainers, boxing gyms, martial arts schools, outdoor fitness boot camps, swimming schools, and online fitness coaches. Each format has its own audience, business model, and marketing approach. We tailor every strategy to your specific segment." } },
      { "@type": "Question", "name": "What marketing channels work best for fitness businesses in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search captures high-intent traffic — people searching for 'gym near me' or 'personal trainer Singapore' are ready to sign up. Instagram and TikTok are essential for fitness businesses as transformation content, workout videos, and trainer personalities perform exceptionally well. Facebook Ads work for targeting specific demographics and locations. A professional website ties everything together as your conversion hub." } },
      { "@type": "Question", "name": "Can you help personal trainers build their own client base?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Personal trainers face unique marketing challenges — building a personal brand, attracting clients independent of a gym, and competing against both gym-employed trainers and online coaches. We help PTs build a professional online presence, rank on Google for location-based PT searches, create content that showcases their expertise and client results, and run targeted ads to attract their ideal client demographic." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Fitness Marketing Singapore", "item": "https://jraftcreative.com/fitness-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Fitness Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Fitness Marketing Singapore — Jraft Creative"
  description="Full-service digital marketing for fitness businesses in Singapore — gyms, studios, personal trainers, and boutique fitness. Website, SEO, Google Ads."
  canonical="https://jraftcreative.com/fitness-marketing-singapore/"
  ogTitle="Fitness Marketing Singapore — Jraft Creative"
  ogDescription="Full-service marketing for fitness businesses in Singapore. Gyms, studios, personal trainers — website, SEO, Google Ads, social media under one roof."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="fitness marketing singapore, fitness marketing agency, gym marketing singapore, personal trainer marketing, boutique fitness marketing, fitness digital marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Full-Service Fitness Marketing"
  heroTitle='Full-Service Marketing for <span class="highlight">Fitness Businesses in Singapore</span>'
  heroSubtitle="Gyms, studios, personal trainers, boutique fitness — one agency that understands how Singaporeans discover, compare, and commit to fitness. SEO, GEO, Google Ads, social, branding, and websites under one roof, built for the member journey."
  heroImage="/images/hero-fitness-marketing.webp"
  heroImageAlt="Two people doing kettlebell push-ups in a Singapore gym"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my fitness business in Singapore."
  ctaLabel="Ready to Grow Your Fitness Business?"
  ctaTitle='Get Your Free <span class="highlight">Fitness Marketing</span> Audit'
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your fitness business's growth goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20fitness%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why fitness businesses need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Singapore Fitness Is <span class="highlight">More Competitive</span> Than <span class="highlight">Ever</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Budget chains made fitness mass-market, boutique studios raised the experience bar, and ClassPass plus online coaching let consumers hop between providers without committing. Whatever your format, the member starts their journey online — and most fitness businesses are invisible at the moment of decision.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Comparison Window</h3>
            <p>Members search "gym near me," compare Instagram feeds for the vibe, read Google reviews, and check your pricing — all before they ever walk in. If any touchpoint is missing or weak, you lose them to a competitor who invested in their digital presence.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Pay-Per-Session Trap</h3>
            <p>ClassPass and pay-per-session models let consumers sample five providers a week on discounted credits, taking a cut and keeping the relationship. Leaning on them builds traffic but never the full-fee members and direct bookings that pay the rent.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Competition Beyond Four Walls</h3>
            <p>Online coaching and home-workout platforms expanded the competition past physical locations entirely. To win, your brand has to show up and convert across search, social, and AI — not just rely on the catchment walking past your door.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for fitness businesses in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Fitness Business <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies for the full spectrum of fitness — gyms, studios, PTs, and boutique formats — combining catchment SEO, AI search optimisation (GEO), paid search, social content, branding, and conversion-focused web design under one roof.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO for Fitness</a></h3>
            <p>Rank for catchment searches like "gym near me", "personal trainer Orchard", or "HIIT classes Tiong Bahru." Google Business Profile and map-pack optimisation that drives trial visits from your neighbourhood.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when members ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best gym for strength training Singapore." The same AI-citation playbook we use for our own agency's discoverability.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google &amp; Meta Ads</a></h3>
            <p>High-intent paid search and social, scaled during the January, post-CNY, and pre-summer sign-up peaks. GCLID tracking from click through to a booked trial or membership enquiry.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Fitness</a></h3>
            <p>Instagram and TikTok built around transformations, trainer personalities, class previews, and member community. The high-energy content engine fitness brands grow on.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Fitness</a></h3>
            <p>The brand system that lifts you out of price-only and ClassPass comparisons — logo, palette, kit and photo direction, positioned by format so members pick you over the cheaper option.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/website-development/">Websites for Fitness</a></h3>
            <p>The site that closes the trial — booking integration with Mindbody, ClassPass or Glofox, class schedules, trainer profiles, transparent pricing, and fast mobile performance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for fitness marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Fitness Members</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We work with gyms, studios, personal trainers, and fitness brands across Singapore — building around the membership vs pay-per-class models, the ClassPass dynamic, seasonal sign-up patterns, and the member journey. Not generic templates, and not vanity-metric retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Fitness Industry Specialisation</h3>
            <p>We know the Singapore fitness market — membership vs pay-per-class economics, the ClassPass dynamic, seasonal sign-up spikes, and the difference between marketing a commercial gym, a boutique studio, and an independent PT. Strategy built on category knowledge.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, branding, websites — under one roof. No coordinating between vendors. Your social feeds your ads, your content boosts your SEO, and your website converts the traffic every channel drives.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Pipeline, Not Vanity Metrics</h3>
            <p>We measure trial sign-ups, membership conversions, retention, and cost per acquisition — not impressions. Month-to-month retainers with no lock-in, because you should stay for the results, not a 12-month contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FITNESS MEMBER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Fitness Member Funnel — how Singapore members decide on a fitness business">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Member Funnel</p>
        <h2>How <span class="highlight">Singapore Members</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From first scroll to long-term member, every fitness joiner in Singapore moves through the same five stages. We build marketing that shows up at each one — from awareness through to the referral that compounds your growth.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Awareness</h3>
          <p>IG/TikTok, Google, AI tools, referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Trial</h3>
          <p>Free session, trial pass, or intro offer</p>
        </li>
        <li class="funnel-stage">
          <h3>Sign-up</h3>
          <p>Membership or package conversion</p>
        </li>
        <li class="funnel-stage">
          <h3>Retention</h3>
          <p>First 90 days, engagement campaigns</p>
        </li>
        <li class="funnel-stage">
          <h3>Referral</h3>
          <p>Member word of mouth &amp; advocacy</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for fitness businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2><span class="highlight">Monthly Marketing Plans</span> for Fitness Businesses</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location fitness businesses and independent trainers.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For fitness businesses scaling memberships across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Fitness content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-location fitness brands.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-location campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Member retention campaigns</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about fitness marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Fitness Marketing</span> — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a fitness business spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most fitness businesses in Singapore invest between $2,500 and $10,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your business format — a personal trainer may start at $2,500/mo while a multi-location gym chain could invest $10,000+/mo. Our Essential plan at $3,000/month suits most single-location fitness businesses.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new clients for my fitness business?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads and Instagram Ads can generate trial bookings and enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community over 2–3 months. Most fitness business clients see a meaningful increase in trial sign-ups or membership enquiries within the first 60 days.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What types of fitness businesses do you work with?</summary>
          <div class="faq-answer"><p>We work with the full spectrum of Singapore's fitness industry — commercial gyms, boutique fitness studios, CrossFit boxes, yoga studios, pilates studios, personal trainers, boxing gyms, martial arts schools, outdoor fitness boot camps, swimming schools, and online fitness coaches. Each format has its own audience, business model, and marketing approach. We tailor every strategy to your specific segment.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>What marketing channels work best for fitness businesses in Singapore?</summary>
          <div class="faq-answer"><p>Google Search captures high-intent traffic — people searching for "gym near me" or "personal trainer Singapore" are ready to sign up. Instagram and TikTok are essential for fitness businesses as transformation content, workout videos, and trainer personalities perform exceptionally well. Facebook Ads work for targeting specific demographics and locations. A professional website ties everything together as your conversion hub.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you help personal trainers build their own client base?</summary>
          <div class="faq-answer"><p>Yes. Personal trainers face unique marketing challenges — building a personal brand, attracting clients independent of a gym, and competing against both gym-employed trainers and online coaches. We help PTs build a professional online presence, rank on Google for location-based PT searches, create content that showcases their expertise and client results, and run targeted ads to attract their ideal client demographic.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Fitness Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/gym-marketing-singapore/" class="related-service-link">Gym Marketing</a>
          <a href="/yoga-studio-marketing-singapore/" class="related-service-link">Yoga Studio Marketing</a>
          <a href="/pilates-marketing-singapore/" class="related-service-link">Pilates Marketing</a>
          <a href="/martial-arts-marketing-singapore/" class="related-service-link">Martial Arts Marketing</a>
      </div>
    </div>
  </section>
</ServiceLayout>
