---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Accounting Firm Website Design Singapore",
    "description": "Professional website design for accounting firms in Singapore. Service pages, client portals, and credential showcases — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Accounting Firm Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Accounting Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page accounting firm website with service pages, team profiles, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Accounting Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with blog, tax resource centre, advanced SEO, Google Business Profile, and credential badges" },
      { "@type": "Offer", "name": "Premium Accounting Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with client portal, document upload, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an accounting firm website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional accounting firm website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service descriptions, team profiles, and contact form. Business and Premium packages add client portals, resource centres, and document management." } },
      { "@type": "Question", "name": "Can you build a client portal for our accounting firm?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package includes a secure client portal where clients can upload documents, download reports, and communicate with your team. The portal uses SSL encryption and access controls to keep financial data secure and compliant." } },
      { "@type": "Question", "name": "Do you display ISCA and ACRA credentials on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We prominently display your firm's professional credentials including ISCA membership, ACRA registration, and any other certifications. Trust signals like these are critical for accounting firms — potential clients need to see that you are properly qualified and registered." } },
      { "@type": "Question", "name": "Can the website help us rank for accounting-related searches in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with keyword targeting for searches like 'accounting firm Singapore', 'tax filing services Singapore', or 'corporate secretary Singapore'. We also set up Google Business Profile and local schema markup." } },
      { "@type": "Question", "name": "How long does it take to build an accounting firm website?", "acceptedAnswer": { "@type": "Answer", "text": "Most accounting firm websites go live within 2–3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or document management may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Accounting Firm Website Singapore", "item": "https://jraftcreative.com/accounting-firm-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Accounting Firm Website Singapore — Jraft Creative"
  description="Professional website design for accounting firms in Singapore. Service pages, client portals, and credential showcases — from S$2,500."
  canonical="https://jraftcreative.com/accounting-firm-website-singapore/"
  ogTitle="Accounting Firm Website Singapore — Jraft Creative"
  ogDescription="Website design for accounting firms in Singapore. Service pages, client portals, ISCA credential badges — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="accounting firm website singapore, cpa website design singapore, tax firm website singapore, bookkeeping website singapore, accountant website design, audit firm website singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Accounting Firm Websites"
  heroTitle='Website Design for <span class="highlight">Accounting Firms in Singapore</span>'
  heroSubtitle="Your firm needs a website that builds trust before the first meeting. We build professional, mobile-friendly websites for accounting practices — with service pages, credential badges, and client portals built in."
  heroImage="/images/service-accounting.webp"
  heroImageAlt="Accountant meeting a client in a Singapore office — accounting firm website design"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my accounting firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Accounting Firm Online"
  ctaDescription="Book a free consultation and tell us about your practice. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20accounting%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why accounting firms need a proper website in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Businesses <span class="highlight">Vet Your Firm Online</span> Before They Ever <span class="highlight">Make Contact</span></h2>
      </div>
      <div class="section-content reveal">
        <p>When a Singapore SME needs an accountant, they search Google, open three or four firm websites, and judge each one in seconds. They scan for the services you offer, check that you're properly qualified, and shortlist the practices that look credible. Accounting is a trust-driven, relationship-led purchase — and your website is doing that vetting on your behalf, whether it's built for it or not.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Credentials Are Checked First</h3>
            <p>Before a business owner trusts you with their books, they look for proof — ISCA membership, ACRA registration, professional qualifications, and a registered business address. If those signals aren't obvious on the page, the prospect assumes the worst and moves to the next firm on the list.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>A Commoditised, Crowded Market</h3>
            <p>Singapore has thousands of registered accounting firms chasing the same SME clients, and most websites read identically — "audit, tax, bookkeeping, corporate secretarial". Without clear differentiation on specialisation, industries served, and how you actually work, you blur into the crowd and compete only on price.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Traffic That Never Enquires</h3>
            <p>A brochure site that just sits there isn't enough. The job of the website is to turn a cautious visitor into a booked consultation — with clear service pages, visible trust signals, and an easy enquiry path. Most firm sites leave prospects with no obvious next step, so the lead quietly disappears.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Accounting firm website design deliverables">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of an Accounting Firm <span class="highlight">Website</span></h2>
      </div>
      <div class="section-content reveal">
        <p>An accounting firm website isn't an e-commerce store or a generic brochure. Business owners arrive cautious, comparing you against three other firms, and they need to see credibility, scope, and a clear way to get in touch. We build every element around how a Singapore SME actually researches and chooses an accountant.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Credibility-Led Design</h3>
            <p>A clean, professional layout that signals competence the moment the page loads. Considered typography, calm colour, and a structure that puts qualifications and clarity first — so a prospect's instinctive "can I trust them with my finances?" is answered before they read a word.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Service Pages for Each Practice Area</h3>
            <p>Dedicated pages for audit &amp; assurance, tax advisory, bookkeeping, GST, and corporate secretarial work. Each explains the scope, the process, and who it's for, so prospects self-qualify and arrive at the enquiry already understanding what you do.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Team &amp; Credentials</h3>
            <p>Team profiles, qualifications, and prominently displayed ISCA membership, ACRA registration, and professional accreditations. The trust signals that matter in accounting, positioned above the fold and on every service page — not buried on an About page.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Secure Enquiry Forms</h3>
            <p>Clear, low-friction enquiry and consultation-booking forms with spam protection and SSL encryption. Tap-to-call and WhatsApp options for owners researching on their phones, so an interested prospect can reach your team in a single tap.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Speed &amp; Core Web Vitals</h3>
            <p>Business owners research accountants between meetings, on their phones. Every site is built mobile-first and tuned for fast load times and strong Core Web Vitals, so the page is ready the moment a prospect arrives and Google rewards the performance.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>SEO Foundations</h3>
            <p>Clean structure, optimised titles and metas, local schema, and Google Business Profile setup — built in from day one so your firm can surface for searches like "tax filing services Singapore" or "corporate secretary Singapore" instead of being invisible.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for accounting firm website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">Web Design Partner</span> Built for <span class="highlight">Professional Services</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for professional services firms across Singapore, and we understand what turns a cautious business owner into a booked consultation — credibility signals, clear scope, and a frictionless enquiry path. We design every element of your site around that conversion.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Professional Services Experience</h3>
            <p>We understand the needs of accounting practices — credential displays, team qualifications, structured service pages, and compliance-conscious design. We know what an SME owner looks for before they trust a firm with their finances, and we build it in.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Built to Convert, Not Just Look Good</h3>
            <p>A handsome site that generates no enquiries is a wasted investment. We structure pages around the prospect's questions and decisions, with trust signals and clear calls to action placed exactly where they tip a visitor into picking up the phone.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A website is the foundation, but discovery and lead flow depend on more. We handle SEO, social, and paid ads on Google and LinkedIn in-house — an integrated system that brings the right business owners to a site built to win them.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — where your website fits the client journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>Where Your <span class="highlight">Website</span> Fits the <span class="highlight">Client Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every Singapore business owner moves through the same five stages before engaging an accountant. Your website carries them from the first search to a booked consultation — and feeds trust signals into every stage along the way.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Google search, Maps, referrals</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Compare 3–4 firms in seconds</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>ISCA, ACRA, team &amp; reviews</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>Book a consultation or call</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Appoint, onboard &amp; refer</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Accounting firm website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Accounting Website Pricing</p>
        <h2>Website Packages for Accounting Firms</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new practices and small accounting firms getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Service pages (audit, tax, bookkeeping)</li>
              <li>Team profiles &amp; credentials</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established firms ready to generate leads online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>ISCA &amp; ACRA credential badges</li>
              <li>Tax resource centre &amp; blog</li>
              <li>Client testimonials section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For larger firms needing client portals and custom features.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Client portal &amp; document upload</li>
              <li>Custom features &amp; design</li>
              <li>Multi-language support</li>
              <li>Document management system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about accounting firm website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Accounting Firm Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an accounting firm website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional accounting firm website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service descriptions, team profiles, and contact form. Business and Premium packages add client portals, resource centres, and document management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build a client portal for our accounting firm?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package includes a secure client portal where clients can upload documents, download reports, and communicate with your team. The portal uses SSL encryption and access controls to keep financial data secure and compliant.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you display ISCA and ACRA credentials on the website?</summary>
          <div class="faq-answer"><p>Yes. We prominently display your firm's professional credentials including ISCA membership, ACRA registration, and any other certifications. Trust signals like these are critical for accounting firms — potential clients need to see that you are properly qualified and registered.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can the website help us rank for accounting-related searches in Singapore?</summary>
          <div class="faq-answer"><p>Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with keyword targeting for searches like "accounting firm Singapore", "tax filing services Singapore", or "corporate secretary Singapore". We also set up Google Business Profile and local schema markup.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an accounting firm website?</summary>
          <div class="faq-answer"><p>Most accounting firm websites go live within 2-3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or document management may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
