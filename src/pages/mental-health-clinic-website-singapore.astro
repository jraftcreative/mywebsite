---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Mental Health Clinic Website Design Singapore",
    "description": "Professional website design for mental health clinics in Singapore. Therapist profiles, confidential booking, and trust-building design — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Mental Health Clinic Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Mental Health Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page mental health clinic website with service pages, therapist profile, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Mental Health Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with confidential online booking, self-assessment tools, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Mental Health Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-location support, therapist directory, insurance panel integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a mental health clinic website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional mental health clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service pages, therapist profile, and contact form. Business and Premium packages add confidential online booking, self-assessment tools, insurance panel information, and multi-location support." } },
      { "@type": "Question", "name": "How do you handle confidentiality on mental health websites?", "acceptedAnswer": { "@type": "Answer", "text": "Confidentiality is central to every mental health website we build. We use SSL encryption across the entire site, build discreet contact forms that don't expose sensitive information, and design the booking process to be private and secure. We also ensure your privacy policy clearly communicates how patient data is handled in compliance with the PDPA." } },
      { "@type": "Question", "name": "Can you build therapist and psychologist profile pages?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build detailed profile pages for each practitioner — including their qualifications, registration status with the Singapore Medical Council (SMC) or Singapore Register of Psychologists (SRP), areas of specialisation, therapeutic approach, and a professional bio. These profiles help potential clients find the right therapist for their needs." } },
      { "@type": "Question", "name": "Can you include self-assessment tools on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above can include validated self-assessment screening tools — such as the PHQ-9 for depression or GAD-7 for anxiety. These are presented with appropriate clinical disclaimers and guide visitors toward booking a professional consultation based on their responses." } },
      { "@type": "Question", "name": "How long does it take to build a mental health clinic website?", "acceptedAnswer": { "@type": "Answer", "text": "Most mental health clinic websites go live within 2–3 weeks. A standard 5-page site can be ready in 2 weeks. Larger projects with self-assessment tools, therapist directories, or multi-location features may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Mental Health Clinic Website Design Singapore", "item": "https://jraftcreative.com/mental-health-clinic-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Mental Health Clinic Website Design Singapore — Therapy & Counselling Websites | Jraft Creative"
  description="Professional website design for mental health clinics in Singapore. Therapist profiles, confidential online booking, self-assessment tools, and trust-building design — from S$2,500."
  canonical="https://jraftcreative.com/mental-health-clinic-website-singapore/"
  ogTitle="Mental Health Clinic Website Design Singapore — Jraft Creative"
  ogDescription="Website design for mental health clinics in Singapore. Therapist profiles, confidential booking, insurance panel info — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="mental health clinic website design singapore, therapy website singapore, counselling website design, psychologist website singapore, mental health web design singapore, psychiatry clinic website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Mental Health Website Design"
  heroTitle='Website Design for Mental Health Clinics in <span class="highlight">Singapore</span>'
  heroSubtitle="People seeking mental health support in Singapore need to feel safe before they reach out. We build sensitive, trust-building websites for counselling practices, psychology clinics, and psychiatric centres — with therapist profiles, confidential online booking, insurance panel information, and self-assessment tools."
  heroImage="/images/service-mentalhealth.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my mental health clinic in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Mental Health Practice Online"
  ctaDescription="Book a free consultation and tell us about your practice. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20mental%20health%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why mental health clinics need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>People Seeking Help Start Their Search Online</h2>
      </div>
      <div class="section-content reveal">
        <p>Mental health awareness in Singapore has grown significantly in recent years. More Singaporeans are seeking professional support for anxiety, depression, relationship issues, and workplace stress than ever before. But for many, the first step is not a phone call — it's a Google search. They look for therapists, compare credentials, read about different approaches, and try to find someone they feel comfortable opening up to — all from the privacy of their phone or laptop.</p>
        <p>This is where most mental health practices fall short online. Many clinics in Singapore either have no website at all, or have one that feels clinical, impersonal, or outdated. In a field where trust and comfort are everything, a poorly designed website can turn away someone who is already hesitant about seeking help. Your website needs to feel approachable, professional, and safe — from the moment a visitor lands on it.</p>
        <p>Mental health clinics face unique design challenges that general web agencies often overlook. The tone has to be warm without being patronising. Service descriptions need to explain therapy approaches without clinical jargon. Practitioner credentials — SMC registration for psychiatrists, SRP registration for psychologists — must be clearly displayed. And every element of the user experience needs to reinforce confidentiality, from the booking form to the privacy policy.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Mental health website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Mental Health Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>Every mental health website we deliver is designed with sensitivity and purpose. We go beyond generic healthcare templates — your site will feature service pages that explain each therapy modality clearly, practitioner profiles that build trust, confidential online booking, and self-assessment tools that guide visitors toward taking the first step.</p>
        <p>Your online presence extends beyond your website. Pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for searches like "therapist near me" and specific mental health conditions, <a href="/services/social-media/">social media marketing</a> to share mental wellness content and reduce stigma, and <a href="/services/paid-ads/">paid ads management</a> to reach people actively searching for professional support in Singapore.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Service Pages by Therapy Type</h3>
            <p>Dedicated pages for counselling, psychotherapy, psychiatry, couples therapy, cognitive behavioural therapy (CBT), and more. Each page explains the approach in accessible language, describes who it helps, what a typical session looks like, and guides visitors toward booking a consultation.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Therapist &amp; Psychologist Profiles</h3>
            <p>Detailed profile pages for each practitioner — qualifications, SMC or SRP registration, areas of specialisation, therapeutic modalities, languages spoken, and a personal statement. Potential clients want to know who they'll be speaking with, and these profiles help them find the right fit.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Confidential Online Booking</h3>
            <p>A secure, private booking system that lets clients schedule appointments without calling. They can select a therapist, choose a session type, pick a convenient time, and provide only the information needed — with SSL encryption and clear privacy assurances throughout the process.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Insurance Panels &amp; Self-Assessment Tools</h3>
            <p>Clear insurance panel information showing which plans your clinic accepts — including coverage details for major insurers in Singapore. Plus, validated self-assessment screening tools like the PHQ-9 and GAD-7, presented with clinical disclaimers, that guide visitors toward professional consultation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for mental health website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Mental Health Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand that mental health websites require a different approach. Every design decision — from colour palette to copy tone — needs to make visitors feel welcome, safe, and understood. We build websites that lower the barrier to reaching out.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Sensitive, Trust-Building Design</h3>
            <p>We design specifically for the mental health space — warm colour palettes, calming layouts, approachable photography, and copy that normalises seeking help. Every element is chosen to make hesitant visitors feel comfortable enough to take the next step.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most mental health clinic websites go live within 2 weeks of kickoff. Whether you're launching a new practice or refreshing an existing clinic's brand, we deliver on schedule so you can start reaching clients sooner.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Privacy &amp; Confidentiality First</h3>
            <p>SSL encryption, discreet contact forms, PDPA-compliant privacy policies, and a booking process designed to protect client information at every step. We treat confidentiality as a core feature, not an afterthought.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence — from ranking for "psychologist near me" searches to running sensitive, compliant ad campaigns that reach people who need professional support.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Mental health website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Mental Health Website Pricing</p>
        <h2>Website Packages for Mental Health Clinics</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new practices and solo therapists.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Service &amp; therapy pages</li>
              <li>Therapist profile page</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For clinics ready to grow their client base.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Confidential online booking</li>
              <li>Self-assessment screening tools</li>
              <li>Blog / mental wellness articles</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-therapist practices and psychiatric centres.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-location support</li>
              <li>Therapist directory &amp; matching</li>
              <li>Insurance panel integration</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about mental health website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Mental Health Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a mental health clinic website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional mental health clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with service pages, therapist profile, and contact form. Business and Premium packages add confidential online booking, self-assessment tools, insurance panel information, and multi-location support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you handle confidentiality on mental health websites?</summary>
          <div class="faq-answer"><p>Confidentiality is central to every mental health website we build. We use SSL encryption across the entire site, build discreet contact forms that don't expose sensitive information, and design the booking process to be private and secure. We also ensure your privacy policy clearly communicates how patient data is handled in compliance with the PDPA.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you build therapist and psychologist profile pages?</summary>
          <div class="faq-answer"><p>Yes. We build detailed profile pages for each practitioner — including their qualifications, registration status with the Singapore Medical Council (SMC) or Singapore Register of Psychologists (SRP), areas of specialisation, therapeutic approach, and a professional bio. These profiles help potential clients find the right therapist for their needs.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you include self-assessment tools on the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above can include validated self-assessment screening tools — such as the PHQ-9 for depression or GAD-7 for anxiety. These are presented with appropriate clinical disclaimers and guide visitors toward booking a professional consultation based on their responses.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a mental health clinic website?</summary>
          <div class="faq-answer"><p>Most mental health clinic websites go live within 2–3 weeks. A standard 5-page site can be ready in 2 weeks. Larger projects with self-assessment tools, therapist directories, or multi-location features may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Mental Health Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/mental-health-marketing-singapore/" class="related-service-link">Mental Health Marketing</a>
          <a href="/mental-health-social-media-singapore/" class="related-service-link">Mental Health Social Media</a>
          <a href="/mental-health-google-ads-singapore/" class="related-service-link">Mental Health Google Ads</a>
      </div>
    </div>
  </section>
</ServiceLayout>
