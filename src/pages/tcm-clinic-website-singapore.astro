---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "TCM Clinic Website Design Singapore",
    "description": "Professional website design for Traditional Chinese Medicine clinics in Singapore. Treatment pages, practitioner profiles, and online appointment booking — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "TCM Clinic Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter TCM Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page TCM clinic website with treatment pages, practitioner profile, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business TCM Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online booking, bilingual EN/CN content, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium TCM Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-location support, herb catalogue, patient portal, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a TCM clinic website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional TCM clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with treatment pages, practitioner profile, and contact form. Business and Premium packages add online appointment booking, bilingual content, herb catalogues, and multi-location support." } },
      { "@type": "Question", "name": "Can you build a bilingual website in English and Chinese for my TCM clinic?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Many TCM clinics in Singapore serve both English-speaking and Mandarin-speaking patients. Our Business package ($5,500) and above include full bilingual support — with properly translated content, language toggle functionality, and SEO optimisation for both English and Chinese search terms." } },
      { "@type": "Question", "name": "Do TCM clinic websites need to comply with any regulations in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Traditional Chinese Medicine Practitioners Board (TCMPB) under MOH regulates TCM advertising in Singapore. Your website must not make unsubstantiated medical claims, and practitioners listed must be TCMPB-registered. We ensure all website content meets these compliance requirements." } },
      { "@type": "Question", "name": "Can patients book TCM appointments online through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online appointment booking integration. Patients can select their preferred practitioner, choose a treatment type such as acupuncture or herbal consultation, pick a time slot, and receive automated confirmation — making it easier for patients and reducing your clinic's admin workload." } },
      { "@type": "Question", "name": "How long does it take to build a TCM clinic website?", "acceptedAnswer": { "@type": "Answer", "text": "Most TCM clinic websites go live within 2–3 weeks. A standard 5-page site can be ready in 2 weeks. Bilingual websites or projects with custom features like herb databases or multi-location pages may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "TCM Clinic Website Design Singapore", "item": "https://jraftcreative.com/tcm-clinic-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="TCM Clinic Website Design Singapore — TCM Websites | Jraft Creative"
  description="Professional website design for Traditional Chinese Medicine clinics in Singapore. Treatment pages, practitioner profiles, bilingual content, and online booking — from S$2,500."
  canonical="https://jraftcreative.com/tcm-clinic-website-singapore/"
  ogTitle="TCM Clinic Website Design Singapore — Jraft Creative"
  ogDescription="Website design for TCM clinics in Singapore. Treatment pages, practitioner profiles, bilingual EN/CN content, online booking — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="TCM clinic website design singapore, TCM website singapore, traditional chinese medicine website, TCM web design singapore, chinese medicine clinic website, TCM digital marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="TCM Website Design"
  heroTitle='Website Design for TCM Clinics in <span class="highlight">Singapore</span>'
  heroSubtitle="Your TCM clinic deserves more than a directory listing. We build fast, mobile-friendly websites for Traditional Chinese Medicine practices — with dedicated treatment pages, TCMPB-compliant practitioner profiles, bilingual EN/CN content, and online appointment booking."
  heroImage="/images/service-tcm.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my TCM clinic in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your TCM Clinic Online"
  ctaDescription="Book a free consultation and tell us about your TCM practice. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20TCM%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why TCM clinics need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Patients Are Searching for TCM Practitioners Online</h2>
      </div>
      <div class="section-content reveal">
        <p>Traditional Chinese Medicine is deeply rooted in Singapore's healthcare landscape. From neighbourhood TCM clinics in Chinatown and Toa Payoh to modern integrative wellness centres in Orchard and Raffles Place, thousands of Singaporeans rely on acupuncture, herbal medicine, and tuina for their health. But most TCM clinics still depend on walk-ins and word-of-mouth — missing the growing number of patients who search online first.</p>
        <p>Younger Singaporeans and expats increasingly turn to Google when looking for a TCM practitioner. They compare treatment options, check practitioner credentials, read reviews, and want to book appointments without making a phone call. If your clinic doesn't have a professional website — or worse, has an outdated one buried on page three of search results — those patients are booking with a competitor instead.</p>
        <p>TCM clinics also face unique challenges online. Patients may not understand the difference between acupuncture, herbal prescriptions, and tuina massage. Your website needs to educate, build trust, and clearly present your practitioner's TCMPB registration — all while complying with MOH advertising regulations for traditional medicine services in Singapore.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="TCM website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for TCM Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>Every TCM website we deliver is built specifically for traditional medicine practices. We go beyond generic templates — your site will feature structured treatment pages for each modality, TCMPB-compliant practitioner profiles, bilingual content, and local SEO so patients find your clinic when searching for TCM services near them.</p>
        <p>We understand that a strong online presence means more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for treatment-related searches, <a href="/services/social-media/">social media marketing</a> to educate patients about TCM benefits, and <a href="/services/paid-ads/">paid ads management</a> to drive appointment bookings from Google and social platforms.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Treatment Pages by Modality</h3>
            <p>Dedicated pages for acupuncture, herbal medicine, tuina massage, cupping therapy, and moxibustion. Each page explains the treatment process, conditions addressed, what patients can expect during a session, and clear calls to action for booking.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Practitioner Profiles &amp; TCMPB Credentials</h3>
            <p>Professional profile pages for each physician — qualifications, TCMPB registration number, areas of specialisation, training background, and languages spoken. Patients searching for a registered TCM practitioner in Singapore want this information upfront.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Online Appointment Booking</h3>
            <p>Let patients book consultations directly from your website — choosing their preferred practitioner, treatment type, and time slot. Automated confirmations and reminders reduce no-shows and free up your reception staff from fielding phone calls.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Bilingual EN/CN Content</h3>
            <p>Serve your full patient base with properly translated English and Chinese content. We build language toggle functionality, optimise for both English and Mandarin search terms, and ensure TCM terminology is accurately presented in both languages for Singapore's multilingual audience.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for TCM website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for TCM Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for healthcare and wellness providers across Singapore. We understand the nuances of marketing traditional medicine services online — from regulatory compliance to the trust signals that turn website visitors into booked patients.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>TCM Compliance Built In</h3>
            <p>We ensure your website meets TCMPB and MOH advertising guidelines for traditional medicine. No unsubstantiated health claims, proper credential display, and compliant language throughout — so you can focus on treating patients, not worrying about regulatory issues.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most TCM clinic websites go live within 2 weeks of kickoff. Whether you're opening a new practice or refreshing an established clinic's online presence, we deliver on time without cutting corners.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Every site is designed for the patient searching on their phone. Fast load times, thumb-friendly navigation, and tap-to-call buttons so patients can reach your clinic instantly — whether they're at home or on the MRT.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence — from ranking for "TCM clinic near me" searches to running Google Ads campaigns that fill your appointment book.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="TCM website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">TCM Website Pricing</p>
        <h2>Website Packages for TCM Clinics</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new clinics and solo TCM practitioners.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Treatment service pages</li>
              <li>Practitioner profile page</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For clinics ready to grow their patient base.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online appointment booking</li>
              <li>Bilingual EN/CN content</li>
              <li>Blog / TCM wellness articles</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-branch TCM groups and wellness centres.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-location support</li>
              <li>Herb catalogue / product listings</li>
              <li>Practitioner management system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about TCM website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>TCM Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a TCM clinic website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional TCM clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with treatment pages, practitioner profile, and contact form. Business and Premium packages add online appointment booking, bilingual content, herb catalogues, and multi-location support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build a bilingual website in English and Chinese for my TCM clinic?</summary>
          <div class="faq-answer"><p>Yes. Many TCM clinics in Singapore serve both English-speaking and Mandarin-speaking patients. Our Business package ($5,500) and above include full bilingual support — with properly translated content, language toggle functionality, and SEO optimisation for both English and Chinese search terms.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do TCM clinic websites need to comply with any regulations in Singapore?</summary>
          <div class="faq-answer"><p>Yes. The Traditional Chinese Medicine Practitioners Board (TCMPB) under MOH regulates TCM advertising in Singapore. Your website must not make unsubstantiated medical claims, and practitioners listed must be TCMPB-registered. We ensure all website content meets these compliance requirements.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can patients book TCM appointments online through the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online appointment booking integration. Patients can select their preferred practitioner, choose a treatment type such as acupuncture or herbal consultation, pick a time slot, and receive automated confirmation — making it easier for patients and reducing your clinic's admin workload.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a TCM clinic website?</summary>
          <div class="faq-answer"><p>Most TCM clinic websites go live within 2–3 weeks. A standard 5-page site can be ready in 2 weeks. Bilingual websites or projects with custom features like herb databases or multi-location pages may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
