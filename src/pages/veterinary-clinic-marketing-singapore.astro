---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Veterinary Clinic Marketing Singapore",
    "description": "Full-service digital marketing for veterinary clinics in Singapore — website design, SEO, Google Ads, social media, and content marketing. Grow client bookings from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Veterinary Clinic Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for veterinary clinics" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, pet owner content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a veterinary clinic spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most veterinary clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your clinic's size, number of branches, and new client targets. Our Essential plan at $3,000/month is a strong starting point for single-location veterinary practices." } },
      { "@type": "Question", "name": "How long before marketing generates new clients for my veterinary clinic?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate new client enquiries within the first week — pet owners searching for a vet often have urgent needs. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds community and trust over 2–3 months. Most veterinary clinic clients see a meaningful increase in new patient registrations within the first 60 days." } },
      { "@type": "Question", "name": "What marketing channels work best for veterinary clinics in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search is critical — pet owners searching for 'vet clinic near me' or 'emergency vet Singapore' have immediate booking intent. Google Business Profile with strong reviews is essential for local visibility. Social media, particularly Instagram and Facebook, builds community through pet content. Content marketing educates pet owners and drives organic search traffic. A professional website ties everything together." } },
      { "@type": "Question", "name": "Can you help market specialised veterinary services?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create targeted campaigns for each specialisation — general practice, emergency care, dental services, surgery, dermatology, cardiology, exotic pets, and grooming services. Each service attracts a different pet owner profile and has unique search behaviour. We build dedicated landing pages, ad campaigns, and content for each service line." } },
      { "@type": "Question", "name": "Do you handle social media for veterinary clinics?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Veterinary clinics have a natural advantage on social media — pet content performs exceptionally well across all platforms. We create content featuring patient stories (with owner permission), pet health tips, team introductions, behind-the-scenes clinic moments, and seasonal pet care advice. This builds the community engagement and trust that drives referrals and repeat visits." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Veterinary Clinic Marketing Singapore", "item": "https://jraftcreative.com/veterinary-clinic-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Pet-Owner Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Veterinary Clinic Marketing Singapore — Jraft Creative"
  description="Full-service digital marketing for veterinary clinics in Singapore — website, SEO, Google Ads, social media, and content marketing."
  canonical="https://jraftcreative.com/veterinary-clinic-marketing-singapore/"
  ogTitle="Veterinary Clinic Marketing Singapore — Jraft Creative"
  ogDescription="Full-service marketing for veterinary clinics in Singapore. Website, SEO, Google Ads, social media — one agency, one strategy, more clients."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="veterinary clinic marketing singapore, vet clinic marketing agency, veterinary advertising singapore, vet digital marketing, veterinary clinic promotion, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Veterinary Clinic Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">Veterinary Clinics in Singapore</span>'
  heroSubtitle="Website, SEO, Google Ads, social media, and content — managed by one agency with one goal: growing your client base. Stop relying on foot traffic alone and start building a patient acquisition engine for your practice."
  heroImage="/images/service-veterinary.webp"
  heroImageAlt="Veterinary clinic examination room in Singapore — veterinary clinic marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my veterinary clinic in Singapore."
  ctaLabel="Ready to Grow Your Practice?"
  ctaTitle="Get Your Free Veterinary Clinic Marketing Audit"
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your clinic's growth goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20veterinary%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why veterinary clinics need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Great <span class="highlight">Care</span> Means Nothing If Pet Owners <span class="highlight">Can't Find or Trust You First</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's pet ownership is booming, and new clinics, corporate chains, and specialist practices are all competing for every pet owner in your catchment. The clinics that win aren't always the ones with the best vets — they're the ones pet owners find, trust, and book before they ever walk in.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Research Window</h3>
            <p>Pet owners treat their animals like family, and choosing a vet is an emotional decision. Before they commit, they read reviews, compare clinic websites, and scroll Instagram for weeks. If you're invisible during that research window, the booking goes to whoever showed up.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trust Threshold</h3>
            <p>A vet visit means handing over a family member. Pet owners validate you through Google reviews, visible credentials, team profiles, and educational content before they ever enquire. Without that proof on display, you stay a faceless name on a directory listing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Vet Near Me" Moment</h3>
            <p>When a pet is unwell or it's an emergency, owners search "vet near me" or "24-hour emergency vet Singapore" with immediate booking intent. If your clinic doesn't surface in that local search, the urgent — and often lifelong — client registers with whoever did.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for veterinary clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Veterinary Clinic <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for veterinary clinics — combining local SEO, AI search optimisation (GEO), paid search, pet-owner social content, branding, and conversion-focused web design, all built around how Singapore pet owners discover and choose their vet.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/veterinary-clinic-seo-singapore/">SEO for Veterinary Clinics</a></h3>
            <p>Rank for local searches like "vet clinic near me," "cat dental Pasir Ris," and "emergency vet Singapore." Google Business Profile, review management, and service pages that capture pet owners ready to register.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when pet owners ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best vet in Singapore" or "is my dog's symptom an emergency." Same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/veterinary-clinic-google-ads-singapore/">Google Ads for Veterinary Clinics</a></h3>
            <p>High-intent campaigns on urgent and service-specific terms, geo-targeted to your catchment. GCLID tracking from click to booked appointment, measured to a real cost-per-new-client.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/veterinary-clinic-social-media-singapore/">Social Media for Veterinary Clinics</a></h3>
            <p>Patient recovery stories (with owner permission), pet health tips, team intros, and behind-the-scenes Reels for Instagram, TikTok, and Facebook — the community engine that drives referrals and client loyalty.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/veterinary-clinic-branding-singapore/">Branding for Veterinary Clinics</a></h3>
            <p>Clinic identity, team positioning, and signage that signals warmth, safety, and expertise — lifting you out of price-only comparisons and into the clinic pet owners feel confident choosing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/veterinary-clinic-website-singapore/">Websites for Veterinary Clinics</a></h3>
            <p>Service pages, team profiles, booking forms, and mobile-first speed — the conversion architecture that turns a researching pet owner into a registered client.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for veterinary clinic marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Pet Owners</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching clinics are generalists who don't understand the emotional, trust-intensive way pet owners choose a vet. We are the opposite — full-service, performance-led, and built around how pet owners in Singapore research, validate, and book their clinic. We understand the local dynamics of a growing pet-care market across Punggol, Pasir Ris, Bukit Timah, and every neighbourhood in between.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Pet Care &amp; Local Market Knowledge</h3>
            <p>We understand Singapore's pet care market — the emotional decision-making of pet owners, the weight of Google reviews in vet selection, seasonal patterns like tick season and year-end boarding rushes, and how new pet owners discover and evaluate clinics.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, Instagram, TikTok, Facebook, branding, and websites under one roof. No coordinating between separate vendors. Every channel reinforces the same caring, professional brand as part of a single strategy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Registrations, Not Vanity Metrics</h3>
            <p>We measure new client registrations, appointment bookings, and cost per new client — not likes. GCLID offline tracking and WhatsApp-routed enquiries prove which ad click became which booking. Month-to-month retainers, no lock-in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PET-OWNER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Pet-Owner Funnel — how Singapore pet owners decide on a veterinary clinic">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Pet-Owner Funnel</p>
        <h2>How <span class="highlight">Singapore Pet Owners</span> Actually <span class="highlight">Choose a Vet</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first "vet near me" search to a lifelong client, every pet owner in Singapore moves through the same five stages. We build marketing that shows up at each one — from discovery through to the repeat visits that build lifetime value.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, Instagram, TikTok, AI search, referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, credentials, team &amp; educational content</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 clinics, services &amp; trust match</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Booking form, WhatsApp, or phone enquiry</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Repeat visits, boarding, refer friends</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for veterinary clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for Veterinary Clinics</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location clinics building a marketing foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics ready to scale client acquisition across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Pet owner content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-branch veterinary groups.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-branch campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Seasonal pet care campaigns</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about veterinary clinic marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Veterinary Clinic Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a veterinary clinic spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most veterinary clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your clinic's size, number of branches, and new client targets. Our Essential plan at $3,000/month is a strong starting point for single-location veterinary practices.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new clients for my veterinary clinic?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate new client enquiries within the first week — pet owners searching for a vet often have urgent needs. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds community and trust over 2–3 months. Most veterinary clinic clients see a meaningful increase in new patient registrations within the first 60 days.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for veterinary clinics in Singapore?</summary>
          <div class="faq-answer"><p>Google Search is critical — pet owners searching for "vet clinic near me" or "emergency vet Singapore" have immediate booking intent. Google Business Profile with strong reviews is essential for local visibility. Social media, particularly Instagram and Facebook, builds community through pet content. Content marketing educates pet owners and drives organic search traffic. A professional website ties everything together.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you help market specialised veterinary services?</summary>
          <div class="faq-answer"><p>Yes. We create targeted campaigns for each specialisation — general practice, emergency care, dental services, surgery, dermatology, cardiology, exotic pets, and grooming services. Each service attracts a different pet owner profile and has unique search behaviour. We build dedicated landing pages, ad campaigns, and content for each service line.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you handle social media for veterinary clinics?</summary>
          <div class="faq-answer"><p>Yes. Veterinary clinics have a natural advantage on social media — pet content performs exceptionally well across all platforms. We create content featuring patient stories (with owner permission), pet health tips, team introductions, behind-the-scenes clinic moments, and seasonal pet care advice. This builds the community engagement and trust that drives referrals and repeat visits.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="general" />

</ServiceLayout>
