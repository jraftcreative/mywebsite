---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Ecommerce AI Search Optimisation Singapore",
    "description": "Ecommerce AI search optimisation in Singapore — get your online store recommended by ChatGPT, Google Gemini, Perplexity, and AI Overviews. GEO for ecommerce from S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Ecommerce Generative Engine Optimisation (GEO)",
    "offers": [
      { "@type": "Offer", "name": "GEO Essentials", "price": "3000", "priceCurrency": "SGD", "description": "AI visibility audit, schema markup, content optimisation (5 pages/mo), llms.txt setup, monthly reporting" },
      { "@type": "Offer", "name": "GEO Growth", "price": "5000", "priceCurrency": "SGD", "description": "Everything in Essentials plus 20 pages/mo, authority building, answer engine content, bi-weekly reporting, dedicated strategist" },
      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Why do ecommerce stores need AI search optimisation?", "acceptedAnswer": { "@type": "Answer", "text": "Shoppers increasingly ask AI platforms like ChatGPT and Gemini for product and store recommendations before making purchases. If your online store isn't in those AI answers, you're losing high-intent buyers to competitors that AI does recommend. AI-referred traffic converts at 4.4x the rate of traditional search traffic." } },
      { "@type": "Question", "name": "How is ecommerce GEO different from regular ecommerce SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Ecommerce SEO focuses on ranking product pages in Google search results. Ecommerce GEO ensures AI platforms recommend your store when shoppers ask questions like 'best online store for sneakers in Singapore'. The overlap between Google rankings and AI citations is below 20%, so strong Google rankings alone won't get you into AI recommendations." } },
      { "@type": "Question", "name": "Which AI platforms matter most for ecommerce?", "acceptedAnswer": { "@type": "Answer", "text": "ChatGPT, Google Gemini, Google AI Overviews, Perplexity, and Microsoft Copilot all influence purchasing decisions. Google AI Overviews appears directly in search results, while ChatGPT and Perplexity are used for product research and comparison shopping. We optimise for all five platforms." } },
      { "@type": "Question", "name": "How long before my online store appears in AI recommendations?", "acceptedAnswer": { "@type": "Answer", "text": "Most ecommerce businesses see measurable improvements in AI citation rates within 30 to 90 days. Product schema implementation and structured data fixes can produce quick wins within weeks. Building product authority and review signals compounds over time for sustained visibility." } },
      { "@type": "Question", "name": "How much does ecommerce AI search optimisation cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Our GEO plans start at $3,000 SGD/month for the Essentials package covering AI audits, product schema markup, and content optimisation. Growth plans at $5,000/month add authority building and a dedicated strategist. Enterprise plans from $10,000/month provide full-service AI search domination for large catalogues." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Ecommerce AI Search Optimisation Singapore", "item": "https://jraftcreative.com/ecommerce-ai-search-optimisation-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Ecommerce AI Search Optimisation — Jraft Creative"
  description="Get your online store recommended by ChatGPT, Gemini, and Perplexity when shoppers search in Singapore — from S$3,000/mo."
  canonical="https://jraftcreative.com/ecommerce-ai-search-optimisation-singapore/"
  ogTitle="Ecommerce AI Search Optimisation Singapore — Jraft Creative"
  ogDescription="Get your ecommerce store recommended by ChatGPT, Gemini, Perplexity, and Google AI Overviews. GEO for online retail in Singapore."
  ogImage="https://jraftcreative.com/images/og-seo.jpg"
  keywords="ecommerce ai search optimisation singapore, ecommerce GEO singapore, online store AI optimisation, ecommerce generative engine optimisation, AI product recommendations singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Ecommerce GEO"
  heroTitle='Ecommerce AI Search Optimisation in <span class="highlight">Singapore</span>'
  heroSubtitle="Shoppers are asking ChatGPT and Gemini 'best online store for [product] in Singapore' before they ever open Google Shopping. AI product recommendations drive high-intent purchase traffic that converts at 4.4x the rate of traditional search. We make sure your ecommerce store is the one AI recommends."
  heroImage="/images/service-seo.webp"
  heroImageAlt="Online shopper receiving AI product recommendations — ecommerce GEO"
  heroButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View GEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to learn about your ecommerce AI search optimisation services in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Ecommerce Store Into AI Answers"
  ctaDescription="Book a free GEO audit and we'll show you exactly how your store appears — and doesn't — when shoppers ask ChatGPT, Gemini, Perplexity, and Google AI Overviews for product recommendations. We'll respond within 24 hours."
  ctaButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20about%20your%20ecommerce%20AI%20search%20optimisation%20services.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why ecommerce businesses need AI search optimisation">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Shoppers Ask <span class="highlight">AI</span> for Product Picks — Not <span class="highlight">Google Shopping</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Consumers now ask ChatGPT, Gemini, Perplexity, and Google AI Mode "where to buy [product] online in Singapore" or "best ecommerce store for [category]" before they ever open Google Shopping. The AI answers with three or four stores based on product range, reviews, and brand authority — not paid placements. If your store isn't named, that high-intent shopper is gone before the search page even loads.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Shoppers Ask the AI First</h3>
            <p>"Best online store for running shoes in Singapore", "cheapest ergonomic chair delivery SG", "where to buy skincare online" — shoppers now put these to ChatGPT, Gemini, Perplexity, and Google AI Mode. The AI hands back a shortlist of stores, and most buyers never scroll past it.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Invisible to AI Loses the Sale</h3>
            <p>If AI can't verify what you sell, your prices, and your ratings, it simply names a competitor. You can rank on page one of Google for dozens of product keywords and still be left out of the AI shortlist — the sale is lost before the shopper ever reaches a search results page.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Product Data &amp; Reviews Are What AI Cites</h3>
            <p>AI recommends the stores it can read and trust — machine-readable product schema, transparent pricing and stock, and rating signals on the platforms it cross-references. Stores with no structured product data and thin review signals give AI nothing to cite, and get skipped.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Ecommerce GEO services we deliver">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of Ecommerce <span class="highlight">GEO</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Ecommerce GEO isn't corporate or local SEO. Shoppers ask AI product-level questions — by category, brand, price, and use case — and the AI answers only with stores it can read, verify, and trust. We build every signal that determines whether AI recommends your store, from product schema to the review platforms AI cross-references before it names a shortlist.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>Product Schema &amp; Structured Data</h3>
            <p>Product, Offer, AggregateRating, and Brand schema (JSON-LD) that tells AI exactly what you sell, your price, your stock status, and your ratings. Without machine-readable product data, your store is functionally invisible to AI recommendations no matter how strong your rankings.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>AI-Friendly Product &amp; Category Content</h3>
            <p>Product descriptions, buying guides, and category pages restructured for AI consumption — answer-first formatting, specification tables, and comparison content that directly match the shopping queries buyers ask ChatGPT and Gemini before they purchase.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Review &amp; Rating Signals</h3>
            <p>AI synthesises ratings across Trustpilot, Google Merchant Centre, and marketplace seller ratings to judge store trust. We strengthen the review signals AI cross-references, so your store reads as credible when the AI decides which options to recommend.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Entity &amp; Brand Authority</h3>
            <p>A clearly defined brand identity AI can recognise — Organization schema with logo, founding date, and social profiles, plus category authority content. Strong entity signals let AI recommend an independent D2C store over a generic marketplace listing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Marketplace &amp; Citation Presence</h3>
            <p>In Singapore, Shopee and Lazada dominate product search and feed AI trust signals. We align your marketplace presence, shopping directories, and citations so your seller reputation reinforces — rather than competes with — your independent store's AI visibility.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-campaign-analytics.webp');">
          <div class="service-detail-card__content">
            <h3>AI-Visibility Monitoring</h3>
            <p>We track ecommerce-specific prompts across ChatGPT, Gemini, Perplexity, Copilot, and Google AI Overviews — showing which stores AI recommends instead of yours, how citation rates move over time, and where to close the next gap. Numbers that prove whether AI is naming you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for ecommerce AI search optimisation">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">GEO Agency</span> Built for <span class="highlight">Online Retail</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We understand both ecommerce and Generative Engine Optimisation — product feeds, catalogue structures, and shopping behaviour, combined with the technical GEO expertise needed to get your store recommended by AI platforms. It's built around how shoppers actually search, compare, and buy.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Ecommerce-Specific Expertise</h3>
            <p>We know how online shoppers search, compare, and buy. Our GEO strategies are built around ecommerce prompts and purchase-intent signals — not generic AI optimisation tactics bolted onto a product catalogue.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Product Schema &amp; Rich Data</h3>
            <p>We implement comprehensive product-level structured data — Product, Offer, AggregateRating, Brand, and Review schemas — giving AI platforms the machine-readable detail they need to confidently recommend your store and products.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>AI visibility drives discovery, but conversion depends on your store, content, and wider marketing. We handle ecommerce web design, SEO, and paid ads in-house — an integrated system that turns AI recommendations into paying customers.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CUSTOMER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Customer Funnel — where GEO fits the shopper journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Customer Funnel</p>
        <h2>Where <span class="highlight">GEO</span> Fits the <span class="highlight">Customer Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every online shopper moves through the same five stages before they buy again and refer others. GEO owns the first one — being the store the AI recommends the moment a shopper asks — and feeds trust signals into every stage after it.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Recommended by ChatGPT, Gemini &amp; AI Overviews</p>
        </li>
        <li class="funnel-stage">
          <h3>Consider</h3>
          <p>Reviews, ratings, buying guides, comparisons</p>
        </li>
        <li class="funnel-stage">
