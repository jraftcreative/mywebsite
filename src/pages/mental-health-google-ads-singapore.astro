---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Mental Health Google Ads Singapore",
    "description": "Google Ads management for mental health clinics in Singapore — therapy-seeking keywords, empathetic ad copy, EAP corporate campaigns, and PDPA-compliant conversion tracking. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for Mental Health Clinics",
    "offers": [
      { "@type": "Offer", "name": "Starter Mental Health Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, therapy keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Mental Health Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, EAP campaigns, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Mental Health Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should mental health clinics budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most mental health practices start with a monthly ad spend of $1,500–$5,000 on top of management fees. Keywords like 'psychologist Singapore' cost $4–$12 per click, while therapy-specific terms like 'CBT therapy Singapore' or 'couples counselling near me' range from $3–$8. The higher cost per click reflects the high lifetime value of each therapy client." } },
      { "@type": "Question", "name": "How do you ensure mental health ads are sensitive and appropriate?", "acceptedAnswer": { "@type": "Answer", "text": "Every element — ad copy, landing pages, and calls-to-action — is crafted with empathy. We avoid fear-based language, stigmatising terms, and high-pressure tactics. Our ads focus on creating a sense of safety and accessibility, acknowledging that searching for therapy is itself a significant step for many people." } },
      { "@type": "Question", "name": "Can Google Ads target corporate EAP contracts?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create separate B2B campaigns targeting HR directors and business owners searching for Employee Assistance Programmes, corporate counselling, and workplace wellness services. These campaigns use different messaging and landing pages from patient-facing ads, focusing on organisational outcomes and programme structures." } },
      { "@type": "Question", "name": "What Google advertising policies apply to mental health services?", "acceptedAnswer": { "@type": "Answer", "text": "Google requires healthcare advertiser certification for mental health ads in Singapore and has policies around prohibited claims and sensitive content. We handle the full compliance process — proper certification, compliant ad copy, appropriate landing page content, and correct handling of crisis-related keywords with safety resources." } },
      { "@type": "Question", "name": "How do you protect client confidentiality in ad tracking?", "acceptedAnswer": { "@type": "Answer", "text": "Client privacy is non-negotiable. We use aggregate conversion tracking that measures campaign performance without exposing individual client data. No personally identifiable information enters Google Ads, and our tracking setup fully complies with Singapore's Personal Data Protection Act (PDPA) and healthcare data standards." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Mental Health Google Ads Singapore", "item": "https://jraftcreative.com/mental-health-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Mental Health Google Ads Singapore — PPC for Therapy Clinics | Jraft Creative"
  description="Google Ads management for mental health clinics in Singapore. Therapy-seeking keywords, empathetic ad copy, EAP corporate campaigns, and PDPA-compliant conversion tracking. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/mental-health-google-ads-singapore/"
  ogTitle="Mental Health Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for mental health clinics in Singapore. Sensitive therapy ads, corporate EAP campaigns, and confidential tracking. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="mental health google ads singapore, therapy advertising singapore, google ads for psychologists, ppc mental health singapore, counselling clinic ads singapore, therapist marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Mental Health Google Ads Singapore"
  heroTitle='Google Ads for Mental Health Clinics <span class="highlight">in Singapore</span>'
  heroSubtitle="When someone searches for a therapist, counsellor, or psychologist in Singapore, they're taking a brave first step. We build Google Ads campaigns that connect your practice with people seeking help — with the empathy, sensitivity, and confidentiality that mental health advertising demands."
  heroImage="/images/service-mentalhealth.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my mental health clinic in Singapore."
  ctaLabel="Reach More Clients"
  ctaTitle="Get a Free Mental Health Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll analyse your practice's positioning, identify the most effective therapy keywords, and map out a sensitive, compliant Google Ads strategy tailored to your specialisations. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20mental%20health%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for mental health clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>People Are Searching for Help — Can They Find Your Practice?</h2>
      </div>
      <div class="section-content reveal">
        <p>Mental health awareness in Singapore has reached a turning point. The Singapore Mental Health Study found that 1 in 7 people experience a mental health condition, and the stigma around seeking help is steadily declining. More Singaporeans are searching Google for "therapist near me", "anxiety counselling Singapore", and "psychologist for depression" than ever before — and that first search is often the hardest step they'll take.</p>
        <p>If your practice doesn't appear when someone finally decides to seek help, they may delay reaching out or choose a less suitable provider. The stakes are higher than a missed appointment — it's a person in need not getting the support they deserve. Yet most digital agencies treat mental health marketing the same as any other industry, using generic tactics that feel clinical, pushy, or tone-deaf. Mental health advertising requires a fundamentally different approach.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for mental health clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Mental Health Ad Services</p>
        <h2>Sensitive, Compliant Google Ads for Therapy Practices</h2>
      </div>
      <div class="section-content reveal">
        <p>We build Google Ads campaigns for mental health clinics in Singapore with the sensitivity and compliance this field demands. Whether you're a solo psychologist, a multi-therapist counselling centre, or a psychiatric practice, every campaign is designed to reduce barriers for people seeking help while maintaining the highest standards of professionalism and confidentiality.</p>
        <p>Our approach covers therapy-specific keyword targeting, empathetic ad copy, PDPA-compliant tracking, and separate B2B campaigns for corporate EAP partnerships — ensuring your practice reaches both individuals seeking therapy and organisations investing in employee mental health.</p>
        <p>Complement your Google Ads with a professional <a href="/mental-health-clinic-website-singapore/">mental health clinic website</a> or <a href="/services/seo-performance/">SEO services</a> for long-term organic visibility among therapy-seekers.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Therapy-Specific Keyword Campaigns</h3>
            <p>Targeted ad groups for each service — individual therapy, couples counselling, child psychology, CBT, EMDR, psychiatric consultations — with empathetic ad copy that acknowledges the searcher's situation without judgement or pressure.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>EAP &amp; Corporate Wellness Campaigns</h3>
            <p>Separate B2B campaigns targeting HR directors, people managers, and business owners searching for Employee Assistance Programmes, corporate counselling, and workplace mental health solutions — using professional messaging focused on organisational outcomes.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>PDPA-Compliant Conversion Tracking</h3>
            <p>Aggregate conversion tracking that measures campaign performance without compromising client confidentiality. No personally identifiable information enters the advertising platform — compliant with Singapore's Personal Data Protection Act and healthcare data standards.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Safe-Space Landing Pages</h3>
            <p>Welcoming, non-judgemental landing pages featuring therapist profiles, clear session descriptions, confidentiality assurances, and simple booking forms. Every element is designed to make taking the first step feel safe and approachable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for mental health Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Mental Health Advertising Done With the Care It Deserves</h2>
      </div>
      <div class="section-content reveal">
        <p>Marketing mental health services is fundamentally different from marketing other businesses. We approach every campaign with the sensitivity and professionalism your clients expect. Here's why therapy practices choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Empathetic Messaging Expertise</h3>
            <p>Every ad and landing page is crafted to reduce barriers, not create pressure. We understand that people searching for therapy are vulnerable, and our messaging creates safety and trust — never using fear-based or stigmatising language.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each new client enquiry costs your practice.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that adapt to your practice's capacity. Scale up when expanding your team, pause when fully booked — no penalties, no minimum terms, no long-term lock-ins.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>PDPA &amp; Healthcare Compliance</h3>
            <p>All tracking, reporting, and data handling is designed to protect client privacy. We navigate Google's healthcare advertiser certification and Singapore's PDPA requirements so your advertising never compromises the trust your clients place in you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Mental health Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Mental Health Ads Pricing</p>
        <h2>Google Ads Plans for Mental Health Practices</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For practices launching their first Google Ads campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Therapy keyword research</li>
              <li>PDPA-compliant tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For practices adding EAP campaigns and scaling services.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; empathetic ad copy</li>
              <li>Landing page optimisation</li>
              <li>EAP corporate campaigns</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-therapist clinics maximising client acquisition.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for mental health clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Mental Health Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should mental health clinics budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Most mental health practices start with a monthly ad spend of $1,500–$5,000 on top of management fees. Keywords like "psychologist Singapore" cost $4–$12 per click, while therapy-specific terms like "CBT therapy Singapore" or "couples counselling near me" range from $3–$8. The higher cost per click reflects the high lifetime value of each therapy client.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you ensure mental health ads are sensitive and appropriate?</summary>
          <div class="faq-answer"><p>Every element — ad copy, landing pages, and calls-to-action — is crafted with empathy. We avoid fear-based language, stigmatising terms, and high-pressure tactics. Our ads focus on creating a sense of safety and accessibility, acknowledging that searching for therapy is itself a significant step for many people.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can Google Ads target corporate EAP contracts?</summary>
          <div class="faq-answer"><p>Yes. We create separate B2B campaigns targeting HR directors and business owners searching for Employee Assistance Programmes, corporate counselling, and workplace wellness services. These campaigns use different messaging and landing pages from patient-facing ads, focusing on organisational outcomes and programme structures.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>What Google advertising policies apply to mental health services?</summary>
          <div class="faq-answer"><p>Google requires healthcare advertiser certification for mental health ads in Singapore and has policies around prohibited claims and sensitive content. We handle the full compliance process — proper certification, compliant ad copy, appropriate landing page content, and correct handling of crisis-related keywords with safety resources.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you protect client confidentiality in ad tracking?</summary>
          <div class="faq-answer"><p>Client privacy is non-negotiable. We use aggregate conversion tracking that measures campaign performance without exposing individual client data. No personally identifiable information enters Google Ads, and our tracking setup fully complies with Singapore's Personal Data Protection Act (PDPA) and healthcare data standards.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Mental Health Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/mental-health-clinic-website-singapore/" class="related-service-link">Mental Health Website Design</a>
          <a href="/mental-health-marketing-singapore/" class="related-service-link">Mental Health Marketing</a>
          <a href="/mental-health-social-media-singapore/" class="related-service-link">Mental Health Social Media</a>
      </div>
    </div>
  </section>
</ServiceLayout>
