---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Physiotherapy Google Ads Singapore",
    "description": "Google Ads management for physiotherapy clinics in Singapore — treatment-specific campaigns, insurance panel targeting, post-surgery rehab lead generation, and conversion tracking. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for Physiotherapy Clinics",
    "offers": [
      { "@type": "Offer", "name": "Starter Physio Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, physiotherapy keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Physio Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, landing page optimisation, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Physio Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should physiotherapy clinics budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most physiotherapy clinics start with a monthly ad spend of $1,500–$4,000 on top of management fees. Keywords like 'physiotherapy Singapore' typically cost $3–$8 per click, while condition-specific terms like 'ACL rehab physiotherapy Singapore' may cost $4–$12 due to higher patient value. We set your budget based on treatment capacity and target patient volume." } },
      { "@type": "Question", "name": "Which physiotherapy keywords convert best?", "acceptedAnswer": { "@type": "Answer", "text": "Treatment-specific and condition-driven keywords convert best — 'sports physiotherapy Singapore', 'lower back pain treatment near me', 'post-surgery rehab clinic', and 'frozen shoulder physiotherapy'. We also target insurance-related queries like 'physiotherapy clinic Medisave approved' which attract patients ready to book." } },
      { "@type": "Question", "name": "Can Google Ads target patients with specific conditions?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create separate campaigns for each treatment area — sports injuries, post-surgical rehabilitation, chronic pain management, workplace ergonomics, and elderly mobility. Each campaign uses condition-specific keywords, ad copy addressing the patient's concern, and dedicated landing pages with relevant treatment information." } },
      { "@type": "Question", "name": "Do you handle healthcare advertising compliance for Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We ensure all ad copy and landing pages comply with Google's healthcare advertising policies and Singapore's PHMC advertising guidelines. This includes avoiding prohibited claims, ensuring proper disclaimers, and structuring ads that Google approves without delays or disapprovals." } },
      { "@type": "Question", "name": "How do you track patient enquiries from Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "We set up comprehensive tracking across appointment booking forms, phone calls, WhatsApp messages, and online scheduling widgets. Every patient enquiry is attributed to the specific keyword and campaign that generated it, giving you clear cost-per-patient data to measure your return on ad spend." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Physiotherapy Google Ads Singapore", "item": "https://jraftcreative.com/physiotherapy-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Physiotherapy Google Ads Singapore — PPC for Physio Clinics | Jraft Creative"
  description="Google Ads management for physiotherapy clinics in Singapore. Treatment-specific campaigns, insurance panel targeting, post-surgery rehab leads, and full conversion tracking. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/physiotherapy-google-ads-singapore/"
  ogTitle="Physiotherapy Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for physiotherapy clinics in Singapore. Target patients searching for sports rehab, chronic pain, and post-surgery physiotherapy. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="physiotherapy google ads singapore, physiotherapy advertising singapore, google ads for physiotherapy, ppc physiotherapy singapore, physiotherapy clinic marketing singapore, physio ads singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Physiotherapy Google Ads Singapore"
  heroTitle='Google Ads for Physiotherapy Clinics <span class="highlight">in Singapore</span>'
  heroSubtitle="Patients searching for physiotherapy in Singapore have a specific condition and want help now. We build Google Ads campaigns that connect your clinic with patients at the moment they're looking — driving appointment bookings for sports rehab, chronic pain, post-surgery recovery, and more."
  heroImage="/images/service-physiotherapy.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my physiotherapy clinic in Singapore."
  ctaLabel="Grow Your Patient Base"
  ctaTitle="Get a Free Physiotherapy Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll analyse your treatment specialties, review competitor ad activity in your area, and map out a Google Ads strategy tailored to your clinic's capacity and patient targets. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20physiotherapy%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for physiotherapy clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Patients Are Searching for Physio — Are They Finding Your Clinic?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's physiotherapy market is growing as the population ages and sports participation increases. When someone searches "physiotherapy near me" or "sports injury clinic Singapore", they see a mix of paid ads, map results, and hospital listings. If your clinic isn't in that first page of results, you're losing patients to the clinic that is — whether it's the hospital chain down the road or a private practice with better online visibility.</p>
        <p>Without targeted Google Ads, physiotherapy clinics rely on doctor referrals and word-of-mouth while competitors capture every patient searching online. Generic brand awareness campaigns don't reach patients at the moment of need, and without proper tracking, you have no idea which marketing channels actually drive appointment bookings versus wasting your budget.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for physiotherapy clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Physiotherapy Ad Services</p>
        <h2>Google Ads Strategy Built for Physio Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>We create Google Ads campaigns specifically for physiotherapy clinics in Singapore — targeting the treatments patients search for, in the areas where your clinic operates. Whether you specialise in sports rehabilitation in the CBD, post-surgical recovery in the East, or elderly mobility in heartland clinics, every campaign is designed to drive appointment bookings.</p>
        <p>Our approach covers treatment-specific keyword targeting, insurance panel visibility, condition-driven ad copy, and healthcare-compliant landing pages — ensuring your ad budget reaches patients with genuine intent to book an appointment.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Treatment-Specific Campaigns</h3>
            <p>Separate campaigns for each treatment area — sports injuries, post-surgery rehab, chronic pain management, workplace ergonomics, and elderly physiotherapy. Each campaign uses condition-specific keywords and ad copy that speaks directly to the patient's concern.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Insurance &amp; Referral Targeting</h3>
            <p>Campaigns targeting patients searching for Medisave-approved physiotherapy, corporate health insurance panel clinics, and GP-referred rehabilitation services. These keywords attract patients who are pre-qualified and ready to book.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Patient Enquiry Tracking</h3>
            <p>Full conversion tracking across appointment booking forms, phone calls, WhatsApp messages, and online scheduling widgets. Every patient enquiry is attributed to the specific treatment keyword and campaign that generated it.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Healthcare-Compliant Landing Pages</h3>
            <p>Dedicated landing pages for each treatment specialty with proper medical disclaimers, therapist credentials, treatment descriptions, and clear booking calls-to-action — all compliant with Google's healthcare advertising policies and PHMC guidelines.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for physiotherapy Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Healthcare Advertising That Drives Real Appointments</h2>
      </div>
      <div class="section-content reveal">
        <p>We've managed ad campaigns for healthcare businesses across Singapore and understand the patient journey from search to booking. Here's why physiotherapy clinics choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare Compliance Expertise</h3>
            <p>We navigate Google's healthcare ad policies and Singapore's PHMC advertising guidelines so your ads get approved without delays. No rejected campaigns, no policy violations, no wasted time.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each patient enquiry costs your clinic.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that flex with your clinic's capacity. Scale up when you hire new physiotherapists, adjust during quieter periods — no penalties, no minimum commitments.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Cost-Per-Patient Optimisation</h3>
            <p>We optimise for booked appointments, not just clicks. Continuous keyword refinement, ad copy testing, and landing page improvements ensure your cost per new patient decreases as campaigns mature.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Physiotherapy Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Physio Ads Pricing</p>
        <h2>Google Ads Plans for Physiotherapy Clinics</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For physiotherapy clinics launching their first ad campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Treatment keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics scaling across multiple treatment specialties.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; ad copy optimisation</li>
              <li>Landing page optimisation</li>
              <li>Competitor ad analysis</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-branch physiotherapy practices maximising patient volume.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for physiotherapy clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Physiotherapy Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should physiotherapy clinics budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Most physiotherapy clinics start with a monthly ad spend of $1,500–$4,000 on top of management fees. Keywords like "physiotherapy Singapore" typically cost $3–$8 per click, while condition-specific terms like "ACL rehab physiotherapy Singapore" may cost $4–$12 due to higher patient value. We set your budget based on treatment capacity and target patient volume.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which physiotherapy keywords convert best?</summary>
          <div class="faq-answer"><p>Treatment-specific and condition-driven keywords convert best — "sports physiotherapy Singapore", "lower back pain treatment near me", "post-surgery rehab clinic", and "frozen shoulder physiotherapy". We also target insurance-related queries like "physiotherapy clinic Medisave approved" which attract patients ready to book.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can Google Ads target patients with specific conditions?</summary>
          <div class="faq-answer"><p>Yes. We create separate campaigns for each treatment area — sports injuries, post-surgical rehabilitation, chronic pain management, workplace ergonomics, and elderly mobility. Each campaign uses condition-specific keywords, ad copy addressing the patient's concern, and dedicated landing pages with relevant treatment information.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you handle healthcare advertising compliance for Google Ads?</summary>
          <div class="faq-answer"><p>Yes. We ensure all ad copy and landing pages comply with Google's healthcare advertising policies and Singapore's PHMC advertising guidelines. This includes avoiding prohibited claims, ensuring proper disclaimers, and structuring ads that Google approves without delays or disapprovals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you track patient enquiries from Google Ads?</summary>
          <div class="faq-answer"><p>We set up comprehensive tracking across appointment booking forms, phone calls, WhatsApp messages, and online scheduling widgets. Every patient enquiry is attributed to the specific keyword and campaign that generated it, giving you clear cost-per-patient data to measure your return on ad spend.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
