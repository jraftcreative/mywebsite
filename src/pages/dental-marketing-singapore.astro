---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Dental Marketing Singapore",
    "description": "Digital marketing for dental clinics in Singapore. Google Ads, social content, and Google Business Profile work built around the SG dental patient journey — CHAS panels, insurance integrations, and MOH-compliant ad creative. From S$2,999/month with the Growth Bundle.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Dental Clinic Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Growth Bundle for Dental Clinics", "price": "2999", "priceCurrency": "SGD", "description": "Paid ads (Google + Meta), 12 pieces of social content per month, GBP management, and one consolidated monthly report — MOH-reviewed before every publish." }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your dental clinic ads follow MOH advertising rules?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, caption and content piece is reviewed against the MOH Private Hospitals and Medical Clinics Act advertising rules and the Singapore Dental Council ethical code before publication. That means no superlatives like 'best dentist', no outcome guarantees, no before-and-after used as a results claim, and no patient testimonials phrased as treatment endorsements. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "What does dental marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our Growth Bundle for dental clinics is $2,999 SGD/month, no lock-in. It covers paid ads on Google and Meta, 12 social posts a month, Google Business Profile management, and a single monthly report. Larger clinics or groups running multi-location campaigns and video content typically sit between $5,500 and $10,000/month depending on ad spend and content volume." } },
      { "@type": "Question", "name": "Can you help us get found by patients moving into a new neighbourhood?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is most of what we do for dental clinics. We run Google Ads on neighbourhood-level searches like 'dentist Tampines' or 'wisdom tooth Bukit Timah', tighten the Google Business Profile so the clinic shows up in the local map pack, and build social content that gives new residents a reason to pick you over the closest chain clinic." } },
      { "@type": "Question", "name": "Can you handle CHAS, insurance panel and Sunday-hours messaging?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. CHAS Blue, Orange and Green positioning, major insurance panel mentions (AIA, Great Eastern, Aetna and the local insurers), and Sunday or public holiday operating hours are all common targeting and creative angles we run for dental clients. We treat them as factual operational details, not promotional claims, which keeps them on the right side of MOH rules." } },
      { "@type": "Question", "name": "How do you reduce no-shows from new-patient bookings?", "acceptedAnswer": { "@type": "Answer", "text": "No-show rates drop when the patient is warm before they book. We do that with retargeting (so they see the clinic 3–5 times before they call), content that shows the actual clinic environment and team, and ad creative that filters out price-shoppers earlier in the funnel. We don't run the reminder system itself — that sits inside your PMS — but our work upstream is what makes those reminders convert." } },
      { "@type": "Question", "name": "How long before we see new patient enquiries?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads usually produces the first enquiries within the first 7–14 days, once conversion tracking is calibrated. Social content takes 4–8 weeks to build familiarity in the neighbourhood. Google Business Profile and local SEO movement shows up in months 2–4. We report enquiry volume monthly, not impressions." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Dental Marketing Singapore", "item": "https://jraftcreative.com/dental-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Patient Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Dental Marketing in Singapore — MOH-Compliant Ads & Content"
  description="Digital marketing for SG dental clinics. Google Ads, neighbourhood social content, GBP, CHAS & insurance angles — every asset MOH-reviewed. From $2,999/month."
  canonical="https://jraftcreative.com/dental-marketing-singapore/"
  ogTitle="Dental Marketing in Singapore — MOH-Compliant Ads & Content"
  ogDescription="Digital marketing for SG dental clinics. Google Ads, neighbourhood social content, GBP, CHAS & insurance angles — every asset MOH-reviewed. From $2,999/month."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="dental marketing singapore, dental clinic marketing, dental clinic digital marketing singapore, dental google ads singapore, marketing agency for dentists singapore, dental social media singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Dental Marketing"
  heroTitle='Marketing for <span class="highlight">Dental Clinics in Singapore</span>'
  heroSubtitle="Built around how patients actually pick a dentist — Google Maps, reviews, and the closest clinic that looks legit. We run the ads, neighbourhood social content and Google Business Profile work that puts you in that shortlist. Every asset MOH-reviewed before it goes live."
  heroImage="/images/service-dental.webp"
  heroImageAlt="Dental clinic treatment room in Singapore — dental clinic marketing"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20dental%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my dental clinic in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at your patient pipeline"
  ctaDescription="Tell us your clinic's location, the chains you're competing with, and a rough idea of your monthly new-patient volume. We'll come back inside 24 hours with where we'd start."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20dental%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why dental clinics need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>World-Class <span class="highlight">Dentistry</span> Means Nothing If Patients <span class="highlight">Can't Find or Trust You First</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has a dental clinic on nearly every block, and chain groups dominate the searches that matter. The clinics filling their chairs aren't always the best — they're the ones patients find first, trust fastest, and book, all within MOH's strict advertising rules.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Compliance Tightrope</h3>
            <p>The MOH Private Hospitals and Medical Clinics Act and the Singapore Dental Council ethical code strictly govern dental advertising — no "best dentist" superlatives, no outcome guarantees, no before-and-after used as a results claim. Generic agencies don't know these lines, and one non-compliant post can put your clinic at regulatory risk.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trust Threshold</h3>
            <p>A dental visit is a high-trust decision. Before booking, patients scrutinise Google reviews, dentist credentials, and how the clinic presents itself. Without visible reviews and credible content, you stay a faceless listing — and the patient picks the clinic that earned their confidence first.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Dentist Near Me" Moment</h3>
            <p>When a family moves into a new BTO or condo and types "dentist near me", the top three on Google Maps win the appointment. If your Google Business Profile is an unoptimised phonebook listing, you don't exist to them — the chain clinic two stops away does.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for dental clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Dental Clinic <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for dental clinics — combining local SEO, AI search optimisation (GEO), paid search, neighbourhood social content, branding, and conversion-focused web design, all reviewed against Singapore's healthcare advertising rules.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO for Dental Clinics</a></h3>
            <p>Rank for neighbourhood searches like "dentist Tampines", "wisdom tooth removal Bukit Timah", and "scaling and polishing near me". Google Business Profile optimisation and local SEO that lands you in the map pack new movers actually click.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when patients ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best dental clinic near me" or "is wisdom tooth removal painful". AI-friendly schema and the same citation playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google Ads for Dental Clinics</a></h3>
            <p>Neighbourhood-tight search ads on the procedure queries patients actually type, with the geo-radius limited to the catchment you can serve. GCLID tracking from click to booked enquiry, measured to a real cost per new patient.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Dental Clinics</a></h3>
            <p>Reels and posts that show the clinic environment, the team, and how a first visit actually runs — for Instagram, TikTok, and Facebook. Factual, familiarity-building content that stays inside MOH and SDC boundaries.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Dental Clinics</a></h3>
            <p>Clinic identity, signage, and a treatment-menu look that signals care and competence — lifting you out of price-only comparisons and into the clinic patients feel comfortable choosing for their family.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/dental-website-design-singapore/">Websites for Dental Clinics</a></h3>
            <p>Service pages, dentist profiles, CHAS and insurance panel info, and a single-field booking form — fast, mobile-first conversion architecture that turns a researching patient into a booked appointment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for dental marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Dental Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching clinics are generalists who don't understand MOH advertising rules or how a patient actually chooses a dentist. We're the opposite — full-service, compliance-aware, and built around how dental patients in Singapore search, validate, and book. We run neighbourhood-level campaigns across Tampines, Bukit Timah, Jurong, Punggol, and other high-density Singapore estates.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>MOH &amp; SDC Compliance Knowledge</h3>
            <p>Every ad, caption, and post is reviewed against the Private Hospitals and Medical Clinics Act and the Singapore Dental Council ethical code before it publishes — no prohibited claims, no risky before-and-afters — so you build authority without regulatory exposure.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, social, branding, and websites under one roof. No coordinating between vendors. Every channel delivers consistent, compliant positioning as part of a single strategy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>New Patients, Not Vanity Metrics</h3>
            <p>We track enquiries, calls, and cost per new patient — not likes. Month-to-month retainers with no lock-in, because clinics should stay for the pipeline, not a contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PATIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Patient Funnel — how Singapore patients decide on a dental clinic">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Patient Funnel</p>
        <h2>How <span class="highlight">Singapore Dental Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first "dentist near me" search to a recall appointment, every dental patient in Singapore moves through the same five stages. We build compliant marketing that shows up at each one — from discovery through to the return visit that builds lifetime value.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google Maps, "dentist near me", social, referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, dentist credentials, CHAS &amp; panel info</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 2–4 clinics on trust, location &amp; fit</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Booking form, WhatsApp, or phone enquiry</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Recall visits, family bookings, referrals</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Dental marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Dental Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Dental Clinics of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card featured reveal reveal-d1">
            <h3>Growth Bundle</h3>
            <div class="price">$2,999 <span>SGD/mo</span></div>
            <p class="pricing-desc">For solo dentists and independent clinics building a steady patient pipeline.</p>
            <ul class="pricing-features">
              <li>Paid ads on Google &amp; Meta</li>
              <li>12 pieces of social content per month</li>
              <li>Google Business Profile management</li>
              <li>One consolidated monthly report</li>
              <li>MOH-reviewed before every publish</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d2">
            <h3>Multi-Location &amp; Groups</h3>
            <div class="price">$5,500–$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For dental groups running multi-location campaigns and video content.</p>
            <ul class="pricing-features">
              <li>Everything in the Growth Bundle</li>
              <li>Multi-location ad accounts, geo-targeted per branch</li>
              <li>Video content production</li>
              <li>Dedicated strategist time</li>
              <li>Scales with ad spend &amp; content volume</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about dental marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions dental clinic owners actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your dental clinic ads follow MOH advertising rules?</summary>
          <div class="faq-answer"><p>Yes. Every ad, caption and content piece is reviewed against the MOH Private Hospitals and Medical Clinics Act advertising rules and the Singapore Dental Council ethical code before publication. That means no superlatives like "best dentist", no outcome guarantees, no before-and-after used as a results claim, and no patient testimonials phrased as treatment endorsements. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What does dental marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>Our Growth Bundle for dental clinics is $2,999 SGD/month, no lock-in. It covers paid ads on Google and Meta, 12 social posts a month, Google Business Profile management, and a single monthly report. Larger clinics or groups running multi-location campaigns and video content typically sit between $5,500 and $10,000/month depending on ad spend and content volume.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you help us get found by patients moving into a new neighbourhood?</summary>
          <div class="faq-answer"><p>Yes — this is most of what we do for dental clinics. We run Google Ads on neighbourhood-level searches like "dentist Tampines" or "wisdom tooth Bukit Timah", tighten the Google Business Profile so the clinic shows up in the local map pack, and build social content that gives new residents a reason to pick you over the closest chain clinic.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you handle CHAS, insurance panel and Sunday-hours messaging?</summary>
          <div class="faq-answer"><p>Yes. CHAS Blue, Orange and Green positioning, major insurance panel mentions (AIA, Great Eastern, Aetna and the local insurers), and Sunday or public holiday operating hours are all common targeting and creative angles we run for dental clients. We treat them as factual operational details, not promotional claims, which keeps them on the right side of MOH rules.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you reduce no-shows from new-patient bookings?</summary>
          <div class="faq-answer"><p>No-show rates drop when the patient is warm before they book. We do that with retargeting (so they see the clinic 3–5 times before they call), content that shows the actual clinic environment and team, and ad creative that filters out price-shoppers earlier in the funnel. We don't run the reminder system itself — that sits inside your PMS — but our work upstream is what makes those reminders convert.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How long before we see new patient enquiries?</summary>
          <div class="faq-answer"><p>Google Ads usually produces the first enquiries within the first 7–14 days, once conversion tracking is calibrated. Social content takes 4–8 weeks to build familiarity in the neighbourhood. Google Business Profile and local SEO movement shows up in months 2–4. We report enquiry volume monthly, not impressions.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore more</p>
        <h2>More for dental clinics</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/dental-website-design-singapore/" class="related-service-link">Dental Website Design</a>
          <a href="/clinic-marketing-singapore/" class="related-service-link">General Clinic Marketing</a>
          <a href="/aesthetics-clinic-marketing-singapore/" class="related-service-link">Aesthetics Clinic Marketing</a>
          <a href="/digital-marketing-agency-singapore/" class="related-service-link">Digital Marketing Agency</a>
      </div>
