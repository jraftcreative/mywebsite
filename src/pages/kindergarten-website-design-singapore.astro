---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Kindergarten Website Design Singapore",
    "description": "Professional website design for kindergartens, preschools, and childcare centres in Singapore. ECDA licensing display, enrolment forms, and programme pages — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Kindergarten Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Kindergarten Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page kindergarten website with programme overview, enrolment form, photo gallery, contact details, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Kindergarten Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with virtual tour, parent testimonials, blog, curriculum pages, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Kindergarten Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with parent portal, multi-branch support, online fee payment, ECDA compliance display, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a kindergarten website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional kindergarten website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages add parent portals, virtual tours, and online fee payment." } },
      { "@type": "Question", "name": "Can you display our ECDA licence on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We prominently display your ECDA licence number, SPARK certification status, and any MOE registration details on your website. This builds trust with parents who check licensing before shortlisting a preschool for their child." } },
      { "@type": "Question", "name": "Do you build websites for childcare centres and enrichment schools too?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We build websites for kindergartens, childcare centres, student care facilities, and enrichment schools across Singapore. Each site is tailored to your programmes, age groups, and curriculum approach — whether Montessori, Reggio Emilia, or MOE-aligned." } },
      { "@type": "Question", "name": "Can parents submit enrolment forms through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build online enrolment and waitlist forms directly into your website. Parents can submit their child's details, select preferred programmes, and receive automated confirmation emails — reducing the admin work your staff handles manually." } },
      { "@type": "Question", "name": "How long does it take to build a kindergarten website?", "acceptedAnswer": { "@type": "Answer", "text": "Most kindergarten websites go live within 2-3 weeks. A simple 5-page site can be ready in 2 weeks, while larger projects with parent portals or multi-branch setups may take 3-4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Kindergarten Website Design Singapore", "item": "https://jraftcreative.com/kindergarten-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Kindergarten Website Design Singapore — Preschool Web Design | Jraft Creative"
  description="Professional website design for kindergartens, preschools, and childcare centres in Singapore. ECDA licensing display, enrolment forms, and programme pages — from S$2,500."
  canonical="https://jraftcreative.com/kindergarten-website-design-singapore/"
  ogTitle="Kindergarten Website Design Singapore — Jraft Creative"
  ogDescription="Website design for kindergartens and preschools in Singapore. Enrolment forms, programme pages, parent testimonials — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="kindergarten website design singapore, preschool website design singapore, childcare centre website, preschool web design, kindergarten web design, nursery website singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Kindergarten Website Design"
  heroTitle='Website Design for <span class="highlight">Kindergartens &amp; Preschools</span>'
  heroSubtitle="Parents shortlist kindergartens online before booking a visit. We build warm, trust-building websites for preschools and childcare centres — with ECDA licence display, online enrolment forms, and programme pages that help families choose your school."
  heroImage="/images/service-kindergarten.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my kindergarten in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Kindergarten Online"
  ctaDescription="Book a free consultation and tell us about your preschool. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20kindergarten%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why kindergartens and preschools need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Choosing Kindergartens Based on What They Find Online</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore parents are thorough researchers. Before they even call your front office, they've already Googled "preschool near me," compared programme pages across three or four kindergartens, and checked whether your ECDA licence is current. If your school doesn't appear on Google — or your website looks outdated and incomplete — parents move on to the next option on their list. First impressions happen on a screen, not at your open house.</p>
        <p>A Facebook page or listing on KiasuParents isn't a substitute for a dedicated website. Parents want structured information they can review at their own pace: your curriculum approach, fee schedule, teacher-to-child ratios, operating hours, and photos of the actual classroom environment. They want to submit an enrolment inquiry at 11pm without waiting for your admin team to respond to a WhatsApp message the next morning.</p>
        <p>Competition among early childhood centres in Singapore is intense. With over 1,800 ECDA-licensed preschools across the island, parents have more choices than ever. Whether you operate a single kindergarten in Tampines or a multi-branch childcare chain, your website is the deciding factor for parents who are comparing schools side by side — and it needs to make them confident enough to book that first visit.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Kindergarten website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Kindergartens &amp; Preschools</h2>
      </div>
      <div class="section-content reveal">
        <p>Every kindergarten website we deliver is purpose-built for the early childhood education sector. We go beyond a generic template — your site will feature programme breakdowns by age group, ECDA licensing details, parent testimonials, and local SEO so families searching "preschool near me" find your centre first.</p>
        <p>We understand that preschools need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to dominate location-based preschool searches, <a href="/services/social-media/">social media marketing</a> to share classroom moments and build parent communities, and <a href="/services/paid-ads/">paid ads management</a> to drive enrolment inquiries from Google and social platforms.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Programme &amp; Curriculum Pages</h3>
            <p>Dedicated pages for each age group — playgroup, nursery, kindergarten 1, and kindergarten 2. We lay out your curriculum approach, daily schedules, learning outcomes, and enrichment activities so parents understand exactly what their child will experience at your centre.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Enrolment &amp; Waitlist Forms</h3>
            <p>Let parents submit enrolment inquiries and join your waitlist directly from your website. Custom forms capture the child's age, preferred start date, and programme selection — with automated confirmation emails that reduce manual follow-up for your admin team.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>ECDA Licence &amp; Accreditation Display</h3>
            <p>We prominently showcase your ECDA licence number, SPARK certification status, and any MOE kindergarten registration details. Parents actively check for these credentials when shortlisting centres, and displaying them builds immediate trust and credibility.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Parent Testimonials &amp; Gallery</h3>
            <p>Curated testimonial sections and photo galleries that showcase your learning environment, outdoor play areas, and classroom activities. Real parent reviews and authentic visuals give prospective families the confidence to schedule a school tour.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for kindergarten website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Kindergarten Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for education businesses across Singapore. We know what makes parents trust a preschool online — and we design every element of your website to convert browsing families into scheduled school visits and submitted enrolment forms.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Early Childhood Sector Knowledge</h3>
            <p>We understand the preschool landscape in Singapore — ECDA regulations, SPARK accreditation, subsidy eligibility displays, and the parent decision-making journey. Your website will be built around how kindergartens actually operate and what parents need to see.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most kindergarten websites go live within 2 weeks of kickoff. We know timing matters when you're preparing for the new academic year or opening a new branch.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Every site is designed for parents browsing on their phones. Fast load times, thumb-friendly navigation, and tap-to-call buttons so families can reach your centre instantly while on the go.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on running your kindergarten and nurturing your students.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Kindergarten website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Kindergarten Website Pricing</p>
        <h2>Website Packages for Kindergartens &amp; Preschools</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For single-centre kindergartens and new preschools.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme overview pages</li>
              <li>Online enrolment form</li>
              <li>Photo gallery</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For kindergartens ready to grow enrolment.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Detailed curriculum pages</li>
              <li>Parent testimonials section</li>
              <li>Blog / parenting tips section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-branch preschool groups and chains.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-branch support</li>
              <li>Parent portal integration</li>
              <li>Online fee payment setup</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about kindergarten website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Kindergarten Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a kindergarten website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional kindergarten website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages add parent portals, virtual tours, and online fee payment.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you display our ECDA licence on the website?</summary>
          <div class="faq-answer"><p>Yes. We prominently display your ECDA licence number, SPARK certification status, and any MOE registration details on your website. This builds trust with parents who check licensing before shortlisting a preschool for their child.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build websites for childcare centres and enrichment schools too?</summary>
          <div class="faq-answer"><p>Absolutely. We build websites for kindergartens, childcare centres, student care facilities, and enrichment schools across Singapore. Each site is tailored to your programmes, age groups, and curriculum approach — whether Montessori, Reggio Emilia, or MOE-aligned.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can parents submit enrolment forms through the website?</summary>
          <div class="faq-answer"><p>Yes. We build online enrolment and waitlist forms directly into your website. Parents can submit their child's details, select preferred programmes, and receive automated confirmation emails — reducing the admin work your staff handles manually.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a kindergarten website?</summary>
          <div class="faq-answer"><p>Most kindergarten websites go live within 2-3 weeks. A simple 5-page site can be ready in 2 weeks, while larger projects with parent portals or multi-branch setups may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
