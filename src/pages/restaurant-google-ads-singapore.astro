---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Restaurant Google Ads Singapore",
    "description": "Google Ads management for restaurants in Singapore. Local search ads, delivery promotions, and reservation-driving campaigns — from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Restaurant Google Ads Management",
    "offers": [
      { "@type": "Offer", "name": "Starter Ads", "price": "1000", "priceCurrency": "SGD", "description": "Google Ads setup and management for single-location restaurants with keyword research and monthly reporting" },
      { "@type": "Offer", "name": "Growth Ads", "price": "2500", "priceCurrency": "SGD", "description": "Multi-campaign Google Ads management with remarketing, delivery ads, and conversion tracking" },
      { "@type": "Offer", "name": "Scale Ads", "price": "5000", "priceCurrency": "SGD", "description": "Full-scale Google Ads management for multi-outlet restaurants with dedicated strategist and advanced analytics" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much do Google Ads cost for a restaurant in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Management fees start at $1,000 SGD per month, plus your ad spend budget. Most restaurants in Singapore see good results with a total monthly investment of $2,000–$5,000 including ad spend. We recommend starting with a minimum ad budget of $1,000/month to gather enough data for optimisation." } },
      { "@type": "Question", "name": "How quickly will I see results from Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads can start driving traffic within 24–48 hours of launching. However, meaningful ROI data typically comes after 2–4 weeks as we optimise keywords, bids, and targeting. Most restaurant clients see measurable increases in reservations and orders within the first month." } },
      { "@type": "Question", "name": "What targeting options are available for restaurant Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "We use location targeting to reach diners within a specific radius of your restaurant, keyword targeting for searches like 'restaurant near me' or cuisine-specific terms, time-of-day scheduling to show ads during meal periods, and audience targeting for people actively searching for dining options in Singapore." } },
      { "@type": "Question", "name": "Can Google Ads promote my restaurant's delivery service?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We run dedicated delivery promotion campaigns targeting searches like 'food delivery near me' and 'order [cuisine] online Singapore.' We can also run ads that drive orders directly to your website rather than third-party platforms, helping you keep more margin on each order." } },
      { "@type": "Question", "name": "What Google Ads budget do you recommend for restaurants?", "acceptedAnswer": { "@type": "Answer", "text": "For a single-location restaurant in Singapore, we recommend a minimum ad spend of $1,000–$2,000/month. Multi-outlet or delivery-focused restaurants typically invest $3,000–$5,000+/month. We help you allocate budget across search, display, and local campaigns based on your goals." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Restaurant Google Ads Singapore", "item": "https://jraftcreative.com/restaurant-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Restaurant Google Ads Singapore — PPC for Restaurants | Jraft Creative"
  description="Google Ads management for restaurants in Singapore. Local search ads, delivery promotions, and reservation-driving campaigns — from S$1,000/month."
  canonical="https://jraftcreative.com/restaurant-google-ads-singapore/"
  ogTitle="Restaurant Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for restaurants in Singapore. Local search campaigns, delivery promotions, and reservation ads — from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-paid-ads.jpg"
  keywords="restaurant google ads singapore, google ads for restaurants, restaurant ppc singapore, restaurant advertising singapore, restaurant near me ads, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Restaurant Google Ads"
  heroTitle='Google Ads for <span class="highlight">Restaurants in Singapore</span>'
  heroSubtitle="Stop waiting for walk-ins. We build Google Ads campaigns that put your restaurant at the top of search results when hungry diners in Singapore are looking for exactly what you serve."
  heroImage="/images/service-restaurant.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/paid-ads/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my restaurant in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Fill Your Tables with Google Ads"
  ctaDescription="Book a free consultation and tell us about your restaurant. We'll get back to you within 24 hours with a tailored Google Ads strategy."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20restaurant%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why restaurants need Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Diners Are Searching — Is Your Restaurant Showing Up?</h2>
      </div>
      <div class="section-content reveal">
        <p>Every day, thousands of people in Singapore search Google for "restaurant near me," "best Italian in Tanjong Pagar," or "dinner delivery Orchard Road." If your restaurant isn't appearing in those search results, you're handing customers directly to your competitors down the street.</p>
        <p>Organic SEO takes months to build. Food delivery platforms take a 30% commission on every order. Google Ads lets you jump to the top of search results immediately — and drive diners directly to your website or reservation page where you keep the full margin.</p>
        <p>But running Google Ads without a proper strategy burns through budget fast. Generic keywords, poor ad copy, and no conversion tracking mean wasted spend. Singapore's dining scene is crowded, and you need campaigns built specifically for how local diners search, browse, and book.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" aria-label="Restaurant Google Ads services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Google Ads Services for Restaurants</h2>
      </div>
      <div class="section-content reveal">
        <p>We build Google Ads campaigns tailored to the restaurant industry in Singapore. From local search ads targeting "restaurant near me" queries to delivery promotion campaigns, every dollar of your ad spend is optimised to bring diners through your door or orders to your kitchen.</p>
        <p>Our restaurant ad campaigns work best alongside a strong online presence. Pair your ads with <a href="/services/website-development/">a high-converting restaurant website</a>, <a href="/services/seo-performance/">local SEO</a> to dominate organic results, and <a href="/services/social-media/">social media marketing</a> to keep your brand top of mind between meals.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Local Search Ads</h3>
            <p>Appear at the top when diners search "restaurant near me" or cuisine-specific terms in your neighbourhood. Geo-targeted campaigns reach hungry customers within walking or delivery distance.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Reservation &amp; Booking Ads</h3>
            <p>Drive direct reservations through Google Ads with call extensions, booking links, and landing pages designed to convert searchers into confirmed diners at your restaurant.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>ROI Tracking &amp; Analytics</h3>
            <p>Full conversion tracking so you know exactly how many reservations, calls, and orders each campaign generates. Monthly reports with clear cost-per-acquisition data and optimisation recommendations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Delivery Promotion Campaigns</h3>
            <p>Compete with delivery platforms by running ads that send orders directly to your website. Target "food delivery" searches and reduce your reliance on GrabFood and Deliveroo commissions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for restaurant Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Restaurant Google Ads</h2>
      </div>
      <div class="section-content reveal">
        <p>We specialise in running Google Ads for restaurants and F&B businesses in Singapore. We know how diners search, when they search, and what makes them click — and we build every campaign around that behaviour.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Restaurant Industry Focus</h3>
            <p>We understand the restaurant business — seasonal menus, lunch vs dinner traffic, delivery vs dine-in, and how Singapore diners decide where to eat. Your campaigns reflect that knowledge.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Reporting</h3>
            <p>Monthly reports that show exactly what you're getting for your ad spend. Cost per reservation, cost per order, and clear recommendations — no vanity metrics or confusing dashboards.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-In Contracts</h3>
            <p>We earn your business every month. No 12-month lock-ins — if we're not delivering results, you're free to walk. Most clients stay because the ROI speaks for itself.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full-Funnel Strategy</h3>
            <p>Google Ads is just one piece. We integrate your campaigns with SEO, social media, and your website to create a complete digital marketing system that keeps tables full.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Restaurant Google Ads pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Google Ads Pricing</p>
        <h2>Google Ads Packages for Restaurants</h2>
        <p>Monthly management fee. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD / mo</span></div>
            <p class="pricing-desc">For single-location restaurants getting started with PPC.</p>
            <ul class="pricing-features">
              <li>Google Search Ads setup</li>
              <li>Keyword research &amp; targeting</li>
              <li>Ad copywriting &amp; extensions</li>
              <li>Location-based targeting</li>
              <li>Monthly performance report</li>
              <li>Conversion tracking setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD / mo</span></div>
            <p class="pricing-desc">For restaurants scaling reservations and delivery orders.</p>
            <ul class="pricing-features">
              <li>Search + Display campaigns</li>
              <li>Remarketing to past visitors</li>
              <li>Delivery promotion campaigns</li>
              <li>A/B testing &amp; optimisation</li>
              <li>Google Business Profile ads</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD / mo</span></div>
            <p class="pricing-desc">For multi-outlet restaurants and high-volume delivery brands.</p>
            <ul class="pricing-features">
              <li>Multi-location campaigns</li>
              <li>Performance Max campaigns</li>
              <li>Dedicated account strategist</li>
              <li>Advanced audience targeting</li>
              <li>Competitor analysis &amp; bidding</li>
              <li>Weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/paid-ads/" class="inline-link">paid ads management</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for restaurants in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Restaurant Google Ads Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much do Google Ads cost for a restaurant in Singapore?</summary>
          <div class="faq-answer"><p>Management fees start at $1,000 SGD per month, plus your ad spend budget. Most restaurants in Singapore see good results with a total monthly investment of $2,000–$5,000 including ad spend. We recommend starting with a minimum ad budget of $1,000/month to gather enough data for optimisation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How quickly will I see results from Google Ads?</summary>
          <div class="faq-answer"><p>Google Ads can start driving traffic within 24–48 hours of launching. However, meaningful ROI data typically comes after 2–4 weeks as we optimise keywords, bids, and targeting. Most restaurant clients see measurable increases in reservations and orders within the first month.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What targeting options are available for restaurant Google Ads?</summary>
          <div class="faq-answer"><p>We use location targeting to reach diners within a specific radius of your restaurant, keyword targeting for searches like "restaurant near me" or cuisine-specific terms, time-of-day scheduling to show ads during meal periods, and audience targeting for people actively searching for dining options in Singapore.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can Google Ads promote my restaurant's delivery service?</summary>
          <div class="faq-answer"><p>Yes. We run dedicated delivery promotion campaigns targeting searches like "food delivery near me" and "order [cuisine] online Singapore." We can also run ads that drive orders directly to your website rather than third-party platforms, helping you keep more margin on each order.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What Google Ads budget do you recommend for restaurants?</summary>
          <div class="faq-answer"><p>For a single-location restaurant in Singapore, we recommend a minimum ad spend of $1,000–$2,000/month. Multi-outlet or delivery-focused restaurants typically invest $3,000–$5,000+/month. We help you allocate budget across search, display, and local campaigns based on your goals.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>