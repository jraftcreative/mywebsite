---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Small Business Website Design",
    "description": "Professional websites for small businesses in Singapore — fast, mobile-responsive, and SEO-ready. Fixed-price packages from S$2,500 with no monthly lock-ins.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Small Business Web Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with contact form, basic SEO, and 2-week delivery for small businesses" },
      { "@type": "Offer", "name": "Business Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page custom website with CMS, blog, advanced SEO, and Google Analytics for growing small businesses" },
      { "@type": "Offer", "name": "Premium Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with unlimited pages, ecommerce, third-party integrations, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a small business website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional small business website in Singapore typically costs between $2,500 and $10,000+ SGD depending on the number of pages and features. Our Starter package at $2,500 includes a 5-page responsive website with a contact form and basic SEO — everything a new small business needs to get online." } },
      { "@type": "Question", "name": "Do I really need a website as a small business?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Over 80% of Singapore consumers research businesses online before making a purchase. Without a website, you're invisible to potential customers searching on Google. A professional website builds credibility, captures leads 24/7, and gives you a platform you fully own — unlike social media pages that can change their rules overnight." } },
      { "@type": "Question", "name": "Can I update the website myself after launch?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Our Business and Premium packages include a content management system (CMS) so you can update text, images, and blog posts without any coding knowledge. We also provide training and documentation to get you comfortable making changes on your own." } },
      { "@type": "Question", "name": "How long does it take to build a small business website?", "acceptedAnswer": { "@type": "Answer", "text": "Most small business websites are ready within 2 weeks of kickoff. More complex sites with custom features, ecommerce, or extensive content may take 3–4 weeks. We provide a clear timeline during the discovery phase so you know exactly when to expect your site to go live." } },
      { "@type": "Question", "name": "Do you offer website maintenance after launch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer optional maintenance plans that cover security updates, performance monitoring, content updates, and technical support. However, there's no obligation — you own your website outright and can manage it yourself or bring in any developer you choose." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Small Business Website Singapore", "item": "https://jraftcreative.com/small-business-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Small Business Website Singapore — Affordable Web Design | Jraft Creative"
  description="Professional websites for small businesses in Singapore — fast, mobile-responsive, and SEO-ready. Fixed-price packages from S$2,500. No monthly lock-ins."
  canonical="https://jraftcreative.com/small-business-website-singapore/"
  ogTitle="Small Business Website Singapore — Jraft Creative"
  ogDescription="Professional websites for small businesses in Singapore. Mobile-responsive, SEO-ready, fast-loading sites from $2,500 SGD. No lock-in contracts."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="small business website singapore, small business web design singapore, affordable website singapore, cheap website singapore, business website singapore, sme website singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Small Business Websites"
  heroTitle='Professional <span class="highlight">Websites for Small Businesses</span> in Singapore'
  heroSubtitle="Stop losing customers to a missing or outdated website. Get a fast, mobile-responsive, SEO-ready site built specifically for Singapore small businesses — from S$2,500 with no monthly lock-ins."
  heroImage="/images/service-web-dev.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my small business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Business Online"
  ctaDescription="Tell us about your small business and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20small%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why small businesses need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Business Deserves More Than a Template Website</h2>
      </div>
      <div class="section-content reveal">
        <p>Too many small businesses in Singapore settle for generic Wix or Squarespace templates that all look the same. These cookie-cutter sites load slowly, lack proper SEO structure, and fail to stand out in a market where customers judge credibility in seconds.</p>
        <p>On the other end, some small business owners overpay agencies for enterprise-level features they don't need — bloated CMS platforms, unnecessary plugins, and ongoing retainers that eat into tight margins. You shouldn't have to choose between a cheap template and a $20,000 build.</p>
        <p>What you need is a clean, professional website that represents your brand, loads fast on mobile, ranks on Google, and turns visitors into enquiries — without breaking the budget.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT YOU GET ========== -->
  <section class="section" id="sub-services" aria-label="What's included in your small business website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What You Get</p>
        <h2>Everything Your Small Business Website Needs</h2>
      </div>
      <div class="section-content reveal">
        <p>Every website we build for small businesses in Singapore is designed with a clear purpose — generate leads, build trust, and give your brand a professional online presence. No filler features, no unnecessary complexity.</p>
        <p>Small businesses in Singapore get the best results when they combine a great website with <a href="/services/seo-performance/">SEO services</a> for organic traffic, <a href="/services/social-media/">social media marketing</a> for brand awareness, and <a href="/services/paid-ads/">paid advertising</a> for immediate leads. See our <a href="/digital-marketing-agency-singapore/">full-service digital marketing packages</a> for bundled options.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-responsive-web.webp">
          <div class="service-detail-card__content">
            <h3>Custom Design</h3>
            <p>A unique website that reflects your brand identity — not a template shared with hundreds of other businesses. Tailored layouts, colours, and typography that make the right first impression.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-ui-ux.webp">
          <div class="service-detail-card__content">
            <h3>Mobile-Responsive</h3>
            <p>Over 70% of web traffic in Singapore comes from mobile devices. Your site will look and work perfectly on every screen size — smartphones, tablets, and desktops.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>SEO Fundamentals</h3>
            <p>Proper heading structure, meta tags, image optimisation, schema markup, and a crawlable site architecture — so Google can find and rank your business from day one.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Speed Optimisation</h3>
            <p>Lightweight, fast-loading pages built to pass Core Web Vitals. No bloated page builders or unnecessary scripts slowing down your site and driving away visitors.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-analytics-reporting.webp">
          <div class="service-detail-card__content">
            <h3>Contact &amp; Lead Capture</h3>
            <p>Integrated contact forms, click-to-call buttons, and WhatsApp links so potential customers can reach you instantly — turning website visitors into real enquiries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY SMALL BUSINESSES CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why small businesses choose Jraft Creative">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Small Businesses Choose Us</p>
        <h2>Built for Small Businesses, Not Enterprise Budgets</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with small business owners across Singapore every day. We understand tight budgets, fast timelines, and the need for a website that just works — without the agency overhead.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Fixed-Price Packages</h3>
            <p>No hourly billing, no scope creep surprises. You get a clear quote upfront and that's what you pay — nothing more.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>You own your website and all its code from day one. No monthly hosting fees that keep you tied down — just a clean handover of everything.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>2-Week Delivery</h3>
            <p>Most small business websites go live within 2 weeks of kickoff. We move fast without cutting corners on quality or testing.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Singapore-Focused</h3>
            <p>Local SEO baked in, SGD pricing throughout, PDPA-compliant forms, and design that resonates with Singapore audiences and search behaviour.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Small business website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Small Business Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new small businesses getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Responsive design</li>
              <li>Contact form</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing businesses that need more.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Custom design &amp; branding</li>
              <li>CMS / blog integration</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Analytics setup</li>
              <li>Speed optimisation</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For businesses with advanced needs.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features</li>
              <li>Ecommerce capability</li>
              <li>Third-party integrations</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about small business websites in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Small Business Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a small business website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional small business website in Singapore typically costs between $2,500 and $10,000+ SGD depending on the number of pages and features. Our Starter package at $2,500 includes a 5-page responsive website with a contact form and basic SEO — everything a new small business needs to get online.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do I really need a website as a small business?</summary>
          <div class="faq-answer"><p>Yes. Over 80% of Singapore consumers research businesses online before making a purchase. Without a website, you're invisible to potential customers searching on Google. A professional website builds credibility, captures leads 24/7, and gives you a platform you fully own — unlike social media pages that can change their rules overnight.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can I update the website myself after launch?</summary>
          <div class="faq-answer"><p>Absolutely. Our Business and Premium packages include a content management system (CMS) so you can update text, images, and blog posts without any coding knowledge. We also provide training and documentation to get you comfortable making changes on your own.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How long does it take to build a small business website?</summary>
          <div class="faq-answer"><p>Most small business websites are ready within 2 weeks of kickoff. More complex sites with custom features, ecommerce, or extensive content may take 3–4 weeks. We provide a clear timeline during the discovery phase so you know exactly when to expect your site to go live.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you offer website maintenance after launch?</summary>
          <div class="faq-answer"><p>Yes. We offer optional maintenance plans that cover security updates, performance monitoring, content updates, and technical support. However, there's no obligation — you own your website outright and can manage it yourself or bring in any developer you choose.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
