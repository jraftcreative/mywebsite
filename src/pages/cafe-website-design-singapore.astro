---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Cafe Website Design Singapore",
    "description": "Cafe web design and development agency in Singapore. Menu-led design, online reservation and ordering integration, IG-grid-matched photography, mobile-first conversion design, multi-outlet support.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Cafe Website Design"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What should a cafe website include in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A cafe website in Singapore should include: a live menu (not a PDF), an online reservation or ordering flow (Chope, SevenRooms, Oddle, or your own), location and hours per outlet, signature drink and interior photography that matches the IG grid, Google Maps embed for each outlet, FoodEstablishment and LocalBusiness schema markup, gift card flow, and mobile-first conversion design. The goal is converting the cafe-goer who already decided you are the weekend brunch shortlist." } },
      { "@type": "Question", "name": "Do you integrate reservation and ordering platforms?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We integrate Chope, SevenRooms, OpenTable, Eatigo (reservations), Oddle and your own POS or ordering system (online ordering), plus gift card platforms. The integration choice depends on your business model — full-service brunch cafes tend toward Chope reservations, specialty coffee with takeaway focus toward Oddle or direct ordering, and multi-outlet cafe groups toward custom flows." } },
      { "@type": "Question", "name": "How long does a cafe website build take?", "acceptedAnswer": { "@type": "Answer", "text": "Most single-outlet cafe websites build in 4-6 weeks: 1 week discovery and content gather, 1 week wireframe and design direction, 2 weeks build, 1 week QA and launch. Multi-outlet cafe builds run 8-12 weeks. We work in fortnightly review cycles so you see and steer the design as it builds, rather than getting a final reveal at the end." } },
      { "@type": "Question", "name": "Do you handle multi-outlet cafe website structure?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Multi-outlet cafe sites get a dedicated page per outlet (each with its own catchment SEO, hours, photos, GBP embed, and reservation or ordering flow) plus a clean parent navigation that lets cafe-goers filter by area, concept, or service. Each outlet page is treated as a landing page in its own right." } },
      { "@type": "Question", "name": "Why does the cafe website need to match the IG grid?", "acceptedAnswer": { "@type": "Answer", "text": "Cafe-goers discover on IG and then click through to the site to confirm. If the website's photography, palette, and tone do not match the IG grid that earned the click, the bounce rate spikes — the visitor assumes they landed on the wrong cafe. We treat the website as the second touchpoint in a unified visual system, not a separate brand expression." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Cafe Website Design Singapore", "item": "https://jraftcreative.com/cafe-website-design-singapore/" }
    ]
  }
];
---

<style is:global>
  .animated-bg__grid { display: none; }
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35); color: var(--text); font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6); color: var(--accent); transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }
  .service-cta-section { background: var(--bg-alt) !important; }
  .fnb-funnel { list-style: none; padding: 0; margin: 56px 0 0; display: grid; grid-template-columns: repeat(5, 1fr); gap: 48px; }
  .funnel-stage { position: relative; text-align: center; padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28); border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; }
  .funnel-stage:hover { transform: translateY(-4px); border-color: rgba(73, 184, 137, 0.55); box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3); }
  .funnel-stage h3 { font-size: 1.05rem; font-weight: 600; color: var(--accent); margin: 0 0 8px 0; letter-spacing: -0.01em; }
  .funnel-stage p { font-size: 0.82rem; color: var(--text); line-height: 1.5; margin: 0; }
  .funnel-stage:not(:last-child)::after { content: '→'; position: absolute; right: -34px; top: 50%; transform: translateY(-50%); color: var(--accent); font-size: 1.6rem; font-weight: 500; z-index: 2; line-height: 1; opacity: 0.7; }
  .funnel-stage--accent { border-color: rgba(73, 184, 137, 0.7); box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.35); }
  @media (max-width: 900px) { .fnb-funnel { grid-template-columns: repeat(2, 1fr); gap: 32px; } .funnel-stage:nth-child(2n)::after, .funnel-stage:last-child::after { display: none; } .funnel-stage:nth-child(2n-1)::after { right: -22px; } }
  @media (max-width: 600px) { .fnb-funnel { grid-template-columns: 1fr; gap: 20px; } .funnel-stage::after { display: none; } }
</style>

<ServiceLayout
  title="Cafe Website Design Singapore | Jraft Creative"
  description="Cafe web design agency in Singapore. Menu-led design, Chope/Oddle integration, reservations, IG-grid-matched photography, mobile-first conversion design."
  canonical="https://jraftcreative.com/cafe-website-design-singapore/"
  ogTitle="Cafe Website Design Singapore | Jraft Creative"
  ogDescription="Cafe web design in Singapore. Menu, Chope/Oddle integration, reservations, mobile-first design, multi-outlet support."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="cafe website design singapore, coffee shop website design, cafe web development singapore, brunch cafe website, oddle cafe integration, chope cafe, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Cafe Website Design Singapore"
  heroTitle='Web Design Agency for <span class="highlight">Cafes &amp; Coffee Shops in Singapore</span>'
  heroSubtitle="Your cafe deserves more than a Squarespace template that does not match the IG grid. We build cafe websites that convert the brunch-goer who already decided yours is the next weekend stop — menu-led, reservation-ready, IG-grid-matched, and mobile-first."
  heroImage="/images/service-cafe.webp"
  heroImageAlt="Singapore cafe website mockup — cafe web design agency"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20cafe%20website%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a cafe website in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle='Let Us <span class="highlight">Build</span> Your <span class="highlight">Cafe Website</span>'
  ctaDescription="Book a free consultation and tell us about your cafe — outlets, current site, reservation and ordering flow, edit needs. We'll respond within 24 hours with a tailored website plan and scope."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20cafe%20website%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why cafes need a real website in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your <span class="highlight">Cafe Website</span> Is the <span class="highlight">Second Touchpoint</span> — and Most Are <span class="highlight">Off-Brand</span></h2>
      </div>
      <div class="section-content reveal">
        <p>A brunch-goer sees your Reel, clicks through to your website to check the menu and book, and lands on a template Squarespace that does not match the IG grid they just fell in love with. Bounce. The website is the second touchpoint in a unified visual system — and most cafe sites break the brand promise the IG just made.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Off-Brand Template Sites</h3>
            <p>Generic Squarespace or Wix template that does not match the IG aesthetic that earned the click. The cafe-goer assumes they landed on the wrong cafe and bounces — losing the conversion the social work just paid for.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>PDF Menus and Buried Reservations</h3>
            <p>Blurry PDF menu nobody can read on mobile. Reservation link hidden in the footer. Gift card flow nowhere. Every extra tap costs 10-20% of intent — and most cafe sites add five too many between landing and booking.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Multi-Outlet Confusion</h3>
            <p>Cafe chains bury outlet info on a generic "Locations" page. Each outlet should be a landing page in its own right — own catchment SEO, hours, photos, GBP embed, and reservation flow. Most sites flatten that to a list of addresses.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Cafe website design services we deliver">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Cafe Website Workstreams</span> Every Operator <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build cafe websites as a six-workstream system — IG-grid-matched design, menu-led layout, reservation flow, online ordering and gift card integration, multi-outlet structure, and mobile-first conversion design. Wired to every measurable cafe-goer action.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>IG-Grid-Matched Design</h3>
            <p>Typography, palette, photography direction, and tone of voice carried directly from your IG grid into the website — so the cafe-goer who clicked from a Reel lands on a site that confirms the brand promise.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Live Menu (Not PDF)</h3>
            <p>Live HTML menu, filterable by section (coffee, brunch, dietary), photography-led layouts, signature-drink hero treatment, and SEO-friendly menu URLs that rank for "[drink] [neighbourhood]" or "[dish] [area]" searches.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-landing-page.webp');">
          <div class="service-detail-card__content">
            <h3>Reservation Flow</h3>
            <p>Chope, SevenRooms, OpenTable, Eatigo, WhatsApp, or custom — wired into above-the-fold CTAs on every outlet page. Date and party-size pickers, capacity rules, confirmation flow — built mobile-first.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-ecommerce.webp');">
          <div class="service-detail-card__content">
            <h3>Ordering &amp; Gift Card Integration</h3>
            <p>Oddle online ordering, your own POS handoff, takeaway scheduling, and gift card flow. Treated as first-class CTAs — not buried links — for the cafe-goer who wants to pre-order or send a friend a gift card.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Multi-Outlet Structure</h3>
            <p>One dedicated page per outlet, each with its own SEO meta, catchment content, hours, photos, GBP embed, and reservation flow. Clean parent navigation lets cafe-goers filter by area, concept, or service.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile-First Conversion Design</h3>
            <p>Built mobile-first because most cafe traffic comes from a brunch-goer on a phone deciding in the next twenty minutes. Core Web Vitals green, sub-2s load, and CTAs sized for thumb-tap conversion.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for cafe website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Cafe Websites</span> Built for <span class="highlight">Walk-Ins</span>, Not <span class="highlight">Awards</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most web agencies pitching cafes build pretty sites that win design awards and lose cafe-goers. We build the inverse — sites engineered to convert IG intent into bookings, walk-ins, and gift card purchases, with measurable handoffs to Chope, Oddle, and your POS. Design quality stays high because it serves the conversion job, not the other way around.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>IG-to-Site Brand Continuity</h3>
            <p>We treat the website as the second touchpoint in a unified IG-and-site visual system. The cafe-goer who clicked from a Reel lands on a site that confirms what the IG promised — not contradicts it.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>You Own the Site and Stack</h3>
            <p>Your domain, your hosting, your CMS, your design files — all in your name from day one. No agency lock-in. If you ever leave, you take the full stack and source files with you.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>SEO and Speed at Launch</h3>
            <p>Core Web Vitals green at handover. FoodEstablishment schema live. Per-outlet pages already wired for catchment SEO. The site ranks from week one rather than needing a separate SEO project six months in.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CAFE BUYER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Cafe Buyer Funnel — and where the website shows up">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Buyer Funnel</p>
        <h2>Where the <span class="highlight">Website</span> Shows Up in the <span class="highlight">Cafe-Goer Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Singapore cafe-goers move through five stages. The website is the conversion point at Choose and First Visit — where IG-led discovery has to translate into a booking, an order, a walk-in, or a gift card purchase.</p>
      </div>
      <ol class="fnb-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>IG Reels, TikTok cafe-hopping (Social-led)</p>
        </li>
        <li class="funnel-stage funnel-stage--accent">
          <h3>Choose</h3>
          <p>Site is the menu and the verdict (Web-led)</p>
        </li>
        <li class="funnel-stage funnel-stage--accent">
          <h3>First Visit</h3>
          <p>Reservation, gift card, direction request convert (Web-led)</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Email capture, loyalty, repeat reservation flow</p>
        </li>
        <li class="funnel-stage">
          <h3>Advocate</h3>
          <p>Review prompts, share buttons, UGC hooks</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about cafe website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Cafe Website Design</span> — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>What should a cafe website include in Singapore?</summary>
          <div class="faq-answer"><p>A cafe website in Singapore should include: a live menu (not a PDF), an online reservation or ordering flow (Chope, SevenRooms, Oddle, or your own), location and hours per outlet, signature drink and interior photography that matches the IG grid, Google Maps embed for each outlet, FoodEstablishment and LocalBusiness schema markup, gift card flow, and mobile-first conversion design. The goal is converting the cafe-goer who already decided you are the weekend brunch shortlist.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you integrate reservation and ordering platforms?</summary>
          <div class="faq-answer"><p>Yes. We integrate Chope, SevenRooms, OpenTable, Eatigo (reservations), Oddle and your own POS or ordering system (online ordering), plus gift card platforms. The integration choice depends on your business model — full-service brunch cafes tend toward Chope reservations, specialty coffee with takeaway focus toward Oddle or direct ordering, and multi-outlet cafe groups toward custom flows.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How long does a cafe website build take?</summary>
          <div class="faq-answer"><p>Most single-outlet cafe websites build in 4-6 weeks: 1 week discovery and content gather, 1 week wireframe and design direction, 2 weeks build, 1 week QA and launch. Multi-outlet cafe builds run 8-12 weeks. We work in fortnightly review cycles so you see and steer the design as it builds.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you handle multi-outlet cafe website structure?</summary>
          <div class="faq-answer"><p>Yes. Multi-outlet cafe sites get a dedicated page per outlet (each with its own catchment SEO, hours, photos, GBP embed, and reservation or ordering flow) plus a clean parent navigation that lets cafe-goers filter by area, concept, or service. Each outlet page is treated as a landing page in its own right.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Why does the cafe website need to match the IG grid?</summary>
          <div class="faq-answer"><p>Cafe-goers discover on IG and then click through to the site to confirm. If the website's photography, palette, and tone do not match the IG grid that earned the click, the bounce rate spikes — the visitor assumes they landed on the wrong cafe. We treat the website as the second touchpoint in a unified visual system, not a separate brand expression.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related cafe services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More <span class="highlight">Cafe</span> Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/cafe-marketing-singapore/" class="related-service-link">Cafe Marketing</a>
          <a href="/cafe-seo-singapore/" class="related-service-link">Cafe SEO</a>
          <a href="/cafe-social-media-singapore/" class="related-service-link">Cafe Social Media</a>
          <a href="/fnb-marketing-singapore/" class="related-service-link">F&amp;B Marketing</a>
          <a href="/fnb-branding-singapore/" class="related-service-link">F&amp;B Branding</a>
          <a href="/fnb-website-design-singapore/" class="related-service-link">F&amp;B Website Design</a>
      </div>
    </div>
  </section>
</ServiceLayout>
