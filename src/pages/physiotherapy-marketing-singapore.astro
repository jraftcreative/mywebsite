---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Physiotherapy Marketing Singapore",
    "description": "Full-service digital marketing for physiotherapy clinics in Singapore — website design, SEO, Google Ads, social media, and content marketing. Grow patient bookings from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Physiotherapy Clinic Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for physiotherapy clinics" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, patient-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a physiotherapy clinic spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most physiotherapy clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and content marketing. The right budget depends on your clinic's size, number of branches, specialisations, and patient acquisition targets. Our Essential plan at $3,000/month is a strong starting point for single-location clinics." } },
      { "@type": "Question", "name": "How long before marketing generates new patients for my physiotherapy clinic?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate patient enquiries within the first week — people searching for physiotherapy are often in acute pain and ready to book immediately. SEO typically takes 3–6 months to build sustainable organic traffic. Content marketing and social media build authority over 2–3 months. Most clients see a meaningful increase in appointment bookings within the first 60 days." } },
      { "@type": "Question", "name": "What marketing channels work best for physiotherapy clinics in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search is the highest-intent channel — patients searching for 'physiotherapy near me' or 'sports physio Singapore' are ready to book. Google Business Profile is critical for local visibility and reviews. Content marketing builds long-term organic traffic through patient education articles. Social media builds credibility and keeps your clinic top-of-mind for referrals. A professional website ties everything together." } },
      { "@type": "Question", "name": "Do you understand healthcare marketing regulations in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We are familiar with the Singapore Medical Council guidelines and PHMC advertising regulations that apply to physiotherapy clinics. We ensure all marketing content avoids prohibited claims, uses appropriate disclaimers, and maintains the professional standards expected in healthcare marketing. All content is reviewed for compliance before publication." } },
      { "@type": "Question", "name": "Can you help market specialised physiotherapy services?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create targeted campaigns for each of your specialisations — sports physiotherapy, post-surgical rehabilitation, paediatric physiotherapy, geriatric care, women's health physiotherapy, occupational therapy, and workplace ergonomics. Each specialisation has its own audience, search behaviour, and marketing approach. We build dedicated landing pages, ad campaigns, and content for each service line." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Physiotherapy Marketing Singapore", "item": "https://jraftcreative.com/physiotherapy-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Gym Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Physiotherapy Marketing Singapore | Patient Bookings + AHPC"
  description="Physiotherapy clinic marketing in Singapore — Medisave-aware, AHPC-compliant. Patient booking funnels via Google + Meta. Solo clinic to chain."
  canonical="https://jraftcreative.com/physiotherapy-marketing-singapore/"
  ogTitle="Physiotherapy Marketing Singapore | Patient Bookings + AHPC"
  ogDescription="Physiotherapy clinic marketing in Singapore — Medisave-aware, AHPC-compliant. Patient booking funnels via Google + Meta. Solo clinic to chain."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="physiotherapy marketing singapore, physio clinic marketing agency, physiotherapy advertising singapore, physio digital marketing, physiotherapy clinic promotion, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Physiotherapy Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">Physiotherapy Clinics in Singapore</span>'
  heroSubtitle="Website, SEO, Google Ads, social media, and content — managed by one agency with one goal: filling your appointment book. Stop juggling vendors and start running a unified patient acquisition strategy."
  heroImage="/images/service-physiotherapy.webp"
  heroImageAlt="Physiotherapist treating a patient in a Singapore clinic — physiotherapy clinic marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my physiotherapy clinic in Singapore."
  ctaLabel="Ready to Grow Your Patient Base?"
  ctaTitle="Get Your Free Physiotherapy Clinic Marketing Audit"
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your clinic's patient acquisition goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20physiotherapy%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why physiotherapy clinics need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2><span class="highlight">Referrals Alone</span> Will Not Sustain Your <span class="highlight">Patient Pipeline</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has hundreds of physiotherapy clinics — hospital-linked practices, boutique sports physio studios, chain clinics, and home-visit services. Many depend heavily on doctor referrals and word-of-mouth, but those channels are limited and unpredictable. The clinics that grow are the ones patients can find, validate, and book the moment a need appears.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Referral Ceiling</h3>
            <p>Your bookings come from a mix of GP and specialist referrals plus self-referring patients. The referral side is finite and outside your control, while the self-referral side — patients searching online without ever asking a doctor — is the growing half of the market you can actually win.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Validation Test</h3>
            <p>Before booking, patients validate you — Google reviews, AHPC registration and physiotherapist credentials, and whether you accept Medisave for eligible rehabilitation. If that proof is hard to find, the enquiry goes to the clinic that made trust obvious first.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Physio Near Me" Moment</h3>
            <p>A patient in acute pain searching "physiotherapy near me" or "sports physio Singapore" at 10pm will not wait for a referral — they book whichever clinic ranks first, has strong reviews, and explains their condition clearly. If you are not visible in that local search, you never enter the shortlist.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for physiotherapy clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Physiotherapy Clinic <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for physiotherapy clinics — combining local SEO, AI search optimisation (GEO), paid search, patient-focused social content, branding, and conversion-focused web design, all within Singapore's healthcare advertising guidelines.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/physiotherapy-seo-singapore/">SEO for Physiotherapy Clinics</a></h3>
            <p>Rank for condition and location searches like "physiotherapy near me," "sports physio Singapore," and "post-surgery rehab Tampines." Google Business Profile, review management, and condition-specific pages that capture patients ready to book.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when patients ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best physio for frozen shoulder Singapore" or "do I need a referral for physiotherapy." AI-friendly schema and the same citation playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/physiotherapy-google-ads-singapore/">Google Ads for Physiotherapy Clinics</a></h3>
            <p>High-intent paid search on condition-specific terms, geo-targeted around your clinic locations. Patients in pain have urgency — GCLID tracking measures every click through to a booked appointment and a real cost-per-booking.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/physiotherapy-social-media-singapore/">Social Media for Physiotherapy Clinics</a></h3>
            <p>Exercise demos, injury-prevention tips, recovery explainers, and practitioner profiles for Instagram, TikTok, and Facebook — the credibility content that humanises your clinic and keeps you top-of-mind for patients and referral sources alike.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/physiotherapy-branding-singapore/">Branding for Physiotherapy Clinics</a></h3>
            <p>Clinic identity, practitioner positioning, and service-menu design that signals expertise and care — lifting you out of price-only comparisons and into the clinic patients feel confident trusting with their recovery.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/physiotherapy-website-singapore/">Websites for Physiotherapy Clinics</a></h3>
            <p>Condition pages, practitioner profiles, clear booking forms, and mobile-first speed — the conversion architecture that turns a patient researching their injury into a booked appointment request.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for physiotherapy marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Physiotherapy Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching clinics are generalists who do not understand healthcare advertising guidelines or the trust-intensive patient journey. We are the opposite — full-service, compliance-aware, and built around how physiotherapy patients in Singapore search, validate, and choose their clinic.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare Compliance Knowledge</h3>
            <p>We create content that respects Singapore Medical Council and PHMC advertising guidelines — no prohibited claims, appropriate disclaimers, and professional standards — so your clinic builds authority without regulatory risk.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, social, branding, and websites under one roof. No coordinating between separate vendors. Every channel reinforces the same clinical brand and targets the same patient audience with a unified, compliant message.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Bookings, Not Vanity Metrics</h3>
            <p>We measure appointment bookings, patient enquiries, and cost per lead by service line — not likes. Month-to-month retainers with no lock-in, because clinics should stay for the pipeline, not a contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PATIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Patient Funnel — how Singapore patients decide on a physiotherapy clinic">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Patient Funnel</p>
        <h2>How <span class="highlight">Singapore Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first pain search to a repeat rehabilitation visit, every physiotherapy patient in Singapore moves through the same five stages. We build compliant marketing that shows up at each one — from discovery through to the return visit that builds lifetime value.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, Instagram, TikTok, AI search, GP referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, AHPC credentials, Medisave eligibility</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 clinics, location &amp; condition match</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Booking form, WhatsApp, or phone enquiry</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Repeat sessions, rehab plan, refer friends</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for physiotherapy clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for Physiotherapy Clinics</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location clinics building a marketing foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics ready to scale patient acquisition across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Patient-focused content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-branch physiotherapy groups.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-branch campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Referral network campaigns</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about physiotherapy marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Physiotherapy Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a physiotherapy clinic spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most physiotherapy clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and content marketing. The right budget depends on your clinic's size, number of branches, specialisations, and patient acquisition targets. Our Essential plan at $3,000/month is a strong starting point for single-location clinics.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new patients for my physiotherapy clinic?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate patient enquiries within the first week — people searching for physiotherapy are often in acute pain and ready to book immediately. SEO typically takes 3–6 months to build sustainable organic traffic. Content marketing and social media build authority over 2–3 months. Most clients see a meaningful increase in appointment bookings within the first 60 days.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for physiotherapy clinics in Singapore?</summary>
          <div class="faq-answer"><p>Google Search is the highest-intent channel — patients searching for "physiotherapy near me" or "sports physio Singapore" are ready to book. Google Business Profile is critical for local visibility and reviews. Content marketing builds long-term organic traffic through patient education articles. Social media builds credibility and keeps your clinic top-of-mind. A professional website ties everything together.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you understand healthcare marketing regulations in Singapore?</summary>
          <div class="faq-answer"><p>Yes. We are familiar with the Singapore Medical Council guidelines and PHMC advertising regulations that apply to physiotherapy clinics. We ensure all marketing content avoids prohibited claims, uses appropriate disclaimers, and maintains the professional standards expected in healthcare marketing. All content is reviewed for compliance before publication.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you help market specialised physiotherapy services?</summary>
          <div class="faq-answer"><p>Yes. We create targeted campaigns for each of your specialisations — sports physiotherapy, post-surgical rehabilitation, paediatric physiotherapy, geriatric care, women's health physiotherapy, and workplace ergonomics. Each specialisation has its own audience, search behaviour, and marketing approach. We build dedicated landing pages, ad campaigns, and content for each service line.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Physiotherapy Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/physiotherapy-website-singapore/" class="related-service-link">Physiotherapy Website Design</a>
          <a href="/physiotherapy-seo-singapore/" class="related-service-link">Physiotherapy SEO</a>
          <a href="/physiotherapy-social-media-singapore/" class="related-service-link">Physiotherapy Social Media</a>
          <a href="/physiotherapy-google-ads-singapore/" class="related-service-link">Physiotherapy Google Ads</a>
          <a href="/physiotherapy-branding-singapore/" class="related-service-link">Physiotherapy Branding</a>
          <a href="/physiotherapy-content-marketing-singapore/" class="related-service-link">Physiotherapy Content Marketing</a>
      </div>
    </div>
  </section>
</ServiceLayout>
