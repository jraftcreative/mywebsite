---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Student Care Centre Website Design Singapore",
    "description": "Custom website design for student care centres in Singapore — programme schedules, online registration, enrichment activities, parent testimonials, and local SEO. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Student Care Centre Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Student Care Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with programme overview, contact form, Google Maps, mobile-responsive design, basic SEO, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Student Care Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online registration forms, enrichment activity showcase, blog, advanced SEO, Google Business Profile optimisation, and staff profiles" },
      { "@type": "Offer", "name": "Premium Student Care Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages with custom design, multi-centre support, parent portal, fee management integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a student care centre website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional student care centre website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with programme information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add online registration, enrichment activity showcases, parent portals, and multi-centre support." } },
      { "@type": "Question", "name": "Can parents register their children online through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business and Premium packages include online registration forms that let parents sign up their children directly through your website. Forms can capture student details, school information, pickup arrangements, dietary requirements, and emergency contacts — reducing your admin workload and making registration seamless for busy working parents." } },
      { "@type": "Question", "name": "How do you display programme schedules and enrichment activities?", "acceptedAnswer": { "@type": "Answer", "text": "We create structured, easy-to-read schedule pages that show your daily after-school programme, weekly enrichment activities, and holiday camp timetables. Parents can see homework supervision timings, enrichment classes like art or coding, and outdoor activities at a glance — so they know exactly what their child will be doing after school." } },
      { "@type": "Question", "name": "Will the website include Google Maps and help with local SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every package includes Google Maps integration showing your centre's location, nearby schools, and pickup/drop-off information. We also optimise your site for local search terms like 'student care near me' and 'after-school care [neighbourhood]' so parents searching in your area find your centre first. Business and Premium packages include Google Business Profile setup and advanced local SEO." } },
      { "@type": "Question", "name": "How long does it take to build a student care centre website?", "acceptedAnswer": { "@type": "Answer", "text": "Most student care centre websites go live within 2 weeks for our Starter package. Business-tier sites with online registration and enrichment showcases typically take 3 weeks, while Premium builds with multi-centre support and parent portals take 4–5 weeks. We provide a clear timeline before starting so you can plan around your school term schedule." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Student Care Website Singapore", "item": "https://jraftcreative.com/student-care-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Student Care Centre Website Singapore — After-School Care Web Design | Jraft Creative"
  description="Custom website design for student care centres in Singapore — programme schedules, online registration, enrichment activities, parent testimonials, and local SEO. From S$2,500."
  canonical="https://jraftcreative.com/student-care-website-singapore/"
  ogTitle="Student Care Centre Website Singapore — Jraft Creative"
  ogDescription="Custom website design for student care centres in Singapore. Programme schedules, online registration, enrichment activities, and local SEO from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="student care centre website singapore, student care website singapore, after-school care website singapore, student care near me, student care centre web design, student care registration website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Student Care Centre Websites"
  heroTitle='Website Design for <span class="highlight">Student Care Centres in Singapore</span>'
  heroSubtitle="Working parents are searching online for reliable after-school care. We build websites that showcase your programmes, highlight enrichment activities, and make registration effortless — so you can focus on caring for children, not chasing enrolments."
  heroImage="/images/service-studentcare.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my student care centre in Singapore."
  ctaLabel="Ready to Fill More Places?"
  ctaTitle="Get Your Student Care Centre Online"
  ctaDescription="Tell us about your student care centre and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20student%20care%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why student care centres need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Searching for After-School Care — Can They Find You?</h2>
      </div>
      <div class="section-content reveal">
        <p>In Singapore, dual-income families are the norm. Every year, thousands of working parents search for "student care near me" on Google, looking for a safe, enriching after-school environment for their children. They compare centres side by side — reading reviews, checking programme schedules, and evaluating enrichment activities. If your student care centre doesn't have a professional website, you're invisible to these parents, and they're registering their children somewhere else.</p>
        <p>A basic listing on a school directory or a dormant Facebook page is not enough. Parents want to see your full daily programme, understand your approach to homework supervision, and know what enrichment activities you offer — from art and music to coding and sports. They want to see photos of your facilities, read testimonials from other parents, and confirm your centre is MOE-registered and SSDB-aligned, all before they ever visit in person.</p>
        <p>Student care centres that invest in a proper website with clear programme information, transparent fee structures, and easy online registration consistently fill their places faster than those relying on word of mouth alone. In a market where parents have dozens of choices within a 2-kilometre radius of any primary school, your website is what separates your centre from the rest.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Student care centre website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Student Care Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>Every student care centre website we deliver is built to convert parent enquiries into confirmed registrations. We go beyond a generic template — your site will feature structured programme schedules, enrichment activity showcases, and a frictionless registration flow that makes it easy for busy working parents to sign up their children.</p>
        <p>A great website is just the starting point. Pair your student care site with <a href="/services/seo-performance/">local SEO services</a> to rank for "student care near me" searches in your neighbourhood, <a href="/services/social-media/">social media marketing</a> to reach parents on Facebook and Instagram, and <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches during registration season.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Programme Schedules &amp; Enrichment Activities</h3>
            <p>Clear, structured daily timetables showing homework supervision hours, enrichment classes, outdoor activities, and meal times. Parents can see exactly what their child will be doing after school — from guided study to creative workshops and sports.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Registration &amp; Waitlist Forms</h3>
            <p>Let parents register their children directly through your website. Capture student details, school information, pickup authorisation, dietary requirements, and emergency contacts in one streamlined form — reducing phone calls and paperwork for your admin team.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Location, Pickup Info &amp; Nearby Schools</h3>
            <p>Embedded Google Maps with your centre's location, walking routes from nearby primary schools, and clear pickup and drop-off instructions. Parents need to know logistics before they commit — make it easy for them to see you're conveniently located.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Parent Testimonials &amp; Facility Showcase</h3>
            <p>Showcase real testimonials from satisfied parents alongside photos of your classrooms, play areas, and study spaces. Visible social proof and a look inside your centre build trust and give hesitant parents the confidence to register.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for student care centre website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Your Student Care Centre Website</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand the student care landscape in Singapore. Our websites are built to address the specific challenges student care operators face — from competing for "student care near me" searches to converting parent visits into confirmed registrations.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Student Care Industry Knowledge</h3>
            <p>We've built websites for student care centres, enrichment centres, and education businesses across Singapore. We know what parents look for — MOE alignment, SSDB values, enrichment variety, and transparent fees — and how to present it effectively.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most student care centre websites go live within 2 weeks. We work fast so you can start capturing online registrations before the next school term begins — no dragging projects out for months.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Parents browse on their phones — during lunch breaks, on the MRT, and after putting children to bed. Every page we build is optimised for mobile first, so your site works perfectly on any device.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Beyond the website, we offer SEO, social media marketing, and Google Ads management — everything your student care centre needs to grow its online presence and fill every available place.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Student care centre website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Student Care Centre Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new centres getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme overview &amp; schedules</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established centres ready to grow.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online registration forms</li>
              <li>Enrichment activity showcase</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Staff profiles &amp; photo gallery</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-centre operations.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; branding</li>
              <li>Multi-centre support</li>
              <li>Parent portal integration</li>
              <li>Fee &amp; billing management</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about student care centre website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Student Care Centre Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a student care centre website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional student care centre website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with programme information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add online registration, enrichment activity showcases, parent portals, and multi-centre support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can parents register their children online through the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business and Premium packages include online registration forms that let parents sign up their children directly through your website. Forms can capture student details, school information, pickup authorisation, dietary requirements, and emergency contacts — reducing your admin workload and making registration seamless for busy working parents.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you display programme schedules and enrichment activities?</summary>
          <div class="faq-answer"><p>We create structured, easy-to-read schedule pages that show your daily after-school programme, weekly enrichment activities, and holiday camp timetables. Parents can see homework supervision timings, enrichment classes like art, coding, or sports, and outdoor activities at a glance — so they know exactly what their child will be doing after school.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will the website include Google Maps and help with local SEO?</summary>
          <div class="faq-answer"><p>Yes. Every package includes Google Maps integration showing your centre's location, nearby schools, and pickup and drop-off information. We also optimise your site for local search terms like "student care near me" and "after-school care [neighbourhood]" so parents searching in your area find your centre first. Business and Premium packages include Google Business Profile setup and advanced local SEO.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a student care centre website?</summary>
          <div class="faq-answer"><p>Most student care centre websites go live within 2 weeks for our Starter package. Business-tier sites with online registration and enrichment showcases typically take 3 weeks, while Premium builds with multi-centre support and parent portals take 4-5 weeks. We provide a clear timeline before starting so you can plan around your school term schedule.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
