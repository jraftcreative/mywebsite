---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Shopify Website Design Singapore",
    "description": "Professional Shopify website design in Singapore — custom themes, Singapore payment gateways (PayNow, GrabPay), product catalogues, and Shopify Plus development. From S$3,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Shopify Website Design",
    "offers": [
      { "@type": "Offer", "name": "Shopify Starter", "price": "3500", "priceCurrency": "SGD", "description": "Shopify store setup with a customised theme, single payment gateway, up to 30 products, mobile-responsive design, and basic SEO configuration" },
      { "@type": "Offer", "name": "Shopify Growth", "price": "7500", "priceCurrency": "SGD", "description": "Custom Shopify theme design with multiple payment gateways (PayNow, GrabPay, Stripe), unlimited products, advanced product filtering, and conversion tracking" },
      { "@type": "Offer", "name": "Shopify Plus / Enterprise", "price": "15000", "priceCurrency": "SGD", "description": "Shopify Plus development with custom checkout, third-party integrations, multi-currency support, headless commerce options, and dedicated support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a Shopify website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professionally designed Shopify store in Singapore typically costs between $3,500 and $15,000+ depending on customisation and features. Our Starter package at $3,500 SGD includes theme customisation, a payment gateway, and up to 30 products. Growth and Enterprise packages add custom theme design, multiple payment gateways, unlimited products, and advanced integrations." } },
      { "@type": "Question", "name": "Can you integrate PayNow and GrabPay with Shopify?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We configure Shopify Payments and integrate local Singapore payment methods including PayNow, GrabPay, Stripe, and credit/debit card processing. Offering familiar local payment options reduces checkout friction and increases conversion rates for Singapore shoppers." } },
      { "@type": "Question", "name": "Do you build custom Shopify themes or use pre-built ones?", "acceptedAnswer": { "@type": "Answer", "text": "Both. Our Starter package customises a premium Shopify theme to match your brand, while our Growth and Enterprise packages include fully custom theme design built from scratch using Shopify Liquid. Custom themes give you complete control over layout, functionality, and performance." } },
      { "@type": "Question", "name": "Can you migrate my existing store to Shopify?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle full migrations to Shopify from WooCommerce, Magento, BigCommerce, and other platforms. We transfer your product data, customer records, order history, and SEO settings. We also set up 301 redirects so your search rankings are preserved during the move." } },
      { "@type": "Question", "name": "How long does it take to launch a Shopify store?", "acceptedAnswer": { "@type": "Answer", "text": "Most Shopify stores go live within 2-4 weeks. A Starter store with up to 30 products can launch in 2 weeks, while custom-themed Growth builds take 3-4 weeks. Shopify Plus projects with advanced integrations and custom checkout typically take 5-6 weeks. We provide a detailed timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Shopify Website Design Singapore", "item": "https://jraftcreative.com/shopify-website-design-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Shopify Website Design Singapore — Jraft Creative"
  description="Professional Shopify website design in Singapore — custom themes, Singapore payment gateways (PayNow, GrabPay), product catalogues. From S$3,500."
  canonical="https://jraftcreative.com/shopify-website-design-singapore/"
  ogTitle="Shopify Website Design Singapore — Jraft Creative"
  ogDescription="Professional Shopify website design in Singapore — custom themes, Singapore payment gateways (PayNow, GrabPay), product catalogues, and Shopify Plus development. From S$3,500."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="shopify website design singapore, shopify store setup singapore, shopify theme customisation, shopify plus singapore, shopify developer singapore, shopify ecommerce singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Shopify Website Design"
  heroTitle='Shopify Website Design <span class="highlight">in Singapore</span>'
  heroSubtitle="We design and build high-converting Shopify stores for Singapore businesses — with custom themes, local payment gateways, and product catalogues that turn visitors into paying customers."
  heroImage="/images/service-shopify.webp"
  heroImageAlt="A Shopify online store on desktop and mobile — Shopify website design in Singapore"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a Shopify store for my business in Singapore."
  ctaLabel="Ready to Launch Your Shopify Store?"
  ctaTitle="Let's Build Your Shopify Store"
  ctaDescription="Book a free consultation and tell us about your products and goals. We'll get back to you within 24 hours with a tailored Shopify proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20Shopify%20store%20for%20my%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why Singapore businesses struggle with Shopify">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>A <span class="highlight">Default Shopify Theme</span> Is Not a <span class="highlight">Conversion Machine</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Shopify makes it easy to open a store — and just as easy to open one that never sells. A theme installed out of the box looks like thousands of other stores, buries your best products, and leaves the checkout feeling foreign to Singapore shoppers. Setting up the platform is not the same as building a store engineered to convert.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>A Theme Out of the Box Won't Sell</h3>
            <p>Installing a Shopify theme gets you a store that looks like everyone else's. Generic layouts, weak product pages, and a home page that doesn't guide anyone to buy. Conversions come from intentional design — hierarchy, trust signals, and a path to checkout — not from dragging default sections into place.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Singapore Checkout Needs Local Setup</h3>
            <p>Shoppers here expect PayNow and GrabPay, correct GST handling, and shipping rates that match local couriers. A store built for a US audience adds friction at the exact moment a customer is ready to pay — and every friction point at checkout is an abandoned cart and lost revenue.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>App Bloat Kills Mobile Speed</h3>
            <p>Every extra app injects scripts that slow your store down, and most Singapore traffic is on mobile. Slow themes and heavy apps tank Core Web Vitals, hurt Google rankings, and drive shoppers away before a product even loads. Speed is a conversion feature, not an afterthought.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Shopify website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of a <span class="highlight">Shopify Store</span></h2>
      </div>
      <div class="section-content reveal">
        <p>A Shopify store that sells is built deliberately, layer by layer — from the theme your customers see to the payment, shipping, and speed systems working behind it. We handle every element so your store looks the part, feels local to Singapore shoppers, and loads fast enough to hold their attention.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Custom Theme &amp; Conversion Design</h3>
            <p>We customise a premium theme or build one from scratch in Liquid to match your brand and guide shoppers to buy. Clear hierarchy, strong product pages, and trust signals throughout — a store that looks nothing like a cookie-cutter template.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Product &amp; Collection Setup</h3>
            <p>We structure your catalogue with clear collections, tags, and variants so customers browse and filter with ease. Optimised product pages with quality imagery, persuasive descriptions, and schema markup help your products surface in Google Shopping.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>SG Payment, Shipping &amp; GST Config</h3>
            <p>We set up Shopify Payments with PayNow, GrabPay, Stripe, and card processing, plus GST handling and local courier shipping rates. Your checkout feels native to Singapore shoppers, so fewer carts are abandoned at the final step.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3>App Selection &amp; Integrations</h3>
            <p>We pick the right apps for reviews, subscriptions, loyalty, and email — and skip the ones that only add bloat. We connect your store to the tools you already use, from accounting to inventory, so everything runs as one system.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Core Web Vitals</h3>
            <p>We audit every app, compress and lazy-load images, and trim theme code so your store loads fast on mobile. Strong Core Web Vitals keep shoppers engaged and give your product pages a better shot at ranking in Google.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-campaign-analytics.webp');">
          <div class="service-detail-card__content">
            <h3>Launch, Migration &amp; Training</h3>
            <p>Moving from WooCommerce, Magento, or another platform? We migrate products, customers, and orders, and set up 301 redirects to protect your rankings. Then we hand over a store you can run confidently, with training on managing products and orders.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for Shopify website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">Shopify Partner</span> Built for <span class="highlight">Singapore Sellers</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We don't just set up Shopify stores — we engineer them to sell. Every decision, from product page layout to checkout flow, is driven by conversion thinking and hands-on experience building Shopify stores for the Singapore market.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Shopify Specialists</h3>
            <p>We work with Shopify daily and know the platform inside out — from Liquid theme development to Shopify Plus checkout customisation. You get a team that understands Shopify's strengths and how to push past its limitations.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Singapore-First Approach</h3>
            <p>We configure your store for the Singapore market — PayNow and GrabPay at checkout, GST handling, SGD pricing, and local shipping integrations. Your store feels native to Singapore shoppers from first click to delivery.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A store is only as strong as the traffic it attracts. We handle product SEO, Google Shopping ads, and social commerce in-house — an integrated system that fills your new Shopify store with the right shoppers, not just a good-looking storefront.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CUSTOMER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Customer Funnel — where your store fits the customer journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Customer Funnel</p>
        <h2>Where Your <span class="highlight">Store</span> Fits the <span class="highlight">Customer Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every online shopper moves through the same five stages before they become a repeat customer. Your Shopify store is the engine that carries them from first click to checkout — and keeps them coming back after the first order.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google Shopping, search &amp; social ads</p>
        </li>
        <li class="funnel-stage">
          <h3>Consider</h3>
          <p>Product pages, reviews &amp; collections</p>
        </li>
        <li class="funnel-stage">
          <h3>Purchase</h3>
          <p>PayNow, GrabPay &amp; frictionless checkout</p>
        </li>
        <li class="funnel-stage">
          <h3>Repeat</h3>
          <p>Email flows, loyalty &amp; re-orders</p>
        </li>
        <li class="funnel-stage">
          <h3>Refer</h3>
          <p>Reviews, word of mouth &amp; social proof</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Shopify website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Shopify Pricing</p>
        <h2>Shopify Store Packages</h2>
        <p>One-time project fee. Shopify subscription billed separately by Shopify.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$3,500 <span>SGD</span></div>
            <p class="pricing-desc">For businesses launching their first Shopify store.</p>
            <ul class="pricing-features">
              <li>Premium theme customisation</li>
              <li>Up to 30 products</li>
              <li>Single payment gateway</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$7,500+ <span>SGD</span></div>
            <p class="pricing-desc">For growing stores ready to scale on Shopify.</p>
            <ul class="pricing-features">
              <li>Custom Shopify theme design</li>
              <li>Unlimited products</li>
              <li>PayNow, GrabPay &amp; Stripe</li>
              <li>Advanced filtering &amp; search</li>
              <li>GA4 ecommerce tracking</li>
              <li>3-4 week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Shopify Plus</h3>
            <div class="price">$15,000+ <span>SGD</span></div>
            <p class="pricing-desc">For high-volume and enterprise-level stores.</p>
            <ul class="pricing-features">
              <li>Shopify Plus setup &amp; customisation</li>
              <li>Custom checkout experience</li>
              <li>Third-party integrations</li>
              <li>Multi-currency support</li>
              <li>Headless commerce options</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about Shopify website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Shopify Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a Shopify website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professionally designed Shopify store in Singapore typically costs between $3,500 and $15,000+ depending on customisation and features. Our Starter package at $3,500 SGD includes theme customisation, a payment gateway, and up to 30 products. Growth and Shopify Plus packages add custom theme design, multiple payment gateways, unlimited products, and advanced integrations.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you integrate PayNow and GrabPay with Shopify?</summary>
          <div class="faq-answer"><p>Yes. We configure Shopify Payments and integrate local Singapore payment methods including PayNow, GrabPay, Stripe, and credit/debit card processing. Offering familiar local payment options reduces checkout friction and increases conversion rates for Singapore shoppers.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build custom Shopify themes or use pre-built ones?</summary>
          <div class="faq-answer"><p>Both. Our Starter package customises a premium Shopify theme to match your brand, while our Growth and Shopify Plus packages include fully custom theme design built from scratch using Shopify Liquid. Custom themes give you complete control over layout, functionality, and performance.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you migrate my existing store to Shopify?</summary>
          <div class="faq-answer"><p>Yes. We handle full migrations to Shopify from WooCommerce, Magento, BigCommerce, and other platforms. We transfer your product data, customer records, order history, and SEO settings. We also set up 301 redirects so your search rankings are preserved during the move.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to launch a Shopify store?</summary>
          <div class="faq-answer"><p>Most Shopify stores go live within 2-4 weeks. A Starter store with up to 30 products can launch in 2 weeks, while custom-themed Growth builds take 3-4 weeks. Shopify Plus projects with advanced integrations and custom checkout typically take 5-6 weeks. We provide a detailed timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
