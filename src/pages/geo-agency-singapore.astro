---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "GEO Agency Singapore",
    "description": "Specialist GEO agency in Singapore — Generative Engine Optimisation to get your brand recommended by ChatGPT, Google Gemini, Perplexity, and AI Overviews. From S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Generative Engine Optimisation (GEO)",
    "offers": [
      { "@type": "Offer", "name": "GEO Essentials", "price": "3000", "priceCurrency": "SGD", "description": "AI visibility audit, schema markup, content optimisation (5 pages/mo), llms.txt setup, monthly reporting" },
      { "@type": "Offer", "name": "GEO Growth", "price": "5000", "priceCurrency": "SGD", "description": "Everything in Essentials plus 20 pages/mo, authority building, answer engine content, bi-weekly reporting, dedicated strategist" },
      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is GEO and how is it different from SEO?", "acceptedAnswer": { "@type": "Answer", "text": "GEO is Generative Engine Optimisation — getting your brand cited and recommended inside generative AI answers (ChatGPT, Gemini, Perplexity, Claude, Google AI Overviews). SEO targets the 10 blue links on a Google search page. GEO targets the AI-generated answer that increasingly appears ABOVE those links. Same business goal (be found), different surfaces. Most GEO work is content structure, schema markup, and authority signals — much of it overlaps with modern SEO, but the optimisation targets and measurement are different." } },
      { "@type": "Question", "name": "Is GEO the same as AI SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Functionally yes. GEO, AI SEO, AEO (Answer Engine Optimisation), and LLMO (Large Language Model Optimisation) all describe the same discipline: making your brand citable by generative AI. Different agencies pick different acronyms. We use GEO because it's the most established term in the industry (originally coined by researchers at Princeton in 2023) and the term ChatGPT itself uses most often when explaining the concept. The work behind every acronym is the same." } },
      { "@type": "Question", "name": "How much does a GEO agency in Singapore cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our GEO Agency plans start at S$3,000/month (Essentials), S$5,000/month (Growth), and S$10,000/month (Enterprise). Pricing reflects the labour: schema implementation, llms.txt config, answer-engine content, authority building (PR, citation strategy, Wikipedia work for Enterprise), and active citation monitoring across 4-50+ AI prompts. Singapore GEO market pricing is currently S$2,500-S$15,000/month depending on scope. Anything below S$2,000/month is almost certainly traditional SEO rebranded." } },
      { "@type": "Question", "name": "Which AI platforms does a GEO agency optimise for?", "acceptedAnswer": { "@type": "Answer", "text": "The five with meaningful SG traffic: ChatGPT (largest by user count), Google AI Overviews and Gemini, Perplexity (highest commercial intent), Claude (rising fast in B2B), and Microsoft Copilot (lower priority but cheap to cover). Most of the technical work — schema, llms.txt, content structure — applies across all five simultaneously. Where they diverge is content authority signals: Perplexity weighs citations heavily, ChatGPT favours Wikipedia and authoritative reviews, Gemini blends in Google Search ranking." } },
      { "@type": "Question", "name": "How long does GEO take to show results in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Technical setup (schema, llms.txt, on-page content restructure) ships in 2-4 weeks. First branded AI citations typically appear within 8-12 weeks. Category citations (e.g. ranking when someone asks \"best preschool in Punggol\" without your brand name) take 4-6 months and require ongoing authority work. Singapore-specific note: AI models are heavier on US/UK content, so SG-specific citation density takes slightly longer to build than the global benchmarks. We track and report monthly." } },
      { "@type": "Question", "name": "Do I still need traditional SEO if I'm doing GEO?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Google still drives 60-70% of high-intent commercial search traffic in Singapore. GEO is additive, not a replacement. The work overlaps significantly though — schema markup, clean content structure, and authority signals all serve both. We don't sell GEO as a standalone if you don't have traditional SEO basics covered. If your Google rankings are weak, we usually recommend fixing those first or running a combined SEO + GEO engagement." } },
      { "@type": "Question", "name": "Can you guarantee AI Overviews citations?", "acceptedAnswer": { "@type": "Answer", "text": "No. AI Overviews trigger probabilistically based on Google's assessment of query type, user signal, and content authority. We can engineer the conditions that make citation likely — structured data, clear definitions, authoritative content, ranking inside Google's top 10 (the AI Overview pool is drawn primarily from top results). We report monthly on which of your tracked queries trigger AI Overviews and whether your brand appears. Most clients see first AI Overview citations within 6-10 weeks." } },
      { "@type": "Question", "name": "What's in a GEO Essentials plan at S$3,000/month?", "acceptedAnswer": { "@type": "Answer", "text": "AI visibility audit (where do you appear in ChatGPT, Gemini, Perplexity, SGE today), schema markup implementation across your key service/product pages, llms.txt setup, content optimisation on 5 pages per month (rewriting for answer-engine parsing), and monthly reporting on citation tracking across 4 branded prompts. It's the minimum viable GEO setup. Most clients on Essentials see first citations by month 3 and decide whether to scale to Growth (S$5K/mo, 20 pages/mo) or stay on maintenance." } },
      { "@type": "Question", "name": "Is GEO worth it for a B2B company in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Often more than for B2C. B2B buyers in Singapore — procurement managers, CMOs, CFOs — are heavy ChatGPT and Perplexity users for research. When a procurement manager asks \"what are the top digital marketing agencies in Singapore for healthcare clients\", the AI's answer is one of the strongest leading indicators of which 3-5 vendors get shortlisted. B2B sales cycles are long enough that being in those AI shortlists compounds over time. We've seen B2B clients move from invisible to consistently cited within 4 months." } },
      { "@type": "Question", "name": "How do I know if my competitors are using GEO?", "acceptedAnswer": { "@type": "Answer", "text": "Ask the AIs. Type \"best [your category] in Singapore\" into ChatGPT, Perplexity, Gemini, and Google SGE. Note who comes up. If competitors appear and you don't, they're either ahead on GEO or have stronger pre-existing authority signals (older domain, more PR coverage, more reviews) that the AIs pick up. Either gap is closable but takes 3-6 months. Our audit benchmarks your share-of-voice vs your top 3 competitors as part of every GEO engagement." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "GEO Agency Singapore", "item": "https://jraftcreative.com/geo-agency-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="GEO Agency Singapore — Rank in ChatGPT & Gemini | Jraft"
  description="Specialist GEO agency in Singapore. We get your brand recommended by ChatGPT, Gemini, Perplexity, and AI Overviews — from S$3,000/mo."
  canonical="https://jraftcreative.com/geo-agency-singapore/"
  ogTitle="GEO Agency Singapore — Rank in ChatGPT & Gemini | Jraft"
  ogDescription="Specialist GEO agency in Singapore. Get your brand recommended by ChatGPT, Gemini, Perplexity, and Google AI Overviews."
  ogImage="https://jraftcreative.com/images/og-seo.jpg"
  keywords="geo agency singapore, generative engine optimisation agency, GEO services singapore, AI search agency, AI optimisation agency singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="GEO Agency"
  heroTitle='GEO Agency in <span class="highlight">Singapore</span>'
  heroSubtitle="60.9% of Singapore already uses AI to search. When someone asks ChatGPT or Gemini for a recommendation, does your brand come up? As Singapore's specialist GEO agency, we use Generative Engine Optimisation to put your business in AI answers — not just search results."
  heroImage="/images/service-seo.webp"
  heroButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View GEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to learn about your GEO services in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Brand Into AI Answers"
  ctaDescription="Book a free GEO audit and we'll show you exactly where your brand appears — and doesn't — across ChatGPT, Gemini, Perplexity, and Google AI Overviews. We'll respond within 24 hours."
  ctaButtons={[
    { text: "Get a Free AI Visibility Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20about%20your%20GEO%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why businesses need a GEO agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Customers Are Asking AI — Not Searching Google</h2>
      </div>
      <div class="section-content reveal">
        <p>Google search volume is declining as consumers shift to ChatGPT, Gemini, and Perplexity for recommendations. When AI answers a question, it names 3&ndash;4 brands &mdash; not 10 blue links. If your brand isn't one of them, you're invisible to a fast-growing segment of your market. And when AI does recommend a brand, those visitors convert at 4.4x the rate of traditional search traffic.</p>
        <p>Singapore has the second highest <a href="/blog/why-ai-search-matters-singapore/">AI adoption rate</a> globally &mdash; <a href="/blog/why-ai-search-matters-singapore/">60.9%</a> of the population already uses generative AI. The overlap between Google rankings and AI citations has dropped below 20%. Ranking on page one of Google no longer means AI will recommend you. Businesses need a specialist GEO agency that understands how AI decides which brands to cite.</p>
        <p>Most digital agencies still treat AI search as an afterthought. They optimise for Google's algorithm while ignoring the signals that ChatGPT, Gemini, and Perplexity use to choose which brands to recommend. A dedicated <a href="/generative-engine-optimisation-singapore/">Generative Engine Optimisation</a> strategy is now essential for any business that wants to stay visible as search behaviour shifts to AI.</p>
      </div>
    </div>
  </section>

  <!-- ========== GEO vs SEO vs PAID ADS ========== -->
  <section class="section" id="geo-vs-seo-vs-ads" style="background: var(--bg-alt);" aria-label="Comparison of GEO, SEO, and paid advertising strategies">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Compare Strategies</p>
        <h2>GEO vs SEO vs Paid Ads &mdash; How They Stack Up</h2>
      </div>
      <div class="section-content reveal">
        <p>Businesses in Singapore often ask whether GEO replaces SEO or paid ads. The short answer: it doesn't &mdash; but it fills a gap neither of them covers. This comparison breaks down how each channel works, what it costs, and where it delivers the strongest results.</p>
      </div>
      <div class="comparison-table-wrap reveal">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th>GEO</th>
              <th>SEO</th>
              <th>Paid Ads</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Goal</strong></td>
              <td>Get recommended in AI answers</td>
              <td>Rank in organic search results</td>
              <td>Buy visibility at the top of search</td>
            </tr>
            <tr>
              <td><strong>What You Compete With</strong></td>
              <td>3&ndash;4 brands the AI chooses to cite</td>
              <td>10 blue links on page one</td>
              <td>Other advertisers bidding on the same keywords</td>
            </tr>
            <tr>
              <td><strong>Key Signals</strong></td>
              <td>Entity clarity, structured data, third-party authority, content freshness</td>
              <td>Backlinks, on-page relevance, technical health, domain authority</td>
              <td>Bid amount, Quality Score, landing page relevance</td>
            </tr>
            <tr>
              <td><strong>Content Style</strong></td>
              <td>Answer-first, fact-dense, comparison tables, FAQ-rich</td>
              <td>Keyword-optimised long-form, internal linking</td>
              <td>Short-form ad copy &amp; landing pages</td>
            </tr>
            <tr>
              <td><strong>Cost Model</strong></td>
              <td>Monthly retainer (from S$3,000/mo)</td>
              <td>Monthly retainer (from S$800/mo)</td>
              <td>Pay-per-click + management fee</td>
            </tr>
            <tr>
              <td><strong>Conversion Advantage</strong></td>
              <td>AI-referred visitors convert at <strong>4.4x</strong> the rate of traditional search</td>
              <td>Baseline organic conversion rate</td>
              <td>Variable &mdash; depends on targeting &amp; ad quality</td>
            </tr>
            <tr>
              <td><strong>Timeline to Results</strong></td>
              <td>30&ndash;90 days for measurable citation improvements</td>
              <td>3&ndash;6 months for meaningful ranking gains</td>
              <td>Immediate &mdash; traffic stops when budget stops</td>
            </tr>
            <tr>
              <td><strong>Best For</strong></td>
              <td>Brands that want to own AI recommendations long-term</td>
              <td>Brands building sustainable organic traffic</td>
              <td>Brands that need leads now and have budget to spend</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="content-callout reveal">
        <p><strong>Key takeaway:</strong> The overlap between Google's top organic results and AI citations has dropped below 20%. That means ranking on page one of Google no longer guarantees AI will recommend you. Businesses that combine GEO with SEO and paid ads cover all three discovery channels &mdash; organic search, AI answers, and paid placement &mdash; and leave no gap for competitors to exploit.</p>
      </div>
    </div>
  </section>

  <!-- ========== OUR GEO PROCESS ========== -->
  <section class="section" id="geo-process" aria-label="Our six-step GEO process">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Process</p>
        <h2>How We Build Your AI Visibility &mdash; 6-Step GEO Process</h2>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3><span class="step-number">1</span> AI Visibility Audit</h3>
            <p>We test 20&ndash;30 real prompts across ChatGPT, Gemini, Perplexity, Copilot, and Google AI Overviews to map exactly where your brand appears &mdash; and where it doesn't. This gives us a clear baseline and identifies the highest-impact opportunities.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3><span class="step-number">2</span> Gap Analysis</h3>
            <p>We map entity gaps, content gaps, and authority gaps against your competitors. This reveals why AI recommends them instead of you &mdash; and exactly what needs to change to shift those recommendations in your favour.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3><span class="step-number">3</span> Schema Foundation</h3>
            <p>We implement comprehensive JSON-LD structured data &mdash; Organization, Service, FAQ, and Speakable schemas &mdash; plus an <code>llms.txt</code> file that gives AI crawlers direct access to your key information. This is the technical backbone of AI visibility.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3><span class="step-number">4</span> Content Engineering</h3>
            <p>We restructure your content for AI extraction: answer-first formatting, comparison tables, fact-dense paragraphs, and FAQ sections that match the prompts your prospects are asking. Content that AI can parse easily gets cited more often.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3><span class="step-number">5</span> Authority Building</h3>
            <p>AI models weigh third-party credibility heavily. We build your brand's presence on review platforms, industry directories, and publications that AI trusts &mdash; strengthening the external signals that determine whether you get recommended.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3><span class="step-number">6</span> Monitoring &amp; Optimisation</h3>
            <p>We track Citation Rate, Brand Visibility Score, and Share of Voice across every major AI platform on a monthly basis. As AI models update and competitors adapt, we refine your strategy to maintain and grow your recommendation share.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" aria-label="GEO services we deliver">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Full-Service Generative Engine Optimisation</h2>
      </div>
      <div class="section-content reveal">
        <p>As a specialist GEO agency, we cover every lever that determines whether AI recommends your brand — from technical schema markup to citation-ready content and third-party authority signals. Our approach works alongside your existing SEO, not against it.</p>
        <p>Pair GEO with our <a href="/services/seo-performance/">SEO services</a> for maximum search visibility, or combine with <a href="/services/paid-ads/">paid ads</a> and <a href="/services/social-media/">social media</a> for a full-funnel digital strategy.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>AI Visibility Audit</h3>
            <p>Comprehensive audit of your brand's presence across ChatGPT, Gemini, Perplexity, Copilot, and Google AI Overviews. We test 20-30 target prompts, benchmark against competitors, and map exactly where your AI visibility stands today.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>Schema &amp; Entity Optimisation</h3>
            <p>Advanced structured data markup (JSON-LD) that tells AI exactly who you are, what you offer, and why you're credible. Organization, Service, FAQ, and Speakable schemas — plus llms.txt implementation for direct AI crawlability.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Citation-Ready Content</h3>
            <p>Content restructured for AI consumption — answer-first formatting, comparison tables, fact-dense paragraphs, and FAQ sections that directly match the prompts your prospects are asking ChatGPT and Gemini.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-analytics-reporting.webp">
          <div class="service-detail-card__content">
            <h3>Authority Building</h3>
            <p>AI models assess credibility through third-party mentions. We build your brand's presence on review platforms, industry directories, and authority sites that AI trusts — strengthening the signals that determine whether you get recommended.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative as your GEO agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A GEO Agency Built for AI-First Search</h2>
      </div>
      <div class="section-content reveal">
        <p>We're not a traditional SEO agency that bolted on AI services. Generative Engine Optimisation is a core discipline at Jraft Creative — we understand the signals AI uses to choose which brands to recommend and we build strategies around them.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>GEO-First Methodology</h3>
            <p>We built our methodology around how AI models actually select brands to recommend — entity clarity, structured data, content freshness, and third-party authority signals. Not recycled SEO tactics with a new label.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Multi-Platform Coverage</h3>
            <p>We optimise across ChatGPT, Google Gemini, Google AI Overviews, Perplexity, and Copilot. Each platform weighs sources differently — our strategies account for platform-specific ranking signals.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Measurable AI Metrics</h3>
            <p>We track Brand Visibility Score, Citation Rate, and Share of Voice across every major AI platform. You see exactly how often AI recommends your brand — and how that compares to competitors.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Integration</h3>
            <p>GEO works best alongside SEO, paid ads, and social media. We handle the full stack — so your AI visibility, search rankings, and paid campaigns all reinforce each other.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== GEO TERMINOLOGY DECODER ========== -->
  <section class="section" id="geo-terminology" aria-label="GEO terminology decoder — GEO, LLMO, AEO, AIO explained">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Terminology</p>
        <h2>GEO, LLMO, AEO, AIO &mdash; What Do They All Mean?</h2>
      </div>
      <div class="section-content reveal">
        <p>The industry hasn't settled on a single name for optimising brands for AI search. You'll see agencies use GEO, LLMO, AEO, and AIO interchangeably &mdash; which can make it difficult to compare services or understand what you're actually buying. Here's what each term means and how they relate to each other.</p>

        <h3>GEO (Generative Engine Optimisation)</h3>
        <p>The broadest and most widely adopted term. GEO covers optimisation across all generative AI platforms &mdash; ChatGPT, Google Gemini, Perplexity, Copilot, and Google AI Overviews. It's the umbrella term that encompasses every strategy for getting your brand recommended in AI answers. This is the term Jraft Creative uses because it reflects the full scope of what we do: optimise for <em>all</em> generative engines, not just one platform or technology.</p>

        <h3>LLMO (Large Language Model Optimisation)</h3>
        <p>LLMO frames the same discipline from a technology angle &mdash; focusing on the large language models that power AI search. The strategies are identical to GEO; the label simply emphasises the underlying AI technology rather than the platforms. If you've been searching for <a href="/llmo-services-singapore/">LLMO services in Singapore</a>, you're looking for the same thing.</p>

        <h3>AEO (Answer Engine Optimisation)</h3>
        <p>AEO positions AI platforms as "answer engines" rather than search engines. This framing is more common in the US market and emphasises the shift from links to direct answers. The optimisation strategies &mdash; structured data, entity clarity, authority building &mdash; are the same as GEO.</p>

        <h3>AIO (AI Overview Optimisation)</h3>
        <p>AIO specifically targets Google's AI Overviews feature &mdash; the AI-generated summaries that appear at the top of Google search results. It's the narrowest of the four terms, focusing on a single platform. Our <a href="/ai-seo-singapore/">AI SEO services</a> include AI Overview optimisation as part of a broader multi-platform strategy.</p>
      </div>
      <div class="content-callout reveal">
        <p><strong>Bottom line:</strong> GEO, LLMO, AEO, and AIO all describe the same core discipline. The strategies are identical regardless of which label you use. What matters is that your agency understands how AI decides which brands to recommend &mdash; and builds a programme around those signals.</p>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="GEO agency pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">GEO Pricing</p>
        <h2>AI Search Optimisation Plans</h2>
        <p>Monthly retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essentials</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses starting their AI visibility journey.</p>
            <ul class="pricing-features">
              <li>AI visibility audit &amp; baseline</li>
              <li>Schema markup implementation</li>
              <li>Content optimisation (5 pages/mo)</li>
              <li>llms.txt setup &amp; maintenance</li>
              <li>Monthly AI visibility report</li>
              <li>Quarterly strategy review</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses ready to dominate AI recommendations.</p>
            <ul class="pricing-features">
              <li>Everything in Essentials</li>
              <li>Content optimisation (20 pages/mo)</li>
              <li>Authority building &amp; directory registrations</li>
