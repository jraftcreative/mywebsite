---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "GEO Agency Singapore",
    "description": "Specialist GEO agency in Singapore — Generative Engine Optimisation to get your brand recommended by ChatGPT, Google Gemini, Perplexity, and AI Overviews. From S$3,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Generative Engine Optimisation (GEO)",
    "offers": [
      { "@type": "Offer", "name": "AI Visibility Audit (AVA)", "price": "1000", "priceCurrency": "SGD", "description": "One-time audit. 20–30 prompts across ChatGPT, Gemini, Perplexity, Claude and AI Overviews. 8–12 page report, citation map, schema and GBP audit, two competitor benchmarks, top 5 prioritised gaps, 60-minute delivery call. 5–7 day delivery. Credits 100% to month one if you sign a retainer within 30 days." },
      { "@type": "Offer", "name": "GEO Essentials", "price": "3000", "priceCurrency": "SGD", "description": "AI visibility audit, schema markup, content optimisation (5 pages/mo), llms.txt setup, monthly reporting" },
      { "@type": "Offer", "name": "GEO Growth", "price": "5000", "priceCurrency": "SGD", "description": "Everything in Essentials plus 20 pages/mo, authority building, answer engine content, bi-weekly reporting, dedicated strategist" },
      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is GEO and how is it different from SEO?", "acceptedAnswer": { "@type": "Answer", "text": "GEO is Generative Engine Optimisation — getting your brand cited and recommended inside generative AI answers (ChatGPT, Gemini, Perplexity, Claude, Google AI Overviews). SEO targets the 10 blue links on a Google search page. GEO targets the AI-generated answer that increasingly appears above those links. Same business goal, different surfaces. Most GEO work overlaps with modern SEO (schema, content structure, authority) but the optimisation targets and measurement are different." } },
      { "@type": "Question", "name": "How much does a GEO agency in Singapore cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our GEO plans start at S$3,000/month (Essentials), S$5,000/month (Growth), and S$10,000/month (Enterprise). The one-time AI Visibility Audit (AVA) sits below at S$1,000. SG GEO market pricing currently runs S$2,500–S$15,000/month depending on scope. Anything below S$2,000/month is almost certainly traditional SEO rebranded." } },
      { "@type": "Question", "name": "Which AI platforms does a GEO agency optimise for?", "acceptedAnswer": { "@type": "Answer", "text": "The five with meaningful SG traffic: ChatGPT (largest by user count), Google AI Overviews and Gemini, Perplexity (highest commercial intent), Claude (rising fast in B2B), and Microsoft Copilot. The technical layer — schema, llms.txt, content structure — applies across all five. Where they diverge is authority signals: Perplexity weighs citations heavily, ChatGPT favours Wikipedia, Gemini blends in Google Search ranking." } },
      { "@type": "Question", "name": "How long does GEO take to show results in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Technical setup (schema, llms.txt, content restructure) ships in 2-4 weeks. First branded AI citations typically appear within 8-12 weeks. Category citations (e.g. ranking when someone asks \"best clinic in Singapore\" without your brand name) take 4-6 months and require ongoing authority work. SG-specific citation density takes slightly longer than global benchmarks because AI models lean US/UK." } },
      { "@type": "Question", "name": "Do I still need traditional SEO if I'm doing GEO?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Google still drives 60-70% of high-intent commercial search traffic in Singapore. GEO is additive, not a replacement. The work overlaps significantly though — schema, content structure, and authority signals serve both. If your Google rankings are weak we usually recommend a combined SEO + GEO engagement rather than GEO standalone." } },
      { "@type": "Question", "name": "Can you guarantee AI Overviews citations?", "acceptedAnswer": { "@type": "Answer", "text": "No. AI Overviews trigger probabilistically based on query type, user signal, and content authority. We can engineer the conditions that make citation likely — structured data, clear definitions, ranking inside Google's top 10 (the AI Overview pool draws primarily from top results). We report monthly on which of your tracked queries trigger AI Overviews and whether your brand appears. Most clients see first AI Overview citations within 6-10 weeks." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "GEO Agency Singapore", "item": "https://jraftcreative.com/geo-agency-singapore/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "ImageObject",
    "url": "https://jraftcreative.com/images/service-seo.webp",
    "caption": "GEO agency Singapore — getting brands recommended inside ChatGPT, Gemini, Perplexity and Google AI Overviews.",
    "description": "Hero image for Jraft Creative's GEO (Generative Engine Optimisation) agency landing page in Singapore. Visual identity supporting the AI search optimisation service that bridges Google SEO and generative AI citation work across ChatGPT, Gemini, Perplexity, Claude and Google AI Overviews."
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Force 3x2 grid on desktop for the deliver section per locked landing-page pattern */
  #sub-services .deliver-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  #sub-services {
    padding-top: 72px;
    padding-bottom: 72px;
  }
  @media (max-width: 900px) {
    #sub-services .deliver-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    #sub-services .deliver-grid {
      grid-template-columns: 1fr;
    }
  }

  /* AI Search Buyer Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="GEO Agency Singapore — Rank in ChatGPT & Gemini | Jraft"
  description="Specialist GEO agency in Singapore. We get your brand recommended by ChatGPT, Gemini, Perplexity, and AI Overviews — from S$3,000/mo."
  canonical="https://jraftcreative.com/geo-agency-singapore/"
  ogTitle="GEO Agency Singapore — Rank in ChatGPT & Gemini | Jraft"
  ogDescription="Specialist GEO agency in Singapore. Get your brand recommended by ChatGPT, Gemini, Perplexity, and Google AI Overviews."
  ogImage="https://jraftcreative.com/images/og-seo.jpg"
  keywords="geo agency singapore, generative engine optimisation agency, GEO services singapore, AI search agency, AI optimisation agency singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="GEO Agency · Singapore"
  heroTitle='Get Your Brand <span class="highlight">Named</span> Inside <span class="highlight">ChatGPT, Gemini &amp; AI Mode</span>'
  heroSubtitle="Google I/O 2026 confirmed AI Overviews now reach 2.5 billion monthly users and AI Mode 1 billion — search is changing fast. The SG buyer who used to type your category into Google now asks an AI that names three brands, and most of the time, none of them rank page-one. GEO is what gets your business into that three-brand answer."
  heroImage="/images/service-seo.webp"
  heroImageAlt="GEO agency Singapore — getting brands cited inside ChatGPT, Gemini, Perplexity, Claude, and Google AI Overviews"
  heroButtons={[
    { text: "Audit my AI visibility · S$1,000", href: "/ai-visibility-audit-singapore/", class: "btn btn-primary" },
    { text: 'DM "AUDIT" on WhatsApp', href: "https://wa.me/6582234578?text=AUDIT", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to learn about your GEO services in Singapore."
  ctaLabel="Start with the audit"
  ctaTitle='Find Out Which <span class="highlight">Competitors ChatGPT Names</span> Instead of <span class="highlight">You</span>'
  ctaDescription="The AI Visibility Audit runs 20–30 commercial prompts across ChatGPT, Gemini, Perplexity, Claude and AI Overviews against your brand and two SG competitors. 8–12 page report, top 5 gaps, 60-minute call. S$1,000 — credits 100% to month one if you sign a retainer within 30 days."
  ctaButtons={[
    { text: "Buy the audit · S$1,000", href: "/ai-visibility-audit-singapore/", class: "btn btn-primary" },
    { text: 'DM "AUDIT" on WhatsApp', href: "https://wa.me/6582234578?text=AUDIT", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why SG businesses need GEO">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The SG Search Market Has <span class="highlight">Split in Two</span> — and Most Agencies Still Only Work <span class="highlight">One Half</span></h2>
      </div>
      <div class="section-content reveal">
        <p>SG buyers research twice in 2026 — once on Google, once on an AI. Across the audits we run, fewer than 20% of brands cited inside AI answers are the same brands ranking page one on Google. Two surfaces, two games.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Google I/O 2026 Changed the Default</h3>
            <p>I/O 2026 made AI Overviews the default for 2.5 billion users. AI answers name three or four brands and stop — if you are not in that podium, you are not in the consideration set, no matter how well you rank on Google.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Sub-20% Overlap</h3>
            <p>Across SG audits we run, fewer than 20% of brands cited inside AI answers also rank page-one on Google for the same query. Different signals, different content shape, different game.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The SG Schema Gap</h3>
            <p>Under 30% of SG SME sites have correct FAQPage, Organization or Service schema. The technical bar to outrank competitors inside AI answers is the lowest it will ever be. Compound now or catch up later.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="What Jraft delivers as a GEO agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">GEO Moves</span> That Move <span class="highlight">Citation Rate</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build GEO programmes specifically for SG businesses — audit, technical foundation, content rewrite, authority building, monitoring, and the productised AVA SKU that lets you start before a retainer.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-seo-audit.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/ai-visibility-audit-singapore/">AI Visibility Audit (AVA)</a></h3>
            <p>20–30 prompts across ChatGPT, Gemini, Perplexity, Claude, AI Overviews. 8–12 page report, citation map, schema audit, two competitor benchmarks, top 5 gaps. S$1,000 one-time.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Schema &amp; Entity Layer</h3>
            <p>Organization, Service, FAQPage, Speakable, Person, BreadcrumbList across every commercial page. llms.txt deployed. Internal linking restructured so AI crawlers map your service tree in one pass.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-copywriting.webp');">
          <div class="service-detail-card__content">
            <h3>Answer-First Content Rewrite</h3>
            <p>LLMs cite definitional opening, specific number, comparison or condition. We rewrite your top commercial pages in that shape without losing the depth Google still rewards. Same content, both surfaces.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Citation &amp; Authority Building</h3>
            <p>Earned media and directory work across the sources LLMs trust — Wikipedia, .gov.sg, Business Times, CNA, The Edge, industry directories. The slow compounding lever, started early.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>Prompt &amp; Share-of-Voice Monitoring</h3>
            <p>4 to 50+ tracked prompts across ChatGPT, Gemini, Perplexity, Claude, AI Overviews. Monthly citation reporting with competitor share-of-voice. You see what moved against baseline, not just what shipped.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-analytics-reporting.webp');">
          <div class="service-detail-card__content">
            <h3>Sentiment Defence &amp; Crisis Alerts</h3>
            <p>Enterprise layer. Defensive monitoring catches the AI describing your business wrong, citing a stale article, or recommending a competitor by name when asked about you. We flag and fix.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative as your GEO agency">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Receipts, Not Decks</span> — Cited Inside AI Mode Across <span class="highlight">Five SG Verticals</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most "GEO agencies" in Singapore added the term to their service menu in late 2024. We built our agency around it — productised, performance-led, and measured on citation rate rather than retainer hours. The receipts are what separate operators from rebrands.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Multi-Niche AI Mode Citations</h3>
            <p>Jraft has been named inside Google AI Mode answers across aesthetics clinics, education, preschool and enrichment, beauty salons, and tuition — five SG verticals, dated screenshots logged. The strongest receipt no rebrand can fake.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Productised SKU Stack</h3>
            <p>S$1,000 AVA as the entry point. S$3K, S$5K, and S$10K+ retainers above it. Pricing published in full. The audit fee credits 100% to month one if you sign onto a retainer within 30 days of delivery.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Vertical-Specific Playbooks</h3>
            <p>The signals citing a clinic differ from those citing an enrichment centre. We run vertical-specific programmes across aesthetics, tuition, preschool, beauty, F&amp;B, clinics, gyms, e-commerce, and law firms.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== AI SEARCH BUYER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The AI Search Buyer Funnel — how SG buyers find brands through AI">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The AI Search Funnel</p>
        <h2>How <span class="highlight">SG Buyers</span> Now <span class="highlight">Find Brands</span> Through AI</h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>The path from a category question to a signed quote now runs through an AI before it touches your site. Five stages — and every retainer we run is built to show up at each one.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Query</h3>
          <p>SG buyer asks ChatGPT, Gemini or Perplexity</p>
        </li>
        <li class="funnel-stage">
          <h3>AI Surface</h3>
          <p>Three to four brands named in the answer</p>
        </li>
        <li class="funnel-stage">
          <h3>Citation</h3>
          <p>Your brand cited with link or sourced quote</p>
        </li>
        <li class="funnel-stage">
          <h3>Click</h3>
          <p>Buyer lands on your page from the citation</p>
        </li>
        <li class="funnel-stage">
          <h3>Convert</h3>
          <p>Quote request, booking or signed contract</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="GEO agency pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">GEO Pricing</p>
        <h2><span class="highlight">GEO Pricing</span> — Published in Full</h2>
        <p>Monthly retainers. No lock-in. SG market range is S$2,500–S$15,000/mo.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
