---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Clinic Website Design Singapore",
    "description": "Professional website design for medical clinics in Singapore. Patient booking systems, MOH-compliant design, PDPA-ready forms, and local SEO — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Clinic Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Clinic Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page clinic website with contact form, Google Maps, mobile-responsive design, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Clinic Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online booking system, blog, advanced SEO, Google Business Profile optimisation, and doctor profiles" },
      { "@type": "Offer", "name": "Premium Clinic Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-location support, patient portal, appointment system, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a clinic website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with contact form, Google Maps, and mobile-responsive design. Business and Premium packages add online booking, doctor profiles, patient portals, and multi-location support." } },
      { "@type": "Question", "name": "Will the clinic website comply with MOH advertising guidelines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We design every clinic website with MOH Private Healthcare Facilities Advertising Guidelines in mind. That means no unsubstantiated claims, proper use of qualifications, compliant before-and-after imagery for aesthetic clinics, and clear disclaimers where required. We work with you to ensure all content meets regulatory standards before going live." } },
      { "@type": "Question", "name": "Can you add an online booking system to my clinic website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online appointment booking integration. We can connect your website to clinic management systems or set up a standalone booking flow that lets patients select a doctor, choose a time slot, and receive confirmation — reducing phone calls and no-shows." } },
      { "@type": "Question", "name": "Will my clinic appear on Google Maps after the website is built?", "acceptedAnswer": { "@type": "Answer", "text": "We optimise your website for local SEO and integrate Google Maps on your contact and location pages. We also help set up and optimise your Google Business Profile so your clinic appears in Google Maps and local search results when patients search for clinics near them in Singapore." } },
      { "@type": "Question", "name": "How long does it take to build a clinic website?", "acceptedAnswer": { "@type": "Answer", "text": "Most clinic websites go live within 2–3 weeks. A straightforward 5-page site can be ready in as little as 2 weeks, while larger projects with booking systems, patient portals, or multi-location features may take 3–4 weeks. We provide a clear timeline before starting work." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Clinic Website Design Singapore", "item": "https://jraftcreative.com/clinic-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Clinic Website Design Singapore — Medical & Healthcare Websites | Jraft Creative"
  description="Professional website design for medical clinics in Singapore. Patient booking systems, MOH-compliant design, PDPA-ready forms, and local SEO — from S$2,500."
  canonical="https://jraftcreative.com/clinic-website-design-singapore/"
  ogTitle="Clinic Website Design Singapore — Jraft Creative"
  ogDescription="Website design for GP clinics, specialist clinics, and aesthetic clinics in Singapore. Booking systems, MOH compliance, local SEO — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="clinic website design singapore, medical website design singapore, doctor website singapore, gp clinic website, aesthetic clinic website singapore, healthcare web design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Clinic Website Design"
  heroTitle='Website Design for Medical <span class="highlight">Clinics in Singapore</span>'
  heroSubtitle="Your clinic needs more than a listing on a directory. We build fast, MOH-compliant websites for GP clinics, specialist practices, and aesthetic clinics — with patient booking, PDPA-ready forms, and local SEO built in."
  heroImage="/images/service-clinic.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my clinic in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Clinic Online"
  ctaDescription="Book a free consultation and tell us about your clinic. We'll get back to you within 24 hours with a tailored proposal — whether you're a solo GP, a specialist practice, or a multi-branch aesthetic clinic."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why clinics in Singapore need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Patients Are Searching — Can They Find Your Clinic?</h2>
      </div>
      <div class="section-content reveal">
        <p>Most patients in Singapore search for "clinic near me" or "GP near Toa Payoh" before deciding where to go. If your clinic doesn't have its own website — or relies on a basic directory listing with no booking option — you're losing patients to the clinic down the road that made it easy to find them, read reviews, and book an appointment online.</p>
        <p>Running a medical practice in Singapore also means navigating strict advertising regulations. The Ministry of Health's Private Healthcare Facilities Advertising Guidelines dictate what you can and cannot say online. A generic website template won't account for these rules, and getting it wrong can mean costly compliance issues — or worse, having your listing taken down.</p>
        <p>Then there's patient data. Every contact form, booking request, and enquiry your website collects falls under Singapore's Personal Data Protection Act. Your website needs proper consent mechanisms, secure data handling, and a clear privacy policy — not an afterthought checkbox. Whether you run a neighbourhood GP clinic, a specialist practice, or an aesthetic clinic with multiple branches, your website has to work harder than most.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Clinic website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Medical Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>Every clinic website we deliver is purpose-built for healthcare in Singapore. We go beyond generic templates — your site will feature patient booking flows, doctor profile pages, MOH-compliant content, and local SEO so patients can find you on Google Maps when they need care.</p>
        <p>We understand that clinics need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for local healthcare searches, <a href="/services/social-media/">social media marketing</a> for patient education content that builds trust, and <a href="/services/paid-ads/">paid ads management</a> for targeted campaigns that bring new patients through your door.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Patient Booking System</h3>
            <p>Let patients book appointments directly from your website. We integrate scheduling tools that show available time slots, send confirmations, and reduce no-shows — so your front desk spends less time on the phone.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>MOH-Compliant Design</h3>
            <p>We build your website with MOH Private Healthcare Facilities Advertising Guidelines front and centre. No unsubstantiated claims, proper credential displays, compliant imagery, and clear disclaimers — so your clinic stays on the right side of the regulations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO &amp; Google Maps</h3>
            <p>We optimise your site so it appears when patients search "clinic near me" or "GP in Tampines." Google Business Profile setup, medical schema markup, and maps integration help patients find you fast.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>PDPA-Compliant Forms</h3>
            <p>Every form on your clinic website — appointment requests, enquiries, feedback — is built with PDPA compliance in mind. Proper consent collection, secure data handling, and a clear privacy policy protect both your patients and your practice.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for clinic website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Clinic Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for healthcare providers across Singapore and understand the unique demands of the medical industry — from regulatory compliance to patient trust. Every design decision we make is focused on helping your clinic attract new patients and deliver a professional online experience.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare Industry Experience</h3>
            <p>We understand MOH advertising guidelines, PDPA requirements, and the patient journey. Your website will be built by a team that knows healthcare — not a generic agency applying a one-size-fits-all approach.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most clinic websites go live within 2 weeks of kickoff. Whether you're opening a new practice or replacing an outdated site, we deliver on time without cutting corners.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Patients search for clinics on their phones. Every site we build loads fast, works perfectly on mobile, and includes tap-to-call buttons and easy-to-use booking forms designed for smaller screens.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on patient care instead of marketing logistics.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Clinic website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Clinic Website Pricing</p>
        <h2>Website Packages for Medical Clinics</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new clinics getting their first professional website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Contact form &amp; enquiry page</li>
              <li>Google Maps integration</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For clinics ready to grow their patient base online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online booking system</li>
              <li>Blog / health articles section</li>
              <li>Advanced SEO &amp; medical schema</li>
              <li>Google Business Profile setup</li>
              <li>Doctor profile pages</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-location clinics or specialist practices.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-location support</li>
              <li>Patient portal integration</li>
              <li>Appointment management system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about clinic website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Clinic Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a clinic website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional clinic website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with contact form, Google Maps, and mobile-responsive design. Business and Premium packages add online booking, doctor profiles, patient portals, and multi-location support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will the website comply with MOH advertising guidelines?</summary>
          <div class="faq-answer"><p>Yes. We design every clinic website with MOH Private Healthcare Facilities Advertising Guidelines in mind. That means no unsubstantiated claims, proper use of qualifications, compliant before-and-after imagery for aesthetic clinics, and clear disclaimers where required. We work with you to ensure all content meets regulatory standards before going live.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you add an online booking system to my clinic website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online appointment booking integration. We can connect your website to clinic management systems or set up a standalone booking flow that lets patients select a doctor, choose a time slot, and receive confirmation — reducing phone calls and no-shows.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will my clinic appear on Google Maps after the website is built?</summary>
          <div class="faq-answer"><p>We optimise your website for local SEO and integrate Google Maps on your contact and location pages. We also help set up and optimise your Google Business Profile so your clinic appears in Google Maps and local search results when patients search for clinics near them in Singapore.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a clinic website?</summary>
          <div class="faq-answer"><p>Most clinic websites go live within 2–3 weeks. A straightforward 5-page site can be ready in as little as 2 weeks, while larger projects with booking systems, patient portals, or multi-location features may take 3–4 weeks. We provide a clear timeline before starting work.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
