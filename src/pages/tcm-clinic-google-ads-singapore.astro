---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "TCM Clinic Google Ads Singapore",
    "description": "Google Ads management for TCM clinics in Singapore — treatment-specific targeting, bilingual campaigns in English and Chinese, culturally sensitive ad copy, and conversion tracking. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for TCM Clinics",
    "offers": [
      { "@type": "Offer", "name": "Starter TCM Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, TCM keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth TCM Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, bilingual campaigns, A/B testing, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale TCM Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should TCM clinics budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most TCM clinics start with a monthly ad spend of $1,000–$3,500 on top of management fees. Keywords like 'TCM clinic Singapore' typically cost $1.50–$5 per click, while treatment-specific terms like 'acupuncture for back pain Singapore' cost $2–$7. We set your budget based on the treatments you want to promote and your clinic's appointment capacity." } },
      { "@type": "Question", "name": "Can you run bilingual Google Ads campaigns for TCM clinics?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We run parallel campaigns in English and Chinese to reach Singapore's multilingual audience. Chinese-language campaigns often have lower competition and cost per click, while capturing an audience segment that many competitors overlook. Ad copy, keywords, and landing pages are crafted natively in both languages — not machine-translated." } },
      { "@type": "Question", "name": "Which TCM treatments work best with Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Treatments with high search volume and clear patient intent perform best — acupuncture, tuina massage, cupping therapy, fertility support, pain management, and herbal medicine consultations. We also target condition-specific searches like 'TCM for insomnia' or 'acupuncture for migraine' to capture patients with specific health concerns." } },
      { "@type": "Question", "name": "How do you handle healthcare advertising regulations for TCM ads?", "acceptedAnswer": { "@type": "Answer", "text": "We follow Google's healthcare advertising policies and Singapore's TCM practitioner advertising guidelines. This means avoiding unsubstantiated claims, using compliant language around treatment benefits, and ensuring landing pages present accurate treatment information with proper practitioner credentials." } },
      { "@type": "Question", "name": "How do you track new patient bookings from Google Ads?", "acceptedAnswer": { "@type": "Answer", "text": "We set up conversion tracking across appointment booking forms, phone calls, WhatsApp messages, and walk-in tracking where possible. Every patient enquiry is attributed to the specific keyword and campaign that generated it — so you know exactly which treatments and keywords bring in the most patients." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "TCM Clinic Google Ads Singapore", "item": "https://jraftcreative.com/tcm-clinic-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="TCM Clinic Google Ads Singapore — PPC for TCM Clinics | Jraft Creative"
  description="Google Ads management for TCM clinics in Singapore. Treatment-specific targeting, bilingual campaigns, culturally sensitive ad copy, and full conversion tracking. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/tcm-clinic-google-ads-singapore/"
  ogTitle="TCM Clinic Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for TCM clinics in Singapore. Acupuncture, tuina, cupping, and herbal medicine campaigns in English and Chinese. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="tcm clinic google ads singapore, tcm advertising singapore, google ads for tcm clinics, ppc tcm singapore, tcm marketing singapore, acupuncture ads singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="TCM Clinic Google Ads Singapore"
  heroTitle='Google Ads for TCM Clinics <span class="highlight">in Singapore</span>'
  heroSubtitle="Patients are searching for acupuncture, tuina, cupping, and herbal medicine — in English and Chinese. We build Google Ads campaigns that connect your TCM clinic with patients at the moment they need treatment, with culturally sensitive messaging and bilingual targeting."
  heroImage="/images/service-tcm.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my TCM clinic in Singapore."
  ctaLabel="Grow Your Patient Base"
  ctaTitle="Get a Free TCM Clinic Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll analyse your treatment specialties, review competitor ad activity, and map out a bilingual Google Ads strategy tailored to your clinic's strengths and patient targets. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20TCM%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for TCM clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Patients Are Searching for TCM — But Finding Your Competitors First</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's TCM market serves over 2 million visits annually, with patients increasingly searching online before choosing a clinic. When someone searches "acupuncture clinic near me" or "TCM for back pain", the clinics that appear in paid search results capture those patients first. If your clinic relies solely on walk-ins and word-of-mouth, you're ceding ground to competitors who advertise online.</p>
        <p>TCM advertising presents unique challenges — the need for bilingual campaigns that resonate with both English and Chinese-speaking patients, healthcare compliance requirements, and the cultural sensitivity required when positioning traditional treatments alongside modern healthcare. Without a specialist approach, TCM clinics either get ads disapproved or run generic campaigns that fail to connect with the right patients.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for TCM clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our TCM Clinic Ad Services</p>
        <h2>Google Ads Strategy Built for TCM Practices</h2>
      </div>
      <div class="section-content reveal">
        <p>We create Google Ads campaigns specifically for TCM clinics in Singapore — targeting the treatments patients search for in both English and Chinese, across the neighbourhoods where your clinic operates. Whether you specialise in acupuncture in Chinatown, fertility TCM in the East, or pain management tuina in heartland clinics, every campaign is designed to drive patient bookings.</p>
        <p>Our approach covers treatment-specific keyword targeting, bilingual campaign management, culturally sensitive ad copy, and healthcare-compliant landing pages — ensuring your ad budget reaches patients with genuine intent to seek TCM treatment.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Treatment-Specific Campaigns</h3>
            <p>Separate campaigns for each treatment modality — acupuncture, tuina, cupping, herbal medicine, and moxibustion. Each campaign targets condition-specific keywords like "acupuncture for migraine" or "TCM fertility treatment" with tailored ad copy and landing pages.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Bilingual Campaign Management</h3>
            <p>Parallel campaigns in English and Chinese that reach Singapore's full patient base. Chinese-language campaigns often have lower competition and unlock an audience segment most competitors miss entirely — with natively written ad copy, not machine translations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Patient Enquiry Tracking</h3>
            <p>Full conversion tracking across booking forms, phone calls, WhatsApp messages, and clinic management system integrations. Every patient enquiry is attributed to the specific keyword and campaign — giving you clear cost-per-patient data across both language campaigns.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Compliant &amp; Culturally Sensitive Pages</h3>
            <p>Landing pages that balance traditional treatment positioning with healthcare compliance requirements. Proper practitioner credentials, treatment descriptions that comply with advertising guidelines, and culturally appropriate messaging that builds trust with patients.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for TCM clinic Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>We Understand Singapore's TCM Market</h2>
      </div>
      <div class="section-content reveal">
        <p>We've managed ad campaigns for healthcare businesses across Singapore and understand the unique requirements of TCM advertising. Here's why TCM clinics choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Bilingual Market Expertise</h3>
            <p>We run campaigns in both English and Chinese — reaching the full spectrum of TCM patients in Singapore. Our bilingual approach captures lower-cost Chinese-language clicks that most agencies can't deliver.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each patient enquiry costs your clinic.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that flex with your clinic's patient flow. Scale up during peak seasons like Chinese New Year wellness checks, adjust during quieter months — no penalties, no fixed terms.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare Compliance Built In</h3>
            <p>Every campaign is built with healthcare advertising compliance from the start — no rejected ads, no policy violations, no wasted time on appeals. We know what Google allows for TCM advertising and structure campaigns accordingly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="TCM clinic Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">TCM Ads Pricing</p>
        <h2>Google Ads Plans for TCM Clinics</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For TCM clinics launching their first Google Ads campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>TCM keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For TCM clinics adding bilingual campaigns and multiple treatments.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>Bilingual English &amp; Chinese campaigns</li>
              <li>Landing page optimisation</li>
              <li>Competitor ad analysis</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-branch TCM practices maximising patient acquisition.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for TCM clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>TCM Clinic Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should TCM clinics budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Most TCM clinics start with a monthly ad spend of $1,000–$3,500 on top of management fees. Keywords like "TCM clinic Singapore" typically cost $1.50–$5 per click, while treatment-specific terms like "acupuncture for back pain Singapore" cost $2–$7. We set your budget based on the treatments you want to promote and your clinic's appointment capacity.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you run bilingual Google Ads campaigns for TCM clinics?</summary>
          <div class="faq-answer"><p>Yes. We run parallel campaigns in English and Chinese to reach Singapore's multilingual audience. Chinese-language campaigns often have lower competition and cost per click, while capturing an audience segment that many competitors overlook. Ad copy, keywords, and landing pages are crafted natively in both languages — not machine-translated.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Which TCM treatments work best with Google Ads?</summary>
          <div class="faq-answer"><p>Treatments with high search volume and clear patient intent perform best — acupuncture, tuina massage, cupping therapy, fertility support, pain management, and herbal medicine consultations. We also target condition-specific searches like "TCM for insomnia" or "acupuncture for migraine" to capture patients with specific health concerns.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you handle healthcare advertising regulations for TCM ads?</summary>
          <div class="faq-answer"><p>We follow Google's healthcare advertising policies and Singapore's TCM practitioner advertising guidelines. This means avoiding unsubstantiated claims, using compliant language around treatment benefits, and ensuring landing pages present accurate treatment information with proper practitioner credentials.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you track new patient bookings from Google Ads?</summary>
          <div class="faq-answer"><p>We set up conversion tracking across appointment booking forms, phone calls, WhatsApp messages, and walk-in tracking where possible. Every patient enquiry is attributed to the specific keyword and campaign that generated it — so you know exactly which treatments and keywords bring in the most patients.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
