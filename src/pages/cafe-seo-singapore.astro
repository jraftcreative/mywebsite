---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Cafe SEO Singapore",
    "description": "SEO services for cafes and coffee shops in Singapore. Local search optimisation, Google Maps ranking, and content strategy to drive foot traffic — from S$800/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Cafe SEO",
    "offers": [
      { "@type": "Offer", "name": "Essential Cafe SEO", "price": "800", "priceCurrency": "SGD", "description": "Technical SEO audit, on-page optimisation for 10 pages, Google Business Profile setup, and monthly reporting" },
      { "@type": "Offer", "name": "Growth Cafe SEO", "price": "1500", "priceCurrency": "SGD", "description": "Everything in Essential plus content strategy, local citation building, review management, competitor monitoring, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Cafe SEO", "price": "3000", "priceCurrency": "SGD", "description": "Full-service SEO with dedicated strategist, multi-location cafe SEO, content creation, advanced link building, and weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does SEO cost for a cafe in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Cafe SEO in Singapore ranges from $800 to $3,000+ per month. Our Essential plan at $800 SGD/month covers technical SEO, on-page optimisation, and Google Business Profile setup. Growth and Enterprise plans add content strategy, review management, and multi-location SEO for cafe chains." } },
      { "@type": "Question", "name": "How long does cafe SEO take to show results?", "acceptedAnswer": { "@type": "Answer", "text": "Most cafes see noticeable ranking improvements within 3 to 4 months. Google Business Profile optimisation and technical fixes can show quick wins in weeks. Neighbourhood-specific keywords like 'cafe near Tiong Bahru' or 'brunch cafe Holland Village' rank faster than broad terms." } },
      { "@type": "Question", "name": "Can SEO help my cafe appear on Google Maps?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Google Maps ranking is a core part of our cafe SEO service. We optimise your Google Business Profile with cafe categories, interior and food photos, menu uploads, and review management so you appear in the Maps 3-pack for 'cafe near me' searches in your area." } },
      { "@type": "Question", "name": "What keywords do people search when looking for a cafe?", "acceptedAnswer": { "@type": "Answer", "text": "Common searches include 'cafe near me', 'brunch cafe Singapore', 'best coffee Tiong Bahru', 'work-friendly cafe', 'aesthetic cafe Singapore', and neighbourhood-specific queries. We research the exact terms driving foot traffic in your area and build your SEO around them." } },
      { "@type": "Question", "name": "Do you work with cafe chains that have multiple outlets?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Enterprise plan handles multi-location cafe SEO. We create unique landing pages for each outlet, manage individual Google Business Profiles, and build location-specific citations so each branch ranks in its own neighbourhood independently." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Cafe SEO Singapore", "item": "https://jraftcreative.com/cafe-seo-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Cafe SEO Singapore — Rank Higher, Drive More Foot Traffic | Jraft Creative"
  description="SEO services for cafes and coffee shops in Singapore. Local search optimisation, Google Maps ranking, and content strategy to drive foot traffic — from S$800/month."
  canonical="https://jraftcreative.com/cafe-seo-singapore/"
  ogTitle="Cafe SEO Singapore — Jraft Creative"
  ogDescription="SEO for cafes and coffee shops in Singapore. Local search, Google Maps ranking, and content strategy — from $800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="cafe seo singapore, coffee shop seo, seo for cafes, cafe google ranking, cafe local seo, cafe near me seo, brunch cafe seo, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Cafe SEO"
  heroTitle='SEO Services for <span class="highlight">Cafes in Singapore</span>'
  heroSubtitle="Singapore's cafe scene is thriving — but that means competition for foot traffic has never been fiercer. When brunch-goers search 'cafe near me' or 'best coffee Tiong Bahru', your cafe needs to be at the top. We build SEO strategies that turn Google searches into customers at your tables."
  heroImage="/images/service-cafe.webp"
  heroButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View SEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need SEO for my cafe in Singapore."
  ctaLabel="Ready to Rank Higher?"
  ctaTitle="Get Your Cafe Found on Google"
  ctaDescription="Book a free SEO audit and we'll show you where your cafe stands in local search compared to nearby competitors. We'll respond within 24 hours."
  ctaButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20SEO%20for%20my%20cafe%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why cafes need SEO">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Hundreds of Cafes — Can Coffee Lovers Find Yours?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's cafe culture has exploded. From specialty coffee roasters in Everton Park to aesthetic brunch spots in Tiong Bahru, new cafes open every month. When someone searches "cafe near me" or "best brunch in Singapore", the top results on Google Maps capture the foot traffic. If your cafe isn't ranking, those customers walk right past your door to the competitor who shows up first.</p>
        <p>Social media can drive buzz, but it's fleeting. A viral Instagram post lasts a day. SEO delivers consistent, long-term traffic from people actively searching for a place to grab coffee, work, or have brunch — every single day. Unlike paid ads, organic search traffic doesn't stop when you stop spending.</p>
        <p>Most cafe websites are minimal — a homepage, a short menu, and an Instagram link. Without proper local SEO signals, menu pages optimised for how people actually search, and a well-managed Google Business Profile, your cafe is invisible to the thousands of people searching for their next coffee spot every week.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" aria-label="Cafe SEO services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our SEO Services</p>
        <h2>SEO Built for Cafes &amp; Coffee Shops</h2>
      </div>
      <div class="section-content reveal">
        <p>Cafe SEO requires understanding how coffee lovers and brunch-goers search. They look by neighbourhood, vibe, dietary options, and occasion. We build SEO strategies tailored to how Singapore's cafe crowd discovers new spots.</p>
        <p>Pair SEO with a professionally designed <a href="/cafe-website-design-singapore/">cafe website</a>, <a href="/services/social-media/">social media marketing</a> for food and coffee content, or <a href="/services/paid-ads/">Google Ads</a> to capture demand during peak brunch hours and weekends.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>Technical SEO Audit</h3>
            <p>Complete crawl of your cafe website to find indexing gaps, broken links, missing structured data, and mobile issues. We fix the technical barriers preventing Google from ranking your cafe for local searches.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>Menu &amp; Page Optimisation</h3>
            <p>Keyword-optimised pages for your menu, location, and cafe experience. Meta titles, descriptions, and Cafe schema markup targeting searches like "brunch cafe Tiong Bahru", "specialty coffee near me", and "work-friendly cafe Singapore".</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO &amp; Google Maps</h3>
            <p>Google Business Profile optimisation with correct cafe categories, interior photos, menu uploads, and review management. Designed to get your cafe into the Maps 3-pack for "cafe near me" searches in your neighbourhood.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Content Strategy &amp; Blog</h3>
            <p>Blog content targeting searches like "best cafes in Tiong Bahru", "specialty coffee guide Singapore", and "work-friendly cafes". Content that builds your authority, earns backlinks, and captures customers during their discovery phase.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for cafe SEO">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>An SEO Agency That Gets Cafe Culture</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with cafes and F&B businesses across Singapore. We understand how brunch-goers, coffee enthusiasts, and remote workers discover and choose cafes — and we build every SEO strategy around that behaviour.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Cafe Industry Knowledge</h3>
            <p>We know the difference between specialty coffee SEO, brunch SEO, and work-friendly cafe searches. Your strategy targets the specific audience your cafe serves, not generic food keywords.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Neighbourhood-Level Targeting</h3>
            <p>Most cafe-goers want somewhere nearby. We optimise for neighbourhood searches — Tiong Bahru, Joo Chiat, Holland Village, Bugis, Dempsey — so your cafe ranks where your customers live and work.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Clear Monthly Reporting</h3>
            <p>Every month you see keyword rankings, organic traffic, Google Maps performance, and foot traffic trends. Data tied to real business outcomes — not vanity metrics.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>SEO, website design, social media, and paid ads under one roof. We can handle your cafe's entire digital presence so you can focus on perfecting your pour-over and pastries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Cafe SEO pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Cafe SEO Pricing</p>
        <h2>SEO Plans for Cafes &amp; Coffee Shops</h2>
        <p>Monthly retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location cafes building search visibility.</p>
            <ul class="pricing-features">
              <li>Technical SEO audit</li>
              <li>On-page optimisation (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Cafe schema markup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$1,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For cafes ready to dominate local search.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Content strategy &amp; blog posts</li>
              <li>Local citation building</li>
              <li>Review management</li>
              <li>Competitor monitoring</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$3,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For cafe chains and multi-outlet operators.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Dedicated SEO strategist</li>
              <li>Multi-location local SEO</li>
              <li>Content creation &amp; publishing</li>
              <li>Advanced link building</li>
              <li>Weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/seo-performance/" class="inline-link">SEO &amp; Performance</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about cafe SEO in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Cafe SEO Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does SEO cost for a cafe in Singapore?</summary>
          <div class="faq-answer"><p>Cafe SEO in Singapore ranges from $800 to $3,000+ per month. Our Essential plan at $800 SGD/month covers technical SEO, on-page optimisation, and Google Business Profile setup. Growth and Enterprise plans add content strategy, review management, and multi-location SEO for cafe chains.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does cafe SEO take to show results?</summary>
          <div class="faq-answer"><p>Most cafes see noticeable ranking improvements within 3 to 4 months. Google Business Profile optimisation and technical fixes can show quick wins in weeks. Neighbourhood-specific keywords like "cafe near Tiong Bahru" or "brunch cafe Holland Village" rank faster than broad terms.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can SEO help my cafe appear on Google Maps?</summary>
          <div class="faq-answer"><p>Yes. Google Maps ranking is a core part of our cafe SEO service. We optimise your Google Business Profile with cafe categories, interior and food photos, menu uploads, and review management so you appear in the Maps 3-pack for "cafe near me" searches in your area.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>What keywords do people search when looking for a cafe?</summary>
          <div class="faq-answer"><p>Common searches include "cafe near me", "brunch cafe Singapore", "best coffee Tiong Bahru", "work-friendly cafe", "aesthetic cafe Singapore", and neighbourhood-specific queries. We research the exact terms driving foot traffic in your area and build your SEO around them.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you work with cafe chains that have multiple outlets?</summary>
          <div class="faq-answer"><p>Yes. Our Enterprise plan handles multi-location cafe SEO. We create unique landing pages for each outlet, manage individual Google Business Profiles, and build location-specific citations so each branch ranks in its own neighbourhood independently.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
