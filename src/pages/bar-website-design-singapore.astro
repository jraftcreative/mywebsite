---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Bar Website Design Singapore",
    "description": "Professional website design for bars, pubs, and cocktail lounges in Singapore. Events calendar, cocktail menus, and reservation systems — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Bar Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Bar Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page bar website with cocktail menu, events page, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Bar Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with reservation system, events calendar, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Bar Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-venue support, membership portal, loyalty programme integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a bar website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional bar website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with cocktail menu, events page, contact form, and Google Maps integration. Business and Premium packages add reservation systems, events calendars, and membership portals." } },
      { "@type": "Question", "name": "Can you add a reservation system to my bar website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include reservation system integration. We can connect to platforms like Chope or build a custom booking system that handles table reservations, VIP bookings, and private event enquiries directly through your website." } },
      { "@type": "Question", "name": "Do you build events pages for bar websites?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Events are a major draw for bars in Singapore. We build dynamic events pages with upcoming listings, past highlights, and easy-to-update calendar systems so you can promote live music, DJ nights, happy hours, and themed events without needing a developer." } },
      { "@type": "Question", "name": "Will my bar show up on Google when people search nearby?", "acceptedAnswer": { "@type": "Answer", "text": "We optimise your website for local SEO and set up your Google Business Profile so your bar appears in Google Maps and local search results. When people search 'bars near me' or 'cocktail bar Clarke Quay', your venue will have the best chance of showing up." } },
      { "@type": "Question", "name": "How long does it take to build a bar website?", "acceptedAnswer": { "@type": "Answer", "text": "Most bar websites go live within 2–3 weeks. A simple 5-page site can be ready in 2 weeks, while larger projects with reservation systems or membership features may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Bar Website Design Singapore", "item": "https://jraftcreative.com/bar-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Bar Website Design Singapore — Cocktail Bar & Pub Websites | Jraft Creative"
  description="Professional website design for bars, pubs, and cocktail lounges in Singapore. Events calendar, cocktail menus, and reservation systems — from S$2,500."
  canonical="https://jraftcreative.com/bar-website-design-singapore/"
  ogTitle="Bar Website Design Singapore — Jraft Creative"
  ogDescription="Website design for bars and cocktail lounges in Singapore. Events calendar, cocktail menus, reservations — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="bar website design singapore, cocktail bar website singapore, pub website design, bar web design singapore, nightlife website singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Bar Website Design"
  heroTitle='Website Design for <span class="highlight">Bars in Singapore</span>'
  heroSubtitle="Your bar's atmosphere shouldn't stop at the door. We build websites for bars, pubs, and cocktail lounges in Singapore — with cocktail menus, events calendars, reservations, and local SEO that brings people through the door."
  heroImage="/images/service-bar.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my bar in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Bar Online"
  ctaDescription="Book a free consultation and tell us about your bar or cocktail lounge. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20bar%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why bars need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Bar Needs More Than an Instagram Page</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's nightlife scene is packed with options — from speakeasies on Ann Siang Hill to rooftop bars on the Marina Bay waterfront. When someone searches "bars near me" or "cocktail bar Clarke Quay" on a Friday night, you need to be the first result they see. An Instagram page alone isn't enough.</p>
        <p>Without a proper website, you're invisible to Google search, missing out on reservation enquiries, and losing event bookings to competitors who make it easy for guests to browse cocktail menus, check upcoming events, and reserve a table from their phone in seconds.</p>
        <p>Whether you run a craft cocktail bar, a neighbourhood pub, a rooftop lounge, or a live music venue, your website is the digital front door to your business. It needs to capture the vibe of your venue and make it effortless for guests to visit, book, and come back.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Bar website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Bars &amp; Lounges</h2>
      </div>
      <div class="section-content reveal">
        <p>Every bar website we deliver is built to capture your venue's identity and convert visitors into guests. From cocktail menus and events calendars to reservation systems and local SEO — your site will work as hard as your bartenders do on a Saturday night.</p>
        <p>We also offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for nightlife searches, <a href="/services/social-media/">social media marketing</a> for cocktail and event content, and <a href="/services/paid-ads/">paid ads management</a> to promote events and happy hours.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Cocktail Menu &amp; Drinks Showcase</h3>
            <p>Beautifully designed menu pages with cocktail descriptions, pricing, and photography. Easy to update when you rotate seasonal drinks or launch new signature cocktails.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Events Calendar &amp; Promotions</h3>
            <p>Dynamic events pages for live music, DJ nights, happy hours, and private bookings. Guests can browse upcoming events and share them directly from your site.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Reservations &amp; VIP Booking</h3>
            <p>Integrated reservation system for table bookings, VIP areas, and private events. Reduce no-shows with automated confirmations and let guests book 24/7 from any device.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Atmosphere &amp; Photography</h3>
            <p>Full-bleed hero shots, gallery pages, and video backgrounds that capture the ambience of your bar. Your website should feel like stepping through the door.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for bar website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Bar Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We build websites for nightlife venues that look the part and drive real results. From cocktail bars to neighbourhood pubs, we understand what makes guests click "Reserve" instead of scrolling past.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Nightlife Industry Experience</h3>
            <p>We know what bar-goers look for — events, menus, location, vibe. Every element of your site is designed around how guests discover, evaluate, and choose bars in Singapore.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most bar websites go live within 2 weeks. Whether you're opening a new venue or refreshing an existing one, we move fast without cutting corners.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Design</h3>
            <p>Most guests check bar websites on their phone while deciding where to go. Every site is optimised for mobile with fast load times, tap-to-call, and easy navigation.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire digital presence so you can focus on creating great drinks and memorable nights.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Bar website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Bar Website Pricing</p>
        <h2>Website Packages for Bars &amp; Lounges</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new bars and pubs getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Cocktail / drinks menu</li>
              <li>Events page</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For bars ready to grow their bookings.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Reservation system integration</li>
              <li>Events calendar</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Photo &amp; video gallery</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-venue or high-end cocktail bars.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-venue support</li>
              <li>Membership / loyalty portal</li>
              <li>Private event booking system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about bar website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Bar Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a bar website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional bar website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with cocktail menu, events page, contact form, and Google Maps integration. Business and Premium packages add reservation systems, events calendars, and membership portals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add a reservation system to my bar website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include reservation system integration. We can connect to platforms like Chope or build a custom booking system that handles table reservations, VIP bookings, and private event enquiries directly through your website.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build events pages for bar websites?</summary>
          <div class="faq-answer"><p>Absolutely. Events are a major draw for bars in Singapore. We build dynamic events pages with upcoming listings, past highlights, and easy-to-update calendar systems so you can promote live music, DJ nights, happy hours, and themed events without needing a developer.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will my bar show up on Google when people search nearby?</summary>
          <div class="faq-answer"><p>We optimise your website for local SEO and set up your Google Business Profile so your bar appears in Google Maps and local search results. When people search "bars near me" or "cocktail bar Clarke Quay", your venue will have the best chance of showing up.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a bar website?</summary>
          <div class="faq-answer"><p>Most bar websites go live within 2–3 weeks. A simple 5-page site can be ready in 2 weeks, while larger projects with reservation systems or membership features may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
