---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Law Firm Website Design Singapore",
    "description": "Professional website design for law firms in Singapore. Practice area pages, lawyer profiles, and compliance with Legal Profession publicity rules — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Law Firm Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Law Firm Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page law firm website with practice area pages, lawyer profiles, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Law Firm Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with case study pages, blog, advanced SEO, Google Business Profile, and client testimonials" },
      { "@type": "Offer", "name": "Premium Law Firm Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with client portal, document management, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a law firm website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional law firm website in Singapore typically costs between $2,500 and $10,000+ depending on complexity. Our Starter package at $2,500 SGD includes a 5-page site with practice area pages, lawyer profiles, and contact form. Business and Premium packages add blogs, client portals, and advanced features." } },
      { "@type": "Question", "name": "Will my law firm website comply with the Legal Profession (Publicity) Rules?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We design law firm websites that comply with Singapore's Legal Profession (Publicity) Rules. This includes restrictions on solicitation, proper disclosure of qualifications, and appropriate presentation of case results. We review all content against current guidelines before launch." } },
      { "@type": "Question", "name": "Can you add a client portal to my law firm website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package includes a secure client portal where clients can access case documents, track matter progress, and communicate with your team. The portal uses SSL encryption and access controls to protect confidential information." } },
      { "@type": "Question", "name": "Do you help with SEO for law firm websites?", "acceptedAnswer": { "@type": "Answer", "text": "Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with practice-area-specific keyword targeting, legal schema markup, and Google Business Profile optimisation. We help you rank for searches like 'corporate lawyer Singapore' or 'family law firm Singapore'." } },
      { "@type": "Question", "name": "How long does it take to build a law firm website?", "acceptedAnswer": { "@type": "Answer", "text": "Most law firm websites go live within 2–3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or multi-language support may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Law Firm Website Singapore", "item": "https://jraftcreative.com/law-firm-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Law Firm Website Singapore — Jraft Creative"
  description="Website design for Singapore law firms — practice areas, lawyer profiles, and compliance with Legal Profession publicity rules. From S$2,500."
  canonical="https://jraftcreative.com/law-firm-website-singapore/"
  ogTitle="Law Firm Website Singapore — Jraft Creative"
  ogDescription="Website design for Singapore law firms — practice areas, lawyer profiles, and compliance with Legal Profession publicity rules. From S$2,500."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="law firm website singapore, legal website design singapore, lawyer website singapore, corporate law firm website, family law website singapore, legal practice web design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Law Firm Websites"
  heroTitle='Website Design for <span class="highlight">Law Firms in Singapore</span>'
  heroSubtitle="Your practice deserves a website that reflects your professionalism. We build authoritative, mobile-friendly websites for law firms — with practice area pages, lawyer profiles, and full compliance with the Legal Profession (Publicity) Rules."
  heroImage="/images/service-law.webp"
  heroImageAlt="Singapore law firm website design — practice area pages and lawyer profiles"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my law firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Law Firm Online"
  ctaDescription="Book a free consultation and tell us about your practice. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why law firms need a credible, compliant website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Clients Judge Your <span class="highlight">Firm</span> by Your <span class="highlight">Website</span> — Before They Call</h2>
      </div>
      <div class="section-content reveal">
        <p>Prospective clients don't choose a lawyer at random. They research firms online, compare practice areas, read lawyer profiles, and look for trust signals — all before making contact. A site that looks dated, generic, or hard to navigate undermines the credibility you've spent years building, and it has to do all of this while staying inside Singapore's publicity rules.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Credibility Decided in Seconds</h3>
            <p>Prospective clients form a judgement about your firm within seconds of landing on your site. Slow load times, an outdated design, or a confusing layout signal exactly the wrong thing to someone weighing who to trust with a sensitive legal matter — and they move on to a firm that presents itself more credibly.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Publicity Rules Compliance</h3>
            <p>Singapore's Legal Profession (Publicity) Rules govern how firms present themselves online — restrictions on solicitation, accurate disclosure of qualifications, and how case results may be shown. You need a designer who builds your site around these rules, not a generic agency that treats your firm like any other business.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Research Without Enquiries</h3>
            <p>Traffic alone doesn't grow a practice. If a researching client can't quickly find the relevant practice area, understand who would handle their matter, and reach you in a couple of taps, the visit ends without an enquiry. The site has to convert quiet research into a booked consultation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Law firm website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of a Law Firm <span class="highlight">Website</span></h2>
      </div>
      <div class="section-content reveal">
        <p>A law firm website isn't a brochure or a generic template. It has to project authority, route a researching client to the right practice area, capture an enquiry without breaching publicity rules, and load fast on a phone. We build every element around how clients actually choose a lawyer in Singapore.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Credibility-Led Design</h3>
            <p>A clean, authoritative design that signals competence and trust the moment a prospective client arrives — considered typography, professional imagery, and a layout that reflects the standing of your practice rather than a stock template.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Practice-Area &amp; Credential Pages</h3>
            <p>Dedicated pages for every area of law you cover — corporate, family, criminal, IP, employment — plus lawyer profiles with qualifications, expertise, and professional memberships, all presented in line with the Legal Profession (Publicity) Rules.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Secure Enquiry &amp; Intake Forms</h3>
            <p>Conversion-focused contact and consultation-booking forms with practice-area routing and conflict-check fields, so a researching client can reach the right person quickly while their information is handled securely and confidentially.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Speed &amp; Core Web Vitals</h3>
            <p>A mobile-first build with fast load times, clean navigation, and tap-to-call buttons. We engineer for strong Core Web Vitals so the site stays quick on a phone — where most prospective clients first find your firm.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>SEO Foundations</h3>
            <p>Practice-area keyword targeting, legal schema markup, and Google Business Profile setup built in from launch — so your firm can rank for searches like "corporate lawyer Singapore" or "family law firm Singapore" as the site matures.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>Compliance &amp; Accessibility</h3>
            <p>Every page is reviewed against the Legal Profession (Publicity) Rules before launch — solicitation restrictions, qualification disclosures, and case-result presentation — alongside accessible markup so the site works for every prospective client.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for law firm website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">Web Studio</span> Built for <span class="highlight">Law Firms</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for law firms and professional-services practices across Singapore. We know what earns trust with prospective clients, how the publicity rules shape what can go on the page, and how to turn quiet online research into booked consultations.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Legal Industry Experience</h3>
            <p>We understand the specific requirements of law firm websites — from Legal Profession (Publicity) Rules compliance to the trust signals prospective clients look for when choosing a lawyer. Your site is built for the legal sector, not adapted from a generic template.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Compliance Built In, Not Bolted On</h3>
            <p>We design with the publicity rules in mind from the first wireframe — solicitation restrictions, qualification disclosures, and how case results are presented — and review every page against current guidelines before launch, so compliance is never an afterthought.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A great site is the foundation, but visibility depends on SEO, content, and wider marketing. We handle website design, SEO, social, and paid ads in-house — an integrated system that turns searches for legal help into enquiries for your firm.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — where your website fits the client journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>Where Your <span class="highlight">Website</span> Fits the <span class="highlight">Client Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Most clients move through the same five stages before instructing a firm. Your website does the heavy lifting in the middle — proving credibility when they validate, and making it effortless when they're ready to enquire.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Google search, referrals, directories</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Compare 3–5 firms by practice area</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Credentials, profiles, trust signals</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>Contact form or consultation booking</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Instruct the firm &amp; refer onward</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Law firm website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Law Firm Website Pricing</p>
        <h2>Website Packages for Law Firms</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new practices and solo practitioners getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Practice area pages</li>
              <li>Lawyer profiles</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established firms ready to grow online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Case study pages</li>
              <li>Blog / news section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Client testimonials</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For full-service firms and multi-practice operations.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Client portal</li>
              <li>Document management</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about law firm website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Law Firm Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a law firm website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional law firm website in Singapore typically costs between $2,500 and $10,000+ depending on complexity. Our Starter package at $2,500 SGD includes a 5-page site with practice area pages, lawyer profiles, and contact form. Business and Premium packages add blogs, client portals, and advanced features.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will my law firm website comply with the Legal Profession (Publicity) Rules?</summary>
          <div class="faq-answer"><p>Yes. We design law firm websites that comply with Singapore's Legal Profession (Publicity) Rules. This includes restrictions on solicitation, proper disclosure of qualifications, and appropriate presentation of case results. We review all content against current guidelines before launch.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you add a client portal to my law firm website?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package includes a secure client portal where clients can access case documents, track matter progress, and communicate with your team. The portal uses SSL encryption and access controls to protect confidential information.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you help with SEO for law firm websites?</summary>
          <div class="faq-answer"><p>Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with practice-area-specific keyword targeting, legal schema markup, and Google Business Profile optimisation. We help you rank for searches like "corporate lawyer Singapore" or "family law firm Singapore".</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a law firm website?</summary>
          <div class="faq-answer"><p>Most law firm websites go live within 2-3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or multi-language support may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
