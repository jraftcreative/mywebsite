---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Law Firm Website Design Singapore",
    "description": "Professional website design for law firms in Singapore. Practice area pages, lawyer profiles, and compliance with Legal Profession publicity rules — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Law Firm Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Law Firm Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page law firm website with practice area pages, lawyer profiles, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Law Firm Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with case study pages, blog, advanced SEO, Google Business Profile, and client testimonials" },
      { "@type": "Offer", "name": "Premium Law Firm Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with client portal, document management, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a law firm website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional law firm website in Singapore typically costs between $2,500 and $10,000+ depending on complexity. Our Starter package at $2,500 SGD includes a 5-page site with practice area pages, lawyer profiles, and contact form. Business and Premium packages add blogs, client portals, and advanced features." } },
      { "@type": "Question", "name": "Will my law firm website comply with the Legal Profession (Publicity) Rules?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We design law firm websites that comply with Singapore's Legal Profession (Publicity) Rules. This includes restrictions on solicitation, proper disclosure of qualifications, and appropriate presentation of case results. We review all content against current guidelines before launch." } },
      { "@type": "Question", "name": "Can you add a client portal to my law firm website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package includes a secure client portal where clients can access case documents, track matter progress, and communicate with your team. The portal uses SSL encryption and access controls to protect confidential information." } },
      { "@type": "Question", "name": "Do you help with SEO for law firm websites?", "acceptedAnswer": { "@type": "Answer", "text": "Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with practice-area-specific keyword targeting, legal schema markup, and Google Business Profile optimisation. We help you rank for searches like 'corporate lawyer Singapore' or 'family law firm Singapore'." } },
      { "@type": "Question", "name": "How long does it take to build a law firm website?", "acceptedAnswer": { "@type": "Answer", "text": "Most law firm websites go live within 2–3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or multi-language support may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Law Firm Website Singapore", "item": "https://jraftcreative.com/law-firm-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Law Firm Website Singapore — Legal Practice Web Design | Jraft Creative"
  description="Professional website design for law firms in Singapore. Practice area pages, lawyer profiles, and compliance with Legal Profession publicity rules — from S$2,500."
  canonical="https://jraftcreative.com/law-firm-website-singapore/"
  ogTitle="Law Firm Website Singapore — Jraft Creative"
  ogDescription="Website design for law firms in Singapore. Practice area pages, lawyer profiles, and publicity rules compliance — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="law firm website singapore, legal website design singapore, lawyer website singapore, corporate law firm website, family law website singapore, legal practice web design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Law Firm Websites"
  heroTitle='Website Design for <span class="highlight">Law Firms in Singapore</span>'
  heroSubtitle="Your practice deserves a website that reflects your professionalism. We build authoritative, mobile-friendly websites for law firms — with practice area pages, lawyer profiles, and full compliance with the Legal Profession (Publicity) Rules."
  heroImage="/images/service-law.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my law firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Law Firm Online"
  ctaDescription="Book a free consultation and tell us about your practice. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why law firms need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Clients Research Lawyers Before Making Contact</h2>
      </div>
      <div class="section-content reveal">
        <p>Potential clients don't pick a lawyer at random. They research firms online, compare practice areas, read lawyer profiles, and look for trust signals — all before ever making a phone call. If your website looks outdated or generic, prospective clients will move on to a firm that presents itself more credibly.</p>
        <p>An unprofessional website undermines the trust you've spent years building. Clients looking for legal representation need confidence that your firm is competent, established, and attentive to detail. A poorly designed site — slow to load, hard to navigate, or missing key information — sends the opposite message.</p>
        <p>Singapore's Legal Profession (Publicity) Rules add another layer of complexity. Your website must comply with restrictions on solicitation, qualification disclosures, and how case results are presented. You need a web designer who understands these rules and builds your site accordingly — not a generic agency that treats your firm like any other business.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Law firm website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Law Firms</h2>
      </div>
      <div class="section-content reveal">
        <p>Every law firm website we deliver is purpose-built for the legal industry. We go beyond a generic template — your site will feature structured practice area pages, professional lawyer profiles, client testimonials, and enquiry forms that convert visitors into consultations.</p>
        <p>We understand that law firms in Singapore need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/" class="inline-link">SEO services</a> to rank for practice-area searches, <a href="/services/social-media/" class="inline-link">social media marketing</a> to build your firm's thought leadership, and <a href="/services/paid-ads/" class="inline-link">paid ads management</a> for targeted legal service campaigns.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Practice Area Pages</h3>
            <p>Dedicated pages for each area of law your firm covers — corporate, family, criminal, IP, employment, and more. Each page is structured for SEO and written to help potential clients understand how you can help.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Lawyer Profiles &amp; Credentials</h3>
            <p>Professional profile pages for every lawyer in your firm — with qualifications, areas of expertise, professional memberships, and headshots. Presented in compliance with the Legal Profession (Publicity) Rules.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Client Testimonials &amp; Case Studies</h3>
            <p>Build credibility with approved client testimonials and anonymised case studies. We present results professionally while ensuring compliance with publicity guidelines on case outcomes.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Enquiry Forms &amp; Consultation Booking</h3>
            <p>Conversion-focused contact forms and consultation booking systems that make it easy for prospective clients to reach your firm. Includes conflict-check fields and practice area routing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for law firm website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Law Firm Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've worked with law firms and professional services practices across Singapore. We know what builds trust with prospective clients and how to present your firm's expertise in a way that converts website visitors into consultations.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Legal Industry Experience</h3>
            <p>We understand the unique requirements of law firm websites — from Legal Profession (Publicity) Rules compliance to the trust signals that prospective clients look for when choosing a lawyer.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most law firm websites go live within 2 weeks of kickoff. We know time matters when you're launching a new practice or refreshing your firm's online presence.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Every site is designed for the mobile-first client. Fast load times, clean navigation, and tap-to-call buttons so prospective clients can reach your firm instantly.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on serving your clients.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Law firm website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Law Firm Website Pricing</p>
        <h2>Website Packages for Law Firms</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new practices and solo practitioners getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Practice area pages</li>
              <li>Lawyer profiles</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established firms ready to grow online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Case study pages</li>
              <li>Blog / news section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Client testimonials</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For full-service firms and multi-practice operations.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Client portal</li>
              <li>Document management</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about law firm website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Law Firm Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a law firm website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional law firm website in Singapore typically costs between $2,500 and $10,000+ depending on complexity. Our Starter package at $2,500 SGD includes a 5-page site with practice area pages, lawyer profiles, and contact form. Business and Premium packages add blogs, client portals, and advanced features.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will my law firm website comply with the Legal Profession (Publicity) Rules?</summary>
          <div class="faq-answer"><p>Yes. We design law firm websites that comply with Singapore's Legal Profession (Publicity) Rules. This includes restrictions on solicitation, proper disclosure of qualifications, and appropriate presentation of case results. We review all content against current guidelines before launch.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you add a client portal to my law firm website?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package includes a secure client portal where clients can access case documents, track matter progress, and communicate with your team. The portal uses SSL encryption and access controls to protect confidential information.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you help with SEO for law firm websites?</summary>
          <div class="faq-answer"><p>Every website includes basic SEO setup. Our Business and Premium packages include advanced SEO with practice-area-specific keyword targeting, legal schema markup, and Google Business Profile optimisation. We help you rank for searches like "corporate lawyer Singapore" or "family law firm Singapore".</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a law firm website?</summary>
          <div class="faq-answer"><p>Most law firm websites go live within 2-3 weeks. A 5-page site can be ready in 2 weeks, while larger projects with client portals or multi-language support may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
