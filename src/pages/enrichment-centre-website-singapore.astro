---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Enrichment Centre Website Design Singapore",
    "description": "Professional website design for enrichment centres, tuition centres, and learning studios in Singapore. Class schedules, online enrolment, parent testimonials — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Enrichment Centre Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Enrichment Centre Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page enrichment centre website with class schedule, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Enrichment Centre Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online enrolment forms, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Enrichment Centre Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-branch support, parent portal, online class booking, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an enrichment centre website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional enrichment centre website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with class schedules, contact form, and Google Maps integration. Business and Premium packages add online enrolment, parent portals, and multi-branch support." } },
      { "@type": "Question", "name": "Can you add online class registration to my enrichment centre website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online registration and enrolment form integration. Parents can browse programmes, select class timeslots, and submit enrolment requests directly through your website — reducing phone calls and walk-in admin for your front desk." } },
      { "@type": "Question", "name": "Do you help with enrolment landing pages for enrichment centres?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We build dedicated landing pages for specific programmes — whether it's a holiday camp, PSLE preparation course, or creative arts workshop. Each landing page is optimised for conversions with clear pricing, class details, instructor profiles, and a prominent enrolment CTA." } },
      { "@type": "Question", "name": "Will parents find my enrichment centre on Google?", "acceptedAnswer": { "@type": "Answer", "text": "We optimise your website for local SEO so you rank when parents search for 'enrichment centre near me' or 'tuition centre in [neighbourhood].' We also set up and optimise your Google Business Profile so your centre appears on Google Maps with reviews, photos, and contact details." } },
      { "@type": "Question", "name": "How long does it take to build an enrichment centre website?", "acceptedAnswer": { "@type": "Answer", "text": "Most enrichment centre websites go live within 2–3 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with online enrolment, parent portals, or multi-branch features may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Enrichment Centre Website Design Singapore", "item": "https://jraftcreative.com/enrichment-centre-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Enrichment Centre Website Design Singapore — Tuition & Learning Centre Websites | Jraft Creative"
  description="Professional website design for enrichment centres, tuition centres, and learning studios in Singapore. Class schedules, online enrolment, parent testimonials — from S$2,500."
  canonical="https://jraftcreative.com/enrichment-centre-website-singapore/"
  ogTitle="Enrichment Centre Website Design Singapore — Jraft Creative"
  ogDescription="Website design for enrichment centres, tuition centres, and learning studios in Singapore. Class schedules, online enrolment, parent testimonials — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="enrichment centre website design singapore, tuition centre website singapore, learning centre website design, enrichment class website, education website design singapore, enrichment centre digital marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Enrichment Centre Website Design"
  heroTitle='Website Design for Enrichment Centres in <span class="highlight">Singapore</span>'
  heroSubtitle="Parents are searching for enrichment classes online — and your website is where they decide to enrol. We build fast, mobile-friendly websites for enrichment and tuition centres with class schedules, online enrolment, and local SEO built in."
  heroImage="/images/service-enrichment.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my enrichment centre in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Enrichment Centre Online"
  ctaDescription="Book a free consultation and tell us about your enrichment centre, programmes, and goals. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20enrichment%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why enrichment centres need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Search Online Before They Enrol</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's enrichment industry is worth an estimated $1.68 billion, with over 1,600 centres competing for the attention of parents who are actively researching programmes online. If your centre doesn't have a professional website — or relies on a dated page with no class details and no way to register — parents will move on to a competitor that makes the process easier.</p>
        <p>Parents searching for "enrichment centre near me" or "tuition centre in Tampines" expect to see your programme details, class schedules, instructor profiles, and pricing within seconds — on their phone. If your site loads slowly, looks unprofessional, or buries key information behind multiple clicks, they'll pick the next centre that shows them what they need upfront.</p>
        <p>Whether you run a STEM lab, a language school, an arts studio, or a multi-subject learning centre, your website is the first impression most parents will have of your centre. It needs to answer their questions, build trust, and make enrolment as frictionless as possible.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Enrichment centre website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Enrichment Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>Every enrichment centre website we deliver is purpose-built for the education industry. We go beyond a generic template — your site will feature structured programme listings, class schedules, instructor profiles, parent testimonials, and online enrolment so parents can register without picking up the phone.</p>
        <p>We understand that enrichment centres in Singapore need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for local enrichment searches, <a href="/services/social-media/">social media marketing</a> to showcase student achievements and build community trust, and <a href="/services/paid-ads/">paid ads management</a> for targeted campaigns during peak enrolment seasons.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Programme Pages &amp; Class Schedules</h3>
            <p>Structured programme listings with age groups, class timings, fees, and curriculum details — so parents can find exactly the right class for their child without calling your front desk.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Enrolment &amp; Registration</h3>
            <p>Built-in enrolment forms that let parents register for trial classes, holiday camps, or regular programmes directly on your website. Reduce admin workload and capture leads 24/7.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO &amp; "Near Me" Rankings</h3>
            <p>We optimise your site for neighbourhood-level searches so parents in Bukit Timah, Jurong, Tampines, or Punggol find your centre first. Google Business Profile setup, schema markup, and maps integration included.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Parent Testimonials &amp; Trust Signals</h3>
            <p>Dedicated testimonial sections, instructor profiles with qualifications, and award or certification badges that give parents the confidence to enrol their child with your centre.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for enrichment centre website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Enrichment Centre Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've worked with education businesses across Singapore and understand what drives parents to pick up the phone, book a trial, or submit an enrolment form. Every element of your website is designed around that decision-making process.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Education Industry Experience</h3>
            <p>We understand the unique needs of enrichment centres — from programme structuring and class schedule layouts to enrolment funnels and parent communication flows.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most enrichment centre websites go live within 2 weeks of kickoff. We know timing matters — especially when you're launching a new branch or preparing for the next enrolment cycle.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First for Parents on the Go</h3>
            <p>Parents browse enrichment options between meetings, during lunch breaks, and while waiting at pickup. Your site will load fast and look sharp on every device, with tap-to-call and tap-to-WhatsApp built in.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on delivering great programmes to your students.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Enrichment centre website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Enrichment Centre Website Pricing</p>
        <h2>Website Packages for Enrichment &amp; Tuition Centres</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new enrichment centres getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme listings with schedules</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For centres ready to grow enrolment online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online enrolment forms</li>
              <li>Blog / news section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Instructor profiles &amp; testimonials</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-branch centres and education brands.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-branch support</li>
              <li>Parent portal integration</li>
              <li>Online class booking system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about enrichment centre website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Enrichment Centre Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an enrichment centre website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional enrichment centre website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with programme listings, contact form, and Google Maps integration. Business and Premium packages add online enrolment, parent portals, and multi-branch support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add online class registration to my enrichment centre website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online registration and enrolment form integration. Parents can browse programmes, select class timeslots, and submit enrolment requests directly through your website — reducing phone calls and walk-in admin for your front desk.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you help with enrolment landing pages for enrichment centres?</summary>
          <div class="faq-answer"><p>Absolutely. We build dedicated landing pages for specific programmes — whether it's a holiday camp, PSLE preparation course, or creative arts workshop. Each landing page is optimised for conversions with clear pricing, class details, instructor profiles, and a prominent enrolment CTA so parents can sign up without friction.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will parents find my enrichment centre on Google?</summary>
          <div class="faq-answer"><p>We optimise your website for local SEO so you rank when parents search for "enrichment centre near me" or "tuition centre in Tampines." We also set up and optimise your Google Business Profile so your centre appears on Google Maps with reviews, photos, and contact details — making it easy for nearby parents to discover you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an enrichment centre website?</summary>
          <div class="faq-answer"><p>Most enrichment centre websites go live within 2–3 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with online enrolment, parent portals, or multi-branch features may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
