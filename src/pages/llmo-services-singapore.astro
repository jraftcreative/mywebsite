    { text: "Get a Free LLMO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20learn%20about%20your%20LLMO%20services.", class: "btn btn-secondary" }
