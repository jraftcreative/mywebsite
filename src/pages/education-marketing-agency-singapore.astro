---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Education Marketing Agency Singapore",
    "description": "Full-service education marketing agency in Singapore. SEO, Google Ads, social, branding, websites — built for tuition centres, enrichment, preschools, and music/coding schools. From S$1,800/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Education Digital Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Education Marketing", "price": "1800", "priceCurrency": "SGD", "description": "Single-channel focus (SEO or Google Ads), Google Business Profile setup, trial-class landing page, and monthly reporting for solo studios and single-branch centres" },
      { "@type": "Offer", "name": "Startup Education Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Multi-channel: SEO + Google Ads + IG/TikTok, parent-focused content production, trial-booking funnel, GA4 + conversion tracking, bi-weekly reporting for growing enrichment and tuition centres" },
      { "@type": "Offer", "name": "Growth Education Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Full-service across all 6 channels, dedicated strategist, video production for teacher-led Reels, multi-branch GBP, and weekly reporting for multi-location schools and chains" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does marketing cost for an education business in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Education marketing in Singapore starts at S$1,800 per month for essential single-channel work (typically Google Ads or SEO + GBP). Startup packages at S$3,000/month combine SEO, Google Ads, and IG/TikTok with parent-focused content and conversion tracking. Growth packages at S$5,500+/month add video production, multi-branch GBP management, and a dedicated strategist. Multi-branch tuition or enrichment chains typically need the Startup tier minimum to compete with brand chains like Mind Stretcher, MindChamps, and Cristofori in their catchment areas." } },
      { "@type": "Question", "name": "What's the parent decision journey for choosing a school in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Singapore parents typically research enrichment, tuition, or schools for 4-8 weeks before committing. The journey is: Discover (Google searches like 'piano lessons Bukit Batok', AI tools like ChatGPT, neighbourhood Facebook groups) → Trial Class (book 1-2 trial sessions across shortlisted centres) → Compare (read Google reviews, check IG/TikTok, ask other parents) → Enrol (sign for the term) → Renew/Refer (term-end retention and word-of-mouth referrals). Education marketing needs to show up at every stage — not just the trial-booking form." } },
      { "@type": "Question", "name": "How is education marketing different from general marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Education marketing targets parents researching for their children — an audience that reads reviews exhaustively, compares 3-5 centres, and decides on trust and outcomes, not price. Enrolment cycles are seasonal (Jan term, mid-year intake, Sep/Oct shortlisting). Keywords are subject + level + neighbourhood specific. The decision is emotional and high-stakes. Generic agencies that treat education like e-commerce miss the long consideration window and the parent-community trust signals that actually drive sign-ups." } },
      { "@type": "Question", "name": "Which marketing channels work best for tuition and enrichment centres in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Six channels in priority order: (1) Google Business Profile + local SEO for 'near me' searches like 'piano lessons Jurong' or 'enrichment Farrer Road', (2) Google Ads for high-intent terms during peak intake seasons, (3) Instagram and TikTok for parent trust and teacher-led content, (4) a clear class-info website with trial booking and term calendar, (5) brand positioning that differentiates you from chains, (6) AI search optimisation (GEO) for parents using ChatGPT to research. We sequence channels based on your centre's stage." } },
      { "@type": "Question", "name": "How long before education marketing brings new enrolments?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads can generate trial-class bookings within the first 7-14 days once conversion tracking is set up. Social media content compounds over 8-12 weeks of consistent posting. SEO and Google Business Profile reviews typically show ranking lift within 3-6 months for catchment-area keywords. Parents research for weeks before committing — so a multi-channel presence shortens the consideration window meaningfully and gets your centre into the shortlist before the trial-class call happens." } },
      { "@type": "Question", "name": "Do you work with multi-branch tuition and enrichment chains?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Multi-location education businesses need location-specific SEO landing pages, a separate Google Business Profile for each branch (with reviews managed per outlet), localised Google Ads campaigns with distinct budgets per neighbourhood, and unified brand messaging across all centres. Our Growth tier includes per-location performance tracking, multi-branch GBP optimisation, and centralised content production that can be deployed across every outlet." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Education Marketing Agency Singapore", "item": "https://jraftcreative.com/education-marketing-agency-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Education Marketing Agency Singapore | Jraft Creative"
  description="Full-service education marketing agency in Singapore. SEO, Google Ads, social, branding, websites — built for tuition, enrichment, preschools, music schools. From $1,800/mo."
  canonical="https://jraftcreative.com/education-marketing-agency-singapore/"
  ogTitle="Education Marketing Agency Singapore | Jraft Creative"
  ogDescription="Full-service marketing agency for education businesses in Singapore. Tuition, enrichment, preschools, music schools — one agency, complete digital strategy. From $1,800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="education marketing agency singapore, education digital marketing singapore, marketing for tuition centres singapore, marketing for enrichment centres singapore, school marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Marketing for Education Businesses"
  heroTitle='Marketing Agency for <span class="highlight">Education Businesses in Singapore</span>'
  heroSubtitle="Singapore parents research enrichment, tuition, and schools for 4 to 8 weeks before booking a trial class — and most centres are invisible during that window. We build full-service marketing strategies (SEO, GEO, Google Ads, IG/TikTok, branding, websites) designed for how Singapore parents actually choose where their child learns."
  heroImage="/images/service-education.webp"
  heroImageAlt="Singapore classroom — education marketing agency"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20an%20education%20business%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I run an education business in Singapore and need marketing help."
  ctaLabel="Ready to Grow Enrolments?"
  ctaTitle='Let Us <span class="highlight">Fill</span> Your <span class="highlight">Trial-Class Calendar</span>'
  ctaDescription="Book a free consultation and tell us about your centre — your programmes, your catchment, your current marketing. We'll get back to you within 24 hours with a tailored, channel-by-channel growth plan for the next intake."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20run%20an%20education%20business%20in%20Singapore%20and%20need%20marketing%20help.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why education businesses need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Centres Are Still <span class="highlight">Losing Trials</span> to Chains with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's private education market is worth over $1.68 billion a year — 800+ tuition centres, 1,600+ enrichment centres, hundreds of preschools, music schools, and coding academies all competing for the same parent shortlist. The centres winning enrolments aren't always the best teachers. They're the ones who show up first.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Shortlist Window</h3>
            <p>Parents spend 4-8 weeks on Google, neighbourhood Facebook groups, IG, TikTok, and increasingly AI tools before booking a single trial. By then they've already shortlisted 3-5 centres. If you're not visible during those weeks, you're not getting the trial.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Chain Threat</h3>
            <p>Brand chains like Mind Stretcher, MindChamps, Cristofori, and Lorna Whiston own the top SERP slots and out-spend solo centres on Google Ads. Independent centres get pushed below the fold, lose the near-me Maps pack, and miss the parent's first three clicks.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Trust Gap</h3>
            <p>Parents don't buy on price — they buy on trust. Google reviews, named teachers on Instagram, parent testimonials, real classroom footage. Centres without these signals lose the trial booking even when their teachers are stronger and their pricing is fairer.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for education businesses in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Centre <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for education businesses — combining catchment-area SEO, AI search optimisation (GEO), trial-booking paid search, parent-focused social content, brand positioning, and class-info web design.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/education-seo-singapore/">SEO for Education</a></h3>
            <p>Rank for parent searches like "piano lessons Bukit Batok" and "tuition centre Tampines." Beat brand chains on long-tail catchment terms with neighbourhood landing pages and Google Business Profile optimisation per branch.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when parents ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best phonics centre near Farrer Road" or "ABRSM theory teacher Jurong." Same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/education-google-ads-singapore/">Google Ads for Centres</a></h3>
            <p>High-intent campaigns timed to Jan, mid-year, and Sep intake windows. GCLID tracking from click to signed enrolment. Industry benchmark CPL for trial bookings: S$20–S$60 depending on subject and level.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/education-social-media-marketing-singapore/">Social Media for Centres</a></h3>
            <p>Teacher-led Reels, classroom moments, student progress stories, exam tips. The parent IG and TikTok content that builds the trust signals chains can't manufacture. Built for how SG parents actually scroll.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/education-branding-agency-singapore/">Branding for Centres</a></h3>
            <p>The brand system that differentiates you from Mind Stretcher, MindChamps, and the 50 other centres in your catchment. Logo, palette, parent-pack template, teacher photo direction — positioned by niche and pedagogy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/education-content-marketing-singapore/">Websites for Centres</a></h3>
            <p>The site that closes the trial booking. Clear class info, term calendars, transparent fees, trial-booking form, teacher profiles, and fast mobile performance for parents shortlisting on their phone in the school carpark.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for education marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Choose</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most marketing agencies pitching education businesses are generalists running e-commerce playbooks on a parent audience that decides on weeks of research, trial classes, and word-of-mouth. We are the opposite — full-service, performance-led, and built around the parent decision journey. We run live SEO + Google Ads for Singapore music schools, draft proposals for ABRSM-focused studios, and pitch enrichment centres on the same catchment-area discipline. We specialise in tuition centre marketing, enrichment centre marketing, preschool marketing, and music school marketing across Bukit Batok, Tampines, Jurong, Farrer Road, and other high-density Singapore catchments.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Cross-Segment Pattern Recognition</h3>
            <p>We work across tuition, enrichment, preschool, music, coding, and language. That cross-segment view tells us instantly which catchment, subject, and level keywords are winnable — and which are dominated by chains and not worth the spend.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, Facebook, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, parent-trust signals, and measurement back to trial bookings.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enrolment-Focused Metrics</h3>
            <p>We measure trial bookings and signed enrolments, not impressions. GCLID offline tracking proves which ad click became which trial became which paying student. Every report ties spend to enrolment outcomes, not vanity metrics.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ENROLMENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Enrolment Funnel — how Singapore parents decide on a school or centre">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Enrolment Funnel</p>
        <h2>How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first Google search to a signed term, every Singapore parent moves through the same five stages. We build marketing campaigns that show up at each one — from discovery scrolling through to renewal and referral.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, IG, TikTok, parent Facebook groups, AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Trial Class</h3>
          <p>Book 1–2 trials across shortlisted centres</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Reviews, IG/TikTok, parent word-of-mouth</p>
        </li>
        <li class="funnel-stage">
          <h3>Enrol</h3>
          <p>Sign for the term</p>
        </li>
        <li class="funnel-stage">
          <h3>Renew / Refer</h3>
          <p>Term-end retention and referrals</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Education marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Education Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Centres of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$1,800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For solo studios and single-branch centres.</p>
            <ul class="pricing-features">
              <li>Single-channel focus (SEO or Google Ads)</li>
              <li>Google Business Profile optimisation</li>
              <li>Trial-class landing page</li>
              <li>4 pieces of content/month</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Startup</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing enrichment and tuition centres.</p>
            <ul class="pricing-features">
              <li>SEO + Google Ads + IG/TikTok</li>
              <li>Parent-focused content production</li>
              <li>GA4 + conversion tracking setup</li>
              <li>Catchment-area landing pages</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Growth</h3>
            <div class="price">$5,500+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-branch chains and premium schools.</p>
            <ul class="pricing-features">
              <li>Full 6-channel coverage</li>
              <li>Dedicated strategist</li>
              <li>Teacher-led Reel video production</li>
              <li>Multi-branch GBP &amp; brand refresh</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about education marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Education</span> Marketing — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does marketing cost for an education business in Singapore?</summary>
          <div class="faq-answer"><p>Education marketing in Singapore starts at S$1,800 per month for essential single-channel work (typically Google Ads or SEO + GBP). Startup packages at S$3,000/month combine SEO, Google Ads, and IG/TikTok with parent-focused content and conversion tracking. Growth packages at S$5,500+/month add video production, multi-branch GBP management, and a dedicated strategist. Multi-branch tuition or enrichment chains typically need the Startup tier minimum to compete with brand chains like Mind Stretcher, MindChamps, and Cristofori in their catchment areas.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What's the parent decision journey for choosing a school in Singapore?</summary>
          <div class="faq-answer"><p>Singapore parents typically research enrichment, tuition, or schools for 4-8 weeks before committing. The journey is: Discover (Google searches like "piano lessons Bukit Batok", AI tools like ChatGPT, neighbourhood Facebook groups) → Trial Class (book 1-2 trial sessions across shortlisted centres) → Compare (read Google reviews, check IG/TikTok, ask other parents) → Enrol (sign for the term) → Renew/Refer (term-end retention and word-of-mouth referrals). Education marketing needs to show up at every stage — not just the trial-booking form.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How is education marketing different from general marketing?</summary>
          <div class="faq-answer"><p>Education marketing targets parents researching for their children — an audience that reads reviews exhaustively, compares 3-5 centres, and decides on trust and outcomes, not price. Enrolment cycles are seasonal (Jan term, mid-year intake, Sep/Oct shortlisting). Keywords are subject + level + neighbourhood specific. The decision is emotional and high-stakes. Generic agencies that treat education like e-commerce miss the long consideration window and the parent-community trust signals that actually drive sign-ups.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Which marketing channels work best for tuition and enrichment centres in Singapore?</summary>
          <div class="faq-answer"><p>Six channels in priority order: (1) Google Business Profile + local SEO for "near me" searches like "piano lessons Jurong" or "enrichment Farrer Road", (2) Google Ads for high-intent terms during peak intake seasons, (3) Instagram and TikTok for parent trust and teacher-led content, (4) a clear class-info website with trial booking and term calendar, (5) brand positioning that differentiates you from chains, (6) AI search optimisation (GEO) for parents using ChatGPT to research. We sequence channels based on your centre's stage.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before education marketing brings new enrolments?</summary>
          <div class="faq-answer"><p>Google Ads can generate trial-class bookings within the first 7-14 days once conversion tracking is set up. Social media content compounds over 8-12 weeks of consistent posting. SEO and Google Business Profile reviews typically show ranking lift within 3-6 months for catchment-area keywords. Parents research for weeks before committing — so a multi-channel presence shortens the consideration window meaningfully and gets your centre into the shortlist before the trial-class call happens.</p></div>
        </details>
