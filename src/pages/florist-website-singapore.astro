---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Florist Website Design Singapore",
    "description": "Professional website design for florists, flower shops, and floral studios in Singapore. Online ordering, delivery zone setup, product catalogues, and occasion-based collections — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Florist Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Florist Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page florist website with product catalogue, about page, delivery information, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Florist Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online ordering, delivery zone configuration, occasion-based collections, blog, advanced SEO, and social media integration" },
      { "@type": "Offer", "name": "Premium Florist Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom florist website with subscription management, corporate gifting portal, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a florist website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional florist website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with product catalogue, delivery information, and contact form. Business and Premium packages add online ordering, delivery zone logic, and subscription management." } },
      { "@type": "Question", "name": "Can customers order flowers directly through my website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include a full online ordering system where customers can browse arrangements, select a delivery date and time slot, enter a delivery address, and pay securely online. You receive instant order notifications and can manage everything from a simple dashboard." } },
      { "@type": "Question", "name": "Can the website handle same-day delivery orders?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We configure same-day delivery cut-off times so customers placing orders before your deadline can select same-day delivery. Orders placed after the cut-off automatically default to the next available slot. This prevents unfulfillable orders while maximising your same-day revenue." } },
      { "@type": "Question", "name": "Do you set up delivery zones on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We configure delivery zones across Singapore — island-wide, CBD, specific districts, or postal code ranges — with different delivery fees for each zone. Customers enter their postal code at checkout and see the applicable delivery fee instantly, reducing abandoned carts and delivery disputes." } },
      { "@type": "Question", "name": "How long does it take to build a florist website?", "acceptedAnswer": { "@type": "Answer", "text": "Most florist websites go live within 2-3 weeks. A 5-page catalogue site can be ready in 2 weeks, while larger projects with online ordering, delivery zone logic, or subscription features may take 3-4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Florist Website Singapore", "item": "https://jraftcreative.com/florist-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Florist Website Singapore — Jraft Creative"
  description="Website design for florists, flower shops, and floral studios in Singapore. Online ordering, delivery zones, product catalogues."
  canonical="https://jraftcreative.com/florist-website-singapore/"
  ogTitle="Florist Website Singapore — Jraft Creative"
  ogDescription="Website design for florists in Singapore. Online ordering, delivery zones, product catalogues — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="florist website design singapore, flower shop website, florist web design singapore, online flower ordering website singapore, flower delivery website singapore, floral studio website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Florist Websites"
  heroTitle='Website Design for <span class="highlight">Florists in Singapore</span>'
  heroSubtitle="Your arrangements deserve more than an Instagram grid. We build fast, conversion-focused websites for florists and flower shops in Singapore — with online ordering, delivery zone logic, occasion-based collections, and same-day delivery built in."
  heroImage="/images/service-florist.webp"
  heroImageAlt="Florist arranging a bouquet in a Singapore flower shop — florist website design"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my florist business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Florist Business Online"
  ctaDescription="Book a free consultation and tell us about your flower shop. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20florist%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why florists need a proper website in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Flowers Are Bought on a <span class="highlight">Phone</span>, for an <span class="highlight">Occasion</span>, in a Hurry</h2>
      </div>
      <div class="section-content reveal">
        <p>When someone in Singapore needs flowers, it is almost always tied to a moment — an anniversary, a birthday, a condolence, a Mother's Day surprise — and it is almost always urgent. They reach for their phone, search, and buy from the first florist that shows the right arrangement and can deliver in time. If your shop only lives on an Instagram grid or a marketplace listing, you are competing on someone else's platform with no control over how your flowers are presented or how orders are placed.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Same-Day, Mobile, Occasion-Driven</h3>
            <p>A last-minute anniversary bouquet or a condolence wreath for a wake is ordered on a phone, minutes after the need appears. If your site is slow, hard to order from, or unclear about same-day cut-offs, the buyer bounces to a competitor who makes it easy — the sale is lost in seconds, not days.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>A Visual-First Product</h3>
            <p>Flowers sell on how they look. A blurry photo, a cramped grid, or slow-loading images make even beautiful arrangements look ordinary. Buyers judge your craft by your product shots, so the site has to present every bouquet, hamper, and wreath the way it deserves to be seen — sharp, generous, and fast.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Orders With Moving Parts</h3>
            <p>A flower order is not one click. It carries a delivery date and time slot, a delivery address and zone, an occasion, and a card message. Handling this over DMs and WhatsApp means manual confirmation, payment chasing, and address clarification — friction that costs sales during Valentine's Day and CNY when speed matters most.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Florist website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of a Florist <span class="highlight">Website</span></h2>
      </div>
      <div class="section-content reveal">
        <p>A florist website is not a generic template with a product page bolted on. It has to make arrangements look irresistible, let an urgent buyer order in under a minute, and handle Singapore's delivery logistics automatically. We build every element around how customers actually shop for flowers — visual-first, occasion-driven, and on mobile.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Visual-Led Design</h3>
            <p>A layout built to show off your florals — generous product imagery, clean typography, and a brand feel that matches your studio. Every arrangement is presented sharp and large, so your craft, not a cramped grid, is what convinces the buyer to order.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Bouquet &amp; Occasion Catalogue</h3>
            <p>Your full range — hand bouquets, table arrangements, wreaths, hampers, preserved flowers — in a searchable, filterable catalogue. Organised by occasion, price range, and flower type, plus dedicated collections for Valentine's Day, Mother's Day, CNY, and corporate gifting.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Delivery Date, Time &amp; Checkout</h3>
            <p>A checkout built for flowers — customers pick a delivery date and time slot, add a personalised card message, and pay in a few taps. Same-day cut-off times are enforced automatically, so orders placed after your deadline roll over to the next available slot.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Speed &amp; Core Web Vitals</h3>
            <p>Flower orders are placed on phones, in a hurry. Every image is optimised — WebP, responsive srcsets, lazy loading — and the site is tuned for fast Core Web Vitals so your catalogue loads instantly and the checkout never stalls the impulse buy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>Payments &amp; Order Management</h3>
            <p>Secure online payment plus a simple dashboard where every order lands with its delivery date, address, occasion, and card message attached. Instant notifications and clean order records keep your fulfilment team on track through peak-period volume spikes.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Local SEO Foundations</h3>
            <p>The technical groundwork to rank for searches like "flower delivery Singapore" and "same-day florist near me" — clean structure, schema markup, optimised occasion pages, and Google Business Profile setup so buyers find your shop, not a marketplace listing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for florist website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">Web Studio</span> That Understands <span class="highlight">Floral Retail</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We have built websites for florists, gift shops, and e-commerce businesses across Singapore. We know what a buyer looks for when ordering flowers online, and we build sites that make your arrangements look irresistible while making the ordering process effortless — even at midnight, even on a phone.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Built for Floral E-Commerce</h3>
            <p>Every product image is optimised for fast loading — WebP, responsive srcsets, lazy loading — so your catalogue looks vibrant on every device. Sharp product photography, clear SGD pricing, and a frictionless checkout convert far better than any marketplace listing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Mobile-First for On-the-Go Orders</h3>
            <p>Flower orders are placed last-minute, often on a commute or lunch break. Every site we build is designed for phones first — fast load times, thumb-friendly navigation, and a checkout flow that takes seconds from product page to payment, timed for peak-season urgency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A website drives conversion, but demand depends on being found. We handle SEO, social media, and paid ads in-house — from ranking for "flower delivery Singapore" to running Valentine's and Mother's Day campaigns — one integrated system, not four vendors.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE CUSTOMER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Customer Funnel — where your website fits the customer journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Customer Funnel</p>
        <h2>Where Your <span class="highlight">Website</span> Fits the <span class="highlight">Customer Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every flower buyer moves through the same five stages before an order lands. Your website is the engine — it turns the discovery into a purchase, then earns the repeat order and the referral that follow.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google search, Maps, social, AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Consider</h3>
          <p>Browse catalogue, compare arrangements &amp; prices</p>
        </li>
        <li class="funnel-stage">
          <h3>Purchase</h3>
          <p>Pick delivery date &amp; time, checkout &amp; pay</p>
        </li>
        <li class="funnel-stage">
          <h3>Repeat</h3>
          <p>Reorder for the next occasion &amp; subscriptions</p>
        </li>
        <li class="funnel-stage">
          <h3>Refer</h3>
          <p>Review, share &amp; recommend to friends</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Florist website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Florist Website Pricing</p>
        <h2>Website Packages for Florists</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For florists building their first dedicated website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Product catalogue (up to 30 items)</li>
              <li>About &amp; delivery info page</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For flower shops ready to sell online and automate deliveries.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Full online ordering system</li>
              <li>Delivery zone &amp; same-day logic</li>
              <li>Occasion-based collections</li>
              <li>Social media integration</li>
              <li>Advanced SEO &amp; schema</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For established florists and corporate gifting operations.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Subscription &amp; recurring orders</li>
              <li>Corporate gifting portal</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about florist website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Florist Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a florist website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional florist website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with product catalogue, delivery information, and contact form. Business and Premium packages add online ordering, delivery zone logic, and subscription management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can customers order flowers directly through my website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include a full online ordering system where customers can browse arrangements, select a delivery date and time slot, enter a delivery address, and pay securely online. You receive instant order notifications and can manage everything from a simple dashboard.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can the website handle same-day delivery orders?</summary>
          <div class="faq-answer"><p>Yes. We configure same-day delivery cut-off times so customers placing orders before your deadline can select same-day delivery. Orders placed after the cut-off automatically default to the next available slot. This prevents unfulfillable orders while maximising your same-day revenue.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you set up delivery zones on the website?</summary>
          <div class="faq-answer"><p>Yes. We configure delivery zones across Singapore — island-wide, CBD, specific districts, or postal code ranges — with different delivery fees for each zone. Customers enter their postal code at checkout and see the applicable delivery fee instantly, reducing abandoned carts and delivery disputes.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a florist website?</summary>
          <div class="faq-answer"><p>Most florist websites go live within 2-3 weeks. A 5-page catalogue site can be ready in 2 weeks, while larger projects with online ordering, delivery zone logic, or subscription features may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
