---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "TCM Marketing Singapore",
    "description": "Full-service digital marketing for TCM clinics in Singapore — website design, SEO, Google Ads, social media, and content marketing. Grow patient bookings from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "TCM Clinic Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for TCM clinics" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, patient-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a TCM clinic spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most TCM clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and content marketing. The right budget depends on your clinic's size, number of branches, and patient acquisition targets. Our Essential plan at $3,000/month is a strong starting point for single-location TCM clinics." } },
      { "@type": "Question", "name": "How long before marketing generates new patients for my TCM clinic?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate patient enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media and content marketing build credibility over 2–3 months. Most TCM clinic clients see a meaningful increase in appointment bookings within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "What marketing channels work best for TCM clinics in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search is highly effective — patients searching for 'TCM clinic near me' or 'acupuncture Singapore' have high booking intent. Google Business Profile is critical for local visibility and reviews. Content marketing educates patients about TCM treatments and builds long-term organic traffic. Social media, particularly Facebook and Instagram, reaches both younger professionals exploring TCM and older demographics seeking traditional treatments." } },
      { "@type": "Question", "name": "Can you market TCM to younger Singaporeans who are new to traditional medicine?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. A growing number of Singaporeans in their 20s and 30s are turning to TCM for stress management, fertility support, skin conditions, and sports recovery. We create marketing campaigns that speak to this audience — demystifying treatments like acupuncture and cupping through educational content, modern website design, and social media that presents TCM as accessible and evidence-informed rather than outdated." } },
      { "@type": "Question", "name": "Do you handle marketing for all TCM services including acupuncture and tuina?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create targeted campaigns for every TCM service — acupuncture, tuina massage, cupping, herbal medicine, moxibustion, fertility support, pain management, and wellness consultations. Each treatment attracts a different patient profile and has unique search behaviour. We build dedicated landing pages, ad campaigns, and content for each service line to maximise patient bookings across your full range of offerings." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "TCM Marketing Singapore", "item": "https://jraftcreative.com/tcm-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Gym Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="TCM Marketing Singapore — Jraft Creative"
  description="Full-service digital marketing for TCM clinics in Singapore — website, SEO, Google Ads, social media, and content marketing."
  canonical="https://jraftcreative.com/tcm-marketing-singapore/"
  ogTitle="TCM Marketing Singapore — Jraft Creative"
  ogDescription="Full-service marketing for TCM clinics in Singapore. Website, SEO, Google Ads, social media — one agency, one strategy, more patients."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="TCM marketing singapore, TCM clinic marketing agency, traditional chinese medicine advertising, TCM digital marketing, acupuncture marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="TCM Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">TCM Clinics in Singapore</span>'
  heroSubtitle="Website, SEO, Google Ads, social media, and content — managed by one agency with one goal: filling your appointment book. Stop relying on walk-ins and referrals alone. Start building a patient acquisition engine."
  heroImage="/images/service-tcm.webp"
  heroImageAlt="TCM clinic treatment room in Singapore — TCM clinic marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my TCM clinic in Singapore."
  ctaLabel="Ready to Grow Your Patient Base?"
  ctaTitle="Get Your Free TCM Clinic Marketing Audit"
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your clinic's patient acquisition goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20TCM%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why TCM clinics need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> TCM Clinics Are Still <span class="highlight">Losing Patients</span> to Clinics with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has thousands of registered TCM practitioners and hundreds of clinics — from neighbourhood shophouse practices to modern wellness-integrated centres. Walk-ins and word-of-mouth no longer fill the appointment book, and the clinics winning new patients aren't always the most experienced. They're the ones patients find, trust, and book — within Singapore's healthcare advertising rules.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Compliance Tightrope</h3>
            <p>TCM Practitioners Board registration and MOH advertising rules govern how clinics can promote treatments, claims, and testimonials. Generic agencies don't know these boundaries — and non-compliant content puts your registration and reputation at risk.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trust Threshold</h3>
            <p>Health is a high-consideration decision. Before booking acupuncture or herbal treatment, patients validate clinics through Google reviews and physician credentials. Without visible reviews and a credible practitioner profile, you stay a faceless listing patients scroll past.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Local Search Window</h3>
            <p>New patients search "TCM clinic near me," "acupuncture Singapore," and treatment-specific terms before they ever walk in. If you're not visible on those catchment and acupuncture local searches, the booking goes to the clinic that showed up first.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for TCM clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every TCM Clinic <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for TCM clinics — combining local SEO, AI search optimisation (GEO), paid search, educational social content, branding, and conversion-focused web design, all framed for both traditional and new-to-TCM patients.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tcm-clinic-seo-singapore/">SEO for TCM Clinics</a></h3>
            <p>Rank for treatment and catchment searches like "acupuncture Singapore," "TCM fertility treatment," and "cupping therapy near me." Google Business Profile, review management, and treatment landing pages that capture patients ready to book.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when patients ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best TCM clinic Singapore" or "does acupuncture help back pain." AI-friendly schema and the same citation playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tcm-clinic-google-ads-singapore/">Google Ads for TCM Clinics</a></h3>
            <p>High-intent paid search on condition- and treatment-specific terms, geo-targeted around your clinic locations. GCLID tracking from click to booked appointment, measured to a real cost-per-booking.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for TCM Clinics</a></h3>
            <p>Educational Reels, treatment explainers, and seasonal wellness content for Instagram, Facebook, and Xiaohongshu — reaching both English- and Chinese-speaking audiences and demystifying TCM for younger patients.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for TCM Clinics</a></h3>
            <p>Clinic identity, practitioner positioning, and treatment-menu design that bridges heritage with accessibility — lifting you out of price-only comparisons and into the clinic patients feel confident choosing.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/tcm-clinic-website-singapore/">Websites for TCM Clinics</a></h3>
            <p>Treatment pages, practitioner profiles, online booking, and mobile-first speed — the conversion architecture that turns a researching patient into a booked appointment for both traditional and new-to-TCM audiences.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for TCM marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">TCM Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching clinics are generalists who don't understand TCM's bilingual patient base, the advertising rules, or the trust-intensive patient journey. We are the opposite — full-service, compliance-aware, and built around how TCM patients in Singapore research, validate, and choose their clinic.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare &amp; TCM Knowledge</h3>
            <p>We understand the bilingual patient base, the mix of traditional and new-to-TCM audiences, treatment-specific search behaviour, and the credibility signals that matter — so your marketing is built on how patients actually discover and choose TCM clinics.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, social, branding, and websites under one roof. No coordinating between vendors. Every channel reinforces the same modern, trustworthy positioning as part of a single strategy.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Bookings, Not Vanity Metrics</h3>
            <p>We track appointment bookings, patient enquiries, and cost per lead by treatment — not likes. Month-to-month retainers with no lock-in, because clinics should stay for the pipeline, not a contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE PATIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Patient Funnel — how Singapore patients decide on a TCM clinic">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Patient Funnel</p>
        <h2>How <span class="highlight">Singapore TCM Patients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first symptom search to a repeat visit, every TCM patient in Singapore moves through the same five stages. We build marketing that shows up at each one — from discovery through to the return visit that builds lifetime value.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, Instagram, Xiaohongshu, AI search, referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Reviews, practitioner credentials, educational content</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 clinics, treatment &amp; trust match</p>
        </li>
        <li class="funnel-stage">
          <h3>Book</h3>
          <p>Online booking, WhatsApp, or phone enquiry</p>
        </li>
        <li class="funnel-stage">
          <h3>Return</h3>
          <p>Repeat treatment, ongoing care, refer friends</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for TCM clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for TCM Clinics</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location clinics building a marketing foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics ready to scale patient acquisition across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Patient education content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-branch TCM groups.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-branch campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Bilingual (EN/CN) content</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about TCM marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>TCM Clinic Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a TCM clinic spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most TCM clinics in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and content marketing. The right budget depends on your clinic's size, number of branches, and patient acquisition targets. Our Essential plan at $3,000/month is a strong starting point for single-location TCM clinics.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new patients for my TCM clinic?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate patient enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media and content marketing build credibility over 2–3 months. Most TCM clinic clients see a meaningful increase in appointment bookings within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for TCM clinics in Singapore?</summary>
          <div class="faq-answer"><p>Google Search is highly effective — patients searching for "TCM clinic near me" or "acupuncture Singapore" have high booking intent. Google Business Profile is critical for local visibility and reviews. Content marketing educates patients about TCM treatments and builds long-term organic traffic. Social media, particularly Facebook and Instagram, reaches both younger professionals exploring TCM and older demographics seeking traditional treatments.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you market TCM to younger Singaporeans who are new to traditional medicine?</summary>
          <div class="faq-answer"><p>Yes. A growing number of Singaporeans in their 20s and 30s are turning to TCM for stress management, fertility support, skin conditions, and sports recovery. We create marketing campaigns that speak to this audience — demystifying treatments like acupuncture and cupping through educational content, modern website design, and social media that presents TCM as accessible and evidence-informed rather than outdated.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you handle marketing for all TCM services including acupuncture and tuina?</summary>
          <div class="faq-answer"><p>Yes. We create targeted campaigns for every TCM service — acupuncture, tuina massage, cupping, herbal medicine, moxibustion, fertility support, pain management, and wellness consultations. Each treatment attracts a different patient profile and has unique search behaviour. We build dedicated landing pages, ad campaigns, and content for each service line to maximise patient bookings across your full range of offerings.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="general" />

</ServiceLayout>
