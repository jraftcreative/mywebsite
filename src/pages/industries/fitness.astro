---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Fitness & Sports Marketing Singapore — Jraft Creative",
    "description": "Website design, SEO, social media, and digital marketing for gyms, yoga studios, pilates studios, and martial arts schools in Singapore.",
    "url": "https://jraftcreative.com/industries/fitness/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Fitness & Sports", "item": "https://jraftcreative.com/industries/fitness/" }
    ]
  }
];

const subIndustries = [
  {
    name: "Gym",
    href: "/gym-website-design-singapore/",
    description: "Commercial gyms, boutique fitness studios, and CrossFit boxes.",
    image: "/images/service-gym.webp",
    services: [
      { label: "Website", href: "/gym-website-design-singapore/" },
      { label: "SEO", href: "/gym-seo-singapore/" },
      { label: "Marketing", href: "/gym-marketing-singapore/" },
      { label: "Social Media", href: "/gym-social-media-singapore/" },
      { label: "Google Ads", href: "/gym-google-ads-singapore/" },
      { label: "Branding", href: "/gym-branding-singapore/" },
    ]
  },
  {
    name: "Yoga Studio",
    href: "/yoga-studio-website-singapore/",
    description: "Yoga studios, hot yoga centres, and wellness spaces.",
    image: "/images/service-yoga.webp",
    services: [
      { label: "Website", href: "/yoga-studio-website-singapore/" },
      { label: "SEO", href: "/yoga-studio-seo-singapore/" },
      { label: "Marketing", href: "/yoga-studio-marketing-singapore/" },
      { label: "Social Media", href: "/yoga-studio-social-media-singapore/" },
      { label: "Google Ads", href: "/yoga-studio-google-ads-singapore/" },
      { label: "Branding", href: "/yoga-studio-branding-singapore/" },
    ]
  },
  {
    name: "Pilates Studio",
    href: "/pilates-studio-website-singapore/",
    description: "Reformer pilates, mat pilates, and clinical pilates studios.",
    image: "/images/service-pilates.webp",
    services: [
      { label: "Website", href: "/pilates-studio-website-singapore/" },
      { label: "SEO", href: "/pilates-seo-singapore/" },
      { label: "Marketing", href: "/pilates-marketing-singapore/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "Google Ads", href: "/services/paid-ads/" },
      { label: "Branding", href: "/services/website-development/" },
    ]
  },
  {
    name: "Martial Arts",
    href: "/martial-arts-website-singapore/",
    description: "Muay Thai, BJJ, taekwondo, and MMA gyms.",
    image: "/images/service-martialarts.webp",
    services: [
      { label: "Website", href: "/martial-arts-website-singapore/" },
      { label: "SEO", href: "/martial-arts-seo-singapore/" },
      { label: "Marketing", href: "/martial-arts-marketing-singapore/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "Google Ads", href: "/services/paid-ads/" },
      { label: "Branding", href: "/services/website-development/" },
    ]
  },
];
---

<ServiceLayout
  title="Fitness & Sports Marketing Singapore | Jraft Creative"
  description="Website design, SEO, social media, and digital marketing for gyms, yoga studios, pilates studios, and martial arts schools in Singapore."
  canonical="https://jraftcreative.com/industries/fitness/"
  ogTitle="Fitness & Sports Marketing Singapore | Jraft Creative"
  ogDescription="Website design, SEO, social media, and digital marketing for gyms, yoga studios, pilates studios, and martial arts schools in Singapore. Drive memberships and class bookings."
  keywords="fitness marketing Singapore, gym marketing Singapore, yoga studio marketing Singapore, pilates studio marketing Singapore, martial arts marketing Singapore, gym website design Singapore, fitness SEO Singapore"
  schemaData={schemaData}
  heroLabel="Fitness & Sports"
  heroTitle='Marketing for <span class="highlight">Fitness &amp; Sports</span> in Singapore'
  heroSubtitle="We help gyms, studios, and sports facilities in Singapore attract members, fill class timetables, and grow their brand — with websites and marketing built for the fitness industry."
  heroImage="/images/service-gym.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "View Services", href: "#services", class: "btn btn-secondary" },
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my fitness business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Fitness Business"
  ctaDescription="Get a free consultation and a tailored marketing plan for your gym or studio."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20fitness%20business%20in%20Singapore.", class: "btn btn-secondary" },
  ]}
>
  <section class="section bg-alt">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why It Matters</p>
        <h2>Why Fitness Businesses Need Specialised Marketing</h2>
        <p>The fitness industry in Singapore is competitive. Members comparison-shop across multiple studios before committing. Your digital presence needs to do more than look good — it needs to convert visitors into trial bookings and trial bookings into paying members.</p>
      </div>
      <div class="features-grid" style="margin-top: 2rem;">
        <div class="feature-card reveal">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="10" y1="14" x2="14" y2="14"/><line x1="12" y1="12" x2="12" y2="16"/></svg>
          </div>
          <h3>Class Timetable Integration</h3>
          <p>We build websites that connect seamlessly with booking systems such as Mindbody and ClassPass, so your live timetable is always visible and easy to book from any device.</p>
        </div>
        <div class="feature-card reveal reveal-d1">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <h3>Membership Signups</h3>
          <p>Clear membership tier pages, pricing tables, and conversion-focused layouts that move prospects from browsing to signing up without friction.</p>
        </div>
        <div class="feature-card reveal reveal-d2">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Trial Class Bookings</h3>
          <p>Dedicated trial offer landing pages with urgency copy and prominent calls to action — designed to turn first-time visitors into paying customers.</p>
        </div>
        <div class="feature-card reveal reveal-d3">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3>Trainer Profiles</h3>
          <p>Showcase the credentials and personalities of your coaching team. Trust in the trainer is one of the top reasons customers choose one fitness studio over another.</p>
        </div>
      </div>

      <style>
        .feature-icon {
          width: 48px;
          height: 48px;
          border-radius: 10px;
          background: rgba(73, 184, 137, 0.1);
          border: 1px solid rgba(73, 184, 137, 0.2);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: 1rem;
          color: var(--accent);
        }
      </style>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>Fitness Website <span class="highlight">Showcase</span></h2>
        <p>A concept gym website designed to demonstrate what a high-converting fitness site looks like.</p>
      </div>
      <div class="cf-wrap reveal reveal-d1" id="cfWrap">
        <div class="cf-track">
          <div class="cf-slide" data-name="FitZone SG" data-type="Gym &middot; Website Concept" data-desc="A boutique gym website with class timetable, membership pricing, trainer profiles, and trial class CTAs." data-href="/demos/fitzone-sg.html">
            <a href="/demos/fitzone-sg.html" target="_blank" rel="noopener"><img src="/images/portfolio-fitzone.webp" alt="FitZone SG" width="1200" height="700" loading="lazy"></a>
          </div>
          <div class="cf-slide" data-name="Iron Fist MMA" data-type="Martial Arts &middot; Website Concept" data-desc="A martial arts academy site with discipline showcases, training schedule, coach profiles, and membership tiers." data-href="/demos/ironfist-mma.html">
            <a href="/demos/ironfist-mma.html" target="_blank" rel="noopener"><img src="/images/portfolio-ironfist.webp" alt="Iron Fist MMA" width="1200" height="700" loading="lazy"></a>
          </div>
          <div class="cf-slide" data-name="Flow Studio" data-type="Yoga &amp; Pilates &middot; Website Concept" data-desc="A yoga and pilates studio site with class cards, reformer booking, instructor profiles, and flexible pricing." data-href="/demos/flow-yoga.html">
            <a href="/demos/flow-yoga.html" target="_blank" rel="noopener"><img src="/images/portfolio-flow.webp" alt="Flow Studio" width="1200" height="700" loading="lazy"></a>
          </div>
        </div>
        <div class="cf-arrows">
          <button class="cf-btn cf-prev" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="cf-btn cf-next" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
      <div class="cf-info reveal reveal-d2" id="cfInfo">
        <span class="portfolio-type" id="cfType">Gym &middot; Website Concept</span>
        <h3 id="cfName">FitZone SG</h3>
        <p id="cfDesc">A boutique gym website with class timetable, membership pricing, trainer profiles, and trial class CTAs.</p>
        <a id="cfLink" href="/demos/fitzone-sg.html" target="_blank" rel="noopener" class="cf-demo-link">View Live Demo →</a>
      </div>

      <style>
        .cf-wrap {
          position: relative;
          max-width: 850px;
          margin: 0 auto;
          padding: 0.5rem 0;
        }
        .cf-track {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 1rem;
          perspective: 900px;
          height: 280px;
        }
        .cf-slide {
          flex: 0 0 52%;
          max-width: 52%;
          height: 100%;
          border-radius: var(--radius);
          overflow: hidden;
          border: 1px solid var(--border);
          transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
          transform: scale(0.8);
          opacity: 0.35;
          filter: brightness(0.5);
          cursor: pointer;
          z-index: 1;
        }
        .cf-slide.active {
          transform: scale(1);
          opacity: 1;
          filter: brightness(1);
          z-index: 3;
          box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
          border-color: var(--border-accent);
        }
        .cf-slide.prev {
          transform: scale(0.8) translateX(18%) rotateY(6deg);
          opacity: 0.45;
          filter: brightness(0.55);
          z-index: 2;
        }
        .cf-slide.next {
          transform: scale(0.8) translateX(-18%) rotateY(-6deg);
          opacity: 0.45;
          filter: brightness(0.55);
          z-index: 2;
        }
        .cf-slide a { display: block; height: 100%; }
        .cf-slide img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: top;
          display: block;
        }
        .cf-arrows {
          position: absolute;
          top: 50%;
          left: 0;
          right: 0;
          transform: translateY(-50%);
          display: flex;
          justify-content: space-between;
          padding: 0 0.25rem;
          pointer-events: none;
          z-index: 10;
        }
        .cf-btn {
          width: 34px;
          height: 34px;
          border-radius: 50%;
          border: 1px solid var(--border);
          background: rgba(18, 18, 27, 0.85);
          backdrop-filter: blur(6px);
          color: var(--text-muted);
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: all 0.2s;
          pointer-events: all;
        }
        .cf-btn:hover {
          border-color: var(--accent);
          color: var(--accent);
        }
        .cf-info {
          text-align: center;
          margin-top: 1.25rem;
          max-width: 520px;
          margin-left: auto;
          margin-right: auto;
        }
        .cf-info h3 {
          font-size: 1.2rem;
          font-weight: 700;
          margin: 0.3rem 0;
        }
        .cf-info p {
          color: var(--text-muted);
          line-height: 1.7;
          font-size: 0.85rem;
        }
        .cf-demo-link {
          display: inline-block;
          margin-top: 0.5rem;
          font-size: 0.82rem;
          font-weight: 600;
          color: var(--accent);
          cursor: pointer;
          transition: opacity 0.2s;
        }
        .cf-demo-link:hover { opacity: 0.8; }
        @media (max-width: 768px) {
          .cf-track { height: 200px; }
          .cf-slide { flex: 0 0 70%; max-width: 70%; }
          .cf-slide.prev, .cf-slide.next { transform: scale(0.75); }
        }
      </style>

      <script is:inline>
        (function() {
          var slides = document.querySelectorAll('.cf-slide');
          var nameEl = document.getElementById('cfName');
          var typeEl = document.getElementById('cfType');
          var descEl = document.getElementById('cfDesc');
          var linkEl = document.getElementById('cfLink');
          var current = 0;
          var total = slides.length;

          function update() {
            var prevIdx = (current - 1 + total) % total;
            var nextIdx = (current + 1) % total;
            slides.forEach(function(s, i) {
              s.classList.remove('active', 'prev', 'next');
              s.style.order = '';
              s.style.visibility = '';
              if (i === current) { s.classList.add('active'); s.style.order = '2'; }
              else if (i === prevIdx) { s.classList.add('prev'); s.style.order = '1'; }
              else if (i === nextIdx) { s.classList.add('next'); s.style.order = '3'; }
              else { s.style.display = 'none'; }
            });
            var s = slides[current];
            nameEl.textContent = s.dataset.name;
            typeEl.innerHTML = s.dataset.type;
            descEl.textContent = s.dataset.desc;
            linkEl.href = s.dataset.href;
          }

          function goTo(i) { current = (i + total) % total; update(); }

          slides.forEach(function(s, i) {
            s.addEventListener('click', function(e) { if (i !== current) { e.preventDefault(); goTo(i); } });
          });
          document.querySelector('.cf-prev').addEventListener('click', function() { goTo(current - 1); });
          document.querySelector('.cf-next').addEventListener('click', function() { goTo(current + 1); });
          update();

          var timer = setInterval(function() { goTo(current + 1); }, 3000);
          document.getElementById('cfWrap').addEventListener('mouseenter', function() { clearInterval(timer); });
          document.getElementById('cfWrap').addEventListener('mouseleave', function() {
            timer = setInterval(function() { goTo(current + 1); }, 3000);
          });
        })();
      </script>
    </div>
  </section>

  <section class="section" id="services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Cover</p>
        <h2>Your Fitness Niche, Our Expertise</h2>
        <p>Select your type of fitness business below to explore the services we offer for your specific category.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((industry, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`} data-bg={industry.image}>
            <h3><a href={industry.href}>{industry.name}</a></h3>
            <p>{industry.description}</p>
            <div class="industry-detail-services">
              {industry.services.map(service => (
                <a href={service.href}>{service.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
