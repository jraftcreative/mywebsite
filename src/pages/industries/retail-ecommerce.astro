---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const subIndustries = [
  {
    name: "Ecommerce",
    href: "/ecommerce-website-singapore/",
    description: "Online stores, DTC brands, and marketplace sellers.",
    services: [
      { label: "Website", href: "/ecommerce-website-singapore/" },
    ],
  },
  {
    name: "Pet Shop",
    href: "/pet-shop-website-singapore/",
    description: "Pet stores, grooming services, and pet supply retailers.",
    services: [
      { label: "Website", href: "/pet-shop-website-singapore/" },
    ],
  },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Retail & Ecommerce Marketing Singapore — Jraft Creative",
    "description": "Marketing services for retail and ecommerce businesses in Singapore. Website design, SEO, social media, and paid ads tailored to online stores, DTC brands, and specialty retailers.",
    "url": "https://jraftcreative.com/industries/retail-ecommerce/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Retail & Ecommerce", "item": "https://jraftcreative.com/industries/retail-ecommerce/" }
    ]
  }
];
---

<ServiceLayout
  title="Retail & Ecommerce Marketing Singapore | Jraft Creative"
  description="Marketing services for retail and ecommerce businesses in Singapore. Website design, SEO, social media, and paid ads tailored to online stores, DTC brands, and specialty retailers."
  canonical="https://jraftcreative.com/industries/retail-ecommerce/"
  ogTitle="Retail & Ecommerce Marketing Singapore — Jraft Creative"
  ogDescription="Marketing services for retail and ecommerce businesses in Singapore. Website design, SEO, social media, and paid ads tailored to online stores, DTC brands, and specialty retailers."
  keywords="retail marketing singapore, ecommerce marketing singapore, online store website singapore, ecommerce seo singapore, Jraft Creative"
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  schemaData={schemaData}
  heroLabel="Retail & Ecommerce"
  heroTitle='Marketing for <span class="highlight">Retail &amp; Ecommerce</span> in Singapore'
  heroSubtitle="We help retail and ecommerce businesses in Singapore build high-converting online stores, reach buyers across search and social, and turn traffic into consistent revenue."
  heroImage="/images/industry-retail.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my retail business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Retail Business"
  ctaDescription="Book a free consultation and tell us about your store, products, and goals. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20retail%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <section class="section" id="services" aria-label="Services by retail type">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Services</p>
        <h2>Services by Retail Type</h2>
        <p>Select your business type to see the full range of services available.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((sub, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`}>
            <h3><a href={sub.href}>{sub.name}</a></h3>
            <p>{sub.description}</p>
            <div class="industry-detail-services">
              {sub.services.map((svc) => (
                <a href={svc.href}>{svc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-alt" aria-label="Why retail and ecommerce businesses need specialised marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why It Matters</p>
        <h2>Why Retail &amp; Ecommerce Businesses Need Specialised Marketing</h2>
      </div>
      <div class="reveal reveal-d1">
        <p>Retail and ecommerce in Singapore is highly competitive. Shoppers compare prices across Shopee, Lazada, and brand-owned stores in seconds — which means your website, product pages, and ad creative all have to work harder than in most other industries. A generic digital marketing approach built for service businesses will not translate into add-to-cart actions and completed checkouts.</p>
        <p style="margin-top: 1rem;">Effective ecommerce marketing requires a specific skill set: product photography and visual content that communicates quality and drives purchase intent, Shopify and WooCommerce website builds optimised for conversion and mobile checkout, payment gateway integrations suited to the Singapore market, inventory-aware SEO that keeps product pages ranking even as stock changes, and DTC strategies that reduce reliance on marketplace platforms and build long-term customer relationships. We understand this industry and build campaigns that translate into orders, repeat buyers, and sustainable growth.</p>
      </div>
    </div>
  </section>

</ServiceLayout>
