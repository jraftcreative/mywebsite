---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Professional Services Marketing — Jraft Creative",
    "description": "Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation.",
    "url": "https://jraftcreative.com/industries/professional-services/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does professional services marketing cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most professional services firms in Singapore invest between $2,500 and $10,000 per month on marketing, depending on practice size, number of partners, and competitiveness of the practice area. A solo property agent or independent advisor may start lower, while a multi-partner law or accounting firm competing on high-value matters invests more. Engagements typically cover website, SEO, paid search, content, and social — coordinated under one strategy." } },
      { "@type": "Question", "name": "Do you understand the advertising compliance rules for my profession?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Legal advertising in Singapore is governed by the Legal Profession (Professional Conduct) Rules, financial advisory marketing must comply with MAS guidelines, and real estate promotions are subject to Council for Estate Agencies (CEA) rules. We build campaigns that generate qualified leads without crossing these regulatory lines — a constraint generic agencies routinely get wrong." } },
      { "@type": "Question", "name": "Which marketing channels work best for professional services firms?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search captures high-intent prospects actively looking for a lawyer, accountant, agent, or advisor. SEO and a credibility-led website convert that research into enquiries. Thought-leadership content and LinkedIn build authority for B2B and high-value work, while Google Ads captures urgent, transactional searches. The right mix depends on whether you serve consumers or businesses, and on your practice area." } },
      { "@type": "Question", "name": "How long before marketing generates new client enquiries?", "acceptedAnswer": { "@type": "Answer", "text": "Paid search can generate enquiries within the first weeks. SEO and content typically take 3–6 months to build sustainable organic visibility for competitive practice-area terms. Most professional services clients see a meaningful lift in qualified enquiries within the first 60–90 days of a coordinated campaign, with authority and rankings compounding over time." } },
      { "@type": "Question", "name": "Do you work with law firms, accounting firms, property agents, and financial advisors?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — those four are our core professional services verticals, each with its own dedicated marketing approach. We also work with consultancies, corporate secretarial firms, and other advisory practices. Every engagement is built around the trust-and-credibility purchase that defines professional services, and around the specific compliance regime that governs your profession." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Professional Services", "item": "https://jraftcreative.com/industries/professional-services/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Client Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Professional Services Marketing — Jraft Creative"
  description="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore."
  canonical="https://jraftcreative.com/industries/professional-services/"
  ogTitle="Professional Services Marketing — Jraft Creative"
  ogDescription="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation."
  keywords="professional services marketing singapore, law firm marketing, accounting firm website singapore, property agent website singapore, insurance advisor marketing, Jraft Creative"
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  schemaData={schemaData}
  heroLabel="Professional Services"
  heroTitle='Marketing for <span class="highlight">Professional Services</span> in Singapore'
  heroSubtitle="Law firms, accounting practices, property agents, and financial advisors win on trust — and prospects research, compare, and vet credentials online before they ever make contact. We build compliant, credibility-led marketing that turns that research into qualified enquiries."
  heroImage="/images/service-corporate.webp"
  heroImageAlt="Professional services firm in Singapore — marketing for law, accounting, property, and advisory practices"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "#case-study", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my professional services firm in Singapore."
  ctaLabel="Ready to Grow Your Practice?"
  ctaTitle='Grow Your <span class="highlight">Practice</span>'
  ctaDescription="Book a free consultation and tell us about your firm or advisory practice. We'll review your current marketing, flag the compliance pitfalls, and recommend a strategy tailored to your practice area. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20professional%20services%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why professional service firms need specialised marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why It Matters</p>
        <h2>Professional Services Are Won on <span class="highlight">Trust</span>, Not <span class="highlight">Generic Funnels</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Whether a prospect is looking for a conveyancing lawyer, a corporate tax advisor, a property agent, or an insurance planner, they research heavily before making contact — assessing credentials, reading reviews, and comparing firms. A weak or non-compliant online presence doesn't just miss opportunities; it actively undermines confidence in your firm.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Trust-First Buyer</h3>
            <p>Prospects vet your credentials, read reviews, and scrutinise your website before they ever reach out. The decision is made on credibility long before the first call — and a dated or thin online presence quietly disqualifies you from the shortlist.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Compliance Line</h3>
            <p>Legal advertising is governed by the Legal Profession (Professional Conduct) Rules, financial advisory by MAS guidelines, and real estate by CEA rules. Generic agencies cross these lines without knowing it. We generate leads without putting your licence at risk.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Expertise Has to Show</h3>
            <p>Effective professional services marketing turns demonstrable expertise into trust signals — credentials, case studies, and thought leadership that convert a cautious prospect into a paying client. Not templates borrowed from e-commerce or retail.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing channels for professional services firms in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Professional Firm <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies for professional services — combining credibility-led SEO, AI search optimisation (GEO), high-intent paid search, authority content, branding, and conversion-focused websites, all built to respect the compliance rules of your profession.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO &amp; Local Search</a></h3>
            <p>Rank for practice-area and catchment searches like "corporate lawyer Singapore", "audit firm Raffles Place", or "property agent [area]" — plus Google Business Profile and reviews that build the trust the purchase depends on.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when prospects ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best corporate law firm Singapore" or "good financial advisor near me." The same AI-citation playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google &amp; LinkedIn Ads</a></h3>
            <p>High-intent paid search for urgent matters, plus LinkedIn for B2B and high-value work — built within the advertising rules of your profession, with tracking from click through to a booked consultation.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social &amp; Thought Leadership</a></h3>
            <p>LinkedIn, Instagram, and TikTok content that builds authority — explainer content, market commentary, and credentials that make a cautious prospect comfortable. The exact play behind our Kairos Advisory results below.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding &amp; Credibility</a></h3>
            <p>The brand system that signals seniority and trust — identity, partner and team presentation, and collateral that positions you above the commoditised competition and justifies premium fees.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/website-development/">Websites That Convert</a></h3>
            <p>The credibility-led site that closes the enquiry — clear service and credential pages, case studies, secure enquiry forms, and fast mobile performance, built to convert a researching prospect into a booked consultation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for professional services marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Clients Choose</span> a <span class="highlight">Firm</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We work with law firms, accounting practices, property agents, and financial advisors across Singapore — building around the trust-and-credibility purchase, the compliance regime of each profession, and the long, research-heavy way clients decide. Not generic templates, and not vanity-metric retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Compliant by Default</h3>
            <p>We know the Legal Profession (Professional Conduct) Rules, MAS advertising guidelines, and CEA rules — and build campaigns that generate leads without crossing them. Compliance is baked in, not bolted on after a complaint.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, paid search, social, branding, and websites under one roof. No coordinating between vendors. Every channel reinforces the same credible, consistent positioning — the only thing that converts a trust-led buyer.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enquiries, Not Vanity Metrics</h3>
            <p>We measure qualified enquiries, consultations booked, and cost per lead — not impressions. Month-to-month engagements, because you should stay for the pipeline, not a contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-alt ps-casestudy-section" id="case-study" aria-label="Case study — Kairos Advisory Group">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Case Study</p>
        <h2><span class="highlight">Kairos Advisory Group</span></h2>
        <p>Financial advisory group in Singapore — website revamp and ongoing social media management.</p>
      </div>

      <!-- Two-column layout: left = website + description, right = TikTok + stats -->
      <div class="cs-layout reveal reveal-d1">
        <!-- Left column -->
        <div class="cs-col">
          <a href="https://kairos-advisorygroup.com/" class="cs-card" target="_blank" rel="noopener">
            <img src="/images/preview-kairos.webp" alt="Kairos Advisory Group website" width="600" height="400" loading="lazy">
            <div class="cs-card-label">Website Revamp</div>
          </a>
          <div class="cs-description">
            <p>We redesigned Kairos Advisory's website to better communicate their services, team credentials, and approach — giving prospects the confidence to reach out. We also manage their social media with educational content across TikTok and Instagram, covering insurance, investing, and market commentary.</p>
            <div class="portfolio-tags" style="margin-top: 1rem;">
              <span class="portfolio-tag">Website Revamp</span>
              <span class="portfolio-tag">Social Media</span>
              <span class="portfolio-tag">Content Creation</span>
              <span class="portfolio-tag">TikTok</span>
            </div>
          </div>
        </div>
        <!-- Right column -->
        <div class="cs-col">
          <div class="cs-card">
            <img src="/images/kairos-tiktok-stats.webp" alt="Kairos Advisory TikTok analytics — 39.9K views, 272 new followers" width="521" height="800" loading="lazy">
          </div>
          <p class="cs-stats-label">TikTok Results — 1 Post</p>
          <div class="cs-stats" id="kairos-stats">
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="39949" data-suffix="" data-format="k">0</span>
              <span class="cs-stat-label">Views</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="272" data-suffix="">0</span>
              <span class="cs-stat-label">Followers</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="470" data-suffix="">0</span>
              <span class="cs-stat-label">Shares</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="208" data-suffix="">0</span>
              <span class="cs-stat-label">Likes</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="313" data-suffix="h">0</span>
              <span class="cs-stat-label">Watch Time</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Gradient glow on Case Study */
    .ps-casestudy-section {
      position: relative;
      overflow: hidden;
    }
    .ps-casestudy-section::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(73, 184, 137, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }
    .ps-casestudy-section::after {
      content: '';
      position: absolute;
      bottom: -15%;
      left: -5%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(73, 184, 137, 0.05) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }
    .ps-casestudy-section > .container {
      position: relative;
      z-index: 1;
    }

    .cs-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1.5rem;
      align-items: start;
    }
    .cs-col {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .cs-card {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      background: var(--bg-card);
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
      display: block;
      max-height: 280px;
    }
    .cs-card:hover {
      border-color: var(--border-accent);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
      transform: translateY(-4px);
    }
    .cs-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
