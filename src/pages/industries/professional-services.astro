---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const subIndustries = [
  {
    name: "Law Firm",
    href: "/law-firm-website-singapore/",
    description: "Corporate law firms, family law practices, and legal consultancies.",
    services: [
      { label: "Website", href: "/law-firm-website-singapore/" },
    ],
  },
  {
    name: "Accounting Firm",
    href: "/accounting-firm-website-singapore/",
    description: "Audit firms, tax consultancies, and bookkeeping services.",
    services: [
      { label: "Website", href: "/accounting-firm-website-singapore/" },
    ],
  },
  {
    name: "Property Agent",
    href: "/property-agent-website-singapore/",
    description: "Real estate agents, property agencies, and developer sales teams.",
    services: [
      { label: "Website", href: "/property-agent-website-singapore/" },
    ],
  },
  {
    name: "Insurance Agent",
    href: "/insurance-agent-website-singapore/",
    description: "Independent financial advisors and insurance agencies.",
    services: [
      { label: "Website", href: "/insurance-agent-website-singapore/" },
    ],
  },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Professional Services Marketing — Jraft Creative",
    "description": "Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation.",
    "url": "https://jraftcreative.com/industries/professional-services/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Professional Services", "item": "https://jraftcreative.com/industries/professional-services/" }
    ]
  }
];
---

<ServiceLayout
  title="Professional Services Marketing Singapore | Jraft Creative"
  description="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation."
  canonical="https://jraftcreative.com/industries/professional-services/"
  ogTitle="Professional Services Marketing Singapore — Jraft Creative"
  ogDescription="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation."
  keywords="professional services marketing singapore, law firm marketing, accounting firm website singapore, property agent website singapore, insurance advisor marketing, Jraft Creative"
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  schemaData={schemaData}
  heroLabel="Professional Services"
  heroTitle='Marketing for <span class="highlight">Professional Services</span> in Singapore'
  heroSubtitle="We help law firms, accounting practices, property agents, and financial advisors in Singapore build credibility online, generate qualified leads, and grow their client base — with marketing that reflects the professionalism their clients expect."
  heroImage="/images/service-law.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my professional services firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Practice"
  ctaDescription="Book a free consultation and tell us about your firm or advisory practice. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20professional%20services%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <section class="section bg-alt" aria-label="Why professional service firms need specialised marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why It Matters</p>
        <h2>Why Professional Service Firms Need Specialised Marketing</h2>
      </div>
      <div class="reveal reveal-d1">
        <p>Professional services firms operate in sectors where trust is the primary purchase driver. Prospective clients — whether they are looking for a conveyancing lawyer, a corporate tax advisor, a property agent, or an insurance planner — conduct significant research before making contact. They assess credentials, read reviews, scrutinise websites, and compare firms before ever reaching out. A poorly positioned online presence is not just a missed opportunity; it actively undermines confidence in your firm.</p>
        <p style="margin-top: 1rem;">Marketing in these industries also carries obligations that generic agencies are ill-equipped to handle. Legal advertising in Singapore is governed by the Legal Profession (Publicity) Rules. Financial advisory marketing must comply with MAS guidelines. Real estate agent promotions are subject to CEA regulations. We understand these constraints and build campaigns that generate leads without crossing regulatory lines.</p>
        <p style="margin-top: 1rem;">Beyond compliance, effective professional services marketing centres on demonstrable expertise: client-facing credentials, case studies, thought leadership content, and trust signals that convert a cautious prospect into a paying client. We design websites and run campaigns built around this reality — not templates borrowed from e-commerce or retail.</p>
      </div>
    </div>
  </section>

  <section class="section" id="services" aria-label="Services by practice type">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Services</p>
        <h2>Services by Practice Type</h2>
        <p>Select your practice type to see the services available for your business.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((sub, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`}>
            <h3><a href={sub.href}>{sub.name}</a></h3>
            <p>{sub.description}</p>
            <div class="industry-detail-services">
              {sub.services.map((svc) => (
                <a href={svc.href}>{svc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</ServiceLayout>
