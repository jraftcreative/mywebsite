---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const subIndustries = [
  {
    name: "Law Firm",
    href: "/law-firm-website-singapore/",
    description: "Corporate law firms, family law practices, and legal consultancies.",
    image: "/images/service-law.webp",
    services: [
      { label: "Website", href: "/law-firm-website-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Paid Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "AI Search (GEO)", href: "/services/ai-search-optimisation/" },
    ],
  },
  {
    name: "Accounting Firm",
    href: "/accounting-firm-website-singapore/",
    description: "Audit firms, tax consultancies, and bookkeeping services.",
    image: "/images/service-accounting.webp",
    services: [
      { label: "Website", href: "/accounting-firm-website-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Paid Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "AI Search (GEO)", href: "/services/ai-search-optimisation/" },
    ],
  },
  {
    name: "Property Agent",
    href: "/property-agent-website-singapore/",
    description: "Real estate agents, property agencies, and developer sales teams.",
    image: "/images/service-property.webp",
    services: [
      { label: "Website", href: "/property-agent-website-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Paid Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "AI Search (GEO)", href: "/services/ai-search-optimisation/" },
    ],
  },
  {
    name: "Insurance Agent",
    href: "/insurance-agent-website-singapore/",
    description: "Independent financial advisors and insurance agencies.",
    image: "/images/service-insurance.webp",
    services: [
      { label: "Website", href: "/insurance-agent-website-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Paid Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "AI Search (GEO)", href: "/services/ai-search-optimisation/" },
    ],
  },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Professional Services Marketing — Jraft Creative",
    "description": "Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation.",
    "url": "https://jraftcreative.com/industries/professional-services/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Professional Services", "item": "https://jraftcreative.com/industries/professional-services/" }
    ]
  }
];
---

<ServiceLayout
  title="Professional Services Marketing — Jraft"
  description="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore."
  canonical="https://jraftcreative.com/industries/professional-services/"
  ogTitle="Professional Services Marketing — Jraft"
  ogDescription="Marketing services for law firms, accounting firms, property agents, and insurance advisors in Singapore. Professional website design and digital marketing built around trust, credibility, and lead generation."
  keywords="professional services marketing singapore, law firm marketing, accounting firm website singapore, property agent website singapore, insurance advisor marketing, Jraft Creative"
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  schemaData={schemaData}
  heroLabel="Professional Services"
  heroTitle='Marketing for <span class="highlight">Professional Services</span> in Singapore'
  heroSubtitle="We help law firms, accounting practices, property agents, and financial advisors in Singapore build credibility online, generate qualified leads, and grow their client base — with marketing that reflects the professionalism their clients expect."
  heroImage="/images/service-corporate.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my professional services firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Practice"
  ctaDescription="Book a free consultation and tell us about your firm or advisory practice. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20professional%20services%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <section class="section ps-why-section" aria-label="Why professional service firms need specialised marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why It Matters</p>
        <h2>Why Professional Service Firms Need <span class="highlight">Specialised</span> Marketing</h2>
      </div>
      <div class="reveal reveal-d1">
        <p>Professional services firms operate in sectors where trust is the primary purchase driver. Prospective clients — whether they are looking for a conveyancing lawyer, a corporate tax advisor, a property agent, or an insurance planner — conduct significant research before making contact. They assess credentials, read reviews, scrutinise websites, and compare firms before ever reaching out. A poorly positioned online presence is not just a missed opportunity; it actively undermines confidence in your firm.</p>
        <p style="margin-top: 1rem;">Marketing in these industries also carries obligations that generic agencies are ill-equipped to handle. Legal advertising in Singapore is governed by the Legal Profession (Publicity) Rules. Financial advisory marketing must comply with MAS guidelines. Real estate agent promotions are subject to CEA regulations. We understand these constraints and build campaigns that generate leads without crossing regulatory lines.</p>
        <p style="margin-top: 1rem;">Beyond compliance, effective professional services marketing centres on demonstrable expertise: client-facing credentials, case studies, thought leadership content, and trust signals that convert a cautious prospect into a paying client. We design websites and run campaigns built around this reality — not templates borrowed from e-commerce or retail.</p>
      </div>
    </div>
  </section>

  <section class="section bg-alt ps-casestudy-section" aria-label="Case study — Kairos Advisory Group">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Case Study</p>
        <h2><span class="highlight">Kairos Advisory Group</span></h2>
        <p>Financial advisory group in Singapore — website revamp and ongoing social media management.</p>
      </div>

      <!-- Two-column layout: left = website + description, right = TikTok + stats -->
      <div class="cs-layout reveal reveal-d1">
        <!-- Left column -->
        <div class="cs-col">
          <a href="https://kairos-advisorygroup.com/" class="cs-card" target="_blank" rel="noopener">
            <img src="/images/preview-kairos.webp" alt="Kairos Advisory Group website" width="600" height="400" loading="lazy">
            <div class="cs-card-label">Website Revamp</div>
          </a>
          <div class="cs-description">
            <p>We redesigned Kairos Advisory's website to better communicate their services, team credentials, and approach — giving prospects the confidence to reach out. We also manage their social media with educational content across TikTok and Instagram, covering insurance, investing, and market commentary.</p>
            <div class="portfolio-tags" style="margin-top: 1rem;">
              <span class="portfolio-tag">Website Revamp</span>
              <span class="portfolio-tag">Social Media</span>
              <span class="portfolio-tag">Content Creation</span>
              <span class="portfolio-tag">TikTok</span>
            </div>
          </div>
        </div>
        <!-- Right column -->
        <div class="cs-col">
          <div class="cs-card">
            <img src="/images/kairos-tiktok-stats.webp" alt="Kairos Advisory TikTok analytics — 39.9K views, 272 new followers" width="521" height="800" loading="lazy">
          </div>
          <p class="cs-stats-label">TikTok Results — 1 Post</p>
          <div class="cs-stats" id="kairos-stats">
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="39949" data-suffix="" data-format="k">0</span>
              <span class="cs-stat-label">Views</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="272" data-suffix="">0</span>
              <span class="cs-stat-label">Followers</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="470" data-suffix="">0</span>
              <span class="cs-stat-label">Shares</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="208" data-suffix="">0</span>
              <span class="cs-stat-label">Likes</span>
            </div>
            <div class="cs-stat">
              <span class="cs-stat-number" data-target="313" data-suffix="h">0</span>
              <span class="cs-stat-label">Watch Time</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Dot pattern overlay on Why It Matters */
    .ps-why-section {
      position: relative;
    }
    .ps-why-section::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
      background-size: 24px 24px;
      pointer-events: none;
      z-index: 0;
    }
    .ps-why-section > .container {
      position: relative;
      z-index: 1;
    }

    /* Gradient glow on Case Study */
    .ps-casestudy-section {
      position: relative;
      overflow: hidden;
    }
    .ps-casestudy-section::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -10%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(73, 184, 137, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }
    .ps-casestudy-section::after {
      content: '';
      position: absolute;
      bottom: -15%;
      left: -5%;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(73, 184, 137, 0.05) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }
    .ps-casestudy-section > .container {
      position: relative;
      z-index: 1;
    }

    .cs-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1.5rem;
      align-items: start;
    }
    .cs-col {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .cs-card {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      background: var(--bg-card);
      transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
      display: block;
      max-height: 280px;
    }
    .cs-card:hover {
      border-color: var(--border-accent);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
      transform: translateY(-4px);
    }
    .cs-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      display: block;
    }
    .cs-card-label {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1rem 1.25rem;
      background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.03em;
    }
    .cs-description {
      color: var(--text-muted);
      line-height: 1.7;
    }
    .cs-stats-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      margin-bottom: 0.25rem;
    }
    .cs-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      padding: 1.25rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .cs-stat {
      text-align: center;
    }
    .cs-stat-number {
      display: block;
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
      font-variant-numeric: tabular-nums;
    }
    .cs-stat-label {
      display: block;
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 0.2rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    @media (max-width: 768px) {
      .cs-layout {
        grid-template-columns: 1fr;
      }
      .cs-stats {
        grid-template-columns: repeat(5, 1fr);
      }
    }
    @media (max-width: 480px) {
      .cs-stats {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>

  <script is:inline>
    (function () {
      function formatNumber(n, format, suffix) {
        var result;
        if (format === 'k' && n >= 1000) {
          result = (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
        } else {
          result = n.toLocaleString();
        }
        return result + suffix;
      }

      function animateCounters(container) {
        var counters = container.querySelectorAll('.cs-stat-number');
        var duration = 2000;
        var start = performance.now();

        counters.forEach(function (el) {
          var target = parseInt(el.dataset.target, 10);
          var suffix = el.dataset.suffix || '';
          var format = el.dataset.format || '';

          function tick(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            // Ease-out cubic
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.round(eased * target);
            el.textContent = formatNumber(current, format, suffix);
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }

      var statsEl = document.getElementById('kairos-stats');
      if (!statsEl) return;

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCounters(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      observer.observe(statsEl);
    })();
  </script>

  <section class="section" id="services" aria-label="Services by practice type">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Services</p>
        <h2>Services by Practice Type</h2>
        <p>Select your practice type to see the services available for your business.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((sub, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`} data-bg={sub.image}>
            <h3><a href={sub.href}>{sub.name}</a></h3>
            <p>{sub.description}</p>
            <div class="industry-detail-services">
              {sub.services.map((svc) => (
                <a href={svc.href}>{svc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</ServiceLayout>
