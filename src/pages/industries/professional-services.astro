        grid-template-columns: repeat(5, 1fr);
      }
    }
    @media (max-width: 480px) {
      .cs-stats {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>

  <script is:inline>
    (function () {
      function formatNumber(n, format, suffix) {
        var result;
        if (format === 'k' && n >= 1000) {
          result = (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
        } else {
          result = n.toLocaleString();
        }
        return result + suffix;
      }

      function animateCounters(container) {
        var counters = container.querySelectorAll('.cs-stat-number');
        var duration = 2000;
        var start = performance.now();

        counters.forEach(function (el) {
          var target = parseInt(el.dataset.target, 10);
          var suffix = el.dataset.suffix || '';
          var format = el.dataset.format || '';

          function tick(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            // Ease-out cubic
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.round(eased * target);
            el.textContent = formatNumber(current, format, suffix);
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }

      var statsEl = document.getElementById('kairos-stats');
      if (!statsEl) return;

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCounters(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      observer.observe(statsEl);
    })();
  </script>

  <!-- ========== THE CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — how professional services clients decide on a firm">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>How <span class="highlight">Clients</span> Actually <span class="highlight">Choose a Firm</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
