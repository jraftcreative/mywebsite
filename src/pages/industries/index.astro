---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const industries = [
  { name: "F&B & Hospitality", description: "Restaurants, cafes, bars, and food delivery brands.", href: "/industries/food-beverage/", image: "/images/service-fnb.webp" },
  { name: "Beauty & Aesthetics", description: "Beauty salons, hair salons, nail studios, spas, and aesthetics clinics.", href: "/industries/beauty-aesthetics/", image: "/images/service-beauty.webp" },
  { name: "Healthcare", description: "Clinics, dental practices, TCM, physiotherapy, and veterinary clinics.", href: "/industries/healthcare/", image: "/images/service-clinic.webp" },
  { name: "Fitness & Sports", description: "Gyms, yoga studios, pilates studios, and martial arts schools.", href: "/industries/fitness/", image: "/images/service-gym.webp" },
  { name: "Education", description: "Tuition centres, enrichment schools, preschools, and music schools.", href: "/industries/education/", image: "/images/service-tuition.webp" },
  { name: "Professional Services", description: "Law firms, accounting firms, property agents, and insurance advisors.", href: "/industries/professional-services/", image: "/images/service-law.webp" },
  { name: "Retail & Ecommerce", description: "Fashion, lifestyle brands, specialty goods, and online stores.", href: "/industries/retail-ecommerce/", image: "/images/service-ecommerce.webp" },
  { name: "Creative & Events", description: "Interior designers, photographers, wedding planners, and event companies.", href: "/industries/creative-events/", image: "/images/service-interior.webp" },
  { name: "Home & Trade Services", description: "Construction firms, cleaning companies, and logistics providers.", href: "/industries/home-trade/", image: "/images/service-construction.webp" },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Industries We Serve — Jraft Creative",
    "description": "Explore the industries we specialise in. Jraft Creative provides website design, SEO, marketing, and social media services tailored to your industry in Singapore.",
    "url": "https://jraftcreative.com/industries/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" }
    ]
  }
];
---

<ServiceLayout
  title="Industries We Serve — Website Design & Marketing | Jraft Creative"
  description="Explore the industries we specialise in. Jraft Creative provides website design, SEO, marketing, and social media services tailored to your industry in Singapore."
  canonical="https://jraftcreative.com/industries/"
  ogTitle="Industries We Serve — Jraft Creative"
  ogDescription="Explore the industries we specialise in. Jraft Creative provides website design, SEO, marketing, and social media services tailored to your industry in Singapore."
  keywords="industry-specific marketing Singapore, website design by industry, SEO by industry, digital marketing Singapore"
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  schemaData={schemaData}
  heroLabel="Industries"
  heroTitle='Industries We <span class="highlight">Serve</span>'
  heroSubtitle="We build websites and run marketing campaigns tailored to your industry — not generic templates. Choose your industry below to see what we can do for you."
  heroImage="/images/industry-education.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to discuss marketing for my business."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Business Online"
  ctaDescription="Book a free consultation and tell us about your business. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20discuss%20marketing%20for%20my%20business.", class: "btn btn-secondary" }
  ]}
>
  <section class="section">
    <div class="container">
      <div class="industries-hub-grid">
        {industries.map((industry, i) => (
          <a href={industry.href} class={`industry-hub-card reveal ${i > 0 ? `reveal-d${Math.min(i, 4)}` : ''}`} data-bg={industry.image}>
            <div class="industry-hub-card-content">
              <h2>{industry.name}</h2>
              <p>{industry.description}</p>
              <span class="industry-hub-card-cta">View services &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-alt">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Approach</p>
        <h2>Why Industry-Specific Marketing Matters</h2>
      </div>
      <div class="features-grid" style="margin-top: 2rem;">
        <div class="feature-card reveal">
          <h3>Industry Expertise</h3>
          <p>We understand the regulations, customer journeys, and conversion patterns specific to your industry.</p>
        </div>
        <div class="feature-card reveal reveal-d1">
          <h3>Targeted Keywords</h3>
          <p>We target the exact search terms your potential customers use — not generic keywords that waste your budget.</p>
        </div>
        <div class="feature-card reveal reveal-d2">
          <h3>Proven Templates</h3>
          <p>Our website layouts are tested and optimised for conversions in your specific industry vertical.</p>
        </div>
        <div class="feature-card reveal reveal-d3">
          <h3>Local Focus</h3>
          <p>Singapore-specific strategies including Google Business Profile, local SEO, and neighbourhood targeting.</p>
        </div>
      </div>
    </div>
  </section>
</ServiceLayout>
