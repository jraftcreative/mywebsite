---
import BaseLayout from '../../layouts/BaseLayout.astro';

const subIndustries = [
  {
    name: "General Clinic",
    href: "/clinic-website-design-singapore/",
    description: "GP clinics, polyclinics, and family medicine practices.",
    services: [
      { label: "Website", href: "/clinic-website-design-singapore/" },
    ],
  },
  {
    name: "Dental Clinic",
    href: "/dental-website-design-singapore/",
    description: "General dentistry, orthodontics, and cosmetic dental practices.",
    services: [
      { label: "Website", href: "/dental-website-design-singapore/" },
    ],
  },
  {
    name: "TCM Clinic",
    href: "/tcm-clinic-website-singapore/",
    description: "Traditional Chinese Medicine clinics and acupuncture centres.",
    services: [
      { label: "Website", href: "/tcm-clinic-website-singapore/" },
    ],
  },
  {
    name: "Physiotherapy",
    href: "/physiotherapy-website-singapore/",
    description: "Physiotherapy clinics and rehabilitation centres.",
    services: [
      { label: "Website", href: "/physiotherapy-website-singapore/" },
      { label: "SEO", href: "/physiotherapy-seo-singapore/" },
      { label: "Marketing", href: "/physiotherapy-marketing-singapore/" },
      { label: "Social Media", href: "/physiotherapy-social-media-singapore/" },
      { label: "Google Ads", href: "/physiotherapy-google-ads-singapore/" },
      { label: "Branding", href: "/physiotherapy-branding-singapore/" },
      { label: "Content Marketing", href: "/physiotherapy-content-marketing-singapore/" },
    ],
  },
  {
    name: "Mental Health",
    href: "/mental-health-clinic-website-singapore/",
    description: "Psychology practices, counselling centres, and psychiatric clinics.",
    services: [
      { label: "Website", href: "/mental-health-clinic-website-singapore/" },
      { label: "Marketing", href: "/mental-health-marketing-singapore/" },
      { label: "Social Media", href: "/mental-health-social-media-singapore/" },
      { label: "Google Ads", href: "/mental-health-google-ads-singapore/" },
    ],
  },
  {
    name: "Veterinary Clinic",
    href: "/veterinary-clinic-website-singapore/",
    description: "Animal hospitals, vet clinics, and pet care centres.",
    services: [
      { label: "Website", href: "/veterinary-clinic-website-singapore/" },
    ],
  },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Healthcare Marketing Services — Jraft Creative",
    "description": "Marketing services for clinics, dental practices, TCM, physiotherapy, mental health, and veterinary businesses in Singapore. Website design, SEO, social media, and Google Ads tailored to the healthcare industry.",
    "url": "https://jraftcreative.com/industries/healthcare/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Healthcare", "item": "https://jraftcreative.com/industries/healthcare/" }
    ]
  }
];
---

<BaseLayout
  title="Healthcare Marketing Singapore — Clinic & Medical Websites | Jraft Creative"
  description="Marketing services for clinics, dental practices, TCM, physiotherapy, mental health, and veterinary businesses in Singapore. Website design, SEO, social media, and Google Ads tailored to the healthcare industry."
  canonical="https://jraftcreative.com/industries/healthcare/"
  currentPath="/industries/healthcare/"
  schema={schemaData}
>
  <section class="service-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/industries/">Industries</a></li>
          <li aria-current="page">Healthcare</li>
        </ol>
      </nav>
      <div class="service-hero-content reveal">
        <h1>Healthcare Marketing</h1>
        <p class="service-hero-sub">We help clinics and medical practices in Singapore attract more patients, build trust in their communities, and grow sustainably — with marketing strategies designed around how Singaporeans search for and choose healthcare providers.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <h2>Services by Healthcare Type</h2>
        <p>Select your practice type to see the full range of services available.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((sub, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`}>
            <h3><a href={sub.href}>{sub.name}</a></h3>
            <p>{sub.description}</p>
            <div class="industry-detail-services">
              {sub.services.map((svc) => (
                <a href={svc.href}>{svc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-alt">
    <div class="container">
      <div class="section-header reveal">
        <h2>Why Healthcare Marketing Needs Specialised Expertise</h2>
      </div>
      <div class="reveal reveal-d1">
        <p>Healthcare marketing in Singapore operates within a distinct regulatory and cultural context that general marketing agencies are not equipped to navigate. The Ministry of Health's advertising guidelines restrict how medical services can be promoted — claims must be factual, testimonials are prohibited, and comparative advertising is not permitted. Every piece of content we produce is reviewed against these standards before it goes live.</p>
        <p style="margin-top: 1rem;">Beyond compliance, trust is the primary conversion factor for any clinic. Patients selecting a GP, specialist, or allied health provider are making decisions about their health and the health of their families. Your website, your Google Business Profile, and your social media presence need to project competence, transparency, and care — not aggressive sales tactics. We build healthcare marketing that earns confidence rather than simply generating clicks.</p>
        <p style="margin-top: 1rem;">Search behaviour in this sector also differs from other industries. Patients regularly search for "clinic near me," "dentist in Tampines," or "physiotherapy Orchard" — highly localised, intent-driven queries where Google Maps rankings and organic search positions directly determine how many new patients your practice sees each month. We specialise in local SEO and PDPA-compliant digital strategies that connect your clinic with patients who are actively looking for care in your area.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align: center;">
      <div class="section-header reveal">
        <h2>Ready to Grow Your Practice?</h2>
        <p>Get a free consultation and a marketing plan tailored to your clinic or medical practice.</p>
      </div>
      <div class="reveal reveal-d1">
        <a href="/contact/" class="btn btn-primary" style="margin-top: 1rem;">Get a Free Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
