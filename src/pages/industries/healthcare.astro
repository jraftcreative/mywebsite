---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const subIndustries = [
  {
    name: "General Clinic",
    href: "/clinic-website-design-singapore/",
    description: "GP clinics, polyclinics, and family medicine practices.",
    image: "/images/service-clinic.webp",
    services: [
      { label: "Website", href: "/clinic-website-design-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Google Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
      { label: "AI Search (GEO)", href: "/clinic-ai-search-optimisation-singapore/" },
    ],
  },
  {
    name: "Dental Clinic",
    href: "/dental-website-design-singapore/",
    description: "General dentistry, orthodontics, and cosmetic dental practices.",
    image: "/images/service-dental.webp",
    services: [
      { label: "Website", href: "/dental-website-design-singapore/" },
      { label: "SEO", href: "/services/seo-performance/" },
      { label: "Google Ads", href: "/services/paid-ads/" },
      { label: "Social Media", href: "/services/social-media/" },
    ],
  },
  {
    name: "TCM Clinic",
    href: "/tcm-clinic-website-singapore/",
    description: "Traditional Chinese Medicine clinics and acupuncture centres.",
    image: "/images/service-tcm.webp",
    services: [
      { label: "Website", href: "/tcm-clinic-website-singapore/" },
      { label: "SEO", href: "/tcm-clinic-seo-singapore/" },
      { label: "Marketing", href: "/tcm-marketing-singapore/" },
      { label: "Google Ads", href: "/tcm-clinic-google-ads-singapore/" },
    ],
  },
  {
    name: "Physiotherapy",
    href: "/physiotherapy-website-singapore/",
    description: "Physiotherapy clinics and rehabilitation centres.",
    image: "/images/service-physiotherapy.webp",
    services: [
      { label: "Website", href: "/physiotherapy-website-singapore/" },
      { label: "SEO", href: "/physiotherapy-seo-singapore/" },
      { label: "Marketing", href: "/physiotherapy-marketing-singapore/" },
      { label: "Social Media", href: "/physiotherapy-social-media-singapore/" },
      { label: "Google Ads", href: "/physiotherapy-google-ads-singapore/" },
      { label: "Content Marketing", href: "/physiotherapy-content-marketing-singapore/" },
    ],
  },
  {
    name: "Mental Health",
    href: "/mental-health-clinic-website-singapore/",
    description: "Psychology practices, counselling centres, and psychiatric clinics.",
    image: "/images/service-mentalhealth.webp",
    services: [
      { label: "Website", href: "/mental-health-clinic-website-singapore/" },
      { label: "Marketing", href: "/mental-health-marketing-singapore/" },
      { label: "Social Media", href: "/mental-health-social-media-singapore/" },
      { label: "Google Ads", href: "/mental-health-google-ads-singapore/" },
    ],
  },
  {
    name: "Veterinary Clinic",
    href: "/veterinary-clinic-website-singapore/",
    description: "Animal hospitals, vet clinics, and pet care centres.",
    image: "/images/service-veterinary.webp",
    services: [
      { label: "Website", href: "/veterinary-clinic-website-singapore/" },
      { label: "SEO", href: "/veterinary-clinic-seo-singapore/" },
      { label: "Marketing", href: "/veterinary-clinic-marketing-singapore/" },
      { label: "Social Media", href: "/veterinary-clinic-social-media-singapore/" },
      { label: "Google Ads", href: "/veterinary-clinic-google-ads-singapore/" },
    ],
  },
];

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Healthcare Marketing Services — Jraft Creative",
    "description": "Marketing services for clinics, dental practices, TCM, physiotherapy, mental health, and veterinary businesses in Singapore. Website design, SEO, social media, and Google Ads tailored to the healthcare industry.",
    "url": "https://jraftcreative.com/industries/healthcare/",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://jraftcreative.com/industries/" },
      { "@type": "ListItem", "position": 3, "name": "Healthcare", "item": "https://jraftcreative.com/industries/healthcare/" }
    ]
  }
];
---

<ServiceLayout
  title="Healthcare Marketing Singapore — Jraft Creative"
  description="Marketing services for clinics, dental practices, TCM, physiotherapy, mental health, and veterinary businesses in Singapore. Website design, SEO."
  canonical="https://jraftcreative.com/industries/healthcare/"
  ogTitle="Healthcare Marketing Singapore — Jraft Creative"
  ogDescription="Marketing services for clinics, dental practices, TCM, physiotherapy, mental health, and veterinary businesses in Singapore. Website design, SEO, social media, and Google Ads tailored to the healthcare industry."
  keywords="healthcare marketing Singapore, clinic website design Singapore, medical practice marketing, dental marketing Singapore, physiotherapy marketing Singapore, mental health marketing Singapore"
  ogImage="/images/service-clinic.webp"
  schemaData={schemaData}
  heroLabel="Healthcare"
  heroTitle='Marketing for <span class="highlight">Healthcare</span> in Singapore'
  heroSubtitle="We help clinics and medical practices in Singapore attract more patients, build trust in their communities, and grow sustainably — with marketing strategies designed around how Singaporeans search for and choose healthcare providers."
  heroImage="/images/hero-healthcare.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "View Services", href: "#services", class: "btn btn-secondary" },
  ]}
  whatsappText="Hi Jraft Creative, I need marketing help for my healthcare practice in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Healthcare Practice"
  ctaDescription="Get a free consultation and a marketing plan tailored to your clinic or medical practice."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20help%20for%20my%20healthcare%20practice%20in%20Singapore.", class: "btn btn-secondary" },
  ]}
>
  <section class="section bg-alt">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Approach</p>
        <h2>Why Healthcare Marketing Needs <span class="highlight">Specialised</span> Expertise</h2>
        <p>Healthcare marketing in Singapore operates within a distinct regulatory and cultural context that general agencies aren't equipped to handle.</p>
      </div>
      <div class="features-grid" style="margin-top: 2rem;">
        <div class="feature-card reveal">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>MOH Compliant</h3>
          <p>Every piece of content is reviewed against MOH advertising guidelines — factual claims only, no prohibited testimonials, no comparative advertising.</p>
        </div>
        <div class="feature-card reveal reveal-d1">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Trust-First Design</h3>
          <p>Patients make decisions about their health and families. Your marketing needs to project competence, transparency, and care — not aggressive sales tactics.</p>
        </div>
        <div class="feature-card reveal reveal-d2">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Local SEO Focus</h3>
          <p>Patients search "clinic near me" and "dentist in Tampines." We specialise in Google Maps rankings and local search that drive new patient appointments.</p>
        </div>
        <div class="feature-card reveal reveal-d3">
          <div class="feature-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3>PDPA Compliant</h3>
          <p>All digital strategies are built around Singapore's Personal Data Protection Act — patient data handling, consent forms, and privacy policies done right.</p>
        </div>
      </div>

      <style>
        .feature-icon {
          width: 48px;
          height: 48px;
          border-radius: 10px;
          background: rgba(73, 184, 137, 0.1);
          border: 1px solid rgba(73, 184, 137, 0.2);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: 1rem;
          color: var(--accent);
        }
      </style>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>Healthcare Website <span class="highlight">Showcase</span></h2>
        <p>Concept websites designed to demonstrate what high-converting healthcare sites look like.</p>
      </div>

      <div class="cf-wrap reveal reveal-d1" id="cfWrap">
        <div class="cf-track">
          <div class="cf-slide" data-name="EastCare Family Clinic" data-type="GP Clinic &middot; Website Concept" data-desc="A neighbourhood GP clinic site with CHAS/MediSave info, clinic hours, doctor profiles, and location map." data-href="/demos/eastcare-clinic.html">
            <a href="/demos/eastcare-clinic.html" target="_blank" rel="noopener"><img src="/images/portfolio-clinic.webp" alt="EastCare Family Clinic" width="1200" height="700" loading="lazy"></a>
          </div>
          <div class="cf-slide" data-name="PawCare Veterinary" data-type="Vet Clinic &middot; Website Concept" data-desc="A modern pet clinic site with emergency hotline, vet profiles, service cards, and online appointment booking." data-href="/demos/pawcare-vet.html">
            <a href="/demos/pawcare-vet.html" target="_blank" rel="noopener"><img src="/images/portfolio-vet.webp" alt="PawCare Veterinary" width="1200" height="700" loading="lazy"></a>
          </div>
          <div class="cf-slide" data-name="Yong He TCM" data-type="TCM Clinic &middot; Website Concept" data-desc="A premium TCM clinic site with treatment pages, physician credentials, pricing, and cultural design elements." data-href="/demos/yonghe-tcm.html">
            <a href="/demos/yonghe-tcm.html" target="_blank" rel="noopener"><img src="/images/portfolio-tcm.webp" alt="Yong He TCM" width="1200" height="700" loading="lazy"></a>
          </div>
          <div class="cf-slide" data-name="Clarity Counselling" data-type="Mental Health &middot; Website Concept" data-desc="A calming counselling practice site with therapist profiles, service areas, session pricing, and gentle CTAs." data-href="/demos/clarity-counselling.html">
            <a href="/demos/clarity-counselling.html" target="_blank" rel="noopener"><img src="/images/portfolio-mental.webp" alt="Clarity Counselling" width="1200" height="700" loading="lazy"></a>
          </div>
        </div>
        <div class="cf-arrows">
          <button class="cf-btn cf-prev" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="cf-btn cf-next" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
      <div class="cf-info reveal reveal-d2" id="cfInfo">
        <span class="portfolio-type" id="cfType">GP Clinic &middot; Website Concept</span>
        <h3 id="cfName">EastCare Family Clinic</h3>
        <p id="cfDesc">A neighbourhood GP clinic site with CHAS/MediSave info, clinic hours, doctor profiles, and location map.</p>
        <a id="cfLink" href="/demos/eastcare-clinic.html" target="_blank" rel="noopener" class="cf-demo-link">View Live Demo →</a>
      </div>
    </div>

    <style>
      .cf-wrap { position: relative; max-width: 850px; margin: 0 auto; padding: 0.5rem 0; }
      .cf-track { display: flex; align-items: center; justify-content: center; gap: 1rem; perspective: 900px; height: 280px; position: relative; }
      .cf-slide { flex: 0 0 52%; max-width: 52%; height: 100%; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); transform: scale(0.8); opacity: 0.35; filter: brightness(0.5); cursor: pointer; z-index: 1; }
      .cf-slide.active { transform: scale(1); opacity: 1; filter: brightness(1); z-index: 3; box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35); border-color: var(--border-accent); }
      .cf-slide.prev { transform: scale(0.8) translateX(18%) rotateY(6deg); opacity: 0.45; filter: brightness(0.55); z-index: 2; }
      .cf-slide.next { transform: scale(0.8) translateX(-18%) rotateY(-6deg); opacity: 0.45; filter: brightness(0.55); z-index: 2; }
      .cf-slide a { display: block; height: 100%; }
      .cf-slide img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
      .cf-arrows { position: absolute; top: 50%; left: 0; right: 0; transform: translateY(-50%); display: flex; justify-content: space-between; padding: 0 0.25rem; pointer-events: none; z-index: 10; }
      .cf-btn { width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--border); background: rgba(18, 18, 27, 0.85); backdrop-filter: blur(6px); color: var(--text-muted); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; pointer-events: all; }
      .cf-btn:hover { border-color: var(--accent); color: var(--accent); }
      .cf-info { text-align: center; margin-top: 1.25rem; max-width: 520px; margin-left: auto; margin-right: auto; }
      .cf-info h3 { font-size: 1.2rem; font-weight: 700; margin: 0.3rem 0; }
      .cf-info p { color: var(--text-muted); line-height: 1.7; font-size: 0.85rem; }
      .cf-demo-link { display: inline-block; margin-top: 0.5rem; font-size: 0.82rem; font-weight: 600; color: var(--accent); cursor: pointer; transition: opacity 0.2s; }
      .cf-demo-link:hover { opacity: 0.8; }
      @media (max-width: 768px) { .cf-track { height: 200px; } .cf-slide { flex: 0 0 70%; max-width: 70%; } .cf-slide.prev, .cf-slide.next { transform: scale(0.75); } }
    </style>

    <script is:inline>
      (function() {
        var slides = document.querySelectorAll('.cf-slide');
        var nameEl = document.getElementById('cfName');
        var typeEl = document.getElementById('cfType');
        var descEl = document.getElementById('cfDesc');
        var linkEl = document.getElementById('cfLink');
        var current = 0;
        var total = slides.length;

        function update() {
          var prevIdx = (current - 1 + total) % total;
          var nextIdx = (current + 1) % total;
          slides.forEach(function(s, i) {
            s.classList.remove('active', 'prev', 'next');
            s.style.order = '';
            s.style.display = '';
            if (i === current) { s.classList.add('active'); s.style.order = '2'; }
            else if (i === prevIdx) { s.classList.add('prev'); s.style.order = '1'; }
            else if (i === nextIdx) { s.classList.add('next'); s.style.order = '3'; }
            else { s.style.display = 'none'; }
          });
          var s = slides[current];
          nameEl.textContent = s.dataset.name;
          typeEl.innerHTML = s.dataset.type;
          descEl.textContent = s.dataset.desc;
          linkEl.href = s.dataset.href;
        }

        function goTo(i) { current = (i + total) % total; update(); }

        slides.forEach(function(s, i) {
          s.addEventListener('click', function(e) { if (i !== current) { e.preventDefault(); goTo(i); } });
        });
        document.querySelector('.cf-prev').addEventListener('click', function() { goTo(current - 1); });
        document.querySelector('.cf-next').addEventListener('click', function() { goTo(current + 1); });
        update();

        var timer = setInterval(function() { goTo(current + 1); }, 3000);
        document.getElementById('cfWrap').addEventListener('mouseenter', function() { clearInterval(timer); });
        document.getElementById('cfWrap').addEventListener('mouseleave', function() {
          timer = setInterval(function() { goTo(current + 1); }, 3000);
        });
      })();
    </script>
  </section>

  <section class="section" id="services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Cover</p>
        <h2>Services by Healthcare Type</h2>
        <p>Select your practice type to see the full range of services available.</p>
      </div>
      <div class="industry-detail-grid">
        {subIndustries.map((sub, i) => (
          <div class={`industry-detail-card reveal${i > 0 ? ` reveal-d${Math.min(i, 4)}` : ''}`} data-bg={sub.image}>
            <h3><a href={sub.href}>{sub.name}</a></h3>
            <p>{sub.description}</p>
            <div class="industry-detail-services">
              {sub.services.map((svc) => (
                <a href={svc.href}>{svc.label}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
