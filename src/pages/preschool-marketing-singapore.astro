---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Preschool Marketing Singapore",
    "description": "Full-service digital marketing for preschools in Singapore — website design, SEO, Google Ads, social media, and parent engagement campaigns. Build trust and grow enrolments. From $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Preschool Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile, social media content, and monthly reporting for single-branch preschools" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads, Facebook and Instagram Ads, parent engagement campaigns, open house promotion, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video tours, waitlist management campaigns, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do parents choose a preschool in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most parents start with a Google search — 'preschool near me', 'best preschool in Punggol', or 'Montessori preschool Singapore'. They compare websites, read Google reviews, check social media for photos and videos of the learning environment, and attend open houses before making a decision. A strong digital presence across these touchpoints is essential for capturing enrolments." } },
      { "@type": "Question", "name": "How much should a preschool invest in marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Preschools in Singapore typically invest between $3,000 and $8,000 per month on marketing. This covers website maintenance, SEO, paid advertising, and social media content. Our Essential plan at $3,000/month provides a solid foundation for single-branch preschools, while the Growth plan at $5,500/month adds paid ads and open house campaigns for faster enrolment growth." } },
      { "@type": "Question", "name": "How do you build trust with parents through marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Trust is built through consistency and authenticity. We create content that shows your preschool's real environment — teacher interactions, learning activities, outdoor play, and milestone celebrations. Google reviews are actively managed, parent testimonials are featured prominently, and your website communicates your curriculum philosophy clearly. Nothing generic or stock-photo-driven." } },
      { "@type": "Question", "name": "Can you promote preschool open house events?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We run full open house campaigns including landing page creation, Google Ads targeting parents in your area, Facebook event promotion, email sequences to registered leads, WhatsApp broadcast coordination, and social media countdown content. Post-event follow-up sequences nurture parents who attended but haven't enrolled yet." } },
      { "@type": "Question", "name": "How do you handle ECDA and SPARK certification in marketing?", "acceptedAnswer": { "@type": "Answer", "text": "We highlight your ECDA licence, SPARK certification, and any curriculum accreditations as trust signals in your marketing — featuring them on your website, in ad copy, and on social media. Parents searching for 'SPARK-certified preschool' or 'ECDA-licensed kindergarten' are high-intent prospects, and we target these keywords specifically in SEO and paid campaigns." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Preschool Marketing Singapore", "item": "https://jraftcreative.com/preschool-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Gym Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Preschool Marketing Singapore — Jraft Creative"
  description="Full-service digital marketing for preschools in Singapore — website, SEO, Google Ads, social media, and parent engagement campaigns."
  canonical="https://jraftcreative.com/preschool-marketing-singapore/"
  ogTitle="Preschool Marketing Singapore — Jraft Creative"
  ogDescription="Full-service preschool marketing in Singapore. Website, SEO, Google Ads, social media — build parent trust and fill every classroom."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="preschool marketing singapore, preschool advertising singapore, preschool digital marketing, kindergarten marketing singapore, preschool enrolment marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Preschool Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">Preschools in Singapore</span>'
  heroSubtitle="Website, SEO, Google Ads, social media, and open house campaigns — managed by one agency to build parent trust and keep every classroom full. From registration to retention, we handle it all."
  heroImage="/images/service-preschool.webp"
  heroImageAlt="Singapore preschool classroom — preschool marketing agency"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my preschool in Singapore."
  ctaLabel="Ready to Grow Enrolments?"
  ctaTitle="Get Your Free Preschool Marketing Audit"
  ctaDescription="Book a free consultation and we'll review your preschool's digital presence, benchmark you against competing centres in your area, and recommend an enrolment growth strategy. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20preschool%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why preschools need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Preschools Are Still <span class="highlight">Losing Enrolments</span> to Centres with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Choosing a preschool is one of the most emotionally significant decisions Singapore parents make — and they make it online first. By the time a parent calls to book a visit, they've already compared curricula, read reviews, and shortlisted two or three ECDA-registered centres. The preschools filling their classrooms aren't always the best teachers. They're the ones parents could actually find.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Enrolment-Cycle Window</h3>
            <p>Singapore's preschool market is crowded with ECDA-registered centres, anchor operators, and MOE Kindergartens all chasing the same intake. Enrolment runs in cycles and waitlists fill fast — if you're invisible during the registration and open-house window, parents commit elsewhere before they ever see your programme.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trust Gap</h3>
            <p>Parents don't enrol on price — they enrol on trust. They validate every centre through Google reviews, real photos of the learning environment, curriculum clarity, and visible safety and teacher-quality signals. Preschools without these lose the enquiry even when their programme is stronger.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Near Me" Search</h3>
            <p>Childcare is hyper-local. Parents search "preschool near me", "childcare Punggol", or "kindergarten near Sengkang" and enrol close to home or work. If you don't own the Maps pack and neighbourhood searches in your catchment, you're not in the consideration set — no matter how good your centre is.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for preschools in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Preschool <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for preschools and childcare centres — combining neighbourhood SEO, AI search optimisation (GEO), enrolment-season paid search, parent-trust social content, warm brand positioning, and conversion-focused web design.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/preschool-seo-singapore/">SEO for Preschools</a></h3>
            <p>Rank for the "near me" searches parents actually use — "preschool Punggol", "childcare near Sengkang", "Montessori kindergarten Bishan". Google Business Profile optimisation, parent reviews, and neighbourhood landing pages that put your centre on the map.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when parents ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best SPARK-certified preschool near Tampines" or "Montessori vs play-based childcare Singapore". The same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/preschool-advertising-singapore/">Google Ads for Preschools</a></h3>
            <p>High-intent campaigns timed to registration season, open-house events, and waitlist-clearing windows. GCLID tracking from click to signed enrolment, plus retargeting that brings back parents who browsed but didn't enquire.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/preschool-social-media-marketing-singapore/">Social Media for Preschools</a></h3>
            <p>Instagram and Facebook content that gives parents a genuine window into your centre — classroom activities, outdoor play, teacher spotlights, and milestone celebrations. The authentic trust signals that turn anxious parents into confident enquiries.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/preschool-branding-singapore/">Branding for Preschools</a></h3>
            <p>The warm, professional brand system that lifts you above the centre down the road. Logo, palette, parent-pack template, and photo direction — positioned around your curriculum philosophy so families feel your centre before they visit.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/preschool-website-design-singapore/">Websites for Preschools</a></h3>
            <p>The site that closes the enquiry. Curriculum and philosophy, facility photos, fee transparency, virtual-tour integration, and a single-field enquiry form — fast on mobile for parents shortlisting centres on their phone.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for preschool marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Choose</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching preschools run generic e-commerce playbooks on a parent audience that decides on weeks of research, centre visits, and word-of-mouth. We are the opposite — full-service, performance-led, and built around the early-childhood decision journey. We understand ECDA registration, SPARK certification, and MOE Kindergarten frameworks, and we treat them as the trust signals parents are searching for. We specialise in neighbourhood-level campaigns across Punggol, Sengkang, Tampines, Bishan, and other high-density Singapore catchments.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Early-Childhood Fluency</h3>
            <p>We understand ECDA regulations, SPARK certification, and MOE Kindergarten frameworks — and the parent concerns that drive preschool selection: safety, teacher quality, curriculum approach, and learning outcomes. Your marketing reflects this knowledge instead of glossing over it.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, Facebook, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, authentic parent-trust signals, and measurement back to enrolment enquiries.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enrolment, Not Vanity Metrics</h3>
            <p>We measure enquiries and signed enrolments, not impressions. GCLID offline tracking and WhatsApp-routed enquiries prove which ad click became which centre visit became which enrolled child — the only numbers that fill classrooms.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ENROLMENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Enrolment Funnel — how Singapore parents decide on a preschool">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Enrolment Funnel</p>
        <h2>How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first "preschool near me" search to a signed enrolment form, every Singapore parent moves through the same five stages. We build marketing campaigns that show up at each one — from discovery through to the moment they enrol their child.</p>
