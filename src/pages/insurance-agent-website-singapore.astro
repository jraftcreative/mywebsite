---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Insurance Agent Website Design Singapore",
    "description": "Professional website design for insurance agents and financial advisors in Singapore. Personal branding, MAS compliance, plan comparison tools, lead capture, and credential display — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Insurance Agent Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Insurance Agent Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page insurance agent website with agent profile, credential display, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Insurance Agent Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with plan comparison tools, blog, lead capture funnels, advanced SEO, and CRM integration" },
      { "@type": "Offer", "name": "Premium Insurance Agent Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with interactive plan calculators, multi-advisor support, client portal, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an insurance agent website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional insurance agent website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with agent profile, credential display, contact form, and Google Maps. Business and Premium packages add plan comparison tools, lead capture funnels, calculators, CRM integration, and multi-advisor support." } },
      { "@type": "Question", "name": "Will the website comply with MAS advertising guidelines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every insurance agent website we build follows the Monetary Authority of Singapore (MAS) guidelines on financial product advertising. We include proper disclaimers, representative number display, and ensure all content meets MAS Notice on Recommendations on Investment Products and other relevant regulations." } },
      { "@type": "Question", "name": "Can you build plan comparison or premium calculator tools?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Our Business package and above include interactive plan comparison tables where visitors can compare coverage, premiums, and benefits side by side. We can also build premium estimate calculators for term life, whole life, or health insurance plans to help prospects understand their options before reaching out to you." } },
      { "@type": "Question", "name": "How do you help insurance agents generate leads online?", "acceptedAnswer": { "@type": "Answer", "text": "We build dedicated lead capture funnels into your website — from needs analysis forms and free consultation booking pages to downloadable guides on topics like CPF planning or Medishield Life top-ups. Every enquiry is routed to your email or CRM so no lead is missed. We can also integrate WhatsApp for instant contact." } },
      { "@type": "Question", "name": "How long does it take to build an insurance agent website?", "acceptedAnswer": { "@type": "Answer", "text": "Most insurance agent websites go live within 2–3 weeks. A 5-page personal branding site can be ready in 2 weeks, while larger projects with plan comparison tools, calculators, and CRM integration may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Insurance Agent Website Singapore", "item": "https://jraftcreative.com/insurance-agent-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Insurance Agent Website Singapore — Jraft Creative"
  description="Website design for insurance agents and financial advisors in Singapore. Personal branding, MAS compliance, plan comparison tools, lead capture."
  canonical="https://jraftcreative.com/insurance-agent-website-singapore/"
  ogTitle="Insurance Agent Website Singapore — Jraft Creative"
  ogDescription="Website design for insurance agents and financial advisors in Singapore. MAS-compliant, plan comparison tools, lead capture — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="insurance agent website singapore, financial advisor website singapore, insurance website design singapore, insurance agent web design, financial advisor web design singapore, insurance digital marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Insurance Agent Websites"
  heroTitle='Website Design for <span class="highlight">Insurance Agents in Singapore</span>'
  heroSubtitle="Your credentials and expertise deserve more than a company profile page. We build fast, mobile-friendly websites for insurance agents and financial advisors — with personal branding, plan comparison tools, and lead capture built in."
  heroImage="/images/service-insurance.webp"
  heroImageAlt="Insurance agent and financial advisor website design in Singapore"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my insurance business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Insurance Business Online"
  ctaDescription="Book a free consultation and tell us about your insurance practice. Whether you're an independent advisor or part of an agency, we'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20insurance%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why insurance agents and financial advisors need a professional website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>In Financial Advice, the <span class="highlight">Website Is the First Trust Test</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singaporeans hand an insurance agent some of the most sensitive decisions of their lives — their family's protection, their CPF, their retirement. Before they share any of that, they research. A company profile page, a LinkTree, or a social feed alone gives prospects no reason to choose you, and no way to verify that you are who you say you are.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Trust Is Vetted Before Contact</h3>
            <p>Prospects check your track record, qualifications, and reputation before they part with a single detail about their finances. Without a credible site that shows your MAS representative status, MDRT or COT standing, and real client stories, they move on to an advisor who looks more established online.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Compliance Is Not Optional</h3>
            <p>Financial advertising in Singapore sits under MAS guidelines and the Financial Advisers Act. Claims must be fair, balanced, and not misleading, with the right disclaimers and representative details. A DIY site or a generic template can quietly breach those rules — a risk to your licence, not just your brand.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Research Has to Become a Consultation</h3>
            <p>Most visitors arrive while still comparing options — not ready to commit. If the path from reading about critical illness cover to booking a needs analysis isn't obvious, they leave and you never know they were there. The site has to turn quiet research into a booked conversation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="What we build into an insurance advisor website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of an Insurance Advisor <span class="highlight">Website</span></h2>
      </div>
      <div class="section-content reveal">
        <p>An insurance advisor website isn't a brochure or an e-commerce store. It has to earn trust, hold up to MAS advertising guidelines, and guide a careful prospect from research to a booked consultation. We build every element around how Singaporeans actually choose someone to manage their financial protection.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Trust-Led Design</h3>
            <p>A clean, professional, mobile-first design that signals credibility from the first scroll — your photo, a clear value proposition, and a measured tone. No loud sales gimmicks, just the calm, considered presence prospects expect from someone handling their family's protection.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Services &amp; Specialisation Pages</h3>
            <p>Dedicated pages for what you actually advise on — life and critical illness cover, hospitalisation and Integrated Shield Plans, retirement and CPF planning, or business and keyman insurance. Clear specialisation pages help the right prospects recognise that you handle exactly their situation.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Credentials &amp; Testimonials</h3>
            <p>A profile that presents your MAS representative number, the agency or firm you represent, qualifications such as MDRT or COT, and years in practice — alongside genuine client testimonials. Proof points that let a prospect verify you before they ever pick up the phone.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-campaign-analytics.webp');">
          <div class="service-detail-card__content">
            <h3>Secure Enquiry &amp; Booking Forms</h3>
            <p>Needs-analysis forms, consultation booking, and downloadable guides — built to handle personal information responsibly and in line with PDPA. Every enquiry routes straight to your email or CRM, with optional WhatsApp contact, so no warm lead slips through the cracks.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Speed &amp; Core Web Vitals</h3>
            <p>Prospects browse on their phones during commutes and lunch breaks. We build for fast load times and strong Core Web Vitals, with tap-to-call and instant WhatsApp contact — so a moment of interest turns into an enquiry instead of a closed tab.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>SEO Foundations</h3>
            <p>Clean structure, proper metadata, schema, and MAS-compliant content built so prospects can find you when they search for an advisor or for help with CPF, retirement, or critical illness planning. The groundwork that lets your site earn visibility over time, not just sit online.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for insurance agent website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A Web Studio That Understands <span class="highlight">Financial Advice</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build for insurance agents and financial advisors who take their licence and their clients seriously. We understand MAS compliance, the difference between a tied agent and an independent financial adviser, and how Singaporeans research protection online — so your site is built with real industry knowledge, not guesswork.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Financial Services Experience</h3>
            <p>We know how Singaporeans research an advisor, what builds confidence on a profile page, and which proof points actually drive a consultation booking. Your website is shaped by how the advisory business works here — not a template borrowed from another industry.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Built Around MAS Compliance</h3>
            <p>We design within MAS advertising guidelines and the Financial Advisers Act — fair and balanced claims, the right disclaimers, and your representative details displayed properly. Your final content stays your responsibility, but we build the structure so compliance is the default, not an afterthought.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A website opens the door, but discovery and conversion depend on the wider picture. We handle SEO, social media, and paid ads in-house — an integrated system that turns searches and referrals into booked consultations, so you can focus on advising.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — where your website fits the client journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>Where Your <span class="highlight">Website</span> Fits the <span class="highlight">Client Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Most Singaporeans move through the same five stages before they trust an advisor with their finances. Your website owns the middle of that journey — turning a name they were given, or a search they ran, into a booked consultation.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Searches for advice or an advisor online</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Weighs a few advisors against each other</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Checks credentials, MAS status &amp; reviews</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>Books a consultation or needs analysis</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Signs on, reviews cover &amp; refers others</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Insurance agent website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Insurance Agent Website Pricing</p>
        <h2>Website Packages for Insurance Agents</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For agents building a personal brand online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Agent profile &amp; MAS credentials</li>
              <li>Service overview pages</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For advisors ready to generate leads online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Plan comparison tools</li>
              <li>Lead capture funnels</li>
              <li>Blog / financial insights section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>CRM integration</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For top producers and advisory firms scaling their brand.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Premium calculator tools</li>
              <li>Multi-advisor profiles</li>
              <li>Client testimonial system</li>
              <li>Appointment booking integration</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about insurance agent website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Insurance Agent Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an insurance agent website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional insurance agent website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with agent profile, MAS credential display, contact form, and Google Maps. Business and Premium packages add plan comparison tools, lead capture funnels, calculators, CRM integration, and multi-advisor support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will the website comply with MAS advertising guidelines?</summary>
          <div class="faq-answer"><p>Yes. Every insurance agent website we build follows the Monetary Authority of Singapore (MAS) guidelines on financial product advertising. We include proper disclaimers, your representative number, and ensure all content meets MAS Notice on Recommendations on Investment Products and other relevant regulations. We stay up to date with MAS requirements so your website remains compliant.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you build plan comparison or premium calculator tools?</summary>
          <div class="faq-answer"><p>Absolutely. Our Business package and above include interactive plan comparison tables where visitors can compare coverage, premiums, and benefits side by side for products like term life, whole life, critical illness, and Integrated Shield Plans. We can also build premium estimate calculators that help prospects understand ballpark costs before reaching out to you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you help insurance agents generate leads online?</summary>
          <div class="faq-answer"><p>We build dedicated lead capture funnels into your website — from needs analysis questionnaires and free consultation booking pages to downloadable guides on topics like CPF planning after 55 or Medishield Life top-up options. Every enquiry is routed to your email or CRM so no lead is missed. We also integrate WhatsApp for instant contact.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an insurance agent website?</summary>
          <div class="faq-answer"><p>Most insurance agent websites go live within 2–3 weeks. A 5-page personal branding site can be ready in 2 weeks, while larger projects with plan comparison tools, calculators, and CRM integration may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
