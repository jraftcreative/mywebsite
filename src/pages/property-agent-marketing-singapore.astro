---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Property Agent Marketing Singapore",
    "description": "Full-service marketing for CEA-registered property agents and real estate agencies in Singapore. Personal-brand websites with listings and lead capture, Google + Meta ads for HDB / condo / private property buyers, and social media content that establishes authority. Every asset CEA-compliance reviewed before publish.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Property Agent Marketing Services",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Property Agent Marketing Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Property Agent Website Design",
            "description": "Personal-brand websites for CEA-registered agents — listings integration, lead capture, mobile-first, area guide pages, and CEA-compliant credential display."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Paid Ads for Property Agents (Google + Meta)",
            "description": "Buyer-search ads on HDB, condo and private property keywords, neighbourhood-tight geo targeting, retargeting recent profile visitors, and CEA-compliance review on every ad."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Social Media Marketing for Property Agents",
            "description": "Listings, neighbourhood market reports, buyer education and short-form video (TikTok / IG Reels) on a cadence that builds authority."
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your property ads follow CEA advertising guidelines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, caption, listing description and content piece is checked against the Council for Estate Agencies advertising rules and the Practice Guidelines on Advertising before it goes live. No false guarantees, no 'best agent in [area]' superlatives, no naming or comparing to other agents, no testimonials phrased as outcome guarantees, and your CEA registration number and agency licence display correctly on every asset that requires it. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "I already have a PropertyGuru and 99.co profile. Why do I need my own marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Because the portals own the relationship, not you. Every buyer who taps your listing is shown ten other agents on the same page. You pay per listing, the platform keeps the data, and the day you stop paying, you disappear. A personal-brand site, paid search on your name and area, and a consistent social presence give you somewhere buyers can find you outside the portals — and somewhere your past clients can refer warm leads to." } },
      { "@type": "Question", "name": "What does property agent marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on which mix you start with. A solo agent kicking off with a personal-brand site and a starter Google + Meta ad budget typically sits between $2,500 and $4,000/month all-in. Agents adding consistent short-form video, area guide content and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you." } },
      { "@type": "Question", "name": "Can you target buyers by district or estate?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Geo-targeting on Google and Meta lets us run ads to people in a defined radius around a specific HDB town, condo cluster, or planning area. We pair that with keyword targeting — 'condo for sale District 9', 'HDB resale Punggol', 'landed Bukit Timah' — so the ad shows for the right person in the right area. If you specialise in one or two estates, the geo work is where most of the leverage sits." } },
      { "@type": "Question", "name": "I'm changing brokerages. Can you handle the rebrand?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is one of the more common engagements we run. New CEA agency licence number, new agency logo lockup, new email and contact details across the website, social channels and ad accounts, redirects from the old domain if you had one, and a launch content plan so your network knows where you've moved. Most rebrands go live cleanly in 2–3 weeks." } },
      { "@type": "Question", "name": "Do you handle short-form video for TikTok and Instagram Reels?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Property buyers and renters scroll TikTok and Reels constantly — listing walkthroughs, neighbourhood tours, market-report explainers and 'a day in the life of an agent' content all perform well when the cadence is consistent. We script, shoot direction (or remote-direct if you film yourself), edit, caption and publish. All scripts go through the same CEA-compliance check as the ads." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Property Agent Marketing Singapore", "item": "https://jraftcreative.com/property-agent-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Gym Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Marketing for Property Agents in Singapore — CEA-Compliant"
  description="Full-service marketing for CEA-registered property agents in SG — personal-brand websites, Google + Meta ads, and social media. CEA-compliance reviewed."
  canonical="https://jraftcreative.com/property-agent-marketing-singapore/"
  ogTitle="Marketing for Property Agents in Singapore — CEA-Compliant"
  ogDescription="Full-service marketing for CEA-registered property agents in SG — personal-brand websites, Google + Meta ads, and social media. CEA-compliance reviewed."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="property agent marketing singapore, real estate marketing agency singapore, property marketing singapore, real estate agent marketing, property agent ads singapore, property agent social media, cea compliant marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Property Agent Marketing"
  heroTitle='Marketing for <span class="highlight">Property Agents in Singapore</span>'
  heroSubtitle="Built for how SG buyers actually find a property — search, scroll, then shortlist one agent. We run the website, the paid ads and the social content that puts you in front of buyers, sellers and tenants searching tonight. Every asset CEA-compliance reviewed before it goes live."
  heroImage="/property-hero.jpg"
  heroImageAlt="Singapore property agent showing a condo unit — property agent marketing"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20property%20agent%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my property agent business in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at where your buyer leads are coming from"
  ctaDescription="Tell us your CEA number, the estates you cover, your current PropertyGuru / 99.co spend, and what your buyer-vs-seller mix looks like. We'll come back inside 24 hours with where we'd start."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20property%20agent%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why CEA-registered property agents in Singapore need marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Property Agents Are Still <span class="highlight">Losing Mandates</span> to Agents with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>There are 36,816 CEA-registered active salespersons in Singapore (CEA Industry Statistics, 1 January 2026) — and every one of them has a PropertyGuru profile, a 99.co profile, and the same "professional, dedicated, results-driven" intro line. The agents winning consistent buyer and seller mandates aren't necessarily the best closers; they're the ones a buyer can actually find, remember, and trust before the first WhatsApp.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The CEA Compliance Trap</h3>
            <p>"Top 1% agent." "Guaranteed sale in 30 days." "Better than [named competitor]." All three break the Council for Estate Agencies advertising rules. We've audited agent ad accounts where every third creative is non-compliant — one complaint and the whole campaign comes down.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Research-First Buyer</h3>
            <p>By the time a buyer or seller sends that first WhatsApp, they've already searched, scrolled, and shortlisted online. If your name, reviews, and content don't show up during that window, you never make the shortlist — no matter how well you'd have closed.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Hyper-Local Search Gap</h3>
            <p>The leverage is in the estate-tight searches — "property agent Punggol", "condo for sale District 9", "HDB resale Tampines". The chain brokerages run firm-wide brand campaigns; you can't out-spend them, but you can out-specialise them on the listing-driven, neighbourhood searches that actually convert.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing channels for property agents in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Property Agent <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for CEA-registered property agents — combining hyper-local SEO, AI search optimisation (GEO), paid search and social ads, authority-building content, branding, and a personal-brand website that converts buyers off the portals. Every asset runs through a CEA-compliance review before it publishes.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO for Property Agents</a></h3>
            <p>Rank for estate-tight searches like "property agent Punggol" and "HDB resale Tampines" — and your own name. Show up outside the portals, where buyers can find you, remember you, and refer warm leads back to you.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when buyers ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best property agent for new launches in District 9" or "who handles expat condo rentals." Same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google + Meta Ads</a></h3>
            <p>Buyer-search ads on HDB, condo and private property keywords, neighbourhood-tight geo targeting, and retargeting recent profile visitors. GCLID tracking from click to enquiry — and every ad CEA-reviewed before it runs.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Property Agents</a></h3>
            <p>Listing walkthroughs, neighbourhood tours, market-report explainers and "a day in the life of an agent" content on TikTok and IG Reels. We script, direct, edit, caption and publish — every script through the same CEA-compliance check as the ads.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Property Agents</a></h3>
            <p>The personal-brand system that lifts you out of the identikit headshot-and-agency-logo template. Logo lockup, palette, photo direction and positioning — so a buyer scrolling ten listings actually remembers you. Built clean for brokerage rebrands too.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/property-agent-website-singapore/">Websites for Property Agents</a></h3>
            <p>The personal-brand site that converts buyer traffic into shortlist enquiries — listings integration, lead capture, area guide pages, mobile-first, and CEA-compliant credential display. Somewhere buyers can find you that isn't a portal.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for property agent marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Property Buyers</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching property agents treat CEA compliance as a friction to route around, and treat your marketing like a generic small-business retainer. We're the opposite — full-service, performance-led, and built around how Singaporean buyers, sellers and tenants actually search, scroll and shortlist. We specialise in estate-tight campaigns across Punggol, Tampines, District 9, Bukit Timah and the other planning areas where the geo work carries the leverage.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>CEA-Compliant by Default</h3>
            <p>Every ad, caption, listing description and content piece is checked against the CEA advertising rules and Practice Guidelines on Advertising before it goes live — no false guarantees, no superlatives, no naming competitors, registration number displayed correctly. We share the compliance check inside the monthly report.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Team, Every Channel</h3>
            <p>SEO, GEO, Google + Meta ads, TikTok, Instagram, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, design and measurement, and one compliance thread instead of three.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Leads to Your Name, Not the Portal's</h3>
            <p>We measure enquiries, not impressions. GCLID offline tracking and WhatsApp-routed leads prove which ad click became which enquiry — and everything points to your personal brand, so the relationship and the data stay with you, not PropertyGuru.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — how Singapore property buyers and sellers choose an agent">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>How <span class="highlight">Singapore Buyers &amp; Sellers</span> Actually <span class="highlight">Choose an Agent</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From first search to signed mandate, every property buyer and seller in Singapore moves through the same five stages. We build marketing campaigns that show up at each one — long before they tap "WhatsApp the agent".</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Google, PropertyGuru, 99.co, TikTok — exploring areas &amp; prices</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Comparing listings &amp; agents, saving a few names</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Checking reviews, social presence &amp; past transactions</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>WhatsApp, form or call to one or two agents</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Viewing, mandate signed, transaction closed</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Property agent marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Property Agent Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Agents of <span class="highlight">Every Size</span></h2>
        <p>Scoped and quoted after a 30-minute call — no fixed package pushed onto you. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Solo Starter</h3>
            <div class="price">$2,500–$4,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For a solo agent building a presence outside the portals.</p>
            <ul class="pricing-features">
              <li>Personal-brand website</li>
              <li>Starter Google + Meta ad budget</li>
              <li>Neighbourhood-tight geo targeting</li>
              <li>CEA-compliance review on every asset</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$4,500–$8,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For agents adding content and retargeting to scale lead flow.</p>
            <ul class="pricing-features">
              <li>Everything in Solo Starter</li>
              <li>Consistent short-form video (TikTok / Reels)</li>
              <li>Area guide content</li>
              <li>Retargeting recent profile visitors</li>
              <li>Bi-weekly optimisation &amp; reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Team / Custom</h3>
            <div class="price">Custom</div>
            <p class="pricing-desc">For small teams of 2–5 agents and brokerage rebrands.</p>
            <ul class="pricing-features">
              <li>Shared site with lead routing by area</li>
              <li>Per-agent social amplification</li>
              <li>Full brokerage rebrand handling</li>
              <li>Dedicated strategist</li>
              <li>Scoped to your team after a call</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about property agent marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions property agents actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your property ads follow CEA advertising guidelines?</summary>
          <div class="faq-answer"><p>Yes. Every ad, caption, listing description and content piece is checked against the Council for Estate Agencies advertising rules and the Practice Guidelines on Advertising before it goes live. No false guarantees, no "best agent in [area]" superlatives, no naming or comparing to other agents, no testimonials phrased as outcome guarantees, and your CEA registration number and agency licence display correctly on every asset that requires it. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I already have a PropertyGuru and 99.co profile. Why do I need my own marketing?</summary>
          <div class="faq-answer"><p>Because the portals own the relationship, not you. Every buyer who taps your listing is shown ten other agents on the same page. You pay per listing, the platform keeps the data, and the day you stop paying, you disappear. A personal-brand site, paid search on your name and area, and a consistent social presence give you somewhere buyers can find you outside the portals — and somewhere your past clients can refer warm leads to.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What does property agent marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>It depends on which mix you start with. A solo agent kicking off with a personal-brand site and a starter Google + Meta ad budget typically sits between $2,500 and $4,000/month all-in. Agents adding consistent short-form video, area guide content and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you target buyers by district or estate?</summary>
          <div class="faq-answer"><p>Yes. Geo-targeting on Google and Meta lets us run ads to people in a defined radius around a specific HDB town, condo cluster, or planning area. We pair that with keyword targeting — "condo for sale District 9", "HDB resale Punggol", "landed Bukit Timah" — so the ad shows for the right person in the right area. If you specialise in one or two estates, the geo work is where most of the leverage sits.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I'm changing brokerages. Can you handle the rebrand?</summary>
          <div class="faq-answer"><p>Yes — this is one of the more common engagements we run. New CEA agency licence number, new agency logo lockup, new email and contact details across the website, social channels and ad accounts, redirects from the old domain if you had one, and a launch content plan so your network knows where you've moved. Most rebrands go live cleanly in 2–3 weeks.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you handle short-form video for TikTok and Instagram Reels?</summary>
          <div class="faq-answer"><p>Yes. Property buyers and renters scroll TikTok and Reels constantly — listing walkthroughs, neighbourhood tours, market-report explainers and "a day in the life of an agent" content all perform well when the cadence is consistent. We script, shoot direction (or remote-direct if you film yourself), edit, caption and publish. All scripts go through the same CEA-compliance check as the ads.</p></div>
        </details>
      </div>
