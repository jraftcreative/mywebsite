---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Property Agent Marketing Singapore",
    "description": "Full-service marketing for CEA-registered property agents and real estate agencies in Singapore. Personal-brand websites with listings and lead capture, Google + Meta ads for HDB / condo / private property buyers, and social media content that establishes authority. Every asset CEA-compliance reviewed before publish.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Property Agent Marketing Services",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Property Agent Marketing Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Property Agent Website Design",
            "description": "Personal-brand websites for CEA-registered agents — listings integration, lead capture, mobile-first, area guide pages, and CEA-compliant credential display."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Paid Ads for Property Agents (Google + Meta)",
            "description": "Buyer-search ads on HDB, condo and private property keywords, neighbourhood-tight geo targeting, retargeting recent profile visitors, and CEA-compliance review on every ad."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Social Media Marketing for Property Agents",
            "description": "Listings, neighbourhood market reports, buyer education and short-form video (TikTok / IG Reels) on a cadence that builds authority."
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your property ads follow CEA advertising guidelines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, caption, listing description and content piece is checked against the Council for Estate Agencies advertising rules and the Practice Guidelines on Advertising before it goes live. No false guarantees, no 'best agent in [area]' superlatives, no naming or comparing to other agents, no testimonials phrased as outcome guarantees, and your CEA registration number and agency licence display correctly on every asset that requires it. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "I already have a PropertyGuru and 99.co profile. Why do I need my own marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Because the portals own the relationship, not you. Every buyer who taps your listing is shown ten other agents on the same page. You pay per listing, the platform keeps the data, and the day you stop paying, you disappear. A personal-brand site, paid search on your name and area, and a consistent social presence give you somewhere buyers can find you outside the portals — and somewhere your past clients can refer warm leads to." } },
      { "@type": "Question", "name": "What does property agent marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on which mix you start with. A solo agent kicking off with a personal-brand site and a starter Google + Meta ad budget typically sits between $2,500 and $4,000/month all-in. Agents adding consistent short-form video, area guide content and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you." } },
      { "@type": "Question", "name": "Can you target buyers by district or estate?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Geo-targeting on Google and Meta lets us run ads to people in a defined radius around a specific HDB town, condo cluster, or planning area. We pair that with keyword targeting — 'condo for sale District 9', 'HDB resale Punggol', 'landed Bukit Timah' — so the ad shows for the right person in the right area. If you specialise in one or two estates, the geo work is where most of the leverage sits." } },
      { "@type": "Question", "name": "I'm changing brokerages. Can you handle the rebrand?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is one of the more common engagements we run. New CEA agency licence number, new agency logo lockup, new email and contact details across the website, social channels and ad accounts, redirects from the old domain if you had one, and a launch content plan so your network knows where you've moved. Most rebrands go live cleanly in 2–3 weeks." } },
      { "@type": "Question", "name": "Do you handle short-form video for TikTok and Instagram Reels?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Property buyers and renters scroll TikTok and Reels constantly — listing walkthroughs, neighbourhood tours, market-report explainers and 'a day in the life of an agent' content all perform well when the cadence is consistent. We script, shoot direction (or remote-direct if you film yourself), edit, caption and publish. All scripts go through the same CEA-compliance check as the ads." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Property Agent Marketing Singapore", "item": "https://jraftcreative.com/property-agent-marketing-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Marketing for Property Agents in Singapore — CEA-Compliant"
  description="Full-service marketing for CEA-registered property agents in SG — personal-brand websites, Google + Meta ads, and social media. CEA-compliance reviewed."
  canonical="https://jraftcreative.com/property-agent-marketing-singapore/"
  ogTitle="Marketing for Property Agents in Singapore — CEA-Compliant"
  ogDescription="Full-service marketing for CEA-registered property agents in SG — personal-brand websites, Google + Meta ads, and social media. CEA-compliance reviewed."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="property agent marketing singapore, real estate marketing agency singapore, property marketing singapore, real estate agent marketing, property agent ads singapore, property agent social media, cea compliant marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Property Agent Marketing"
  heroTitle='Marketing for <span class="highlight">Property Agents in Singapore</span>'
  heroSubtitle="Built for how SG buyers actually find a property — search, scroll, then shortlist one agent. We run the website, the paid ads and the social content that puts you in front of buyers, sellers and tenants searching tonight. Every asset CEA-compliance reviewed before it goes live."
  heroImage="/property-hero.jpg"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20property%20agent%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my property agent business in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at where your buyer leads are coming from"
  ctaDescription="Tell us your CEA number, the estates you cover, your current PropertyGuru / 99.co spend, and what your buyer-vs-seller mix looks like. We'll come back inside 24 hours with where we'd start."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20property%20agent%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE PROBLEM ========== -->
  <section class="section" id="problem" aria-label="What CEA-registered property agents in Singapore are up against">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Problem</p>
        <h2>Why your PropertyGuru profile isn't winning you the listing</h2>
      </div>
      <div class="section-content reveal">
        <p>There are 36,816 CEA-registered active salespersons in Singapore (CEA Industry Statistics, 1 January 2026). Every one of them has a PropertyGuru profile, a 99.co profile, and the same template "professional, dedicated, results-driven" intro line. The agents winning consistent buyer and seller mandates aren't necessarily the best closers — they're the ones a buyer can actually find, remember, and trust before the first WhatsApp.</p>
        <p>Here's what we usually find when we audit a solo agent or small team's marketing:</p>
      </div>
      <div class="problem-grid">
        <article class="problem-card reveal reveal-d1">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <h3 class="problem-card__title">Indistinguishable from <span class="problem-card__accent">36,000</span> other agents</h3>
            <p class="problem-card__copy">Your PropertyGuru and 99.co profile is identical in shape to every other agent's. Same headshot crop, same agency logo, same generic blurb. A buyer scrolling ten listings tonight has zero reason to remember you tomorrow. Personal-brand marketing fixes that — but most agents never build any.</p>
          </div>
        </article>
        <article class="problem-card reveal reveal-d2">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <h3 class="problem-card__title">Competing with the <span class="problem-card__accent">chain brokerages</span></h3>
            <p class="problem-card__copy">PropNex, ERA, Huttons and OrangeTee run firm-wide brand campaigns. As a solo agent or small team, you can't out-spend them — but you can out-specialise them. Tighter geo, sharper niche, content that proves you actually know the estate.</p>
          </div>
        </article>
        <article class="problem-card reveal reveal-d3">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <h3 class="problem-card__title">CEA advertising rules <span class="problem-card__accent">quietly broken</span></h3>
            <p class="problem-card__copy">"Top 1% agent." "Guaranteed sale in 30 days." "Better than [named competitor]." All three break CEA practice guidelines. We've audited agent ad accounts where every third creative is non-compliant. One CEA complaint and the campaign comes down.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER — 3 PILLARS ========== -->
  <section class="section" id="what-we-deliver" style="background: var(--bg-alt);" aria-label="What we deliver — three service pillars for property agents">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What we deliver</p>
        <h2>Your <span class="pillar-col__accent">marketing engine</span>, three pillars.</h2>
      </div>
      <div class="pillars-grid">
        <!--
          Image: Unsplash — laptop on a designer's workspace
          Source: https://unsplash.com/photos/turned-on-gray-laptop-computer-FlPc9_VocJ4
          Photographer: Igor Miske (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--website reveal reveal-d1" id="website">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <h3 class="pillar-col__title">Website</h3>
            <p class="pillar-col__lede">A personal-brand site that converts buyer traffic into shortlist enquiries, not a generic PropertyGuru profile.</p>
          </div>
        </article>

        <!--
          Image: Unsplash — analytics dashboard on screen
          Source: https://unsplash.com/photos/macbook-pro-near-white-open-book-bA7pTQk9V_E
          Photographer: Carlos Muza (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--ads reveal reveal-d2" id="paid-ads">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <h3 class="pillar-col__title">Paid Ads</h3>
            <p class="pillar-col__lede">Meta + Google Ads targeted to buyers searching tonight in your neighbourhood, every ad CEA-reviewed.</p>
          </div>
        </article>

        <!--
          Image: Unsplash — phone on ring-light, short-form content setup
          Source: https://unsplash.com/photos/black-iphone-on-tripod-photo-1611162617213
          Photographer: Ivan Samkov via Unsplash (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--social reveal reveal-d3" id="social-media">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <h3 class="pillar-col__title">Social Media Marketing</h3>
            <p class="pillar-col__lede">Listings, market reports, and short-form video that builds authority while you sleep.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ========== WHO THIS IS FOR ========== -->
  <section class="section" id="who-this-is-for" aria-label="Who this is for">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Who this is for</p>
        <h2>Right fit if you're one of these</h2>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Solo CEA-registered agent</h3>
            <p>You're licensed under one of the chain agencies (PropNex, ERA, Huttons, OrangeTee, Realstar Premier, etc.) but the brand campaign isn't your brand campaign — it's the agency's. You want lead flow that comes to your name, not the firm's call centre.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Small team — 2 to 5 agents</h3>
            <p>You run a small division or pod inside a larger agency, or an independent team. One shared website, one ad account, one social content engine — leads routed by area or speciality. Most teams at this size don't have a dedicated marketer; we sit in that seat.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Niche specialist — GCB, expat rental, new launch, en-bloc</h3>
            <p>You don't sell everything in every estate — you specialise. Good Class Bungalows, expat condo rentals, new launch units, en-bloc consolidation. Niche-tight marketing outperforms generalist marketing here, and that's where we want to be.</p>
          </div>
        </div>
      </div>
      <div class="who-cta reveal">
        <p class="who-cta__text">Not sure which one is you? That's exactly what the first call is for.</p>
        <a href="/contact/" class="btn btn-primary">Book Your Consultation</a>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="section" id="how-it-works" style="background: var(--bg-alt);" aria-label="How property agent marketing engagement runs">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">How it works</p>
        <h2>Three steps. No 90-day onboarding theatre.</h2>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>1. 30-minute scoping call</h3>
            <p>You walk us through your CEA registration, the estates you cover, your buyer-vs-seller mix, current portal spend, and what your past 12 months of closings looked like. We tell you which of the three services to start with. No deck, no sales pressure.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>2. Week 1–2: setup</h3>
            <p>Website wireframes (if applicable), ad accounts, conversion tracking, content plan, CEA-compliance review of every starter asset. Ads typically go live by day 10. Website usually goes live in 2–3 weeks.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>3. Month 2 onwards: run and report</h3>
            <p>Ads optimised weekly, content shipped on schedule, listings updated as you close and pick up new ones, monthly call and monthly report. No lock-in. Leave at the end of any month, no penalty.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about property agent marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions property agents actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your property ads follow CEA advertising guidelines?</summary>
          <div class="faq-answer"><p>Yes. Every ad, caption, listing description and content piece is checked against the Council for Estate Agencies advertising rules and the Practice Guidelines on Advertising before it goes live. No false guarantees, no "best agent in [area]" superlatives, no naming or comparing to other agents, no testimonials phrased as outcome guarantees, and your CEA registration number and agency licence display correctly on every asset that requires it. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I already have a PropertyGuru and 99.co profile. Why do I need my own marketing?</summary>
          <div class="faq-answer"><p>Because the portals own the relationship, not you. Every buyer who taps your listing is shown ten other agents on the same page. You pay per listing, the platform keeps the data, and the day you stop paying, you disappear. A personal-brand site, paid search on your name and area, and a consistent social presence give you somewhere buyers can find you outside the portals — and somewhere your past clients can refer warm leads to.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What does property agent marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>It depends on which mix you start with. A solo agent kicking off with a personal-brand site and a starter Google + Meta ad budget typically sits between $2,500 and $4,000/month all-in. Agents adding consistent short-form video, area guide content and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you target buyers by district or estate?</summary>
          <div class="faq-answer"><p>Yes. Geo-targeting on Google and Meta lets us run ads to people in a defined radius around a specific HDB town, condo cluster, or planning area. We pair that with keyword targeting — "condo for sale District 9", "HDB resale Punggol", "landed Bukit Timah" — so the ad shows for the right person in the right area. If you specialise in one or two estates, the geo work is where most of the leverage sits.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I'm changing brokerages. Can you handle the rebrand?</summary>
          <div class="faq-answer"><p>Yes — this is one of the more common engagements we run. New CEA agency licence number, new agency logo lockup, new email and contact details across the website, social channels and ad accounts, redirects from the old domain if you had one, and a launch content plan so your network knows where you've moved. Most rebrands go live cleanly in 2–3 weeks.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you handle short-form video for TikTok and Instagram Reels?</summary>
          <div class="faq-answer"><p>Yes. Property buyers and renters scroll TikTok and Reels constantly — listing walkthroughs, neighbourhood tours, market-report explainers and "a day in the life of an agent" content all perform well when the cadence is consistent. We script, shoot direction (or remote-direct if you film yourself), edit, caption and publish. All scripts go through the same CEA-compliance check as the ads.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="section" id="final-cta" aria-label="Talk to us about your property business">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 0;">
        <p class="section-label">Next step</p>
        <h2>Tell us about your patch</h2>
        <p>30 minutes on the phone, no slide deck, no obligation. You'll leave with a clearer view of which of the three services to start with and whether we're the right team to run it.</p>
        <div class="hero-buttons" style="margin-top: 32px;">
          <a href="/contact/" class="btn btn-primary">Book Your Consultation</a>
          <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20property%20agent%20business%20in%20Singapore." class="btn btn-secondary" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore more</p>
        <h2>More for property agents</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/property-agent-website-singapore/" class="related-service-link">Property Agent Website Design</a>
          <a href="/services/paid-ads/" class="related-service-link">Paid Ads Management</a>
          <a href="/services/social-media/" class="related-service-link">Social Media Marketing</a>
          <a href="/digital-marketing-agency-singapore/" class="related-service-link">Digital Marketing Agency</a>
      </div>
    </div>
  </section>
</ServiceLayout>

<style>
  /* ============================================================
     Section 2 — Problem cards
     3-column equal-width grid. All 3 cards same width and same
     height (align-items: stretch). Accent green top bar, mono
     "01 / 02 / 03" index, accent typographic highlight inside
     title. 5% accent-green gradient wash applied uniformly to
     all 3 cards. Bottom padding tight to the last line of copy.
     ============================================================ */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 32px;
    align-items: stretch;
  }

  .problem-card {
    position: relative;
    background: linear-gradient(150deg, rgba(73, 184, 137, 0.05) 0%, var(--bg-card) 55%);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    padding: 36px 32px 28px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }

  .problem-card:hover {
    border-color: rgba(73, 184, 137, 0.35);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .problem-card__bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 3px;
    width: 64px;
    background: var(--accent);
    border-radius: 0 0 3px 0;
  }

  .problem-card__body {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .problem-card__index {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
    line-height: 1;
  }

  .problem-card__title {
    font-size: 22px;
    line-height: 1.22;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .problem-card__accent {
    color: var(--accent);
    font-weight: 600;
  }

  .problem-card__copy {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.65;
    margin: 4px 0 0;
  }

  @media (max-width: 1024px) {
    .problem-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .problem-card {
      padding: 32px 24px 26px;
    }
  }

  /* ============================================================
     Section 3 — 3-pillar columns (image-backed)
     Side-by-side on desktop, stacks to 1 column on mobile.
     Uniform width and height (align-items: stretch). Each card
     is image-backed with a dark overlay so text reads clearly.
     Accent green top bar stays at the card top. Bottom padding
     tight to the last line of copy.
     ============================================================ */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
    align-items: stretch;
  }

  .pillar-col {
    position: relative;
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    padding: 36px 28px 32px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 320px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .pillar-col:hover {
    border-color: rgba(73, 184, 137, 0.35);
    transform: translateY(-2px);
  }

  /* Image-backed variant — image fills card, dark overlay on top */
  .pillar-col--image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Image: Unsplash — Igor Miske (Unsplash License) */
  .pillar-col--website {
