---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "TCM Clinic SEO Singapore",
    "description": "SEO services for TCM clinics in Singapore. Local SEO, Google Business Profile optimisation, bilingual keyword strategy (English and Chinese), and content marketing to grow your patient base — from S$800/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "TCM Clinic SEO",
    "offers": [
      { "@type": "Offer", "name": "Essential TCM SEO", "price": "800", "priceCurrency": "SGD", "description": "Technical SEO audit, on-page optimisation for 10 pages, Google Business Profile setup, Google Analytics and Search Console configuration, monthly reporting" },
      { "@type": "Offer", "name": "Growth TCM SEO", "price": "1500", "priceCurrency": "SGD", "description": "Everything in Essential plus bilingual content strategy, local citation building, review generation strategy, competitor monitoring, bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise TCM SEO", "price": "3000", "priceCurrency": "SGD", "description": "Full-service SEO with dedicated strategist, multi-clinic local SEO, bilingual content creation and publishing, advanced link building, Core Web Vitals optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does SEO cost for a TCM clinic in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "TCM clinic SEO in Singapore ranges from $800 to $3,000+ per month. Our Essential plan at $800 SGD/month covers technical SEO, on-page optimisation, and Google Business Profile setup. Growth and Enterprise plans add bilingual content strategy, link building, and multi-clinic local SEO." } },
      { "@type": "Question", "name": "How long does it take for TCM clinic SEO to show results?", "acceptedAnswer": { "@type": "Answer", "text": "Most TCM clinics see measurable ranking improvements within 3 to 4 months. Google Business Profile optimisation and technical fixes can produce quick wins in weeks. Treatment-specific keywords like 'acupuncture near Chinatown' or 'TCM fertility Singapore' often rank faster than broad competitive terms." } },
      { "@type": "Question", "name": "Can you do bilingual SEO in English and Chinese for my TCM clinic?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Bilingual SEO is a key component of our TCM clinic strategy. Many patients search in Chinese — '中医诊所', '针灸新加坡', '推拿按摩' — alongside English terms. We optimise for both languages to capture the full spectrum of patient searches in Singapore's multilingual market." } },
      { "@type": "Question", "name": "What keywords do patients search when looking for TCM in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Common search terms include 'TCM clinic near me', 'acupuncture Singapore', 'TCM for fertility', 'tuina massage near me', 'Chinese medicine clinic Singapore', and treatment-specific queries like 'TCM for eczema' or 'cupping therapy Singapore'. We also target Chinese-language keywords for clinics serving Mandarin-speaking patients." } },
      { "@type": "Question", "name": "Does your SEO content comply with TCMPB advertising regulations?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All content we create for TCM clinics is written with TCMPB (Traditional Chinese Medicine Practitioners Board) guidelines in mind. We avoid prohibited treatment claims and ensure all content accurately represents the services your clinic provides, building patient trust through informative, compliant content." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "TCM Clinic SEO Singapore", "item": "https://jraftcreative.com/tcm-clinic-seo-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="TCM Clinic SEO Singapore — Rank Higher, Grow Your Patient Base | Jraft Creative"
  description="SEO services for TCM clinics in Singapore. Local SEO, Google Business Profile optimisation, bilingual keyword strategy (EN/CN), and Google Maps ranking to grow your patient base — from S$800/month."
  canonical="https://jraftcreative.com/tcm-clinic-seo-singapore/"
  ogTitle="TCM Clinic SEO Singapore — Jraft Creative"
  ogDescription="SEO for TCM clinics in Singapore. Local search optimisation, Google Maps ranking, and bilingual content strategy to drive patient bookings. Plans from $800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="tcm clinic seo singapore, tcm seo, seo for tcm clinics, acupuncture seo singapore, chinese medicine seo, tcm google ranking, tcm local seo, tcm marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="TCM Clinic SEO"
  heroTitle='SEO for <span class="highlight">TCM Clinics in Singapore</span>'
  heroSubtitle="Singapore has over 2,800 registered TCM practitioners and hundreds of clinics across the island. When patients search 'acupuncture near me', 'TCM Singapore', or '中医诊所' on Google, they choose from the clinics that appear first. If your clinic isn't ranking, those patients — and the lifetime value they represent — go to the competitor down the street."
  heroImage="/images/service-tcm.webp"
  heroButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View SEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need SEO for my TCM clinic in Singapore."
  ctaLabel="Ready to Rank Higher?"
  ctaTitle="Get Your TCM Clinic Found on Google"
  ctaDescription="Book a free SEO audit and we'll show you exactly where your TCM clinic stands in local search compared to nearby competitors. We'll respond within 24 hours."
  ctaButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20SEO%20for%20my%20TCM%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="SEO challenges for TCM clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>2,800+ TCM Practitioners in Singapore — Can Patients Find Your Clinic?</h2>
      </div>
      <div class="section-content reveal">
        <p>Traditional Chinese Medicine is deeply embedded in Singapore's healthcare landscape. Over 2,800 registered TCM practitioners serve a population that increasingly blends conventional and traditional medicine — using acupuncture alongside physiotherapy, tuina alongside sports massage, and herbal remedies alongside western prescriptions. But the way patients find their TCM practitioner has fundamentally shifted. Word-of-mouth referrals still matter, but the first stop for most new patients is now Google.</p>
        <p>"Acupuncture near me", "TCM clinic Singapore", "中医诊所附近", "TCM for fertility", "cupping therapy near MRT" — these searches happen thousands of times each month from patients ready to book an appointment. The clinics appearing in the top three Google results and the Maps 3-pack capture the overwhelming majority of these new patients. The rest depend on walk-ins and an ageing referral base that shrinks with each passing year.</p>
        <p>TCM clinics face a unique SEO challenge in Singapore: many patients search in both English and Chinese. A clinic optimising only for English keywords misses the significant volume of Mandarin-language searches. Add to this the TCMPB advertising regulations that restrict what practitioners can claim online, and most TCM clinics find themselves with websites that are either invisible to Google or too generic to convert the patients who do find them.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="SEO services for TCM clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our SEO Services</p>
        <h2>SEO Built for TCM Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>TCM clinic SEO requires a specialist approach that accounts for bilingual search behaviour, treatment diversity, and regulatory compliance. Patients search by treatment type, condition, language, and neighbourhood — creating dozens of keyword combinations in both English and Chinese that need dedicated, compliant pages. We build SEO strategies specifically for how Singapore patients research and choose TCM providers.</p>
        <p>From technical foundations to treatment-specific landing pages and Google Maps dominance, every element of our approach is designed to drive qualified patient bookings from people actively searching for TCM near them.</p>
        <p>Pair SEO with a professionally designed <a href="/tcm-clinic-website-singapore/">TCM clinic website</a>, <a href="/services/social-media/">social media marketing</a> to build patient trust, or <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches from patients seeking immediate treatment.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>Technical SEO Audit</h3>
            <p>Complete crawl of your TCM clinic website to find indexing gaps, broken links, missing structured data, slow page loads, and mobile usability issues. We fix the technical barriers stopping Google from ranking your clinic for searches like "acupuncture near me", "TCM Singapore", and "中医诊所" in your area.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>On-Page Optimisation</h3>
            <p>Keyword-optimised treatment pages for every service you offer — acupuncture, tuina, cupping, herbal medicine, moxibustion, and fertility TCM. Meta titles, descriptions, heading structures, and internal links targeting searches like "acupuncture Chinatown", "TCM fertility Singapore", and "tuina massage near me" in both English and Chinese.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO &amp; Google Business Profile</h3>
            <p>Google Business Profile optimisation with correct TCM categories, treatment details, clinic photos, patient review management, and local citation building across Singapore healthcare directories. Designed to get your clinic into the Google Maps 3-pack for every "TCM near me" and "acupuncture near me" search in your neighbourhood.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Bilingual Content Strategy</h3>
            <p>Blog articles and treatment guides in English and Chinese answering the questions patients search — "does acupuncture hurt", "TCM vs western medicine for fertility", "针灸治疗有用吗". Content that builds your clinical authority, earns organic backlinks, and captures patients in both language segments — fully compliant with TCMPB advertising guidelines.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for TCM clinic SEO">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>An SEO Agency That Understands TCM Marketing</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with healthcare and wellness businesses across Singapore. We understand patient acquisition in the TCM sector, bilingual search behaviour, TCMPB compliance requirements, and which search terms actually convert online browsers into booked appointments.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Bilingual SEO Expertise</h3>
            <p>Singapore's TCM patients search in both English and Chinese. We optimise for both — targeting "acupuncture Singapore" and "针灸新加坡", "TCM clinic near me" and "中医诊所附近". This bilingual approach captures the full spectrum of patient searches that monolingual SEO misses entirely.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>TCMPB-Compliant Content</h3>
            <p>TCM advertising in Singapore is regulated by the Traditional Chinese Medicine Practitioners Board. We create SEO content that builds clinical authority and patient trust without making prohibited treatment claims. Compliance is built into every page we optimise and every article we publish.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Clear Monthly Reporting</h3>
            <p>Every month you receive a report showing keyword rankings across treatments and languages, organic traffic, Google Business Profile insights, and appointment booking trends. We show you the numbers that matter — data tied directly to patient discovery and conversion.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Presence Under One Roof</h3>
            <p>SEO is one piece of the puzzle. We also handle TCM clinic website design, social media content, and paid ads — so your entire digital marketing works together as a single system to grow your patient base across both English and Chinese-speaking audiences.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="TCM clinic SEO pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">TCM Clinic SEO Pricing</p>
        <h2>SEO Plans for TCM Clinics</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-clinic TCM practices building local visibility.</p>
            <ul class="pricing-features">
              <li>Technical SEO audit</li>
              <li>On-page optimisation (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Google Analytics &amp; Search Console</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$1,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For TCM clinics ready to dominate local search.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Bilingual content strategy (EN/CN)</li>
              <li>Local citation building</li>
              <li>Review generation strategy</li>
              <li>Competitor monitoring</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$3,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-clinic TCM operators.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Dedicated SEO strategist</li>
              <li>Multi-clinic local SEO</li>
              <li>Bilingual content creation &amp; publishing</li>
              <li>Advanced link building</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/seo-performance/" class="inline-link">SEO &amp; Performance</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about TCM clinic SEO in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>TCM Clinic SEO — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does SEO cost for a TCM clinic in Singapore?</summary>
          <div class="faq-answer"><p>TCM clinic SEO in Singapore ranges from $800 to $3,000+ per month. Our Essential plan at $800 SGD/month covers technical SEO, on-page optimisation, and Google Business Profile setup. Growth and Enterprise plans add bilingual content strategy, link building, and multi-clinic local SEO.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take for TCM clinic SEO to show results?</summary>
          <div class="faq-answer"><p>Most TCM clinics see measurable ranking improvements within 3 to 4 months. Google Business Profile optimisation and technical fixes can produce quick wins in weeks. Treatment-specific keywords like "acupuncture near Chinatown" or "TCM fertility Singapore" often rank faster than broad competitive terms like "TCM clinic Singapore".</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you do bilingual SEO in English and Chinese for my TCM clinic?</summary>
          <div class="faq-answer"><p>Yes. Bilingual SEO is a key component of our TCM clinic strategy. Many patients in Singapore search in Chinese — "中医诊所", "针灸新加坡", "推拿按摩" — alongside English terms. We optimise for both languages to capture the full spectrum of patient searches in Singapore's multilingual market.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>What keywords do patients search when looking for TCM in Singapore?</summary>
          <div class="faq-answer"><p>Common search terms include "TCM clinic near me", "acupuncture Singapore", "TCM for fertility", "tuina massage near me", "Chinese medicine clinic", "cupping therapy Singapore", and Chinese-language terms like "中医诊所" and "针灸治疗". We research the exact terms driving appointments in your area across both languages.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Does your SEO content comply with TCMPB advertising regulations?</summary>
          <div class="faq-answer"><p>Yes. All content we create for TCM clinics is written with TCMPB (Traditional Chinese Medicine Practitioners Board) guidelines in mind. We avoid prohibited treatment claims and ensure all content accurately represents your clinic's services, building patient trust through informative, compliant content rather than promotional language.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
