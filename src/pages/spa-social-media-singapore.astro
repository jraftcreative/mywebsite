---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Spa Social Media Marketing Singapore",
    "description": "Social media marketing for spas in Singapore. Wellness content, relaxation aesthetics, treatment showcases, seasonal promotions, and gift voucher campaigns to grow your spa's presence and bookings.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Spa Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting for spas" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting for spas" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting for spas" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost for spas in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing for spas in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, video production, and community management." } },
      { "@type": "Question", "name": "Which social media platforms work best for spas in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Instagram is the strongest platform for spas — calming visuals, treatment Reels, and Stories create an aspirational brand experience. Facebook is excellent for promoting gift vouchers and reaching a professional demographic. TikTok is growing for wellness and self-care content in the Singapore market." } },
      { "@type": "Question", "name": "What kind of content do you create for spas?", "acceptedAnswer": { "@type": "Answer", "text": "We create serene treatment environment videos, therapist spotlight posts, wellness tips and self-care guides, seasonal promotion graphics, gift voucher campaigns, couples package features, and behind-the-scenes content. Every post is designed to evoke relaxation and inspire bookings." } },
      { "@type": "Question", "name": "Can social media help promote my spa gift vouchers?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Gift voucher campaigns on social media perform exceptionally well during Valentine's Day, Mother's Day, Christmas, and birthday seasons. We create targeted campaigns with compelling visuals and clear purchase links that drive voucher sales — often one of the highest-margin revenue streams for spas." } },
      { "@type": "Question", "name": "How do you capture the right mood and aesthetic for spa content?", "acceptedAnswer": { "@type": "Answer", "text": "We develop a visual identity and content style guide specific to your spa's brand — from colour palettes and typography to photography mood boards and video editing styles. Whether your spa is minimal and Zen-inspired or luxurious and indulgent, every piece of content reinforces that experience." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" },
      { "@type": "ListItem", "position": 3, "name": "Spa Social Media", "item": "https://jraftcreative.com/spa-social-media-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Spa Social Media Singapore — Social Media Marketing | Jraft Creative"
  description="Social media marketing for spas in Singapore. Wellness content, treatment showcases, seasonal promotions, and gift voucher campaigns that drive bookings. Monthly plans from S$2,500."
  canonical="https://jraftcreative.com/spa-social-media-singapore/"
  ogTitle="Spa Social Media Singapore — Jraft Creative"
  ogDescription="Social media marketing built for spas in Singapore. Calming visuals, wellness content, and gift voucher campaigns that drive bookings. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="spa social media singapore, spa marketing singapore, social media for spas, spa instagram marketing, spa digital marketing singapore, wellness social media singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Spa Social Media"
  heroTitle='Social Media Marketing for <span class="highlight">Spas in Singapore</span>'
  heroSubtitle="Calming visuals, wellness content, and seasonal campaigns that showcase your spa experience and turn social media followers into loyal clients. We manage your spa's online presence so you can focus on delivering exceptional relaxation and renewal."
  heroImage="/images/service-spa.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need social media marketing for my spa in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Spa with Social Media"
  ctaDescription="Book a free consultation and tell us about your spa. We'll get back to you within 24 hours with a tailored social media strategy that drives bookings and gift voucher sales."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20social%20media%20marketing%20for%20my%20spa%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for spas in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Spa Experience Needs to Be Felt Before It's Booked</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's wellness industry is booming, but so is the competition. From luxury hotel spas in Marina Bay to neighbourhood wellness centres in Tiong Bahru, clients have more options than ever. The decision to book often happens on social media — clients scroll through Instagram looking for the spa that resonates with their mood, and they book the one whose content makes them feel relaxed just by looking at it. If your social media doesn't evoke that experience, you're invisible to an audience ready to spend.</p>
        <p>Most spas in Singapore struggle with social media because the content requires a specific aesthetic sensibility. Generic stock photos of candles and stones don't differentiate your spa from hundreds of others. Inconsistent posting makes your business look neglected. And when someone searches for "spa Singapore" on Instagram and your page hasn't been updated in weeks, they move on to a competitor whose feed looks active, inviting, and professional.</p>
        <p>The spa industry also has significant seasonal and gift-giving opportunities that most businesses miss on social media. Valentine's Day, Mother's Day, Christmas, and corporate wellness season are all periods when a well-timed campaign can generate thousands in gift voucher sales and group bookings. Without a planned content strategy, these high-revenue moments pass by untapped.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media services for spas">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services Built for Spas</h2>
      </div>
      <div class="section-content reveal">
        <p>We handle your spa's entire social media presence — from curating calming visual content to running seasonal gift voucher campaigns. Every post is designed to transport your audience into your spa experience and convert that aspiration into confirmed bookings.</p>
        <p>Our team creates treatment showcase Reels, therapist introductions, wellness tips, and promotional campaigns timed around key occasions — Valentine's Day couples packages, Mother's Day gift vouchers, year-end corporate wellness offers, and more. We build the kind of social media presence that makes people tag their friends and say "we need this".</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Treatment Showcase Reels</h3>
            <p>Atmospheric short-form videos capturing your spa environment, treatment processes, and the sensory details that make your spa unique — the content that makes viewers stop scrolling and start dreaming of their next visit.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Gift Voucher Campaigns</h3>
            <p>Targeted social media campaigns around Valentine's Day, Mother's Day, Christmas, and birthdays that drive gift voucher purchases — one of the highest-margin revenue streams for spas in Singapore.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Wellness &amp; Self-Care Content</h3>
            <p>Branded posts and Stories sharing relaxation tips, skincare routines, stress management advice, and seasonal wellness guides that position your spa as a trusted resource for health-conscious Singaporeans.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Seasonal &amp; Corporate Campaigns</h3>
            <p>Campaigns for festive packages, couples retreats, corporate wellness days, and membership drives — timed to maximise bookings and voucher sales during the highest-demand periods of the year.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for spa social media">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A Social Media Partner That Understands Wellness</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with spas and wellness businesses across Singapore and understand the visual language, seasonal patterns, and content strategies that drive bookings and gift voucher sales. Here's why spas choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Wellness Aesthetic Expertise</h3>
            <p>We craft content that captures the calming, restorative essence of your spa. From colour grading to copywriting tone, every detail reinforces the relaxation experience your clients are seeking.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Revenue-Focused Campaigns</h3>
            <p>We tie social media directly to revenue — gift voucher sales, package bookings, and membership sign-ups. Every campaign is designed to generate measurable returns, not just likes and comments.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Approval Before Publishing</h3>
            <p>You review and approve every post, caption, and visual before it goes live. Full content calendar delivered in advance so nothing is published without your sign-off.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans with no binding agreements. Stay because your bookings are growing and your gift voucher revenue is climbing — not because of a contract clause.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Spa social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Spas of Every Size</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For spas building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing spas ready to scale bookings.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For established spas that want a complete social team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about spa social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Spa Social Media — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost for spas in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing for spas in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering more content, video production, and community management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which social media platforms work best for spas in Singapore?</summary>
          <div class="faq-answer"><p>Instagram is the strongest platform for spas — calming visuals, treatment Reels, and Stories create an aspirational brand experience. Facebook is excellent for promoting gift vouchers and reaching a professional demographic. TikTok is growing for wellness and self-care content in the Singapore market.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What kind of content do you create for spas?</summary>
          <div class="faq-answer"><p>We create serene treatment environment videos, therapist spotlight posts, wellness tips and self-care guides, seasonal promotion graphics, gift voucher campaigns, couples package features, and behind-the-scenes content. Every post is designed to evoke relaxation and inspire bookings.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can social media help promote my spa gift vouchers?</summary>
          <div class="faq-answer"><p>Absolutely. Gift voucher campaigns on social media perform exceptionally well during Valentine's Day, Mother's Day, Christmas, and birthday seasons. We create targeted campaigns with compelling visuals and clear purchase links that drive voucher sales — often one of the highest-margin revenue streams for spas.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you capture the right mood and aesthetic for spa content?</summary>
          <div class="faq-answer"><p>We develop a visual identity and content style guide specific to your spa's brand — from colour palettes and typography to photography mood boards and video editing styles. Whether your spa is minimal and Zen-inspired or luxurious and indulgent, every piece of content reinforces that experience.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>