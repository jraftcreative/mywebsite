---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "WordPress Website Design Singapore",
    "description": "Custom WordPress website design in Singapore — theme development, plugin integration, WooCommerce, security hardening, and ongoing maintenance. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "WordPress Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter WordPress Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page WordPress website with a premium theme, essential plugins, contact form, basic SEO, and 2-week delivery" },
      { "@type": "Offer", "name": "Business WordPress Website", "price": "5500", "priceCurrency": "SGD", "description": "Custom WordPress theme, up to 10 pages, WooCommerce-ready, advanced SEO, security hardening, and performance optimisation" },
      { "@type": "Offer", "name": "Premium WordPress Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom WordPress development with bespoke theme, unlimited pages, WooCommerce store, third-party integrations, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a WordPress website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional WordPress website in Singapore typically costs between $2,500 and $10,000+ SGD depending on complexity and features. Our Starter package at $2,500 includes a 5-page WordPress site with a premium theme, essential plugins, and basic SEO. Business and Premium packages add custom theme development, WooCommerce, advanced security, and third-party integrations." } },
      { "@type": "Question", "name": "Is WordPress still a good choice for business websites in 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. WordPress powers over 40% of all websites globally and remains the most flexible CMS for businesses of any size. It offers thousands of plugins, full content ownership, and the ability to scale from a simple brochure site to a full ecommerce store. The key is having a developer who builds it properly — with clean code, security hardening, and performance optimisation from the start." } },
      { "@type": "Question", "name": "Will my WordPress site be secure?", "acceptedAnswer": { "@type": "Answer", "text": "Security is a top priority in every WordPress site we build. We implement SSL certificates, firewall configuration, login protection, automatic backups, malware scanning, and regular plugin and core updates. Most WordPress security issues stem from outdated plugins and weak passwords — we eliminate both through proper configuration and ongoing maintenance." } },
      { "@type": "Question", "name": "Can you add WooCommerce to my WordPress site?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. WooCommerce is the most popular ecommerce plugin for WordPress and we integrate it into our Business and Premium packages. We set up product catalogues, payment gateways including PayNow and Stripe, shipping calculators, inventory management, and order notifications — everything you need to sell online in Singapore." } },
      { "@type": "Question", "name": "Do you offer WordPress maintenance after launch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer optional WordPress maintenance plans covering core updates, plugin updates, security monitoring, daily backups, uptime checks, and content changes. WordPress requires regular maintenance to stay secure and fast — our plans handle all of that so you can focus on running your business." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "WordPress Website Design Singapore", "item": "https://jraftcreative.com/wordpress-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="WordPress Website Design Singapore — Custom WP Development | Jraft Creative"
  description="Custom WordPress website design in Singapore — theme development, plugin integration, WooCommerce, security hardening, and ongoing maintenance. From S$2,500."
  canonical="https://jraftcreative.com/wordpress-website-design-singapore/"
  ogTitle="WordPress Website Design Singapore — Jraft Creative"
  ogDescription="Custom WordPress website design in Singapore — theme development, plugin integration, WooCommerce, security hardening, and ongoing maintenance. From S$2,500."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="wordpress website design singapore, wordpress developer singapore, wordpress development singapore, custom wordpress theme singapore, woocommerce singapore, wordpress maintenance singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="WordPress Website Design"
  heroTitle='WordPress Website Design <span class="highlight">in Singapore</span>'
  heroSubtitle="We build fast, secure, and fully customised WordPress websites for Singapore businesses — from custom theme development and plugin integration to WooCommerce stores and ongoing maintenance."
  heroImage="/images/service-wordpress.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a WordPress website for my business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your WordPress Site Built Right"
  ctaDescription="Book a free consultation and tell us about your WordPress project. We'll get back to you within 24 hours with a tailored proposal and clear pricing."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20WordPress%20website%20for%20my%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why businesses need a professional WordPress developer">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Why Most WordPress Sites Underperform</h2>
      </div>
      <div class="section-content reveal">
        <p>WordPress powers over 40% of the web, but that popularity comes with a catch — most WordPress sites in Singapore are poorly built. Cheap themes packed with bloated code, dozens of conflicting plugins, and zero security hardening leave businesses with websites that are slow, vulnerable, and difficult to maintain.</p>
        <p>DIY WordPress setups often start well but quickly spiral into problems. Plugin conflicts break layouts overnight. Core updates crash functionality. Brute-force attacks exploit weak login pages. And page speeds tank as more plugins get stacked on top of each other to fix issues that shouldn't exist in the first place.</p>
        <p>A WordPress website built by a professional developer is a different experience entirely. Clean code, carefully selected plugins, proper caching, security layers, and a theme built specifically for your business — not a multipurpose template stretched beyond its limits. That's what separates a WordPress site that drives results from one that drains your time.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="WordPress website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>WordPress Development That Actually Works</h2>
      </div>
      <div class="section-content reveal">
        <p>Every WordPress site we build is engineered for speed, security, and ease of use. We don't install 30 plugins and hope for the best — we write clean code, select only the tools your site genuinely needs, and deliver a platform you can confidently manage on your own.</p>
        <p>A great WordPress website is just the foundation. Pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank on Google for the keywords your customers are searching, <a href="/services/social-media/">social media marketing</a> to build brand awareness across platforms, and <a href="/services/paid-ads/">paid advertising</a> to drive targeted traffic from day one.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Custom Theme Development</h3>
            <p>Bespoke WordPress themes built from scratch to match your brand identity and business goals. No bloated multipurpose themes — just clean, lightweight code that loads fast and looks exactly the way you want it to.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Plugin Integration &amp; WooCommerce</h3>
            <p>Strategic plugin selection and WooCommerce store setup — product catalogues, payment gateways (PayNow, Stripe, PayPal), shipping calculators, and inventory management. Only the plugins your site actually needs, configured properly.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Security Optimisation</h3>
            <p>Server-level caching, image compression, database optimisation, SSL, firewall setup, login protection, and malware scanning. Your WordPress site will load fast and stay protected against the threats that plague unmanaged installations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Content Management Training</h3>
            <p>Hands-on training so you can confidently update pages, publish blog posts, manage products, and handle day-to-day content changes without needing a developer for every small edit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for WordPress website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for WordPress</h2>
      </div>
      <div class="section-content reveal">
        <p>We don't just install WordPress and hand you the keys. We build WordPress websites that are fast, secure, and maintainable — with clean architecture that won't fall apart the moment you update a plugin.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Clean, Lightweight Code</h3>
            <p>Custom themes built with minimal dependencies — no page builders, no bloated frameworks. Your site loads fast because there's nothing unnecessary slowing it down.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Security-First Approach</h3>
            <p>Every WordPress site we deliver includes hardened login pages, firewall configuration, automated backups, and malware monitoring. We close the security gaps that most builders ignore.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Plugin Discipline</h3>
            <p>We install only the plugins your site genuinely needs — each one vetted for performance, security, and long-term compatibility. Fewer plugins means fewer conflicts and faster load times.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Singapore-Focused</h3>
            <p>Local SEO structure, SGD pricing for WooCommerce, PDPA-compliant forms, and design that resonates with Singapore audiences. Built by a team that understands the local market.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="WordPress website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">WordPress Pricing</p>
        <h2>WordPress Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For businesses getting started with WordPress.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Premium theme setup</li>
              <li>Essential plugins</li>
              <li>Contact form</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing businesses that need custom WordPress.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Custom theme development</li>
              <li>WooCommerce-ready</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Security hardening</li>
              <li>Performance optimisation</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For businesses with advanced WordPress needs.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Bespoke theme &amp; functionality</li>
              <li>Full WooCommerce store</li>
              <li>Third-party integrations</li>
              <li>Priority support</li>
              <li>CMS training session</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about WordPress website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>WordPress Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a WordPress website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional WordPress website in Singapore typically costs between $2,500 and $10,000+ SGD depending on complexity and features. Our Starter package at $2,500 includes a 5-page WordPress site with a premium theme, essential plugins, and basic SEO. Business and Premium packages add custom theme development, WooCommerce, advanced security, and third-party integrations.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Is WordPress still a good choice for business websites in 2026?</summary>
          <div class="faq-answer"><p>Yes. WordPress powers over 40% of all websites globally and remains the most flexible CMS for businesses of any size. It offers thousands of plugins, full content ownership, and the ability to scale from a simple brochure site to a full ecommerce store. The key is having a developer who builds it properly — with clean code, security hardening, and performance optimisation from the start.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Will my WordPress site be secure?</summary>
          <div class="faq-answer"><p>Security is a top priority in every WordPress site we build. We implement SSL certificates, firewall configuration, login protection, automatic backups, malware scanning, and regular plugin and core updates. Most WordPress security issues stem from outdated plugins and weak passwords — we eliminate both through proper configuration and ongoing maintenance.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you add WooCommerce to my WordPress site?</summary>
          <div class="faq-answer"><p>Absolutely. WooCommerce is the most popular ecommerce plugin for WordPress and we integrate it into our Business and Premium packages. We set up product catalogues, payment gateways including PayNow and Stripe, shipping calculators, inventory management, and order notifications — everything you need to sell online in Singapore.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you offer WordPress maintenance after launch?</summary>
          <div class="faq-answer"><p>Yes. We offer optional WordPress maintenance plans covering core updates, plugin updates, security monitoring, daily backups, uptime checks, and content changes. WordPress requires regular maintenance to stay secure and fast — our plans handle all of that so you can focus on running your business.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
