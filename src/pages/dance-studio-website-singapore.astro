---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Dance Studio Website Design Singapore",
    "description": "Custom website design for dance studios and dance schools in Singapore — class timetables, instructor bios, video galleries, online trial booking, dance style pages, and local SEO. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Dance Studio Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Dance Studio Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with class timetable, dance style overview, contact form, Google Maps, mobile-responsive design, basic SEO, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Dance Studio Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online trial booking, instructor profiles, video gallery, blog, advanced SEO, Google Business Profile optimisation, and membership/package pricing" },
      { "@type": "Offer", "name": "Premium Dance Studio Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages with custom design, recital/performance showcase, multi-location support, online payment integration, student portal, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a dance studio website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional dance studio website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with a class timetable, dance style overview, contact form, Google Maps integration, and basic SEO. Business and Premium packages add online trial booking, instructor profiles, video galleries, membership pricing, recital showcases, and online payment integration." } },
      { "@type": "Question", "name": "Can you add online class booking to our dance studio website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business and Premium packages include an online booking system that lets students register for trial classes, regular sessions, and workshops directly through your website. The system displays class schedules by dance style — ballet, K-pop, hip-hop, contemporary, jazz — shows instructor availability, and sends automated confirmation emails. This reduces phone calls and WhatsApp messages so your front desk can focus on welcoming students." } },
      { "@type": "Question", "name": "Can you build a video gallery for our dance studio website?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We build video galleries that showcase student performances, recital highlights, choreography reels, and instructor demos. Videos are embedded from YouTube or Vimeo and optimised for fast loading so your site stays quick even with dozens of clips. This is one of the most effective ways to convert visitors — prospective students want to see your teaching quality and studio energy before they walk in." } },
      { "@type": "Question", "name": "Can you help our dance studio rank on Google in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We optimise your website for keywords students actually search — like 'dance studio near me', 'K-pop dance class Singapore', 'ballet lessons for kids Singapore', or 'hip-hop classes Orchard'. This includes on-page SEO, schema markup for dance studios, Google Business Profile optimisation, and location-targeted content that helps you rank in local search results and Google Maps." } },
      { "@type": "Question", "name": "How long does it take to build a dance studio website?", "acceptedAnswer": { "@type": "Answer", "text": "Most dance studio websites go live within 2 weeks for our Starter package. Business-tier sites with online booking, instructor profiles, and video galleries typically take 3 weeks, while Premium builds with recital showcases, student portals, and multi-location support take 4–5 weeks. We provide a clear timeline before starting so you can plan around your term or recital schedule." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Dance Studio Website Singapore", "item": "https://jraftcreative.com/dance-studio-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Dance Studio Website Singapore — Dance School Web Design | Jraft Creative"
  description="Custom website design for dance studios and dance schools in Singapore — class timetables, instructor bios, video galleries, online trial booking, dance style pages, and local SEO. From S$2,500."
  canonical="https://jraftcreative.com/dance-studio-website-singapore/"
  ogTitle="Dance Studio Website Singapore — Jraft Creative"
  ogDescription="Custom website design for dance studios and dance schools in Singapore. Class timetables, instructor profiles, video galleries, and online booking from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="dance studio website design singapore, dance studio website singapore, dance school website singapore, dance class website singapore, ballet website singapore, K-pop dance class website, hip-hop dance studio website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Dance Studio Websites"
  heroTitle='Website Design for <span class="highlight">Dance Studios in Singapore</span>'
  heroSubtitle="Students are searching for dance classes online before they ever step into a studio. We build websites that showcase your dance styles, highlight your instructors, and make booking a trial class effortless — so you can focus on choreography, not chasing enquiries."
  heroImage="/images/service-dancestudio.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my dance studio in Singapore."
  ctaLabel="Ready to Grow Your Dance Studio?"
  ctaTitle="Get Your Dance Studio Online"
  ctaDescription="Tell us about your dance studio and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20dance%20studio%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why dance studios need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Students Are Searching — Can They Find Your Dance Studio?</h2>
      </div>
      <div class="section-content reveal">
        <p>Every week, thousands of people in Singapore search "dance studio near me", "K-pop dance class Singapore", or "ballet lessons for kids" on Google. They compare studios side by side, watching choreography videos, reading instructor bios, and checking class schedules. If your dance studio doesn't have a professional website, you're invisible to these potential students — and they're signing up for trial classes at your competitors instead.</p>
        <p>An Instagram page or a listing on ClassPass alone is not enough. Prospective students want to see your full range of dance styles, understand each instructor's training background and performance credits, watch student showcases and recital highlights, and check available class slots — all before they ever message you on WhatsApp. Parents researching dance classes for their children are especially thorough, comparing syllabi, checking recital schedules, and reading reviews from other parents.</p>
        <p>Dance studios that invest in a proper website with clear class timetables, compelling instructor profiles, video galleries, and easy trial booking consistently outperform those relying on social media or word of mouth alone. In a market as competitive as Singapore's dance scene — from established academies in Dhoby Ghaut to boutique studios in Bugis and Tampines — your website is the first impression that determines whether a student books a trial or scrolls past.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Dance studio website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Dance Studios</h2>
      </div>
      <div class="section-content reveal">
        <p>Every dance studio website we deliver is built to convert visitors into enrolled students. We go beyond a generic template — your site will feature dedicated pages for every dance style you teach, instructor profiles that highlight training and performance credentials, a video gallery that captures your studio's energy, and a frictionless booking flow that makes it easy to sign up for a trial class.</p>
        <p>A great website is just the starting point. Pair your dance studio site with <a href="/services/seo-performance/">local SEO services</a> to rank for "dance studio near me" searches in your area, <a href="/services/social-media/">social media marketing</a> to reach students on Instagram and TikTok, and <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches during peak enrolment periods.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Dance Style &amp; Class Pages</h3>
            <p>Dedicated pages for every dance style you offer — ballet, K-pop, hip-hop, contemporary, jazz, Latin, street, and more. Each page details class levels from beginner to advanced, age groups, session formats, and what students can expect, so prospective dancers find exactly the right class for them.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Trial Booking &amp; Timetables</h3>
            <p>Let students book trial classes directly through your website. The booking system displays your weekly timetable, filters by dance style and instructor, and sends automated confirmation emails — cutting down WhatsApp back-and-forth and giving your reception team more time to welcome students at the door.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Instructor Profiles &amp; Bios</h3>
            <p>Each instructor gets a profile page featuring their training background, performance credits, choreography highlights, and teaching philosophy. We include professional photos, embedded video clips of performances or classes, and certifications — giving prospective students full confidence in your teaching team.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Video Gallery &amp; Recital Showcases</h3>
            <p>A dedicated gallery for choreography reels, student performances, recital highlights, and behind-the-scenes studio moments. Videos are embedded from YouTube or Vimeo and optimised for fast loading — letting visitors feel your studio's energy and teaching quality before they walk through the door.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for dance studio website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Your Dance Studio Website</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand the dance industry in Singapore. Our websites are built to address the specific challenges dance studios face — from competing for "dance studio near me" searches to converting casual browsers into long-term students and members.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Dance Industry Experience</h3>
            <p>We've built websites for dance studios, performing arts schools, and fitness studios across Singapore. We know what students look for — class variety, instructor credentials, studio atmosphere — and how to structure content that turns first-time visitors into committed members.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most dance studio websites go live within 2 weeks. We work fast so you can start capturing online bookings before the next term or workshop series begins — no dragging projects out for months.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Video &amp; Media Optimised</h3>
            <p>Dance is visual. Your website will handle embedded choreography videos, performance reels, student showcases, and high-resolution studio photos without slowing down. We optimise media delivery so visitors get a rich, immersive experience on any device.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Beyond the website, we offer SEO, social media marketing, and Google Ads management — everything your dance studio needs to grow its online presence, fill more class slots, and build a loyal student community across all dance styles.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Dance studio website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Dance Studio Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new dance studios getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Class timetable &amp; dance style overview</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established studios ready to grow.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online trial class booking system</li>
              <li>Instructor profiles &amp; bios</li>
              <li>Video gallery &amp; embeds</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For large studios and multi-location academies.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; branding</li>
              <li>Recital &amp; performance showcase</li>
              <li>Membership &amp; package pricing</li>
              <li>Multi-location support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about dance studio website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Dance Studio Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a dance studio website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional dance studio website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with a class timetable, dance style overview, contact form, Google Maps integration, and basic SEO. Business and Premium packages add online trial booking, instructor profiles, video galleries, membership pricing, recital showcases, and online payment integration.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add online class booking to our dance studio website?</summary>
          <div class="faq-answer"><p>Yes. Our Business and Premium packages include an online booking system that lets students register for trial classes, regular sessions, and workshops directly through your website. The system displays class schedules by dance style — ballet, K-pop, hip-hop, contemporary, jazz — shows instructor availability, and sends automated confirmation emails. This reduces phone calls and WhatsApp messages so your front desk can focus on welcoming students.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you build a video gallery for our dance studio website?</summary>
          <div class="faq-answer"><p>Absolutely. We build video galleries that showcase student performances, recital highlights, choreography reels, and instructor demos. Videos are embedded from YouTube or Vimeo and optimised for fast loading so your site stays quick even with dozens of clips. This is one of the most effective ways to convert visitors — prospective students want to see your teaching quality and studio energy before they walk in.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you help our dance studio rank on Google in Singapore?</summary>
          <div class="faq-answer"><p>Yes. We optimise your website for keywords students actually search — like "dance studio near me", "K-pop dance class Singapore", "ballet lessons for kids Singapore", or "hip-hop classes Orchard". This includes on-page SEO, schema markup for dance studios, Google Business Profile optimisation, and location-targeted content that helps you rank in local search results and Google Maps.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a dance studio website?</summary>
          <div class="faq-answer"><p>Most dance studio websites go live within 2 weeks for our Starter package. Business-tier sites with online booking, instructor profiles, and video galleries typically take 3 weeks, while Premium builds with recital showcases, student portals, and multi-location support take 4-5 weeks. We provide a clear timeline before starting so you can plan around your term or recital schedule.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
