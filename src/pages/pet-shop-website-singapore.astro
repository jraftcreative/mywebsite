---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Pet Shop Website Design Singapore",
    "description": "Professional website design for pet shops, pet grooming salons, veterinary clinics, and pet boarding facilities in Singapore. Product catalogues, grooming booking, pet care blogs, and e-commerce — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Pet Shop Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Pet Shop Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page pet shop website with product overview, service list, contact form, Google Maps, mobile-responsive design, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Pet Shop Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with product catalogue, grooming booking integration, pet care blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Pet Shop Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with full e-commerce store, multi-location support, loyalty programme, subscription ordering for pet food, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a pet shop website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional pet shop website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with your product overview, service list, and contact form. Business and Premium packages add product catalogues, grooming booking, e-commerce, and subscription ordering." } },
      { "@type": "Question", "name": "Can you build an online store for my pet shop?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package ($10,000+) includes a full e-commerce store where customers can browse and purchase pet food, accessories, toys, and supplies online. We also set up subscription ordering for recurring purchases like pet food and treats, which is popular with pet owners in Singapore." } },
      { "@type": "Question", "name": "Do you integrate grooming booking systems into pet websites?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include grooming booking integration. Customers can select a grooming service, choose a time slot, specify their pet's breed and size, and confirm the appointment — all directly on your website without needing to call or message." } },
      { "@type": "Question", "name": "Can you help my pet shop rank on Google in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Every website we build includes on-page SEO setup, and our Business and Premium packages include advanced SEO with schema markup and Google Business Profile optimisation. For ongoing rankings, we also offer dedicated SEO services starting at $800/month to help your pet shop rank for searches like 'pet shop near me' or 'dog grooming Singapore.'" } },
      { "@type": "Question", "name": "How long does it take to build a pet shop website?", "acceptedAnswer": { "@type": "Answer", "text": "Most pet shop websites go live within 2-4 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with e-commerce, booking systems, or custom product catalogues may take 3-4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Pet Shop Website Singapore", "item": "https://jraftcreative.com/pet-shop-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Pet Shop Website Singapore — Jraft Creative"
  description="Website design for pet shops, pet grooming salons, veterinary clinics, and pet boarding facilities in Singapore. Product catalogues, grooming booking."
  canonical="https://jraftcreative.com/pet-shop-website-singapore/"
  ogTitle="Pet Shop Website Singapore — Jraft Creative"
  ogDescription="Website design for pet shops, grooming salons, and veterinary clinics in Singapore. Product catalogues, booking systems, e-commerce — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="pet shop website design singapore, pet grooming website singapore, veterinary clinic website singapore, pet boarding website design, pet shop web design, pet business website singapore, pet shop e-commerce singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Pet Shop Websites"
  heroTitle='Website Design for <span class="highlight">Pet Businesses in Singapore</span>'
  heroSubtitle="Pet owners in Singapore search online before they walk into a shop. We build fast, mobile-friendly websites for pet shops, grooming salons, veterinary clinics, and boarding facilities — with product catalogues, booking systems, and e-commerce built in."
  heroImage="/images/service-petshop.webp"
  heroImageAlt="Pet shop and grooming salon in Singapore — pet business website design"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my pet business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Pet Business Online"
  ctaDescription="Book a free consultation and tell us about your pet shop, grooming salon, or veterinary clinic. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20pet%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why pet businesses need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Pet Owners <span class="highlight">Research Online</span> Long Before They <span class="highlight">Walk In</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's pet owners compare shops, groomers, and vets on their phones before they ever step through a door. If your pet business isn't easy to find, easy to browse, and easy to book, the sale quietly goes to whoever has the better website — not the better shop.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>They Decide Before They Visit</h3>
            <p>"Dog grooming near me", "pet shop Tampines", "cat food delivery Singapore" — searched by owners who are ready to buy or book. They scan a website, check photos and prices, then commit. A Carousell listing or an Instagram grid can't carry that decision.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>You Sell Products <em>and</em> Services</h3>
            <p>A pet business is a shop and a service counter at once — food, accessories, and supplies on one side; grooming, boarding, and vet visits on the other. Your site has to display a browsable catalogue <em>and</em> take bookings, or half your revenue stays invisible online.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Out-Priced by the Online Giants</h3>
            <p>Shopee, Lazada, and the big pet marketplaces win on price and range. Independent shops win on trust — local pickup, hands-on grooming, real advice, and a face behind the counter. Your website has to make that local-store advantage obvious.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Pet shop website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Pillars</span> of a Pet Shop <span class="highlight">Website</span></h2>
      </div>
      <div class="section-content reveal">
        <p>A pet shop website isn't a brochure. It has to sell food and accessories, take grooming and boarding bookings, load fast on a phone, and show up when a nearby owner searches. We build every element around how Singapore pet owners actually browse, buy, and book.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Conversion-Led Design</h3>
            <p>A clean, trust-led layout that puts your best photos, prices, and calls to action where owners look first — so a visitor becomes a booking or an order instead of bouncing back to Google.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Product &amp; Supplies Catalogue</h3>
            <p>Organised pages for food, accessories, toys, and supplies — with category filters and search, so owners find the right kibble or crate in seconds instead of scrolling an Instagram feed.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3>Grooming &amp; Services Booking</h3>
            <p>Online booking for grooming, boarding, daycare, or vet visits. Customers pick a service, specify their pet's breed and size, choose a time slot, and confirm — no phone calls or DMs needed.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Checkout &amp; Payments</h3>
            <p>A tap-friendly cart and secure checkout with the payment methods Singapore owners expect, plus subscription ordering for recurring buys like pet food and litter — built to finish the sale on a phone.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Core Web Vitals</h3>
            <p>Fast-loading pages that pass Core Web Vitals, because owners browsing on the MRT abandon slow sites. Optimised images, lean code, and clean structure keep your catalogue quick under load.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Local SEO Foundations</h3>
            <p>On-page SEO, schema markup, and Google Business Profile groundwork so your shop surfaces for "pet shop near me" and "dog grooming [your area]" — and lands in the Maps 3-pack owners tap first.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for pet shop website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A <span class="highlight">Web Studio</span> Built for <span class="highlight">Pet Businesses</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build for retail and service businesses across Singapore, and we understand what makes a pet owner choose one shop over another online — trust signals, clear pricing, easy booking, and a site that works as hard as your storefront.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Built for the Pet Industry</h3>
            <p>We design around real pet-shop needs — catalogue layouts, grooming booking flows, and content that reflects AVS licensing and HDB pet regulations, so your site reads as credible to owners who take pet welfare seriously.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Shop and Booking in One Site</h3>
            <p>Most agencies build a catalogue or a booking system. We build both into one coherent experience, so your product sales and your grooming, boarding, and vet appointments all convert on the same website.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>A great site is the start. We handle SEO, social, and paid ads in-house too — an integrated system that turns local searches and scroll-stopping content into foot traffic and online orders for your pet business.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CUSTOMER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Customer Funnel — where your website fits the pet owner journey">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Customer Funnel</p>
        <h2>Where Your <span class="highlight">Website</span> Fits the <span class="highlight">Customer Journey</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>Every pet owner moves through the same five stages before they become a regular. Your website owns the first one — being found and trusted the moment they search — and carries them all the way to the repeat orders and referrals that grow your shop.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google search, Maps 3-pack, social</p>
        </li>
        <li class="funnel-stage">
          <h3>Consider</h3>
          <p>Browse catalogue, prices, reviews</p>
        </li>
        <li class="funnel-stage">
          <h3>Purchase</h3>
          <p>Order online or book a grooming slot</p>
        </li>
        <li class="funnel-stage">
          <h3>Repeat</h3>
          <p>Subscription food &amp; return visits</p>
        </li>
        <li class="funnel-stage">
          <h3>Refer</h3>
          <p>Reviews &amp; word-of-mouth to new owners</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Pet shop website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pet Shop Website Pricing</p>
        <h2>Website Packages for Pet Businesses</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new pet shops and grooming studios getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Product overview &amp; service list</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For pet businesses ready to take bookings and orders online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Product catalogue with filters</li>
              <li>Grooming booking integration</li>
              <li>Pet care blog section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For established pet businesses and multi-location chains.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Full e-commerce store</li>
              <li>Subscription ordering</li>
              <li>Multi-location support</li>
              <li>Loyalty programme integration</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about pet shop website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Pet Shop Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a pet shop website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional pet shop website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with your product overview, service list, and contact form. Business and Premium packages add product catalogues, grooming booking, e-commerce, and subscription ordering.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build an online store for my pet shop?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package ($10,000+) includes a full e-commerce store where customers can browse and purchase pet food, accessories, toys, and supplies online. We also set up subscription ordering for recurring purchases like pet food and treats, which is popular with pet owners in Singapore who want regular deliveries.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you integrate grooming booking systems into pet websites?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include grooming booking integration. Customers can select a grooming service, choose a time slot, specify their pet's breed and size, and confirm the appointment — all directly on your website without needing to call or message.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you help my pet shop rank on Google in Singapore?</summary>
          <div class="faq-answer"><p>Every website we build includes on-page SEO setup, and our Business and Premium packages include advanced SEO with schema markup and Google Business Profile optimisation. For ongoing rankings, we also offer dedicated <a href="/services/seo-performance/" class="inline-link">SEO services</a> starting at $800/month to help your pet shop rank for searches like "pet shop near me" or "dog grooming Singapore."</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a pet shop website?</summary>
          <div class="faq-answer"><p>Most pet shop websites go live within 2-4 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with e-commerce, booking systems, or custom product catalogues may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="website" />

</ServiceLayout>
