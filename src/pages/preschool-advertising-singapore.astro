---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Preschool Advertising Singapore",
    "description": "Google and Facebook ads management for preschools in Singapore — open house campaigns, enrolment drives, parent targeting, and waitlist generation. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Advertising for Preschools",
    "offers": [
      { "@type": "Offer", "name": "Starter Preschool Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Preschool Ads", "price": "2500", "priceCurrency": "SGD", "description": "Google and Facebook, up to $10K ad spend management, A/B testing, open house campaigns, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Preschool Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does preschool advertising cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most preschools start with a monthly ad spend of $1,500–$5,000 on top of management fees. Google Ads for keywords like 'preschool near me' typically cost $3–$10 per click, while Facebook ads targeting parents with young children cost $0.50–$3 per click. We help you allocate budget across both platforms for maximum enrolment impact." } },
      { "@type": "Question", "name": "Should my preschool use Google Ads or Facebook Ads?", "acceptedAnswer": { "@type": "Answer", "text": "Both work well but serve different purposes. Google Ads captures parents actively searching for preschools — high intent, ready to enrol. Facebook Ads reaches parents who may not be actively searching but fit your ideal profile — great for awareness, open house invitations, and building waitlists. We recommend running both for a full-funnel approach." } },
      { "@type": "Question", "name": "How do you promote preschool open house events?", "acceptedAnswer": { "@type": "Answer", "text": "We run dedicated open house campaigns 3–4 weeks before the event, combining Google search ads for parents actively looking with Facebook event campaigns targeting parents by child age, location, and interests. Landing pages capture RSVPs, and we retarget visitors who didn't register to maximise attendance." } },
      { "@type": "Question", "name": "Can ads help build a preschool waitlist?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create waitlist-specific campaigns with lead generation forms on both Google and Facebook. Parents who submit their details are automatically added to your waitlist pipeline. This is particularly effective for popular preschools in estates like Bukit Timah, Holland Village, and Novena where demand exceeds available spots." } },
      { "@type": "Question", "name": "How do you target parents with preschool-age children?", "acceptedAnswer": { "@type": "Answer", "text": "On Google, we target search keywords parents use when looking for preschools. On Facebook, we use detailed demographic targeting — parents with children aged 18 months to 6 years, in specific neighbourhoods, with relevant interests. We also build lookalike audiences from your existing parent database to find similar families in Singapore." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Preschool Advertising Singapore", "item": "https://jraftcreative.com/preschool-advertising-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Preschool Advertising Singapore — Google &amp; Facebook Ads | Jraft Creative"
  description="Google and Facebook ads for preschools in Singapore. Open house campaigns, enrolment drives, parent targeting, and waitlist generation. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/preschool-advertising-singapore/"
  ogTitle="Preschool Advertising Singapore — Jraft Creative"
  ogDescription="Google and Facebook ads for preschools in Singapore. Open house campaigns, enrolment drives, and parent targeting. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="preschool advertising singapore, preschool marketing singapore, google ads preschool singapore, facebook ads preschool singapore, preschool enrolment marketing, preschool open house advertising, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Preschool Advertising Singapore"
  heroTitle='Advertising for Preschools <span class="highlight">in Singapore</span>'
  heroSubtitle="Fill your preschool classrooms with qualified families. We run Google and Facebook ad campaigns that reach parents searching for preschools in your neighbourhood — driving open house registrations, tour bookings, and enrolments."
  heroImage="/images/service-preschool.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need advertising for my preschool in Singapore."
  ctaLabel="Fill Your Classrooms"
  ctaTitle="Get a Free Preschool Advertising Strategy"
  ctaDescription="Book a free consultation and we'll review your current enrolment pipeline, analyse competitor advertising in your area, and map out a Google and Facebook campaign strategy for your preschool. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20advertising%20for%20my%20preschool%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Advertising challenges for preschools">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Competing for Enrolments in a Saturated Preschool Market?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has over 1,800 registered preschools, and parents now compare options online long before scheduling a tour. When a parent searches "preschool near Toa Payoh" or "Montessori kindergarten Singapore", they see a page full of options — and preschools without a strong digital presence get overlooked in favour of those running targeted ads.</p>
        <p>Without a proper advertising strategy, your preschool relies on neighbourhood visibility and word-of-mouth while larger chains dominate Google search results and Facebook feeds. Open house events go under-attended, waitlists stay short, and available classroom spots go unfilled — all while competitors in the same estate run ads that capture the parents you should be reaching.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Advertising services for preschools">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Preschool Advertising Services</p>
        <h2>Google &amp; Facebook Ads Built for Preschool Enrolment</h2>
      </div>
      <div class="section-content reveal">
        <p>We run cross-platform advertising campaigns designed specifically for preschools in Singapore. Google Ads captures parents actively searching for preschool options, while Facebook and Instagram ads reach parents who match your ideal family profile — building awareness, driving open house attendance, and generating waitlist sign-ups.</p>
        <p>Every campaign is tailored to your preschool's location, curriculum approach, and enrolment timeline — whether you're filling spots for the next intake or building a waitlist months in advance.</p>
        <p>Complement your advertising with a professional <a href="/preschool-website-design-singapore/">preschool website</a>, <a href="/services/seo-performance/">SEO for organic search visibility</a>, or <a href="/services/social-media/">social media content management</a> for a complete marketing strategy.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Google Search Campaigns</h3>
            <p>Keyword-targeted ads for "preschool near me", "Montessori kindergarten Singapore", and area-specific searches — capturing parents actively looking for preschool options in your neighbourhood.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Facebook &amp; Instagram Ads</h3>
            <p>Targeted social campaigns reaching parents with children aged 18 months to 6 years in your area. Carousel ads showcasing your facilities, video tours, and testimonial-driven creative to build trust and drive tour bookings.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Open House &amp; Enrolment Campaigns</h3>
            <p>Dedicated campaigns for open house events and enrolment drives — Facebook event promotion, Google search ads, RSVP landing pages, and retargeting for parents who viewed but didn't register.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Waitlist Generation</h3>
            <p>Lead capture campaigns with dedicated landing pages that collect parent details for your waitlist pipeline. Automated follow-up sequences keep interested families engaged until spots become available.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for preschool advertising">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>We Understand Preschool Enrolment in Singapore</h2>
      </div>
      <div class="section-content reveal">
        <p>We've run advertising campaigns for preschools and early childhood centres across Singapore and understand the parent decision journey — from first search to scheduled tour to signed enrolment form. Here's why preschools choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Early Childhood Expertise</h3>
            <p>We understand the preschool enrolment cycle in Singapore — registration windows, ECDA requirements, and the factors parents weigh when choosing a centre. Our campaigns speak directly to parent concerns.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google and Meta — we never mark up media spend. You see every dollar in your own ad accounts and know exactly what each tour booking costs.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that flex with your enrolment calendar. Ramp up before registration periods and open houses, adjust during full-capacity months — no penalties, no fixed terms.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full-Funnel Parent Tracking</h3>
            <p>We track the complete parent journey — from ad click to tour booking to waitlist sign-up. You'll know which campaigns fill classrooms and which keywords attract the right families.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Preschool advertising pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Preschool Ads Pricing</p>
        <h2>Advertising Plans for Preschools</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google and Meta.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location preschools starting with digital ads.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Parent keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For preschools running Google and Facebook campaigns together.</p>
            <ul class="pricing-features">
              <li>Google &amp; Facebook/Instagram</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; creative optimisation</li>
              <li>Open house campaign management</li>
              <li>Retargeting campaigns</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-branch preschools maximising enrolments across locations.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about preschool advertising">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Preschool Advertising — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does preschool advertising cost in Singapore?</summary>
          <div class="faq-answer"><p>Most preschools start with a monthly ad spend of $1,500–$5,000 on top of management fees. Google Ads for keywords like "preschool near me" typically cost $3–$10 per click, while Facebook ads targeting parents with young children cost $0.50–$3 per click. We help you allocate budget across both platforms for maximum enrolment impact.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Should my preschool use Google Ads or Facebook Ads?</summary>
          <div class="faq-answer"><p>Both work well but serve different purposes. Google Ads captures parents actively searching for preschools — high intent, ready to enrol. Facebook Ads reaches parents who may not be actively searching but fit your ideal profile — great for awareness, open house invitations, and building waitlists. We recommend running both for a full-funnel approach.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you promote preschool open house events?</summary>
          <div class="faq-answer"><p>We run dedicated open house campaigns 3–4 weeks before the event, combining Google search ads for parents actively looking with Facebook event campaigns targeting parents by child age, location, and interests. Landing pages capture RSVPs, and we retarget visitors who didn't register to maximise attendance.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can ads help build a preschool waitlist?</summary>
          <div class="faq-answer"><p>Yes. We create waitlist-specific campaigns with lead generation forms on both Google and Facebook. Parents who submit their details are automatically added to your waitlist pipeline. This is particularly effective for popular preschools in estates like Bukit Timah, Holland Village, and Novena where demand exceeds available spots.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you target parents with preschool-age children?</summary>
          <div class="faq-answer"><p>On Google, we target search keywords parents use when looking for preschools. On Facebook, we use detailed demographic targeting — parents with children aged 18 months to 6 years, in specific neighbourhoods, with relevant interests. We also build lookalike audiences from your existing parent database to find similar families in Singapore.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
