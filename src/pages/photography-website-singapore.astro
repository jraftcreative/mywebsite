---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Photography Website Design Singapore",
    "description": "Professional website design for photographers and photography studios in Singapore. Portfolio galleries, online booking, client proofing, and package pages — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Photography Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Photography Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page photography website with portfolio gallery, about page, pricing overview, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Photography Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with categorised portfolio galleries, online booking system, client proofing portal, blog, advanced SEO, and Instagram integration" },
      { "@type": "Offer", "name": "Premium Photography Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom photography website with client login portal, digital download delivery, e-commerce for prints, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a photography website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional photography website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with portfolio gallery, about page, and contact form. Business and Premium packages add online booking, client proofing, and e-commerce for prints." } },
      { "@type": "Question", "name": "Can clients book sessions directly through my website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include an online booking system where clients can view your availability, select a session type, and book directly through your website. You receive instant notifications and can manage bookings from a simple dashboard." } },
      { "@type": "Question", "name": "Do you build client proofing galleries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build password-protected client galleries where your clients can view, favourite, and select images from their session. This replaces clunky file-sharing links and gives your clients a branded, professional proofing experience." } },
      { "@type": "Question", "name": "Can you integrate my Instagram feed into the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We integrate your Instagram feed directly into your website so new posts appear automatically. This keeps your site looking fresh and encourages visitors to follow you on social media — all without any manual updates on your end." } },
      { "@type": "Question", "name": "How long does it take to build a photography website?", "acceptedAnswer": { "@type": "Answer", "text": "Most photography websites go live within 2–3 weeks. A 5-page portfolio site can be ready in 2 weeks, while larger projects with booking systems, client proofing, or e-commerce may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Photography Website Singapore", "item": "https://jraftcreative.com/photography-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Photography Website Singapore — Photographer Web Design | Jraft Creative"
  description="Professional website design for photographers and photography studios in Singapore. Portfolio galleries, online booking, client proofing, and package pages — from S$2,500."
  canonical="https://jraftcreative.com/photography-website-singapore/"
  ogTitle="Photography Website Singapore — Jraft Creative"
  ogDescription="Website design for photographers in Singapore. Portfolio galleries, booking systems, client proofing — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="photography website singapore, photographer website design, photography studio website, photography portfolio website singapore, photographer web design singapore, photography booking website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Photography Websites"
  heroTitle='Website Design for <span class="highlight">Photographers in Singapore</span>'
  heroSubtitle="Your images tell a story — your website should set the stage. We build fast, visually stunning websites for photographers and studios in Singapore — with portfolio galleries, online booking, client proofing, and package pages built in."
  heroImage="/images/service-photography.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my photography business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Photography Business Online"
  ctaDescription="Book a free consultation and tell us about your photography business. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20photography%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why photographers need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Photographers Are Losing Clients Without a Proper Online Portfolio</h2>
      </div>
      <div class="section-content reveal">
        <p>Couples planning their wedding, businesses sourcing brand photographers, and families booking studio sessions all start with a Google search or an Instagram scroll. If your work lives only on social media or a generic portfolio platform, you are competing on someone else's terms — buried among thousands of other accounts with no control over how your brand is presented. Potential clients move on to the photographer with a dedicated website that loads fast, displays beautifully, and makes booking effortless.</p>
        <p>Instagram and Facebook are discovery tools, not conversion tools. A social media profile cannot display curated galleries by category, present detailed pricing packages, accept session bookings, or deliver a branded client proofing experience. Without your own website, every inquiry requires manual back-and-forth on DMs or WhatsApp — slowing your response time and increasing the chance a lead goes cold before you can close the booking.</p>
        <p>Singapore's photography market is crowded. Wedding photographers, commercial studios, lifestyle shooters, and portrait specialists are all competing for the same pool of local clients. A well-built website turns your portfolio into a 24/7 sales tool — one that showcases your best work, communicates your packages clearly, and lets clients book or enquire without friction.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Photography website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Photographers &amp; Studios</h2>
      </div>
      <div class="section-content reveal">
        <p>Every photography website we deliver is purpose-built for the visual industry. We go beyond a generic template — your site will feature high-performance image galleries, online booking, client proofing portals, and package pages designed to convert visitors into paying clients.</p>
        <p>We understand that photographers in Singapore need more than just a portfolio site. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/" class="inline-link">SEO services</a> to rank for photography searches, <a href="/services/social-media/" class="inline-link">social media marketing</a> to grow your following, and <a href="/services/paid-ads/" class="inline-link">paid ads management</a> for targeted lead generation campaigns.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Portfolio Galleries</h3>
            <p>Showcase your best work in fast-loading, full-resolution galleries organised by category — weddings, portraits, commercial, events, or any genre you shoot. Lazy-loaded images, lightbox viewing, and responsive layouts ensure your portfolio looks stunning on every device without slowing down your site.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Booking System</h3>
            <p>Let clients view your availability, select a session type, and book directly through your website. Automated confirmation emails, calendar sync, and deposit collection reduce the back-and-forth and lock in bookings faster than manual DM conversations.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Client Proofing Portal</h3>
            <p>Deliver a branded proofing experience with password-protected galleries where clients can view, favourite, and select their final images. Replaces clunky file-sharing links and positions your studio as professional and organised — exactly what clients expect when paying premium rates.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Package Pages &amp; Instagram Integration</h3>
            <p>Dedicated pricing pages that present your packages clearly — session types, deliverables, pricing in SGD, and add-ons — so clients can self-qualify before reaching out. We also integrate your live Instagram feed directly into the site, keeping your portfolio fresh with zero manual updates.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for photography website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Photography Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We have built websites for photographers, studios, and creative professionals across Singapore. We know what clients look for when choosing a photographer online, and we build websites that let your images do the talking while making it easy for visitors to book.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Built for Visual Content</h3>
            <p>We optimise every image for web delivery — WebP format, responsive srcsets, lazy loading — so your galleries load fast without sacrificing quality. Your work deserves a site that presents it at its best, not one that compresses everything into muddy thumbnails.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most photography websites go live within 2 weeks of kickoff. Peak season waits for no one — we deliver quickly so you can start converting enquiries before your calendar fills up.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Over 70% of photography website traffic in Singapore comes from mobile. Every site we build is designed for phones first — fast load times, swipeable galleries, and tap-to-call buttons so potential clients can reach you instantly.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can manage your entire online presence — from Google rankings to Instagram growth — so you can focus on shooting.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Photography website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Photography Website Pricing</p>
        <h2>Website Packages for Photographers</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For photographers building their first dedicated website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Portfolio gallery (up to 3 categories)</li>
              <li>About &amp; services page</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For studios ready to streamline bookings and impress clients.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Categorised portfolio galleries</li>
              <li>Online booking system</li>
              <li>Client proofing portal</li>
              <li>Instagram feed integration</li>
              <li>Advanced SEO &amp; schema</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For established studios and commercial photographers.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>E-commerce for prints &amp; downloads</li>
              <li>Client login portal</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about photography website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Photography Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a photography website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional photography website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with portfolio gallery, about page, and contact form. Business and Premium packages add online booking, client proofing, and e-commerce for prints.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can clients book sessions directly through my website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include an online booking system where clients can view your availability, select a session type, and book directly through your website. You receive instant notifications and can manage bookings from a simple dashboard.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build client proofing galleries?</summary>
          <div class="faq-answer"><p>Yes. We build password-protected client galleries where your clients can view, favourite, and select images from their session. This replaces clunky file-sharing links and gives your clients a branded, professional proofing experience.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you integrate my Instagram feed into the website?</summary>
          <div class="faq-answer"><p>Yes. We integrate your Instagram feed directly into your website so new posts appear automatically. This keeps your site looking fresh and encourages visitors to follow you on social media — all without any manual updates on your end.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a photography website?</summary>
          <div class="faq-answer"><p>Most photography websites go live within 2-3 weeks. A 5-page portfolio site can be ready in 2 weeks, while larger projects with booking systems, client proofing, or e-commerce may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
