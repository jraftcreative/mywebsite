---
import ServiceLayout from '../layouts/ServiceLayout.astro';
import RelatedServices from '../components/RelatedServices.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Enrichment Centre Marketing Singapore",
    "description": "Full-service digital marketing for enrichment centres in Singapore — website design, SEO, Google Ads, social media, and content marketing. Stand out among 1,600+ centres. From $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Enrichment Centre Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly social content, and performance reporting for single-branch enrichment centres" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads, Facebook and Instagram Ads, parent-focused content strategy, class showcase campaigns, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video content, advanced ad funnels, seasonal campaigns, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How competitive is the enrichment centre market in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Singapore has over 1,600 registered enrichment centres — and that number grows every year. Parents have more choices than ever, and most begin their research online. Centres without a strong digital presence lose enrolments to competitors who rank on Google, run targeted ads, and maintain active social media profiles." } },
      { "@type": "Question", "name": "What marketing budget should an enrichment centre set aside?", "acceptedAnswer": { "@type": "Answer", "text": "Most enrichment centres in Singapore invest between $3,000 and $8,000 per month on marketing. The exact amount depends on your programme types, number of branches, and growth targets. Our Essential plan at $3,000/month covers the foundations — website, SEO, and social media — while the Growth plan at $5,500/month adds paid advertising for faster results." } },
      { "@type": "Question", "name": "How do you market niche enrichment programmes like robotics or art?", "acceptedAnswer": { "@type": "Answer", "text": "Niche programmes require targeted keyword strategies and audience segmentation. We identify the specific search terms parents use — such as 'robotics class for kids Singapore' or 'children's art enrichment Bukit Timah' — and build campaigns around those queries. Social media content showcases student projects and outcomes, while ads target parents with relevant interests." } },
      { "@type": "Question", "name": "Do you handle marketing for enrichment centres with multiple branches?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Multi-branch centres need location-specific SEO, separate Google Business Profiles for each outlet, localised ad campaigns, and consistent branding across all touchpoints. Our Growth and Enterprise plans include multi-branch campaign management with individual performance tracking per location." } },
      { "@type": "Question", "name": "Can marketing help during low-enrolment periods between school terms?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We run holiday camp promotions, early-bird campaigns for the next term, and retargeting ads to parents who visited your website but didn't register. Strategic content marketing during off-peak periods keeps your centre visible so parents think of you first when the next enrolment window opens." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Enrichment Centre Marketing Singapore", "item": "https://jraftcreative.com/enrichment-centre-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Enrolment Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Enrichment Centre Marketing — Jraft Creative"
  description="Full-service digital marketing for enrichment centres in Singapore — website, SEO, Google Ads, social media, and content. Stand out among 1,600+ centres."
  canonical="https://jraftcreative.com/enrichment-centre-marketing-singapore/"
  ogTitle="Enrichment Centre Marketing — Jraft Creative"
  ogDescription="Full-service marketing for enrichment centres in Singapore. Website, SEO, Google Ads, social media — one agency, multi-channel strategy, more enrolments."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="enrichment centre marketing singapore, enrichment centre advertising, enrichment centre digital marketing singapore, enrichment programme marketing, enrichment centre promotion, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Enrichment Centre Marketing Singapore"
  heroTitle='Full-Service Marketing for <span class="highlight">Enrichment Centres in Singapore</span>'
  heroSubtitle="Over 1,600 enrichment centres compete for the same families. Website, SEO, ads, and social media — managed by one agency to make your centre the one parents choose."
  heroImage="/images/service-enrichment.webp"
  heroImageAlt="Singapore enrichment centre classroom — enrichment centre marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my enrichment centre in Singapore."
  ctaLabel="Ready to Stand Out?"
  ctaTitle="Get Your Free Enrichment Centre Marketing Audit"
  ctaDescription="Book a free consultation and we'll assess your centre's digital presence, benchmark you against local competitors, and map out a strategy to grow enrolments. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20enrichment%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why enrichment centres need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>1,600+ <span class="highlight">Enrichment Centres</span>. One Question Every Parent Asks: <span class="highlight">Why Yours?</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's enrichment market is one of the most crowded education categories anywhere — over 1,600 registered centres spanning coding, art, speech &amp; drama, abacus, and sports, all competing for the same parent shortlist. The centres filling their classes aren't always the ones with the best programmes. They're the ones parents can actually find, trust, and book.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Crowded Category</h3>
            <p>Coding, art, speech &amp; drama, abacus, sports — every enrichment niche in Singapore is packed with options, often several within the same mall or HDB cluster. Parents don't lack choices; they're overwhelmed by them. Without clear positioning and visibility, even a strong programme blends into the noise.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Trial-Class Test</h3>
            <p>Parents don't enrol on a brochure. They validate — booking trial classes, reading Google reviews, and checking the outcomes other children achieved before committing a single term's fees. Centres without visible reviews, real class footage, and proof of progress lose the trial booking before the lesson even happens.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Local &amp; Seasonal Search</h3>
            <p>Parents search "coding class for kids Tampines" or "art enrichment near me" — local, programme-specific queries — and spike again around holiday-programme season. If you're not ranking for your catchment and visible when the next intake or June/December holiday window opens, those families find a competitor first.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for enrichment centres in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Enrichment Centre <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for enrichment centres — combining catchment-area SEO, AI search optimisation (GEO), trial-booking paid search, parent-focused social content, brand positioning, and conversion-focused web design.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/enrichment-centre-seo-singapore/">SEO for Enrichment Centres</a></h3>
            <p>Rank for programme-and-catchment searches like "coding class for kids Tampines" and "art enrichment near me." Google Business Profile optimisation per branch, local citations, and content that wins the long-tail queries where parents are ready to book a trial.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when parents ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best robotics enrichment for kids Singapore" or "speech and drama class near Bukit Timah." Same citation playbook we've used for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/enrichment-centre-google-ads-singapore/">Google Ads for Centres</a></h3>
            <p>High-intent campaigns timed to term intakes and the June and December holiday-programme peaks. GCLID tracking from click to signed enrolment, with seasonal camp promotions and retargeting for parents who visited but didn't register.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/enrichment-centre-social-media-singapore/">Social Media for Centres</a></h3>
            <p>Student project showcases, class activity Reels, progress stories, and teacher-led content — the Instagram and TikTok trust signals parents look for. Built for how Singapore parents actually scroll, shortlist, and validate a centre.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/enrichment-centre-branding-singapore/">Branding for Centres</a></h3>
            <p>The brand system that lifts you above the dozen other centres in your catchment. Logo, palette, parent-pack template, and class photo direction — positioned by programme and age group so parents pick you over the cheaper option.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/enrichment-centre-website-singapore/">Websites for Centres</a></h3>
            <p>The site that closes the trial booking. Programme pages, class schedules, transparent fees, trial-booking form, and parent testimonials — with fast mobile performance for parents shortlisting on their phone between pickups.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for enrichment centre marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Choose a Centre</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching enrichment centres run generic e-commerce playbooks on a parent audience that decides on trial classes, reviews, and word-of-mouth over weeks. We are the opposite — full-service, performance-led, and built around how families actually pick a programme. We work across enrichment, tuition, and education businesses, which means we know which programme and catchment keywords are winnable and which to skip. We run catchment-area campaigns across Tampines, Bukit Timah, Jurong, Novena, and other high-density Singapore neighbourhoods.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Programme &amp; Outcome Storytelling</h3>
            <p>Enrichment is a visual, proof-driven category. We treat your classes, student projects, and learning outcomes as the marketing asset they are — shot lists, format-by-format reformatting, and integration into a conversion-focused website that earns the trial booking.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, Facebook, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, parent-trust signals, and measurement back to trial bookings and enrolments.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enrolment-Focused Metrics</h3>
            <p>We measure trial bookings and signed enrolments, not impressions. GCLID offline tracking proves which ad click became which trial became which paying student. Every report ties spend to enrolment outcomes, not vanity metrics.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ENROLMENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Enrolment Funnel — how Singapore parents decide on an enrichment centre">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Enrolment Funnel</p>
        <h2>How <span class="highlight">Singapore Parents</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first Google search to a signed term, every parent choosing an enrichment centre moves through the same five stages. We build marketing campaigns that show up at each one — from discovery scrolling through to enrolment.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, IG, TikTok, parent groups, AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Trial classes, reviews, student outcomes</p>
        </li>
        <li class="funnel-stage">
          <h3>Compare</h3>
          <p>Shortlist 3–5 centres in the catchment</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>WhatsApp, call, or booking form</p>
        </li>
        <li class="funnel-stage">
          <h3>Enrol</h3>
          <p>Sign for the term &amp; renew</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for enrichment centres">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Monthly Marketing Plans for Enrichment Centres</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-branch centres building their digital foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For centres scaling enrolments with ads and multi-channel content.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Programme showcase content</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-branch enrichment centres.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-branch campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Holiday camp promotions</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Need individual services? See our <a href="/enrichment-centre-seo-singapore/" class="inline-link">enrichment centre SEO</a>, <a href="/enrichment-centre-google-ads-singapore/" class="inline-link">Google Ads</a>, or <a href="/enrichment-centre-website-singapore/" class="inline-link">website design</a> packages.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about enrichment centre marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Enrichment Centre Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How competitive is the enrichment centre market in Singapore?</summary>
          <div class="faq-answer"><p>Singapore has over 1,600 registered enrichment centres — and that number grows every year. Parents have more choices than ever, and most begin their research online. Centres without a strong digital presence lose enrolments to competitors who rank on Google, run targeted ads, and maintain active social media profiles.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What marketing budget should an enrichment centre set aside?</summary>
          <div class="faq-answer"><p>Most enrichment centres in Singapore invest between $3,000 and $8,000 per month on marketing. The exact amount depends on your programme types, number of branches, and growth targets. Our Essential plan at $3,000/month covers the foundations — website, SEO, and social media — while the Growth plan at $5,500/month adds paid advertising for faster results.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you market niche enrichment programmes like robotics or art?</summary>
          <div class="faq-answer"><p>Niche programmes require targeted keyword strategies and audience segmentation. We identify the specific search terms parents use — such as "robotics class for kids Singapore" or "children's art enrichment Bukit Timah" — and build campaigns around those queries. Social media content showcases student projects and outcomes, while ads target parents with relevant interests.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you handle marketing for enrichment centres with multiple branches?</summary>
          <div class="faq-answer"><p>Yes. Multi-branch centres need location-specific SEO, separate Google Business Profiles for each outlet, localised ad campaigns, and consistent branding across all touchpoints. Our Growth and Enterprise plans include multi-branch campaign management with individual performance tracking per location.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can marketing help during low-enrolment periods between school terms?</summary>
          <div class="faq-answer"><p>Absolutely. We run holiday camp promotions, early-bird campaigns for the next term, and retargeting ads to parents who visited your website but didn't register. Strategic content marketing during off-peak periods keeps your centre visible so parents think of you first when the next enrolment window opens.</p></div>
        </details>
      </div>
    </div>
  </section>


  <RelatedServices topic="general" />

</ServiceLayout>
