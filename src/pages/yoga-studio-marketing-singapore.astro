---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Yoga Studio Marketing Singapore",
    "description": "Full-service digital marketing for yoga studios in Singapore — website design, SEO, Google Ads, social media, and content marketing. Grow memberships from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Yoga Studio Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for yoga studios" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, class-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-location campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a yoga studio spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most yoga studios in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your studio's size, number of locations, and membership targets. Our Essential plan at $3,000/month is a strong starting point for single-location studios." } },
      { "@type": "Question", "name": "How long before marketing generates new members for my yoga studio?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads and social media ads can generate trial class bookings within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness over 2–3 months. Most yoga studio clients see a meaningful increase in trial class sign-ups within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "What marketing channels work best for yoga studios in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Instagram is the dominant platform for yoga studios — it is visual, community-driven, and aligns perfectly with the yoga aesthetic. Google Search captures high-intent traffic from people actively searching for yoga classes. Facebook Ads work well for targeting specific demographics and locations. A well-designed website ties everything together as your booking hub." } },
      { "@type": "Question", "name": "Do you work with all types of yoga studios?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We work with hot yoga studios, vinyasa studios, hatha and yin yoga spaces, aerial yoga studios, prenatal yoga providers, and multi-discipline wellness centres that include yoga. Each style has its own audience, search behaviour, and marketing approach. We tailor every strategy to your studio's specific offerings and target clientele." } },
      { "@type": "Question", "name": "Can you help fill off-peak classes and workshops?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Filling off-peak time slots is a common challenge for yoga studios. We address this through targeted promotions — Google Ads campaigns for lunchtime classes targeting CBD office workers, social media ads for weekday morning sessions targeting stay-at-home parents, and email campaigns for weekend workshops. Seasonal campaigns around New Year resolutions, post-holiday fitness, and corporate wellness trends also help fill capacity." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Yoga Studio Marketing Singapore", "item": "https://jraftcreative.com/yoga-studio-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Yoga Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Yoga Studio Marketing Singapore | Fill Your Mat Slots"
  description="Singapore yoga studio marketing that fills mat slots — bookings funnels, Meta + Google retargeting, GBP. From small studios to multi-location."
  canonical="https://jraftcreative.com/yoga-studio-marketing-singapore/"
  ogTitle="Yoga Studio Marketing Singapore | Fill Your Mat Slots"
  ogDescription="Singapore yoga studio marketing that fills mat slots — bookings funnels, Meta + Google retargeting, GBP. From small studios to multi-location."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="yoga studio marketing singapore, yoga marketing agency, yoga studio advertising singapore, yoga digital marketing, yoga studio promotion singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Marketing for Yoga Studios"
  heroTitle='Full-Service Marketing for <span class="highlight">Yoga Studios in Singapore</span>'
  heroSubtitle="Most students compare three to five studios online before booking a trial — and most yoga studios are invisible in that window. We build full-service marketing (SEO, GEO, Google Ads, IG/TikTok, branding, websites) designed for how Singapore yogis actually choose where to practise."
  heroImage="/images/service-yoga.webp"
  heroImageAlt="Yoga studio in Singapore — yoga studio marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my yoga studio in Singapore."
  ctaLabel="Ready to Fill Your Classes?"
  ctaTitle='Get Your Free <span class="highlight">Yoga Studio Marketing</span> Audit'
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your studio's membership goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20yoga%20studio%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why yoga studios need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Beautiful <span class="highlight">Classes</span> Aren't Enough to <span class="highlight">Fill the Mat</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has 300-plus yoga studios — plus ClassPass, freelance instructors, and online platforms all competing for the same students. A stunning space with skilled teachers means nothing if students can't find you in the window where they decide.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Instagram-Only Trap</h3>
            <p>Most studios market on Instagram alone. It builds community, but it misses the high-intent student Googling "hot yoga Tanjong Pagar" or "prenatal yoga Bukit Timah" — someone ready to book today, who goes to whoever ranks.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The ClassPass Discount Spiral</h3>
            <p>ClassPass fills off-peak mats with class-hoppers on discounted credits, takes a cut of every visit, and keeps the student relationship. Studios that lean on it never build the full-fee members and direct bookings that actually pay the rent.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Empty Off-Peak Slot</h3>
            <p>Weekday mornings and lunchtime classes run half-empty while evenings overflow. Without marketing that targets the right student for the right slot, that unsold capacity is pure lost revenue — every single day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for yoga studios in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Yoga Studio <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for yoga studios — combining catchment SEO, AI search optimisation (GEO), paid search, social content, branding, and conversion-focused web design that turns a scroll into a booked trial.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/yoga-studio-seo-singapore/">SEO for Yoga Studios</a></h3>
            <p>Rank for class-plus-neighbourhood searches like "hot yoga Orchard" or "prenatal yoga Toa Payoh." Google Business Profile and map-pack optimisation that wins trial bookings from the nearest MRT and HDB catchment.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when students ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best beginner yoga studio Singapore." The same AI-citation playbook we use for our own agency's discoverability.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/yoga-studio-google-ads-singapore/">Google Ads for Yoga Studios</a></h3>
            <p>High-intent paid search plus off-peak fillers — lunchtime classes targeted at CBD workers, weekday mornings at stay-at-home parents. GCLID tracking from click to booked trial.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/yoga-studio-social-media-singapore/">Social Media for Yoga Studios</a></h3>
            <p>Instagram and TikTok content that captures your studio's energy — class clips, instructor stories, student journeys, and community moments. The visual proof engine the yoga category lives on.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/yoga-studio-branding-singapore/">Branding for Yoga Studios</a></h3>
            <p>The brand system that lifts you out of price-and-ClassPass comparisons. Visual identity, class-menu and pricing design, and photo direction that makes students choose you on more than discount.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/yoga-studio-website-singapore/">Websites for Yoga Studios</a></h3>
            <p>The site that closes the trial. Mindbody, ClassPass or Momence booking integration, live class schedule, instructor profiles, transparent pricing, and fast mobile performance for students comparing options.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for yoga studio marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Yoga Students</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We work with yoga studios, fitness businesses, and wellness brands across Singapore — and we build around the membership model, the seasonal rushes, and the community-driven way students discover and choose a studio. Not generic templates, and not vanity-metric retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Wellness Industry Expertise</h3>
            <p>We know the Singapore yoga market — class formats, pricing expectations, the New Year and post-holiday surges, and how students discover and evaluate studios. Strategy built on category knowledge, not a recycled template.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, design, and measurement.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Pipeline, Not Vanity Metrics</h3>
            <p>We measure trial bookings, sign-ups, and cost per lead — not impressions. Month-to-month retainers with no lock-in, because you should stay for the results, not a 12-month contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== YOGA MEMBER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Yoga Member Funnel — how Singapore students decide on a studio">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Member Funnel</p>
        <h2>How <span class="highlight">Singapore Students</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From first scroll to long-term member, every yoga student in Singapore moves through the same five stages. We build marketing that shows up at each one — from discovery through to the referral that fills your mats.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Instagram, Google, ClassPass, friend referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Trial</h3>
          <p>Trial class or intro pack booking</p>
        </li>
        <li class="funnel-stage">
          <h3>Sign-up</h3>
          <p>Class pack or membership conversion</p>
        </li>
        <li class="funnel-stage">
          <h3>Retention</h3>
          <p>First 90 days, rebooking &amp; engagement</p>
        </li>
        <li class="funnel-stage">
          <h3>Referral</h3>
          <p>Bring-a-friend &amp; community word of mouth</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for yoga studios">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2><span class="highlight">Monthly Marketing Plans</span> for Yoga Studios</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location studios building a marketing foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For studios ready to scale memberships across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Class-focused content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-location yoga studios.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-location campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Workshop &amp; retreat promotions</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about yoga studio marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Yoga Studio Marketing</span> — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a yoga studio spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most yoga studios in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your studio's size, number of locations, and membership targets. Our Essential plan at $3,000/month is a strong starting point for single-location studios building a solid marketing foundation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new members for my yoga studio?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads and Instagram Ads can generate trial class bookings within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds community and brand awareness over 2–3 months. Most yoga studio clients see a meaningful increase in trial class sign-ups within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for yoga studios in Singapore?</summary>
          <div class="faq-answer"><p>Instagram is the dominant platform for yoga studios — it is visual, community-driven, and aligns with the yoga lifestyle aesthetic. Google Search captures high-intent traffic from people actively searching for yoga classes. Facebook Ads work well for targeting specific demographics and neighbourhoods. A well-designed website ties everything together as your central booking hub.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you work with all types of yoga studios?</summary>
          <div class="faq-answer"><p>Yes. We work with hot yoga studios, vinyasa studios, hatha and yin yoga spaces, aerial yoga studios, prenatal yoga providers, and multi-discipline wellness centres that include yoga. Each style has its own audience, search behaviour, and marketing approach. We tailor every strategy to your studio's specific offerings and target clientele.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you help fill off-peak classes and workshops?</summary>
          <div class="faq-answer"><p>Yes. Filling off-peak time slots is a common challenge for yoga studios. We address this through targeted promotions — Google Ads campaigns for lunchtime classes targeting CBD office workers, social media ads for weekday morning sessions targeting stay-at-home parents, and email campaigns for weekend workshops. Seasonal campaigns around New Year resolutions, post-holiday fitness, and corporate wellness trends also help fill capacity.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Yoga Studio Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/yoga-studio-website-singapore/" class="related-service-link">Yoga Studio Website Design</a>
          <a href="/yoga-studio-seo-singapore/" class="related-service-link">Yoga Studio SEO</a>
          <a href="/yoga-studio-google-ads-singapore/" class="related-service-link">Yoga Studio Google Ads</a>
          <a href="/yoga-studio-social-media-singapore/" class="related-service-link">Yoga Studio Social Media</a>
          <a href="/yoga-studio-branding-singapore/" class="related-service-link">Yoga Studio Branding</a>
      </div>
    </div>
  </section>
</ServiceLayout>
