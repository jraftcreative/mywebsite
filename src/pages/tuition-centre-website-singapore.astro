---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Tuition Centre Website Design Singapore",
    "description": "Custom website design for tuition centres and enrichment centres in Singapore — class schedules, online enrolment, parent testimonials, and local SEO. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Tuition Centre Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Tuition Centre Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with class information, contact form, Google Maps, mobile-responsive design, basic SEO, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Tuition Centre Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online enrolment forms, blog, advanced SEO, Google Business Profile optimisation, and teacher profiles" },
      { "@type": "Offer", "name": "Premium Tuition Centre Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages with custom design, multi-branch support, parent portal, learning management integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a tuition centre website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional tuition centre website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with class information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add online enrolment, teacher profiles, parent portals, and multi-branch support." } },
      { "@type": "Question", "name": "Can you integrate online enrolment forms into our website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business and Premium packages include online enrolment forms that let parents register their children directly through your website. Forms can capture student details, preferred class timings, subject selections, and even process deposit payments — reducing your admin workload and making enrolment seamless for parents." } },
      { "@type": "Question", "name": "Do you support multi-branch tuition centres?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package is designed for tuition centres with multiple branches across Singapore. Each branch gets its own page with location-specific class schedules, teacher profiles, Google Maps embed, and unique local SEO targeting so parents searching near each branch can find you." } },
      { "@type": "Question", "name": "How do you help tuition centres rank on Google?", "acceptedAnswer": { "@type": "Answer", "text": "We optimise your website for keywords parents actually search — like 'tuition near me', 'maths tuition Tampines', or 'primary school English tuition Singapore'. This includes on-page SEO, schema markup for educational organisations, Google Business Profile optimisation, and location-targeted content that helps each branch rank in local search results." } },
      { "@type": "Question", "name": "How long does it take to build a tuition centre website?", "acceptedAnswer": { "@type": "Answer", "text": "Most tuition centre websites go live within 2 weeks for our Starter package. Business-tier sites with online enrolment and blog typically take 3 weeks, while Premium builds with multi-branch support and parent portals take 4–5 weeks. We provide a clear timeline before starting so you can plan around your term schedule." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tuition Centre Website Singapore", "item": "https://jraftcreative.com/tuition-centre-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Tuition Centre Website Singapore — Education Web Design | Jraft Creative"
  description="Custom website design for tuition centres and enrichment centres in Singapore — class schedules, online enrolment, parent testimonials, and local SEO. From S$2,500."
  canonical="https://jraftcreative.com/tuition-centre-website-singapore/"
  ogTitle="Tuition Centre Website Singapore — Jraft Creative"
  ogDescription="Custom website design for tuition centres and enrichment centres in Singapore. Class schedules, online enrolment, parent testimonials, and local SEO from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="tuition centre website design singapore, tuition centre website singapore, enrichment centre website singapore, tuition near me, education website design singapore, tuition website design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Tuition Centre Websites"
  heroTitle='Website Design for <span class="highlight">Tuition Centres in Singapore</span>'
  heroSubtitle="Parents are searching for tuition centres online every day. We build websites that showcase your classes, highlight student results, and make enrolment effortless — so you can focus on teaching, not chasing leads."
  heroImage="/images/service-tuition.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my tuition centre in Singapore."
  ctaLabel="Ready to Enrol More Students?"
  ctaTitle="Get Your Tuition Centre Online"
  ctaDescription="Tell us about your tuition centre and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20tuition%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why tuition centres need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Searching — Can They Find You?</h2>
      </div>
      <div class="section-content reveal">
        <p>Every week, thousands of parents in Singapore search "tuition near me" on Google. They compare centres side by side, reading reviews, checking class schedules, and looking at teacher credentials. If your tuition centre doesn't have a professional website, you're invisible to these parents — and they're enrolling their children with your competitors instead.</p>
        <p>A Facebook page or a listing on a tuition directory is not enough. Parents want to see your full programme lineup, understand your teaching methodology, and read real testimonials from other parents. They want to know your class sizes, your tutors' qualifications, and whether you offer trial classes — all before they ever pick up the phone.</p>
        <p>Tuition centres that invest in a proper website with clear class information, visible results, and easy enrolment consistently outperform those relying on word of mouth alone. In a market as competitive as Singapore's education sector, your website is the first impression that determines whether a parent chooses you or scrolls past.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Tuition centre website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Tuition Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>Every tuition centre website we deliver is built to convert visitors into enrolled students. We go beyond a generic school template — your site will feature structured class schedules, compelling teacher profiles, and a frictionless enrolment flow that makes it easy for parents to sign up.</p>
        <p>A great website is just the starting point. Pair your tuition centre site with <a href="/services/seo-performance/">local SEO services</a> to rank for "tuition near me" searches in your area, <a href="/services/social-media/">social media marketing</a> to reach parents on Facebook and Instagram, and <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches during peak enrolment periods.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Class Schedules &amp; Timetables</h3>
            <p>Organised, easy-to-read timetables for every subject and level. Parents can quickly find available slots, check timings, and see which branch offers the classes they need — without calling to ask.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Enrolment Forms</h3>
            <p>Let parents register their children directly through your website. Capture student details, subject preferences, and preferred timings in one streamlined form — reducing phone tag and manual admin work.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Parent Testimonials &amp; Results</h3>
            <p>Showcase real testimonials from satisfied parents and highlight student results. Visible proof of your track record builds trust and gives hesitant parents the confidence to enrol their children.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Subject &amp; Programme Pages</h3>
            <p>Dedicated pages for each subject and level you offer — from primary school Maths to O-Level Science. Detailed programme descriptions help parents understand your curriculum and teaching approach.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for tuition centre website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Your Tuition Centre Website</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand the education industry in Singapore. Our websites are built to address the specific challenges tuition centres face — from competing for "tuition near me" searches to converting parent visits into student enrolments.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Education Industry Experience</h3>
            <p>We've built websites for tuition centres, enrichment centres, and education businesses across Singapore. We know what parents look for and how to structure content that converts enquiries into enrolments.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most tuition centre websites go live within 2 weeks. We work fast so you can start capturing online enrolments before the next term begins — no dragging projects out for months.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Parents browse on their phones — between drop-offs, during lunch breaks, and late at night. Every page we build is optimised for mobile first, so your site works perfectly on any device.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Beyond the website, we offer SEO, social media marketing, and Google Ads management — everything your tuition centre needs to grow its online presence and fill more class slots.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Tuition centre website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Tuition Centre Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new tuition centres getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Class information &amp; schedules</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established centres ready to grow.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online enrolment forms</li>
              <li>Blog &amp; resource section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Teacher profiles</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-branch and large centres.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; branding</li>
              <li>Multi-branch support</li>
              <li>Parent portal integration</li>
              <li>Learning management features</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about tuition centre website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Tuition Centre Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a tuition centre website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional tuition centre website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with class information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add online enrolment, teacher profiles, parent portals, and multi-branch support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you integrate online enrolment forms into our website?</summary>
          <div class="faq-answer"><p>Yes. Our Business and Premium packages include online enrolment forms that let parents register their children directly through your website. Forms can capture student details, preferred class timings, subject selections, and even process deposit payments — reducing your admin workload and making enrolment seamless for parents.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you support multi-branch tuition centres?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package is designed for tuition centres with multiple branches across Singapore. Each branch gets its own page with location-specific class schedules, teacher profiles, Google Maps embed, and unique local SEO targeting so parents searching near each branch can find you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you help tuition centres rank on Google?</summary>
          <div class="faq-answer"><p>We optimise your website for keywords parents actually search — like "tuition near me", "maths tuition Tampines", or "primary school English tuition Singapore". This includes on-page SEO, schema markup for educational organisations, Google Business Profile optimisation, and location-targeted content that helps each branch rank in local search results.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a tuition centre website?</summary>
          <div class="faq-answer"><p>Most tuition centre websites go live within 2 weeks for our Starter package. Business-tier sites with online enrolment and blog typically take 3 weeks, while Premium builds with multi-branch support and parent portals take 4-5 weeks. We provide a clear timeline before starting so you can plan around your term schedule.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
