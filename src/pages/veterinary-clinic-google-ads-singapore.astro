---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Veterinary Clinic Google Ads Singapore",
    "description": "Google Ads management for veterinary clinics in Singapore — emergency vet keywords, pet owner targeting, vaccination campaigns, and service-specific advertising. Plans from S$1,000/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Google Ads Management for Veterinary Clinics",
    "offers": [
      { "@type": "Offer", "name": "Starter Vet Ads", "price": "1000", "priceCurrency": "SGD", "description": "1 platform, up to $3K ad spend management, veterinary keyword research, campaign setup, monthly reporting" },
      { "@type": "Offer", "name": "Growth Vet Ads", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms, up to $10K ad spend management, A/B testing, landing page optimisation, bi-weekly reporting" },
      { "@type": "Offer", "name": "Scale Vet Ads", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, unlimited ad spend management, dedicated strategist, conversion rate optimisation, weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should vet clinics budget for Google Ads in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most veterinary clinics start with a monthly ad spend of $1,000–$4,000 on top of management fees. General keywords like 'vet clinic Singapore' cost $2–$5 per click, while emergency searches like '24 hour vet Singapore' cost $5–$12 due to urgency and competition. We allocate budgets across emergency and routine services based on your clinic's priorities." } },
      { "@type": "Question", "name": "Should vet clinics advertise emergency services on Google?", "acceptedAnswer": { "@type": "Answer", "text": "If you offer after-hours or emergency care, absolutely. Emergency vet searches like '24 hour vet' and 'emergency animal hospital near me' have the highest conversion rates because pet owners need immediate help and will call the first clinic they find. We set up call-priority campaigns with location extensions so distressed owners reach you within seconds." } },
      { "@type": "Question", "name": "How do you target pet owners in my clinic's area?", "acceptedAnswer": { "@type": "Answer", "text": "We use radius targeting around your clinic — typically 5–8 km — combined with neighbourhood keywords like 'vet clinic Bukit Timah' or 'animal hospital Tampines'. For routine services, pet owners almost always choose a conveniently located vet, so tight location targeting is essential for efficient ad spend." } },
      { "@type": "Question", "name": "Can Google Ads promote seasonal vaccination campaigns?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create timed campaigns for annual vaccination reminders, puppy and kitten first-visit packages, and seasonal health screening promotions. These campaigns target pet owners at key moments in their pet's care cycle — building long-term patient relationships rather than one-off visits." } },
      { "@type": "Question", "name": "How do you track whether Google Ads generate actual vet appointments?", "acceptedAnswer": { "@type": "Answer", "text": "We set up conversion tracking across phone calls, online booking forms, WhatsApp messages, and Google Maps direction requests. Each conversion is attributed to the specific keyword and ad that generated it — giving you clear cost-per-appointment data so you know exactly which campaigns deliver the best return." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Veterinary Clinic Google Ads Singapore", "item": "https://jraftcreative.com/veterinary-clinic-google-ads-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Veterinary Clinic Google Ads Singapore — PPC for Vet Clinics | Jraft Creative"
  description="Google Ads management for veterinary clinics in Singapore. Emergency vet keywords, pet owner targeting, vaccination campaigns, and service-specific advertising. Plans from S$1,000/month."
  canonical="https://jraftcreative.com/veterinary-clinic-google-ads-singapore/"
  ogTitle="Veterinary Clinic Google Ads Singapore — Jraft Creative"
  ogDescription="Google Ads for vet clinics in Singapore. Emergency vet keywords, pet owner targeting, and service-specific campaigns. Plans from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="veterinary clinic google ads singapore, vet clinic advertising singapore, google ads for vet clinics, ppc veterinary singapore, vet marketing singapore, animal clinic ads singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Veterinary Clinic Google Ads Singapore"
  heroTitle='Google Ads for Veterinary Clinics <span class="highlight">in Singapore</span>'
  heroSubtitle="When a pet owner searches for a vet — whether it's a 2 AM emergency or a routine vaccination — they choose the clinic that shows up first. We build Google Ads campaigns that put your veterinary practice at the top of search results, from emergency care to wellness packages and everything in between."
  heroImage="/images/service-veterinary.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need Google Ads for my veterinary clinic in Singapore."
  ctaLabel="Grow Your Practice"
  ctaTitle="Get a Free Veterinary Clinic Ad Strategy Session"
  ctaDescription="Book a free consultation and we'll analyse your local competition, identify the highest-value keywords for your services, and map out a Google Ads strategy tailored to your clinic's strengths and patient capacity. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20Google%20Ads%20for%20my%20veterinary%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Google Ads challenges for veterinary clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Pet Owners Are Searching — Is Your Clinic the One They Find?</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has over 824,000 pet-owning households, and pet care spending grows year on year. When a dog stops eating, a cat needs emergency care at midnight, or a new puppy owner looks for their first vet, they start with Google. The clinics that appear in paid ads and map listings capture those pet owners — the clinics that don't appear lose them permanently to a competitor just a few kilometres away.</p>
        <p>Without a structured Google Ads strategy, vet clinics rely on walk-in traffic and word-of-mouth while competitors run location-targeted campaigns that capture every pet owner searching nearby. The real cost isn't just one lost appointment — it's the lifetime value of that pet patient, the repeat vaccinations, the dental cleanings, and every friend that pet owner would have referred.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Google Ads services for veterinary clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Our Veterinary Clinic Ad Services</p>
        <h2>Google Ads Strategy Built for Vet Practices</h2>
      </div>
      <div class="section-content reveal">
        <p>We build Google Ads campaigns specifically for veterinary clinics in Singapore — from emergency after-hours ads with click-to-call extensions to routine vaccination campaigns that build long-term patient relationships. Whether you're a neighbourhood practice in Serangoon or a specialist animal hospital in the West, every campaign is designed to bring pet owners through your door.</p>
        <p>Our approach covers service-specific keyword targeting, radius-based location campaigns, emergency call extensions, and seasonal promotions for vaccination drives and wellness packages — ensuring your ad budget reaches pet owners who need your services now.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Emergency &amp; After-Hours Campaigns</h3>
            <p>Priority campaigns for urgent searches — "24 hour vet Singapore", "emergency vet near me", "animal hospital open now". Click-to-call extensions and location targeting connect distressed pet owners with your clinic in seconds, not minutes.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Neighbourhood Pet Owner Targeting</h3>
            <p>Radius campaigns centred on your clinic targeting pet owners within convenient travel distance. Neighbourhood keywords — "vet Toa Payoh", "animal clinic Pasir Ris" — capture pet owners who want a conveniently located practice they can visit regularly.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Service-Specific Ad Groups</h3>
            <p>Separate campaigns for vaccinations, dental cleaning, sterilisation, health screenings, dermatology, and specialist consultations. Each ad group targets the exact keywords pet owners use when searching for that specific service.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Vaccination &amp; Wellness Promotions</h3>
            <p>Seasonal campaigns promoting annual vaccination packages, puppy starter plans, senior pet wellness checks, and preventive care bundles. These campaigns capture pet owners at key moments and build long-term patient relationships.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for veterinary clinic Google Ads">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>We Understand What Drives Pet Owners to Book</h2>
      </div>
      <div class="section-content reveal">
        <p>We've managed ad campaigns for pet care businesses across Singapore and understand how pet owners search, compare, and choose veterinary clinics. Here's why vet practices choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Pet Care Market Knowledge</h3>
            <p>We understand Singapore's pet care landscape — which services have the highest search demand, seasonal patterns for vaccinations and health checks, and how pet owners evaluate clinics online before booking.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Transparent Ad Spend</h3>
            <p>Your ad budget goes directly to Google — we never mark up media spend. You maintain full access to your Google Ads account and see exactly what each new patient appointment costs your practice.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans that adapt to your clinic's needs. Scale up during vaccination seasons or when launching new services, adjust during quieter months — no penalties, no minimum commitments.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Lifetime Patient Value Focus</h3>
            <p>We optimise for long-term patient acquisition, not one-off visits. Campaigns are designed to attract pet owners who become loyal, recurring patients — tracking the full value from first appointment through ongoing wellness care.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Veterinary clinic Google Ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Vet Ads Pricing</p>
        <h2>Google Ads Plans for Veterinary Clinics</h2>
        <p>Monthly management fees. No lock-in contracts. Ad spend billed separately by Google.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For vet clinics launching their first Google Ads campaigns.</p>
            <ul class="pricing-features">
              <li>1 advertising platform</li>
              <li>Up to $3K ad spend management</li>
              <li>Veterinary keyword research</li>
              <li>Conversion tracking setup</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics scaling across emergency and routine service campaigns.</p>
            <ul class="pricing-features">
              <li>2 advertising platforms</li>
              <li>Up to $10K ad spend management</li>
              <li>A/B testing &amp; ad copy optimisation</li>
              <li>Landing page optimisation</li>
              <li>Competitor ad analysis</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For multi-branch vet practices maximising patient acquisition.</p>
            <ul class="pricing-features">
              <li>All advertising platforms</li>
              <li>Unlimited ad spend management</li>
              <li>Dedicated account strategist</li>
              <li>Conversion rate optimisation</li>
              <li>Custom audience &amp; remarketing</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/paid-ads/" class="inline-link">Paid Ads</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about Google Ads for veterinary clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Veterinary Clinic Google Ads — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should vet clinics budget for Google Ads in Singapore?</summary>
          <div class="faq-answer"><p>Most veterinary clinics start with a monthly ad spend of $1,000–$4,000 on top of management fees. General keywords like "vet clinic Singapore" cost $2–$5 per click, while emergency searches like "24 hour vet Singapore" cost $5–$12 due to urgency and competition. We allocate budgets across emergency and routine services based on your clinic's priorities.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Should vet clinics advertise emergency services on Google?</summary>
          <div class="faq-answer"><p>If you offer after-hours or emergency care, absolutely. Emergency vet searches like "24 hour vet" and "emergency animal hospital near me" have the highest conversion rates because pet owners need immediate help and will call the first clinic they find. We set up call-priority campaigns with location extensions so distressed owners reach you within seconds.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you target pet owners in my clinic's area?</summary>
          <div class="faq-answer"><p>We use radius targeting around your clinic — typically 5–8 km — combined with neighbourhood keywords like "vet clinic Bukit Timah" or "animal hospital Tampines". For routine services, pet owners almost always choose a conveniently located vet, so tight location targeting is essential for efficient ad spend.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can Google Ads promote seasonal vaccination campaigns?</summary>
          <div class="faq-answer"><p>Yes. We create timed campaigns for annual vaccination reminders, puppy and kitten first-visit packages, and seasonal health screening promotions. These campaigns target pet owners at key moments in their pet's care cycle — building long-term patient relationships rather than one-off visits.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you track whether Google Ads generate actual vet appointments?</summary>
          <div class="faq-answer"><p>We set up conversion tracking across phone calls, online booking forms, WhatsApp messages, and Google Maps direction requests. Each conversion is attributed to the specific keyword and ad that generated it — giving you clear cost-per-appointment data so you know exactly which campaigns deliver the best return.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
