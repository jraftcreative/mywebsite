---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Preschool Social Media Marketing Singapore",
    "description": "Social media marketing for preschools in Singapore. Daily activity showcases, milestone celebrations, parent community building, and open house promotion across Instagram and Facebook.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Preschool Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting for preschools" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting for preschools" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting for preschools" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost for preschools in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing for preschools in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans including more content, Reels production, and parent community management." } },
      { "@type": "Question", "name": "What social media content works best for preschools?", "acceptedAnswer": { "@type": "Answer", "text": "The best-performing preschool content includes daily learning activity snapshots, milestone celebrations, curriculum highlights, teacher introductions, facility tours, and parent testimonials. Short-form video content showing children engaged in play-based learning consistently generates the highest reach and engagement from parents." } },
      { "@type": "Question", "name": "How do you handle child privacy on social media for preschools?", "acceptedAnswer": { "@type": "Answer", "text": "We take child privacy seriously. All content follows your centre's consent policies. We work with photos and videos that have parental consent, and we can create content strategies that showcase your environment, curriculum, and facilities without featuring identifiable children — using activity close-ups, classroom setups, and branded graphics instead." } },
      { "@type": "Question", "name": "Can social media help promote our preschool open house events?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We create multi-phase open house campaigns with announcement posts, countdown stories, virtual tour Reels, and follow-up content. Campaigns are targeted to parents in your area and timed to align with ECDA registration periods and common decision-making windows for preschool placement." } },
      { "@type": "Question", "name": "Which platforms should preschools focus on in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Facebook and Instagram are the primary platforms for preschools in Singapore. Facebook is effective for reaching parents through local community groups and neighbourhood discussions, while Instagram excels at visual storytelling through photos, carousels, and Reels that showcase your learning environment and daily activities." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" },
      { "@type": "ListItem", "position": 3, "name": "Preschool Social Media Marketing", "item": "https://jraftcreative.com/preschool-social-media-marketing-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Preschool Social Media Marketing Singapore — Social Media Agency | Jraft Creative"
  description="Social media marketing for preschools in Singapore. Daily activities, milestone celebrations, parent community building, and open house promotion. Monthly plans from S$2,500."
  canonical="https://jraftcreative.com/preschool-social-media-marketing-singapore/"
  ogTitle="Preschool Social Media Marketing Singapore — Jraft Creative"
  ogDescription="Social media marketing for preschools in Singapore. Warm, trust-building content that connects with parents and drives enrolment. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="preschool social media marketing singapore, preschool marketing singapore, social media for preschools, preschool instagram marketing, preschool facebook marketing, kindergarten marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Preschool Social Media Marketing"
  heroTitle='Social Media Marketing for <span class="highlight">Preschools</span> in Singapore'
  heroSubtitle="Warm, authentic content that shows parents what daily life at your preschool looks like. We build trust through storytelling, celebrate milestones, and turn your social media into a reliable source of new enrolments."
  heroImage="/images/service-preschool.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need social media marketing for my preschool in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Preschool with Social Media"
  ctaDescription="Book a free consultation and tell us about your preschool. We'll get back to you within 24 hours with a tailored social media strategy."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20social%20media%20marketing%20for%20my%20preschool%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for preschools in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Choose Preschools Based on What They See Online</h2>
      </div>
      <div class="section-content reveal">
        <p>Choosing a preschool is one of the most emotionally charged decisions Singaporean parents make. They want to see what a typical day looks like, how teachers interact with children, and whether the environment feels safe, nurturing, and stimulating. Before booking a visit, they check your Instagram, scroll through your Facebook page, and read what other parents have said. If what they find is a handful of outdated posts or a page that hasn't been touched in months, they move on.</p>
        <p>Singapore's preschool landscape is intensely competitive. From anchor operators like PCF Sparkletots and My First Skool to boutique centres in Holland Village and Tiong Bahru, parents have dozens of options within a short drive. The preschools that win enrolments are the ones that show — not just tell — what makes them special. A dormant social media page doesn't just look unprofessional; it raises questions about whether your centre is still actively operating.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media services for preschools">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services for Preschools in Singapore</h2>
      </div>
      <div class="section-content reveal">
        <p>We create warm, engaging social media content that gives parents an authentic window into your preschool. From daily learning activities and milestone celebrations to open house promotions and parent testimonials, every post is crafted to build trust and drive enrolment enquiries.</p>
        <p>Our team handles content planning, photography direction, graphic design, Reels production, and community management — giving your preschool a professional, consistent social media presence that parents notice and remember when they're making their decision.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Daily Activity Reels</h3>
            <p>Short-form video content capturing the joy of daily learning — outdoor play, art sessions, story time, and group activities that let parents see and feel your preschool experience.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Parent Community Building</h3>
            <p>Active engagement with parents across comments, DMs, and group discussions. We build a supportive online community that strengthens loyalty and generates organic word-of-mouth referrals.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Milestone &amp; Event Graphics</h3>
            <p>Beautifully designed posts celebrating graduations, festive celebrations, Children's Day, and developmental milestones — content that parents love to share and that showcases your centre's culture.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Open House Campaigns</h3>
            <p>Multi-phase campaigns with virtual tours, parent testimonials, and countdown content timed around ECDA registration periods and peak decision-making windows for preschool placement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for preschool social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Social Media That Reflects the Heart of Your Preschool</h2>
      </div>
      <div class="section-content reveal">
        <p>We don't treat preschool marketing the same as every other industry. Our team creates content that captures the warmth and care parents are looking for, while maintaining the professionalism and consistency that builds genuine trust over time.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Privacy-Conscious Content</h3>
            <p>We follow your centre's consent policies and can create compelling content using activity close-ups, classroom setups, and branded graphics — without compromising child privacy.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Warm, Authentic Tone</h3>
            <p>No corporate jargon. Our content sounds like your centre — caring, approachable, and genuine. Parents connect with your story, not a sales pitch.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Full Approval Workflow</h3>
            <p>Every post, caption, and design goes through your review before publishing. You see the full content calendar in advance and nothing is shared without your explicit sign-off.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans. Stay because you're seeing more parent enquiries and enrolment growth, not because of a contract obligation.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Preschool social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Preschools of Every Size</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For preschools building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing preschools ready to increase enrolments.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For established preschools that want a complete social team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about preschool social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Preschool Social Media Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost for preschools in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing for preschools in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans including more content, Reels production, and parent community management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What social media content works best for preschools?</summary>
          <div class="faq-answer"><p>The best-performing preschool content includes daily learning activity snapshots, milestone celebrations, curriculum highlights, teacher introductions, facility tours, and parent testimonials. Short-form video content showing children engaged in play-based learning consistently generates the highest reach and engagement from parents.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you handle child privacy on social media for preschools?</summary>
          <div class="faq-answer"><p>We take child privacy seriously. All content follows your centre's consent policies. We work with photos and videos that have parental consent, and we can create content strategies that showcase your environment, curriculum, and facilities without featuring identifiable children — using activity close-ups, classroom setups, and branded graphics instead.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can social media help promote our preschool open house events?</summary>
          <div class="faq-answer"><p>Absolutely. We create multi-phase open house campaigns with announcement posts, countdown stories, virtual tour Reels, and follow-up content. Campaigns are targeted to parents in your area and timed to align with ECDA registration periods and common decision-making windows for preschool placement.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which platforms should preschools focus on in Singapore?</summary>
          <div class="faq-answer"><p>Facebook and Instagram are the primary platforms for preschools in Singapore. Facebook is effective for reaching parents through local community groups and neighbourhood discussions, while Instagram excels at visual storytelling through photos, carousels, and Reels that showcase your learning environment and daily activities.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Preschool Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/preschool-website-design-singapore/" class="related-service-link">Preschool Website Design</a>
          <a href="/preschool-seo-singapore/" class="related-service-link">Preschool SEO</a>
          <a href="/preschool-marketing-singapore/" class="related-service-link">Preschool Marketing</a>
          <a href="/preschool-advertising-singapore/" class="related-service-link">Preschool Advertising</a>
          <a href="/preschool-branding-singapore/" class="related-service-link">Preschool Branding</a>
      </div>
    </div>
  </section>
</ServiceLayout>
