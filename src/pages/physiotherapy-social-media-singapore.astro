---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Physiotherapy Social Media Marketing Singapore",
    "description": "Social media marketing for physiotherapy clinics in Singapore. Exercise tips, patient education content, therapist credibility building, and appointment-driving campaigns across Instagram and Facebook.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Physiotherapy Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting for physiotherapy clinics" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting for physiotherapy clinics" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting for physiotherapy clinics" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost for physiotherapy clinics in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing for physiotherapy clinics in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering expanded content, Reels production, and dedicated community management." } },
      { "@type": "Question", "name": "What social media content works best for physiotherapy clinics?", "acceptedAnswer": { "@type": "Answer", "text": "The most effective physiotherapy content includes exercise demonstration videos, injury prevention tips, therapist credentials and specialisations, patient recovery stories (with consent), and educational content about common conditions like lower back pain, sports injuries, and post-surgery rehabilitation. Reels showing simple home exercises consistently generate the highest engagement." } },
      { "@type": "Question", "name": "How do you handle patient privacy in physiotherapy social media content?", "acceptedAnswer": { "@type": "Answer", "text": "We strictly follow PDPA guidelines and your clinic's consent policies. Content focuses on exercise demonstrations, therapist expertise, facility showcases, and educational graphics — none of which require patient identification. When patients consent to testimonials or recovery stories, we follow a documented approval process." } },
      { "@type": "Question", "name": "Can social media help a physiotherapy clinic get more patients?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Social media builds credibility and trust that drives referrals and direct bookings. When someone searches for a physiotherapist or gets a recommendation, they typically check the clinic's social media before booking. A strong presence with educational content and therapist profiles significantly increases the conversion rate from awareness to appointment." } },
      { "@type": "Question", "name": "Which platforms are best for physiotherapy clinics in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Instagram and Facebook are the most effective platforms for physiotherapy clinics in Singapore. Instagram works well for exercise videos, therapist spotlights, and educational carousels. Facebook is strong for community engagement, patient reviews, and reaching the 35+ demographic. LinkedIn can be valuable for clinics targeting corporate wellness partnerships and sports teams." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" },
      { "@type": "ListItem", "position": 3, "name": "Physiotherapy Social Media", "item": "https://jraftcreative.com/physiotherapy-social-media-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Physiotherapy Social Media Singapore &mdash; Social Media Marketing | Jraft Creative"
  description="Social media marketing for physiotherapy clinics in Singapore. Exercise tips, patient education, therapist credibility content, and appointment-driving campaigns. Monthly plans from S$2,500."
  canonical="https://jraftcreative.com/physiotherapy-social-media-singapore/"
  ogTitle="Physiotherapy Social Media Singapore — Jraft Creative"
  ogDescription="Social media marketing for physiotherapy clinics in Singapore. Build therapist credibility, educate patients, and drive appointments. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="physiotherapy social media singapore, physio clinic marketing singapore, physiotherapy instagram marketing, physiotherapy digital marketing singapore, physio content creation, healthcare social media singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Physiotherapy Social Media Marketing"
  heroTitle='Social Media for <span class="highlight">Physiotherapy Clinics</span> in Singapore'
  heroSubtitle="Exercise tips, patient education content, and therapist credibility campaigns that position your clinic as a trusted authority. We help physiotherapy practices in Singapore build reputation, educate their community, and convert followers into booked appointments."
  heroImage="/images/service-physiotherapy.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need social media marketing for my physiotherapy clinic in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Physiotherapy Practice with Social Media"
  ctaDescription="Book a free consultation and tell us about your clinic. We'll get back to you within 24 hours with a tailored social media strategy."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20social%20media%20marketing%20for%20my%20physiotherapy%20clinic%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for physiotherapy clinics in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Patients Google Their Symptoms Before They Book Your Clinic</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has hundreds of physiotherapy clinics — from hospital-affiliated rehabilitation centres to independent sports physio practices in shophouse units. When someone twists an ankle playing futsal, develops chronic back pain from sitting at a desk in the CBD, or needs post-surgery rehabilitation, their first instinct is not to call a clinic. It is to search online. They look up their condition, read about treatment options, and then start evaluating which physiotherapist seems most credible and experienced for their specific problem.</p>
        <p>This is where social media becomes your most powerful trust-building tool. A clinic that publishes regular exercise demonstrations, explains common conditions in plain language, and shows the faces and qualifications of its therapists gives potential patients exactly what they need to feel confident booking. Clinics that post nothing — or post only clinic opening hours and holiday greetings — lose these patients to competitors who show up consistently with helpful, credible content. In healthcare, trust is earned before the first appointment, and social media is where that trust begins.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media services for physiotherapy clinics">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services for Physiotherapy Clinics</h2>
      </div>
      <div class="section-content reveal">
        <p>We create educational, trust-building social media content for physiotherapy clinics in Singapore. From exercise demonstration videos and condition explainers to therapist profiles and patient recovery stories, every post positions your clinic as the go-to authority for musculoskeletal care in your area.</p>
        <p>Our team handles content strategy, graphic design, video editing, copywriting, and community management — ensuring your therapists spend their time treating patients, not struggling with Canva or caption writing.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Exercise &amp; Rehab Reels</h3>
            <p>Short-form video content demonstrating stretches, strengthening exercises, and rehabilitation techniques — therapist-led videos that showcase your clinical expertise while providing genuine value to viewers dealing with pain or injury.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Patient Education &amp; Engagement</h3>
            <p>Educational carousels explaining common conditions, injury prevention tips, and rehabilitation timelines. Proactive community management answering health questions and directing enquiries to your booking system.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Therapist Credibility Content</h3>
            <p>Professional profiles highlighting your therapists' qualifications, specialisations, and clinical experience. Thought leadership posts that establish each practitioner as a trusted authority in their area — sports injuries, spinal conditions, paediatric physio, or post-operative care.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Appointment-Driving Campaigns</h3>
            <p>Targeted campaigns promoting specific services — sports physio during marathon season, office ergonomics assessments for CBD workers, post-surgical rehab packages — timed to capture demand when patients are actively searching.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for physiotherapy clinic social media">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>A Social Media Partner That Understands Healthcare</h2>
      </div>
      <div class="section-content reveal">
        <p>Healthcare marketing has different rules. Content must be accurate, compliant, and credible — while still being engaging enough to stop the scroll. We create social media strategies that build genuine clinical authority without sensationalism or unsubstantiated claims.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Healthcare Content Expertise</h3>
            <p>We create content that is clinically accurate and patient-friendly. Your therapists review all health-related claims before publishing, and we ensure content follows AHPC advertising guidelines and PDPA privacy requirements.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Privacy-First Approach</h3>
            <p>All content complies with the Personal Data Protection Act. We never use patient images or testimonials without documented consent, and we can create effective content entirely without featuring identifiable patients.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Full Review &amp; Approval</h3>
            <p>Every post, caption, and video is sent to your clinical team for review before publishing. Healthcare content demands accuracy — nothing goes live without your therapists' sign-off on clinical claims and exercise demonstrations.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans with no long-term commitments. Stay because your appointment bookings are increasing and your online reputation is growing — not because of a binding agreement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Physiotherapy clinic social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Physiotherapy Clinics of Every Size</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For clinics building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing clinics ready to build authority.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For established practices that want a complete social team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about physiotherapy social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Physiotherapy Social Media — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost for physiotherapy clinics in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing for physiotherapy clinics in Singapore ranges from $2,500 to $5,000+ per month. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, with Professional and Full-Service plans offering expanded content, Reels production, and dedicated community management.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What social media content works best for physiotherapy clinics?</summary>
          <div class="faq-answer"><p>The most effective physiotherapy content includes exercise demonstration videos, injury prevention tips, therapist credentials and specialisations, patient recovery stories (with consent), and educational content about common conditions like lower back pain, sports injuries, and post-surgery rehabilitation. Reels showing simple home exercises consistently generate the highest engagement.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you handle patient privacy in physiotherapy social media content?</summary>
          <div class="faq-answer"><p>We strictly follow PDPA guidelines and your clinic's consent policies. Content focuses on exercise demonstrations, therapist expertise, facility showcases, and educational graphics — none of which require patient identification. When patients consent to testimonials or recovery stories, we follow a documented approval process.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can social media help a physiotherapy clinic get more patients?</summary>
          <div class="faq-answer"><p>Yes. Social media builds credibility and trust that drives referrals and direct bookings. When someone searches for a physiotherapist or gets a recommendation, they typically check the clinic's social media before booking. A strong presence with educational content and therapist profiles significantly increases the conversion rate from awareness to appointment.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which platforms are best for physiotherapy clinics in Singapore?</summary>
          <div class="faq-answer"><p>Instagram and Facebook are the most effective platforms for physiotherapy clinics in Singapore. Instagram works well for exercise videos, therapist spotlights, and educational carousels. Facebook is strong for community engagement, patient reviews, and reaching the 35+ demographic. LinkedIn can be valuable for clinics targeting corporate wellness partnerships and sports teams.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
