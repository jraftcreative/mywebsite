---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Yoga Studio Website Design Singapore",
    "description": "Professional website design for yoga studios in Singapore — class timetables, instructor profiles with RYT certifications, online class booking, style pages for vinyasa, hatha, yin and hot yoga, membership packages, and workshop listings. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Yoga Studio Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Yoga Studio Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with class timetable, yoga style overview, instructor bios, contact form, Google Maps, mobile-responsive design, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Yoga Studio Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online class booking, detailed instructor profiles with RYT certifications, membership and package pricing, workshop and retreat pages, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Yoga Studio Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages with custom design, multi-location support, member portal, online payment integration, video-on-demand library, retreat booking, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a yoga studio website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional yoga studio website in Singapore costs between $2,500 and $10,000+ SGD depending on features. Our Starter package at $2,500 includes a 5-page site with class timetables, instructor bios, and contact form. Business and Premium packages add online booking, membership portals, workshop pages, and video-on-demand libraries." } },
      { "@type": "Question", "name": "Can you add online class booking to my yoga studio website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online class booking. We can integrate with platforms like Momoyoga, Mindbody, or Vagaro, or build a custom booking system where students select a class type — vinyasa, hatha, yin, hot yoga — choose a time slot, and receive automated confirmations." } },
      { "@type": "Question", "name": "Do you display yoga instructor certifications on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Each instructor gets a dedicated profile page featuring their Yoga Alliance certifications (RYT-200, RYT-500, E-RYT), specialisations, teaching philosophy, and a personal bio. This builds trust with prospective students who want to know their teacher's credentials before committing to a class or membership." } },
      { "@type": "Question", "name": "Can you build pages for yoga workshops and retreats?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We create dedicated pages for upcoming workshops, teacher training programmes, and retreat experiences — complete with schedules, pricing, instructor details, and online registration. Past events can be archived with photos and testimonials to showcase your studio's community." } },
      { "@type": "Question", "name": "How long does it take to build a yoga studio website?", "acceptedAnswer": { "@type": "Answer", "text": "Most yoga studio websites go live within 2 weeks for our Starter package. Business-tier sites with online booking, instructor profiles, and membership pricing typically take 3 weeks. Premium builds with member portals and video libraries take 4–5 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Yoga Studio Website Singapore", "item": "https://jraftcreative.com/yoga-studio-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Yoga Studio Website Design Singapore — Yoga Web Design | Jraft Creative"
  description="Professional website design for yoga studios in Singapore — class timetables, instructor profiles with RYT certifications, online class booking, style pages for vinyasa, hatha, yin and hot yoga, membership packages, and workshop listings. From S$2,500."
  canonical="https://jraftcreative.com/yoga-studio-website-singapore/"
  ogTitle="Yoga Studio Website Design Singapore — Jraft Creative"
  ogDescription="Website design for yoga studios in Singapore. Class timetables, instructor profiles, online booking, membership packages — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="yoga studio website design singapore, yoga studio website singapore, yoga class website singapore, vinyasa yoga website singapore, hot yoga website singapore, hatha yoga website singapore, yoga web design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Yoga Studio Websites"
  heroTitle='Website Design for <span class="highlight">Yoga Studios in Singapore</span>'
  heroSubtitle="Singapore's wellness scene is booming, and students are searching online before they ever unroll a mat. We build yoga studio websites that showcase your teaching styles, highlight instructor certifications, and turn first-time visitors into loyal members — so you can focus on what happens on the mat."
  heroImage="/images/service-yoga.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my yoga studio in Singapore."
  ctaLabel="Ready to Grow Your Yoga Studio?"
  ctaTitle="Get Your Yoga Studio Online"
  ctaDescription="Tell us about your studio and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20yoga%20studio%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why yoga studios need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Yoga Studio Is Invisible to Students Searching Online</h2>
      </div>
      <div class="section-content reveal">
        <p>Every day, hundreds of people in Singapore search "yoga studio near me", "hot yoga class Singapore", or "beginner yoga Orchard" on Google. They compare studios by scrolling through class schedules, reading instructor bios, checking certifications, and looking for an easy way to book a trial class. If your studio doesn't have a professional website with this information laid out clearly, those students are booking at a competitor instead.</p>
        <p>An Instagram feed or a ClassPass listing can introduce your studio, but they can't replace a dedicated website. Prospective students want to understand the difference between your vinyasa and yin classes, see that your instructors hold recognised Yoga Alliance certifications like RYT-200 or RYT-500, review membership packages and drop-in pricing, and register for an upcoming workshop — all from their phone, without sending a DM and waiting hours for a reply.</p>
        <p>Singapore's wellness industry has grown rapidly, with yoga studios in practically every neighbourhood from Tanjong Pagar to Katong to Bukit Timah. Whether you run a boutique shala in Tiong Bahru or a multi-location operation, your website is the single most important tool for attracting new students. Studios that present their offerings clearly online consistently fill more mats than those relying on word of mouth alone.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Yoga studio website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Yoga Studios</h2>
      </div>
      <div class="section-content reveal">
        <p>Every yoga studio website we create is designed specifically for the wellness industry. We go beyond generic templates — your site will feature dedicated pages for each yoga style, instructor profiles that highlight Yoga Alliance certifications, interactive class timetables, online booking, and membership package displays that make it easy for students to choose the right plan.</p>
        <p>A website is just the foundation. Pair your yoga studio site with <a href="/services/seo-performance/">local SEO services</a> to rank for "yoga studio near me" searches across Singapore, <a href="/services/social-media/">social media marketing</a> to grow your community on Instagram, and <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches during peak enrolment periods like January and post-summer.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Class Timetables &amp; Yoga Style Pages</h3>
            <p>Dedicated pages for every style you teach — vinyasa, hatha, yin, hot yoga, aerial, restorative, and prenatal. Each page explains the practice, intensity level, who it's suited for, and what to bring. An interactive weekly timetable lets students filter by class type, instructor, or location and see what's available today, tomorrow, or next week.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Class Booking &amp; Trial Registration</h3>
            <p>Let students book classes and register for trials directly through your website. The booking flow displays real-time availability, accepts drop-in or package credits, and sends automated confirmation emails — reducing WhatsApp back-and-forth so your front desk can focus on welcoming students into the studio.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Instructor Profiles &amp; Certifications</h3>
            <p>Each instructor gets a profile page featuring their Yoga Alliance credentials (RYT-200, RYT-500, E-RYT), specialisations, years of teaching experience, and personal philosophy. Professional photos and training lineage details give prospective students full confidence in your teaching team before they ever step on the mat.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Workshop, Retreat &amp; Membership Pages</h3>
            <p>Dedicated sections for upcoming workshops, teacher training programmes, and retreat experiences — with schedules, pricing, and online registration. Membership and package pricing pages present your drop-in rates, class packs, and monthly unlimited options side by side so students can compare and sign up without asking.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for yoga studio website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Your Yoga Studio Website</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand the yoga and wellness industry in Singapore. Our websites are designed to address the specific challenges yoga studios face — from standing out in a saturated market to converting casual browsers into committed, long-term practitioners.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Wellness Industry Experience</h3>
            <p>We've built websites for yoga studios, Pilates spaces, meditation centres, and fitness studios across Singapore. We know what students look for — teaching credentials, class variety, studio atmosphere, and transparent pricing — and we structure every page to build trust and drive bookings.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most yoga studio websites go live within 2 weeks. We move quickly so you can start capturing online bookings ahead of your next workshop series, teacher training intake, or seasonal promotion.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Calm, On-Brand Design</h3>
            <p>Your website should reflect the experience of your studio. We design with intentional white space, natural colour palettes, and clean typography that feels authentic to the yoga community — not a loud, generic business template.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Beyond the website, we offer SEO, social media marketing, and Google Ads management — everything your yoga studio needs to rank locally, grow your following, and keep your classes full throughout the year.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Yoga studio website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Yoga Studio Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new studios getting their practice online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Class timetable &amp; yoga style overview</li>
              <li>Instructor bio pages</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established studios ready to grow.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online class booking system</li>
              <li>Instructor profiles with certifications</li>
              <li>Membership &amp; package pricing</li>
              <li>Workshop &amp; retreat pages</li>
              <li>Advanced SEO &amp; Google Business Profile</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-location studios and yoga academies.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; branding</li>
              <li>Member portal &amp; video library</li>
              <li>Online payment integration</li>
              <li>Multi-location support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about yoga studio website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Yoga Studio Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a yoga studio website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional yoga studio website in Singapore costs between $2,500 and $10,000+ SGD depending on features. Our Starter package at $2,500 includes a 5-page site with class timetables, instructor bios, and contact form. Business and Premium packages add online booking, membership portals, workshop pages, and video-on-demand libraries.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add online class booking to my yoga studio website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online class booking. We can integrate with platforms like Momoyoga, Mindbody, or Vagaro, or build a custom booking system where students select a class type — vinyasa, hatha, yin, hot yoga — choose a time slot, and receive automated confirmations. This cuts down on WhatsApp messages and lets your front desk focus on the in-studio experience.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you display yoga instructor certifications on the website?</summary>
          <div class="faq-answer"><p>Absolutely. Each instructor gets a dedicated profile page featuring their Yoga Alliance certifications (RYT-200, RYT-500, E-RYT), specialisations such as prenatal yoga or yin therapy, teaching philosophy, and a personal bio. This builds trust with prospective students who want to verify their teacher's credentials before committing to a class or membership.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you build pages for yoga workshops and retreats?</summary>
          <div class="faq-answer"><p>Yes. We create dedicated pages for upcoming workshops, teacher training programmes, and retreat experiences — complete with schedules, pricing, instructor details, and online registration. Past events can be archived with photos and testimonials to showcase your studio's community and track record.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a yoga studio website?</summary>
          <div class="faq-answer"><p>Most yoga studio websites go live within 2 weeks for our Starter package. Business-tier sites with online booking, instructor profiles, and membership pricing typically take 3 weeks. Premium builds with member portals and video libraries take 4-5 weeks. We provide a clear timeline before starting so you can plan around your class schedule.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
