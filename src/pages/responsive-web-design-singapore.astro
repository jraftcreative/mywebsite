---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Responsive Web Design Singapore",
    "description": "Mobile-first responsive web design in Singapore. Cross-device websites built for touch-friendly UX, Core Web Vitals, and Google mobile-first indexing. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Responsive Web Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Responsive Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page mobile-first responsive website with touch-friendly navigation, Core Web Vitals optimisation, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Responsive Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page responsive website with custom breakpoints, cross-device testing, CMS integration, and advanced SEO" },
      { "@type": "Offer", "name": "Premium Responsive Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom responsive website with advanced interactions, third-party integrations, ecommerce capability, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is responsive web design and why does it matter in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Responsive web design means your website automatically adapts its layout, images, and navigation to fit any screen size — from smartphones and tablets to desktop monitors. In Singapore, over 70% of web traffic comes from mobile devices. A responsive site ensures every visitor gets a fast, usable experience regardless of how they access your site, and it's required for strong Google rankings under mobile-first indexing." } },
      { "@type": "Question", "name": "How much does a responsive website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Responsive web design in Singapore typically costs between $2,500 and $10,000+ depending on the number of pages and features. Our Starter package begins at $2,500 SGD for a 5-page mobile-first website, while Business and Premium packages include more pages, custom breakpoints, CMS integration, and advanced performance optimisation." } },
      { "@type": "Question", "name": "Will a responsive design improve my Google rankings?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Google uses mobile-first indexing, which means it primarily evaluates the mobile version of your website when determining search rankings. A responsive website that loads fast, passes Core Web Vitals, and delivers a strong mobile experience will rank higher than a desktop-only or poorly optimised site. Every responsive website we build is designed to meet Google's performance and usability standards." } },
      { "@type": "Question", "name": "How do you test responsiveness across different devices?", "acceptedAnswer": { "@type": "Answer", "text": "We test every website across a comprehensive device matrix that includes iPhones, Android phones, iPads, Android tablets, laptops, and desktop monitors. We verify layouts at every common breakpoint — 320px, 375px, 414px, 768px, 1024px, 1440px, and above. We also run automated testing for touch target sizing, font readability, and Core Web Vitals scores on both mobile and desktop." } },
      { "@type": "Question", "name": "Can you make my existing website responsive?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer responsive retrofits for existing websites that aren't mobile-friendly. Depending on your current site's codebase, we either restructure your CSS and layout system to be fluid and adaptive, or recommend a rebuild if the existing code would limit performance. We'll assess your site and recommend the most cost-effective approach during a free consultation." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Responsive Web Design Singapore", "item": "https://jraftcreative.com/responsive-web-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Responsive Web Design Singapore — Mobile-First Websites | Jraft Creative"
  description="Responsive web design in Singapore — mobile-first websites built for cross-device compatibility, touch-friendly UX, and Core Web Vitals. From S$2,500."
  canonical="https://jraftcreative.com/responsive-web-design-singapore/"
  ogTitle="Responsive Web Design Singapore — Jraft Creative"
  ogDescription="Mobile-first responsive websites for Singapore businesses. Cross-device compatibility, touch-friendly UX, and Core Web Vitals optimisation. From S$2,500."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="responsive web design singapore, mobile-first website singapore, responsive website design, mobile-friendly website singapore, cross-device website, responsive design agency, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Responsive Web Design"
  heroTitle='Responsive Web Design <span class="highlight">in Singapore</span>'
  heroSubtitle="Mobile-first websites that adapt seamlessly across every device. Built for touch-friendly UX, cross-device compatibility, and the Core Web Vitals scores Google demands for top rankings."
  heroImage="/images/service-responsive.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a responsive website for my business in Singapore."
  ctaLabel="Ready to Go Mobile-First?"
  ctaTitle="Get a Website That Works on Every Device"
  ctaDescription="Book a free consultation and we will audit your current site's mobile experience. We will get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20responsive%20website%20for%20my%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why responsive design matters for Singapore businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Website Is Failing on Mobile</h2>
      </div>
      <div class="section-content reveal">
        <p>Over 70% of web traffic in Singapore comes from mobile devices, yet many business websites still look broken on a phone screen. Text that's too small to read, buttons that are impossible to tap, images that overflow off-screen, and horizontal scrolling that frustrates every visitor. These are not minor annoyances — they are costing you customers every day.</p>
        <p>Google now uses mobile-first indexing, which means it evaluates the mobile version of your site first when deciding where to rank you in search results. If your website doesn't deliver a fast, usable experience on a smartphone, your rankings will suffer — regardless of how good your desktop version looks. A site that isn't responsive is a site that's invisible.</p>
        <p>Poor mobile UX drives bounce rates above 60% and kills conversions. Visitors who struggle with your navigation, wait too long for pages to load, or can't complete a form on their phone will leave and go to a competitor who made the effort to get responsive design right.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Responsive web design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>Responsive Design Services for Singapore Businesses</h2>
      </div>
      <div class="section-content reveal">
        <p>We build websites mobile-first — starting with the smallest screen and scaling up. Every layout, image, and interaction is designed to work naturally on the device your visitor is using, whether that's an iPhone on the MRT or a desktop monitor in the office.</p>
        <p>Responsive design is just the foundation. Pair your new site with our <a href="/services/seo-performance/">SEO services</a> to rank for the keywords your customers search on mobile, <a href="/services/paid-ads/">paid advertising</a> to drive targeted traffic, or <a href="/services/social-media/">social media marketing</a> to capture mobile-first audiences on Instagram and TikTok.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Mobile-First Design</h3>
            <p>We design for the smallest screen first, then progressively enhance for tablets and desktops. This ensures your mobile visitors — the majority in Singapore — always get the best possible experience.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Cross-Device Testing</h3>
            <p>Rigorous testing across iPhones, Android phones, iPads, laptops, and desktop monitors. We verify every breakpoint — from 320px to ultrawide — so your site looks and works perfectly on any screen.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Touch-Friendly Navigation</h3>
            <p>Buttons, menus, and interactive elements sized and spaced for finger taps — not mouse clicks. Swipe gestures, collapsible menus, and thumb-zone optimisation for a natural mobile experience.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>Core Web Vitals Optimisation</h3>
            <p>Performance tuning for LCP, CLS, and INP — the metrics Google uses to evaluate user experience. Fast load times, stable layouts, and instant interactivity on both mobile and desktop.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for responsive web design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>What Sets Our Responsive Design Apart</h2>
      </div>
      <div class="section-content reveal">
        <p>We don't bolt responsiveness onto a desktop design as an afterthought. Every website starts mobile-first and is engineered for real-world device usage in Singapore. Here's what sets our approach apart:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>True Mobile-First Process</h3>
            <p>We design for the phone screen first, not as a second pass. Content hierarchy, navigation patterns, and interactions are built for touch before they're scaled up for desktop.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Real-Device Testing</h3>
            <p>We test on actual devices — not just browser simulators. Your site is verified on the phones and tablets your Singapore customers are actually using, under real network conditions.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Performance Obsessed</h3>
            <p>Responsive images, lazy loading, minimal CSS, and zero render-blocking resources. We build for speed on 4G connections, not just fibre broadband — because that's how your mobile visitors browse.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Google-Ready from Day One</h3>
            <p>Every site passes mobile-first indexing checks, meets Core Web Vitals thresholds, and includes structured data — giving you the best possible foundation for Google search rankings.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Responsive web design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Responsive Design Pricing</p>
        <h2>Website Packages for Every Budget</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new businesses and personal brands.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Mobile-first responsive design</li>
              <li>Touch-friendly navigation</li>
              <li>Core Web Vitals optimisation</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing businesses that need more.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Custom breakpoints &amp; layouts</li>
              <li>Cross-device testing suite</li>
              <li>CMS / blog integration</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Analytics setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For businesses with advanced requirements.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Fully custom responsive design</li>
              <li>Ecommerce / booking systems</li>
              <li>Third-party integrations</li>
              <li>Priority support</li>
              <li>Performance monitoring</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about responsive web design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Responsive Web Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>What is responsive web design and why does it matter in Singapore?</summary>
          <div class="faq-answer"><p>Responsive web design means your website automatically adapts its layout, images, and navigation to fit any screen size — from smartphones and tablets to desktop monitors. In Singapore, over 70% of web traffic comes from mobile devices. A responsive site ensures every visitor gets a fast, usable experience regardless of how they access your site, and it is required for strong Google rankings under mobile-first indexing.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How much does a responsive website cost in Singapore?</summary>
          <div class="faq-answer"><p>Responsive web design in Singapore typically costs between $2,500 and $10,000+ depending on the number of pages and features. Our Starter package begins at $2,500 SGD for a 5-page mobile-first website, while Business and Premium packages include more pages, custom breakpoints, CMS integration, and advanced performance optimisation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Will a responsive design improve my Google rankings?</summary>
          <div class="faq-answer"><p>Yes. Google uses mobile-first indexing, which means it primarily evaluates the mobile version of your website when determining search rankings. A responsive website that loads fast, passes Core Web Vitals, and delivers a strong mobile experience will rank higher than a desktop-only or poorly optimised site. Every responsive website we build is designed to meet Google's performance and usability standards.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How do you test responsiveness across different devices?</summary>
          <div class="faq-answer"><p>We test every website across a comprehensive device matrix that includes iPhones, Android phones, iPads, Android tablets, laptops, and desktop monitors. We verify layouts at every common breakpoint — 320px, 375px, 414px, 768px, 1024px, 1440px, and above. We also run automated testing for touch target sizing, font readability, and Core Web Vitals scores on both mobile and desktop.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you make my existing website responsive?</summary>
          <div class="faq-answer"><p>Yes. We offer responsive retrofits for existing websites that are not mobile-friendly. Depending on your current site's codebase, we either restructure your CSS and layout system to be fluid and adaptive, or recommend a rebuild if the existing code would limit performance. We will assess your site and recommend the most cost-effective approach during a free consultation.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
