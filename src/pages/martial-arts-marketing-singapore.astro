---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Martial Arts Marketing Singapore",
    "description": "Full-service digital marketing for martial arts schools in Singapore — website design, SEO, Google Ads, social media, and content marketing. Grow student enrolments from $3,000 SGD/month.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Martial Arts School Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Marketing", "price": "3000", "priceCurrency": "SGD", "description": "Website, SEO foundations, Google Business Profile optimisation, monthly content, and performance reporting for martial arts schools" },
      { "@type": "Offer", "name": "Growth Marketing", "price": "5500", "priceCurrency": "SGD", "description": "Everything in Essential plus Google Ads management, social media marketing, class-focused content strategy, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Enterprise Marketing", "price": "10000", "priceCurrency": "SGD", "description": "Full-service marketing with dedicated strategist, multi-branch campaigns, video content, advanced ad funnels, and weekly strategy calls" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should a martial arts school spend on marketing in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Most martial arts schools in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your school's size, number of disciplines offered, and student targets. Our Essential plan at $3,000/month is ideal for single-location schools building a marketing foundation." } },
      { "@type": "Question", "name": "How long before marketing generates new students for my martial arts school?", "acceptedAnswer": { "@type": "Answer", "text": "Paid channels like Google Ads can generate trial class enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community engagement over 2–3 months. Most martial arts school clients see a meaningful increase in trial sign-ups within the first 60 days of a full-service campaign." } },
      { "@type": "Question", "name": "What marketing channels work best for martial arts schools in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Google Search is the highest-intent channel — parents searching for 'kids martial arts Singapore' or adults searching for 'muay thai classes near me' are ready to sign up. Instagram and TikTok work well for showcasing training, competitions, and student progress. Facebook Ads are effective for targeting parents in specific neighbourhoods. A professional website ties everything together as your conversion hub." } },
      { "@type": "Question", "name": "Do you work with all types of martial arts disciplines?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We work with schools teaching Brazilian Jiu-Jitsu, Muay Thai, taekwondo, karate, boxing, kickboxing, MMA, Krav Maga, Wing Chun, and multi-discipline academies. Each discipline attracts a different demographic and has unique search behaviour. We tailor every marketing strategy to your specific discipline, target audience, and competitive positioning in Singapore." } },
      { "@type": "Question", "name": "Can you help market both kids and adult programmes?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Kids and adult programmes require fundamentally different marketing approaches. For kids programmes, we target parents through Google Ads, parent-focused content, and Facebook campaigns highlighting discipline, confidence, and physical development. For adult programmes, we target individuals through Instagram, Google Search, and content around fitness, self-defence, and competition. We run separate campaigns for each audience to maximise results." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Martial Arts Marketing Singapore", "item": "https://jraftcreative.com/martial-arts-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Martial Arts Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Martial Arts Marketing Singapore | Trial-to-Member Funnel"
  description="Martial arts studio marketing in Singapore — trial-to-member funnels, parent-led campaigns for kids' classes, adult fitness conversion."
  canonical="https://jraftcreative.com/martial-arts-marketing-singapore/"
  ogTitle="Martial Arts Marketing Singapore | Trial-to-Member Funnel"
  ogDescription="Martial arts studio marketing in Singapore — trial-to-member funnels, parent-led campaigns for kids' classes, adult fitness conversion."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="martial arts marketing singapore, martial arts school advertising, BJJ marketing singapore, muay thai marketing, martial arts digital marketing, taekwondo marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Marketing for Martial Arts Schools"
  heroTitle='Full-Service Marketing for <span class="highlight">Martial Arts Schools in Singapore</span>'
  heroSubtitle="BJJ, Muay Thai, taekwondo, boxing and MMA schools are all competing for the same students — and parents and adults compare three to five before booking a trial. We build full-service marketing (SEO, GEO, Google Ads, IG/TikTok, branding, websites) that fills your mats."
  heroImage="/images/service-martialarts.webp"
  heroImageAlt="Martial arts school training in Singapore — martial arts marketing"
  heroButtons={[
    { text: "Get a Free Marketing Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my martial arts school in Singapore."
  ctaLabel="Ready to Fill Your Mats?"
  ctaTitle='Get Your Free <span class="highlight">Martial Arts Marketing</span> Audit'
  ctaDescription="Book a free consultation and we will review your current marketing, identify gaps, and recommend a strategy tailored to your school's enrolment goals. No obligations."
  ctaButtons={[
    { text: "Book a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20martial%20arts%20school%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why martial arts schools need full-service marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Great <span class="highlight">Training</span> Alone Won't <span class="highlight">Fill Your Mats</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore's martial arts scene is crowded — BJJ gyms, Muay Thai camps, taekwondo dojangs, boxing studios and multi-discipline academies all fighting for the same students. Reputation matters, but it doesn't scale to the parents and adults deciding online.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Word-of-Mouth Ceiling</h3>
            <p>Community reputation and competition results matter — but they don't scale. A parent Googling "kids martial arts Tampines" won't find you through word of mouth; they'll find whichever school ranks on page one and looks credible.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Dual-Audience Split</h3>
            <p>Kids programmes are sold to parents; adult programmes are sold to the trainee directly. They search differently, decide differently, and respond to different messaging. One generic campaign reaches neither audience properly.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The "Classes Near Me" Booking</h3>
            <p>An adult searching "muay thai near me" books a trial at the first school with a professional website, clear pricing, and easy booking. If that's not you, the discipline and the coaching never even get a look.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for martial arts schools in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Martial Arts School <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for martial arts schools — combining catchment SEO, AI search optimisation (GEO), paid search, social content, branding, and conversion-focused web design, with separate plays for your kids and adult programmes.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/martial-arts-seo-singapore/">SEO for Martial Arts Schools</a></h3>
            <p>Rank for discipline-plus-neighbourhood searches like "BJJ Bugis" or "kids taekwondo Bukit Timah." Google Business Profile and map-pack optimisation that wins trial bookings from your catchment.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/geo-agency-singapore/">GEO (AI Search Optimisation)</a></h3>
            <p>Get cited when students ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best Muay Thai gym Singapore" or "kids martial arts near me." The same AI-citation playbook we use for our own agency.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google &amp; Meta Ads</a></h3>
            <p>Separate high-intent campaigns for kids programmes (targeting parents) and adult programmes (targeting trainees), scaled during school holidays and New Year. GCLID tracking from click to booked trial.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Martial Arts</a></h3>
            <p>Instagram, TikTok and Facebook content that captures your training culture — sparring highlights, technique breakdowns, belt promotions, and student progress. Martial arts content performs exceptionally well on social.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Martial Arts</a></h3>
            <p>A brand system that signals credibility to parents and intensity to adults — logo, palette, kit and photo direction that positions your school above the cheaper option down the road.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/martial-arts-website-singapore/">Websites for Martial Arts Schools</a></h3>
            <p>The site that closes the trial. Dedicated pages per discipline and programme (kids BJJ, adult Muay Thai), instructor credentials, transparent pricing, class schedule, and a single-field trial booking form.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for martial arts marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Martial Arts Students</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We work with martial arts schools, fitness businesses, and wellness brands across Singapore — and we build around the dual kids-and-adults audience, the seasonal enrolment patterns, and the community-driven way students discover and choose a school. Not generic templates, and not vanity-metric retainers.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Combat Sports Expertise</h3>
            <p>We know the Singapore martial arts market — discipline-specific audiences, the kids-vs-adult split, competing with large franchises, and how students discover and evaluate schools. Strategy built on category knowledge, not guesswork.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, IG, TikTok, branding, websites — under one roof. No coordinating between three vendors. Every channel delivers consistent positioning, design, and measurement.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Pipeline, Not Vanity Metrics</h3>
            <p>We measure trial bookings, enrolments, and cost per lead by discipline — not impressions. Month-to-month retainers with no lock-in, because you should stay for the results, not a 12-month contract.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== MARTIAL ARTS MEMBER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Martial Arts Member Funnel — how Singapore students decide on a school">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Member Funnel</p>
        <h2>How <span class="highlight">Singapore Students</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From first search to long-term member, every martial arts student in Singapore moves through the same five stages. We build marketing that shows up at each one — from discovery through to the referral that fills your mats.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Discover</h3>
          <p>Google, Instagram, TikTok, parent referral</p>
        </li>
        <li class="funnel-stage">
          <h3>Trial</h3>
          <p>Trial class or intro week booking</p>
        </li>
        <li class="funnel-stage">
          <h3>Sign-up</h3>
          <p>Programme enrolment &amp; membership</p>
        </li>
        <li class="funnel-stage">
          <h3>Retention</h3>
          <p>Belt progression, engagement, attendance</p>
        </li>
        <li class="funnel-stage">
          <h3>Referral</h3>
          <p>Family &amp; training-partner word of mouth</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Marketing pricing for martial arts schools">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2><span class="highlight">Monthly Marketing Plans</span> for Martial Arts Schools</h2>
        <p>Month-to-month retainer. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For single-location schools building a marketing foundation.</p>
            <ul class="pricing-features">
              <li>Website design &amp; maintenance</li>
              <li>SEO foundations (10 pages)</li>
              <li>Google Business Profile setup</li>
              <li>Monthly performance report</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$5,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For schools ready to scale enrolments across channels.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Google Ads management</li>
              <li>Facebook &amp; Instagram Ads</li>
              <li>Discipline-specific content strategy</li>
              <li>Bi-weekly reporting &amp; calls</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$10,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service marketing for multi-branch martial arts academies.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Multi-branch campaign management</li>
              <li>Video content production</li>
              <li>Advanced ad funnels &amp; retargeting</li>
              <li>Competition &amp; event promotions</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about martial arts marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Martial Arts Marketing</span> — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should a martial arts school spend on marketing in Singapore?</summary>
          <div class="faq-answer"><p>Most martial arts schools in Singapore invest between $2,500 and $8,000 per month on marketing. A typical allocation covers website maintenance, SEO, Google Ads, and social media content. The right budget depends on your school's size, number of disciplines offered, and student targets. Our Essential plan at $3,000/month is ideal for single-location schools building a solid marketing foundation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long before marketing generates new students for my martial arts school?</summary>
          <div class="faq-answer"><p>Paid channels like Google Ads can generate trial class enquiries within the first week. SEO typically takes 3–6 months to build sustainable organic traffic. Social media builds brand awareness and community engagement over 2–3 months. Most martial arts school clients see a meaningful increase in trial sign-ups within the first 60 days of a full-service campaign.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What marketing channels work best for martial arts schools in Singapore?</summary>
          <div class="faq-answer"><p>Google Search is the highest-intent channel — parents searching for "kids martial arts Singapore" or adults searching for "muay thai classes near me" are ready to sign up. Instagram and TikTok work exceptionally well for showcasing training, competitions, and student progress. Facebook Ads are effective for targeting parents in specific neighbourhoods. A professional website ties everything together as your conversion hub.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you work with all types of martial arts disciplines?</summary>
          <div class="faq-answer"><p>Yes. We work with schools teaching Brazilian Jiu-Jitsu, Muay Thai, taekwondo, karate, boxing, kickboxing, MMA, Krav Maga, Wing Chun, and multi-discipline academies. Each discipline attracts a different demographic and has unique search behaviour. We tailor every marketing strategy to your specific discipline, target audience, and competitive positioning in Singapore.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you help market both kids and adult programmes?</summary>
          <div class="faq-answer"><p>Yes. Kids and adult programmes require fundamentally different marketing approaches. For kids programmes, we target parents through Google Ads, parent-focused content, and Facebook campaigns highlighting discipline, confidence, and physical development. For adult programmes, we target individuals through Instagram, Google Search, and content around fitness, self-defence, and competition. We run separate campaigns for each audience to maximise results.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More Martial Arts Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/martial-arts-website-singapore/" class="related-service-link">Martial Arts Website Design</a>
          <a href="/martial-arts-seo-singapore/" class="related-service-link">Martial Arts SEO</a>
      </div>
    </div>
  </section>
</ServiceLayout>
