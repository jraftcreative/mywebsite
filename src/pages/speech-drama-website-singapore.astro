---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Speech & Drama Website Design Singapore",
    "description": "Custom website design for speech and drama schools in Singapore — programme pages for public speaking, drama, and exam prep, performance video galleries, instructor profiles, trial class booking, and local SEO. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Speech & Drama Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Speech & Drama Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with programme overview, contact form, Google Maps, mobile-responsive design, basic SEO, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Speech & Drama Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with trial class booking, instructor profiles, performance video gallery, blog, advanced SEO, Google Business Profile optimisation, and recital/show calendar" },
      { "@type": "Offer", "name": "Premium Speech & Drama Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages with custom design, online registration and payment, LAMDA/Trinity exam prep pages, multi-location support, student achievement showcase, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a speech and drama website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional speech and drama school website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with programme information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add trial class booking, instructor profiles, performance video galleries, show calendars, and online registration with payment." } },
      { "@type": "Question", "name": "Can you include a video and performance showcase on our website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business and Premium packages include a dedicated performance gallery where you can showcase student recitals, drama productions, public speaking showcases, and storytelling performances. We embed videos from YouTube or Vimeo and optimise loading so the gallery stays fast on any device. Parents can see first-hand what your students achieve — a powerful trust signal that drives enrolments." } },
      { "@type": "Question", "name": "Can parents register and pay for classes online through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Premium package includes a full online registration system where parents can browse programmes by age group or skill level, select a term or holiday workshop, and pay securely online. The Business package includes trial class booking with automated confirmation emails. Both options reduce admin work and let parents sign up at any hour — not just during office hours." } },
      { "@type": "Question", "name": "Can you help our speech and drama school rank on Google locally?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We optimise your website for keywords parents actually search — like 'speech and drama classes near me', 'public speaking for kids Singapore', or 'LAMDA exam prep Singapore'. This includes on-page SEO, schema markup for educational services, Google Business Profile optimisation, and location-targeted content that helps you rank in local search results and Google Maps." } },
      { "@type": "Question", "name": "How long does it take to build a speech and drama school website?", "acceptedAnswer": { "@type": "Answer", "text": "Most speech and drama school websites go live within 2 weeks for our Starter package. Business-tier sites with instructor profiles, booking systems, and video galleries typically take 3 weeks, while Premium builds with online registration, show calendars, and multi-location support take 4–5 weeks. We provide a clear timeline before starting so you can plan around your term and performance schedule." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Speech & Drama Website Singapore", "item": "https://jraftcreative.com/speech-drama-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Speech & Drama Website Singapore — Speech & Drama School Web Design | Jraft Creative"
  description="Custom website design for speech and drama schools in Singapore — programme pages for public speaking, drama, and exam prep, performance video galleries, instructor profiles, trial class booking, and local SEO. From S$2,500."
  canonical="https://jraftcreative.com/speech-drama-website-singapore/"
  ogTitle="Speech & Drama Website Singapore — Jraft Creative"
  ogDescription="Custom website design for speech and drama schools in Singapore. Programme pages, performance galleries, instructor profiles, and local SEO from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="speech and drama website design singapore, speech and drama website singapore, drama school website singapore, public speaking classes website singapore, speech and drama classes near me, LAMDA exam prep singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Speech & Drama Websites"
  heroTitle='Website Design for <span class="highlight">Speech &amp; Drama Schools in Singapore</span>'
  heroSubtitle="Parents are searching online before enrolling their child in a single class. We build websites that showcase your programmes — from public speaking and drama to LAMDA and Trinity exam prep — highlight your instructors, and make trial class booking effortless so you can focus on developing confident communicators."
  heroImage="/images/service-speechdrama.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my speech and drama school in Singapore."
  ctaLabel="Ready to Grow Your Speech & Drama School?"
  ctaTitle="Get Your Speech & Drama School Online"
  ctaDescription="Tell us about your school and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20speech%20and%20drama%20school%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why speech and drama schools need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Searching — Can They Find Your Speech &amp; Drama School?</h2>
      </div>
      <div class="section-content reveal">
        <p>Every week, thousands of parents in Singapore search "speech and drama classes near me", "public speaking for kids Singapore", or "LAMDA exam prep" on Google. They compare schools side by side, watching performance clips, reading instructor bios, and checking class schedules. If your speech and drama school doesn't have a professional website, you're invisible to these families — and they're signing up for trial classes with your competitors instead.</p>
        <p>A Facebook page or an entry on a directory listing is not enough. Parents evaluating speech and drama programmes want to see the full range of what you offer — public speaking, creative drama, storytelling, musical theatre, debate, and exam preparation for LAMDA and Trinity. They want to know each instructor's background and teaching approach, watch clips from past performances and showcases, and check available class times for their child's age group — all before they ever contact you.</p>
        <p>Speech and drama education is a growing segment in Singapore, driven by parents who recognise the importance of oral communication, confidence building, and presentation skills. Schools that invest in a professional website with clear programme details, compelling performance showcases, and easy trial class booking consistently outperform those relying on word of mouth or social media alone. In a market with established names and new entrants alike, your website is the first impression that determines whether a parent enrols their child or scrolls past.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Speech and drama website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Speech &amp; Drama Schools</h2>
      </div>
      <div class="section-content reveal">
        <p>Every speech and drama website we deliver is built to convert visitors into enrolled students. We go beyond a generic template — your site will feature dedicated programme pages for public speaking, drama, storytelling, and exam preparation, instructor profiles that highlight credentials and teaching philosophy, and a frictionless booking flow that makes it easy to schedule a trial class.</p>
        <p>A great website is just the starting point. Pair your speech and drama site with <a href="/services/seo-performance/">local SEO services</a> to rank for "speech and drama classes near me" searches in your area, <a href="/services/social-media/">social media marketing</a> to reach parents on Instagram and Facebook, and <a href="/services/paid-ads/">Google Ads</a> to capture high-intent searches during peak enrolment periods.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Programme &amp; Course Pages</h3>
            <p>Dedicated pages for every programme you offer — public speaking, creative drama, storytelling, musical theatre, debate, and exam prep for LAMDA and Trinity. Each page details class formats, age groups from preschool to teens, skill levels, and learning outcomes so parents find exactly the right fit for their child.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Performance Video Gallery</h3>
            <p>A dedicated showcase gallery featuring student recitals, drama productions, public speaking presentations, and storytelling performances. Parents can see first-hand what your students achieve on stage — a powerful trust signal that turns website visitors into enrolments.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Instructor Profiles &amp; Credentials</h3>
            <p>Each instructor gets a profile page with their qualifications, performance and directing experience, teaching philosophy, and specialisations. We include professional headshots, embedded video clips of their work, and certification details — giving parents full confidence in the people guiding their children.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Recital Calendar &amp; Trial Class Booking</h3>
            <p>A built-in calendar for showcases, productions, and holiday workshops alongside an online booking system for trial classes. Parents can view upcoming events, filter classes by age group, and book a trial slot directly — reducing phone calls and admin time for your team.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for speech and drama website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Your Speech &amp; Drama Website</h2>
      </div>
      <div class="section-content reveal">
        <p>We understand the performing arts education industry in Singapore. Our websites are built to address the specific challenges speech and drama schools face — from competing for "speech and drama classes near me" searches to converting enquiries into long-term student enrolments.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Performing Arts Experience</h3>
            <p>We've built websites for speech and drama schools, enrichment centres, and performing arts academies across Singapore. We know what parents look for — clear programme details, strong instructor credentials, and proof of student achievement — and how to present it in a way that drives enrolments.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most speech and drama school websites go live within 2 weeks. We work fast so you can start capturing online bookings before the next term begins — no dragging projects out for months.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Video &amp; Media Optimised</h3>
            <p>Your website will handle embedded performance videos, student showcase reels, and photo galleries without slowing down. We optimise media delivery so parents get a rich, immersive experience of your school on any device — desktop, tablet, or mobile.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Beyond the website, we offer SEO, social media marketing, and Google Ads management — everything your speech and drama school needs to grow its online presence and fill more class slots across all programmes and age groups.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Speech and drama website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Speech &amp; Drama Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new schools getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme overview &amp; class info</li>
              <li>Contact form &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established schools ready to grow.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Trial class booking system</li>
              <li>Instructor profiles with credentials</li>
              <li>Performance video gallery</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For large academies and multi-location schools.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; branding</li>
              <li>Online registration &amp; payment</li>
              <li>Recital &amp; show calendar</li>
              <li>Multi-location support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about speech and drama website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Speech &amp; Drama Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a speech and drama website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional speech and drama school website in Singapore costs between $2,500 and $10,000+ SGD depending on features and complexity. Our Starter package at $2,500 includes a 5-page website with programme information, a contact form, Google Maps integration, and basic SEO. Business and Premium packages add trial class booking, instructor profiles, performance video galleries, show calendars, and online registration with payment.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you include a video and performance showcase on our website?</summary>
          <div class="faq-answer"><p>Yes. Our Business and Premium packages include a dedicated performance gallery where you can showcase student recitals, drama productions, public speaking showcases, and storytelling performances. We embed videos from YouTube or Vimeo and optimise loading so the gallery stays fast on any device. Parents can see first-hand what your students achieve on stage — a powerful trust signal that drives enrolments.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can parents register and pay for classes online through the website?</summary>
          <div class="faq-answer"><p>Yes. Our Premium package includes a full online registration system where parents can browse programmes by age group or skill level, select a term or holiday workshop, and pay securely online. The Business package includes trial class booking with automated confirmation emails. Both options reduce admin work and let parents sign up at any hour — not just during office hours.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you help our speech and drama school rank on Google locally?</summary>
          <div class="faq-answer"><p>Yes. We optimise your website for keywords parents actually search — like "speech and drama classes near me", "public speaking for kids Singapore", or "LAMDA exam prep Singapore". This includes on-page SEO, schema markup for educational services, Google Business Profile optimisation, and location-targeted content that helps you rank in local search results and Google Maps.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a speech and drama school website?</summary>
          <div class="faq-answer"><p>Most speech and drama school websites go live within 2 weeks for our Starter package. Business-tier sites with instructor profiles, booking systems, and video galleries typically take 3 weeks, while Premium builds with online registration, show calendars, and multi-location support take 4-5 weeks. We provide a clear timeline before starting so you can plan around your term and performance schedule.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
