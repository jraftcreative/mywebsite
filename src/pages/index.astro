---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import IndustryCard from '../components/IndustryCard.astro';
import ContactForm from '../components/ContactForm.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Jraft Creative",
    "description": "Full-service marketing agency in Singapore specialising in website development, SEO, paid performance marketing, and social media content creation.",
    "url": "https://jraftcreative.com/",
    "logo": "https://jraftcreative.com/images/logo.png",
    "email": "contact@jraftcreative.com",
    "telephone": "+6582234578",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
      "postalCode": "409051",
      "addressLocality": "Singapore",
      "addressCountry": "SG"
    },
    "areaServed": {
      "@type": "Country",
      "name": "Singapore"
    },
    "serviceType": [
      "Website Development",
      "SEO & Performance Optimisation",
      "Paid Performance Marketing",
      "Social Media Content Creation"
    ],
    "knowsAbout": [
      "Web Design",
      "Ecommerce",
      "Google Ads",
      "Meta Ads",
      "Search Engine Optimisation",
      "Social Media Marketing"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a website cost in Singapore?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Website costs in Singapore range from $2,500 SGD for a starter business website (up to 5 pages) to $10,000+ SGD for full ecommerce stores and web applications. Jraft Creative offers transparent pricing with no hidden fees."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to build a website?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our average turnaround is 2 weeks for standard business websites. More complex projects like ecommerce stores and web applications may take 4-6 weeks depending on scope."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer SEO services in Singapore?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Jraft Creative offers full SEO services including technical SEO audits, on-page optimisation, local SEO with Google Business Profile, link building, and monthly performance reporting. Plans start from $800 SGD per month."
        }
      },
      {
        "@type": "Question",
        "name": "What industries do you serve?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We specialise in Music & Creative, F&B & Hospitality, Retail & Ecommerce, Education, Property, and Insurance. We have deep expertise in these industries and understand their specific marketing needs."
        }
      }
    ]
  }
];

const webDevSubItems = [
  { title: "Business Websites", description: "Custom-designed, mobile-responsive sites that showcase your brand and convert visitors." },
  { title: "Ecommerce Stores", description: "Online stores with product catalogs, secure checkout, and inventory management." },
  { title: "Web Applications", description: "Booking systems, client portals, dashboards, and custom operational tools." },
  { title: "Landing Pages", description: "High-converting campaign pages for promotions and lead generation." },
  { title: "AI Integration", description: "Chatbots, automated workflows, and AI-powered features for smarter business." },
];

const seoSubItems = [
  { title: "Technical SEO Audit", description: "Comprehensive site crawl, indexing fixes, schema markup, and site architecture improvements." },
  { title: "On-Page Optimisation", description: "Keyword research, meta tags, content optimisation, and internal linking strategy." },
  { title: "Speed & Core Web Vitals", description: "Page speed optimisation, image compression, caching, and performance monitoring." },
  { title: "Analytics & Reporting", description: "Google Analytics 4 setup, Search Console, conversion tracking, and monthly performance reports." },
  { title: "Local SEO", description: "Google Business Profile optimisation, local citations, review management, and map pack rankings." },
];

const adsSubItems = [
  { title: "Google Ads (Search & Display)", description: "Keyword targeting, ad copywriting, bid management, and Quality Score optimisation." },
  { title: "Meta Ads (Facebook & Instagram)", description: "Audience targeting, creative production, A/B testing, and conversion campaigns." },
  { title: "TikTok & YouTube Ads", description: "Video ad campaigns, interest-based targeting, and brand awareness at scale." },
  { title: "Retargeting & Remarketing", description: "Pixel setup, custom audiences, lookalike targeting, and cross-platform retargeting funnels." },
  { title: "Campaign Analytics & Optimisation", description: "Conversion tracking, ROAS reporting, budget allocation, and continuous campaign refinement." },
];

const socialSubItems = [
  { title: "Content Strategy & Planning", description: "Monthly content calendars, pillar themes, and platform-specific strategies aligned to your goals." },
  { title: "Graphic Design & Visuals", description: "Branded carousels, infographics, quote cards, and on-brand static posts for all platforms." },
  { title: "Reels & Short-form Video", description: "Trending-format vertical videos for Instagram Reels, TikTok, and YouTube Shorts." },
  { title: "Copywriting & Captions", description: "Engaging captions, hashtag strategy, and platform-optimised copy that drives interaction." },
  { title: "Community Management", description: "Comment moderation, DM responses, engagement tracking, and audience growth tactics." },
];
---

<BaseLayout
  title="Marketing Agency & Web Design Singapore | Jraft Creative"
  description="Full-service marketing agency in Singapore. Website development, SEO, paid ads, and social media content creation for businesses across all industries."
  canonical="https://jraftcreative.com/"
  ogTitle="Marketing Agency Singapore — Jraft Creative"
  ogDescription="Website development, SEO, paid ads, and social media content creation. We help Singapore brands grow, launch, and stand out."
  keywords="marketing agency Singapore, web design Singapore, SEO agency, paid ads management, social media marketing, website development, ecommerce, Jraft Creative"
  preloadImage="/images/hero.webp"
  schemaData={schemaData}
  hreflang={[
    { lang: "en-sg", href: "https://jraftcreative.com/" },
    { lang: "x-default", href: "https://jraftcreative.com/" }
  ]}
>

  <Hero
    title='Marketing Agency Singapore — We Help Brands <span class="highlight">Grow, Launch & Stand Out</span>'
    subtitle="Strategy, design, development, and marketing — all under one roof. We build brands that convert, campaigns that perform, and websites that leave a lasting impression."
    backgroundImage="/images/hero.webp"
    heroLabel="Full-Service Creative & Marketing Agency in Singapore"
    buttons={[
      { text: "Start Your Project", href: "#contact", class: "btn btn-primary" },
      { text: "View Our Work", href: "#work", class: "btn btn-secondary" }
    ]}
  />

  <!-- ========== TRUST BAR ========== -->
  <section class="trust-bar" aria-label="Trust statistics">
    <div class="container">
      <div class="trust-inner reveal">
        <p class="trust-label">Trusted by businesses across Singapore</p>
        <div class="trust-stats">
          <div class="trust-stat">
            <span class="number">15+</span>
            <span class="label">Projects Delivered</span>
          </div>
          <div class="trust-stat">
            <span class="number">6</span>
            <span class="label">Industries Served</span>
          </div>
          <div class="trust-stat">
            <span class="number">100%</span>
            <span class="label">Client Satisfaction</span>
          </div>
          <div class="trust-stat">
            <span class="number">2 wks</span>
            <span class="label">Avg. Turnaround</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="services" aria-label="Our services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Services</p>
        <h2>What We Do</h2>
      </div>
      <div class="section-content reveal">
        <p>End-to-end digital solutions tailored to your business needs. As a full-service digital marketing agency in Singapore, JRaft Creative helps brands build a powerful online presence through expert website development, SEO services, social media marketing, and paid ads management.</p>
        <p>Whether you need a high-converting web design, an ecommerce store, or a results-driven digital strategy, our team delivers measurable business growth — from concept to launch and beyond.</p>
      </div>
      <div class="services-grid services-grid-4">
        <ServiceCard
          title="Website Development"
          description="Custom websites, stores, and web apps — designed to convert and built to scale."
          backgroundImage="/images/service-webdev.webp"
          id="serviceWebDev"
          revealClass="reveal-d1"
          expandable={true}
          subItems={webDevSubItems}
          pricing={{
            title: "Transparent Pricing",
            description: "No hidden fees. Choose the package that fits your needs.",
            id: "pricing-webdev",
            cards: [
              { name: "Starter", price: "$2,500", unit: "SGD", description: "Perfect for small businesses needing a professional online presence.", features: ["Up to 5 pages", "Mobile responsive design", "Contact form", "Basic SEO setup", "2 rounds of revisions", "1 month support"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-secondary" },
              { name: "Business", price: "$5,500", unit: "SGD", description: "For growing businesses that need more functionality and polish.", features: ["Up to 12 pages", "Custom design & animations", "CMS / blog integration", "Booking or enquiry system", "Advanced SEO & analytics", "3 months support"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-primary", featured: true },
              { name: "Premium", price: "$10,000+", unit: "SGD", description: "Full ecommerce, web apps, and complex custom builds.", features: ["Unlimited pages", "Ecommerce / web app", "Payment integration", "User accounts & dashboards", "API integrations", "6 months support"], cta: "Let's Talk", ctaHref: "#contact", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="SEO & Performance"
          description="Search engine optimisation, speed optimisation, and analytics setup to maximise your online visibility and rankings."
          backgroundImage="/images/service-seo.webp"
          id="serviceSeo"
          revealClass="reveal-d2"
          expandable={true}
          subItems={seoSubItems}
          pricing={{
            title: "SEO Pricing",
            description: "Monthly retainer plans. Results-driven, no lock-in contracts.",
            cards: [
              { name: "Essential", price: "$800", unit: "SGD/mo", description: "For small businesses looking to build organic visibility.", features: ["Technical SEO audit", "On-page optimisation (10 pages)", "Google Analytics & Search Console", "Monthly keyword tracking", "Monthly performance report"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-secondary" },
              { name: "Growth", price: "$1,500", unit: "SGD/mo", description: "For businesses ready to dominate search rankings.", features: ["Everything in Essential", "Content strategy & blog SEO", "Link building (5 links/mo)", "Competitor analysis", "Local SEO & Google Business", "Bi-weekly reporting"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-primary", featured: true },
              { name: "Enterprise", price: "$3,000+", unit: "SGD/mo", description: "Full-service SEO for high-traffic sites and competitive industries.", features: ["Everything in Growth", "Dedicated SEO strategist", "Advanced link building (15+/mo)", "Content creation & publishing", "Core Web Vitals optimisation", "Weekly reporting & strategy calls"], cta: "Let's Talk", ctaHref: "#contact", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="Paid Performance Marketing"
          description="Google Ads, Meta Ads, and data-driven paid campaigns that deliver measurable ROI and qualified leads."
          backgroundImage="/images/service-ads.webp"
          id="serviceAds"
          revealClass="reveal-d3"
          expandable={true}
          subItems={adsSubItems}
          pricing={{
            title: "Paid Ads Pricing",
            description: "Management fees are separate from ad spend. No minimum contract.",
            cards: [
              { name: "Starter", price: "$1,000", unit: "SGD/mo", description: "For businesses testing paid channels for the first time.", features: ["1 platform (Google or Meta)", "Campaign setup & strategy", "Ad copywriting & creatives", "Pixel & conversion tracking", "Monthly performance report"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-secondary" },
              { name: "Growth", price: "$2,500", unit: "SGD/mo", description: "For businesses scaling with multi-platform campaigns.", features: ["2 platforms (Google + Meta)", "A/B testing & creative iteration", "Retargeting & lookalike audiences", "Landing page recommendations", "Bi-weekly reporting & optimisation", "Dedicated account manager"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-primary", featured: true },
              { name: "Scale", price: "$5,000+", unit: "SGD/mo", description: "Full-funnel paid strategy across all major platforms.", features: ["All platforms (Google, Meta, TikTok, YouTube)", "Video ad production", "Advanced attribution modelling", "Real-time dashboard access", "Weekly strategy calls", "Dedicated strategist"], cta: "Let's Talk", ctaHref: "#contact", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="Social Media Content Creation"
          description="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn that build your brand."
          backgroundImage="/images/service-social.webp"
          id="serviceSocial"
          revealClass="reveal-d4"
          expandable={true}
          subItems={socialSubItems}
          pricing={{
            title: "Social Media Pricing",
            description: "Monthly content packages. All content is yours to keep and reuse.",
            cards: [
              { name: "Essential", price: "$2,000", unit: "SGD/mo", description: "For brands starting their social media presence.", features: ["12 posts per month", "2 platforms", "Branded graphic design", "Captions & hashtags", "Monthly content calendar"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-secondary" },
              { name: "Professional", price: "$3,000", unit: "SGD/mo", description: "For brands ready to grow and engage consistently.", features: ["20 posts per month", "3 platforms", "4 Reels / short-form videos", "Stories & highlights design", "Captions, hashtags & scheduling", "Basic community management"], cta: "Get Started", ctaHref: "#contact", ctaClass: "btn btn-primary", featured: true },
              { name: "Full-Service", price: "$5,000+", unit: "SGD/mo", description: "End-to-end social media management for serious brands.", features: ["30+ posts per month", "All platforms", "8+ Reels & video production", "Full community management", "Influencer coordination", "Monthly analytics & strategy review"], cta: "Let's Talk", ctaHref: "#contact", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
      </div>
    </div>
  </section>

  <!-- ========== PORTFOLIO ========== -->
  <section class="section" id="work" aria-label="Our portfolio">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Portfolio</p>
        <h2>Selected Work</h2>
        <p>Real projects we've designed and built for clients across industries.</p>
      </div>

      <PortfolioCard
        title="Music with Pat"
        description="Portfolio and booking website for a piano teacher in Singapore. Features an interactive consultation calendar, automated lead capture via Google Sheets, testimonial carousel, and mobile-first design with bottom navigation."
        image="/images/preview-music.webp"
        imageAlt="Music with Pat"
        link="https://www.musicwithpat.com"
        type="Music &middot; Website"
        gradClass="grad-music"
        tags={["Astro", "Tailwind CSS", "Lead Generation", "Cloudflare"]}
        featured={true}
        badge="Featured"
      />

      <div class="portfolio-grid">
        <PortfolioCard
          title="Kairos Advisory Group"
          description="Website revamp for an independent financial advisory firm in Singapore. Features service pages, team profiles, WhatsApp integration, and a professional design that builds trust and credibility."
          image="/images/preview-kairos.webp"
          imageAlt="Kairos Advisory Group"
          link="https://kairos-advisorygroup.com/"
          type="Finance &middot; Website Revamp"
          gradClass="grad-finance"
          tags={["Web Design", "Finance", "Astro"]}
          revealClass="reveal-d1"
        />
        <PortfolioCard
          title="Sakura Kitchen"
          description="Modern restaurant website with online menu, reservation system, and gallery. Warm, inviting design that captures the dining experience."
          image="/images/preview-restaurant.webp"
          imageAlt="Sakura Kitchen"
          link="https://jraftcreative.github.io/portfolio-restaurant/"
          type="F&B &middot; Website"
          gradClass="grad-restaurant"
          tags={["Web Design", "F&B", "Responsive"]}
          revealClass="reveal-d1"
        />
        <PortfolioCard
          title="BrightPath Tutors"
          description="Tutor discovery and booking platform with subject filtering, tutor profiles, testimonials, and a streamlined enquiry flow."
          image="/images/preview-tutor.webp"
          imageAlt="BrightPath Tutors"
          link="https://jraftcreative.github.io/portfolio-tutor/"
          type="Education &middot; Platform"
          gradClass="grad-tutor"
          tags={["Web App", "Education", "Booking"]}
          revealClass="reveal-d2"
        />
        <PortfolioCard
          title="MŌDA — Fashion & Lifestyle"
          description="Premium ecommerce storefront with product collections, editorial layouts, category browsing, and a curated shopping experience."
          image="/images/preview-ecommerce.webp"
          imageAlt="MŌDA Fashion & Lifestyle"
          link="https://jraftcreative.github.io/portfolio-ecommerce/"
          type="Retail &middot; Ecommerce"
          gradClass="grad-ecommerce"
          tags={["Ecommerce", "Retail", "UI/UX"]}
          revealClass="reveal-d1"
        />
        <PortfolioCard
          title="PawHaus"
          description="Pet supplies ecommerce store with product pages for dogs and cats, Snipcart checkout, FAQ section, and a clean, modern storefront design."
          image="/images/preview-pawhaus.webp"
          imageAlt="PawHaus Pet Store"
          link="https://jraftcreative.github.io/pawhaus/"
          type="Pets &middot; Ecommerce"
          gradClass="grad-ecommerce"
          tags={["Astro", "Ecommerce", "Snipcart"]}
          revealClass="reveal-d2"
        />
      </div>
    </div>
  </section>

  <!-- ========== INDUSTRIES ========== -->
  <section class="section" id="industries" aria-label="Industries we serve">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Industries</p>
        <h2>Who We Work With</h2>
        <p>Deep expertise in industries where we deliver the most impact.</p>
      </div>
      <div class="industries-grid">
        <IndustryCard title="Music & Creative" description="Music schools, studios, performers, and creative agencies." backgroundImage="/images/industry-music.webp" revealClass="reveal-d1" />
        <IndustryCard title="F&B & Hospitality" description="Restaurants, cafes, catering, and food delivery brands." backgroundImage="/images/industry-fnb.webp" revealClass="reveal-d2" />
        <IndustryCard title="Retail & Ecommerce" description="Fashion, lifestyle, specialty goods, and DTC brands." backgroundImage="/images/industry-retail.webp" revealClass="reveal-d3" />
        <IndustryCard title="Education" description="Tuition centres, enrichment schools, online courses, and edtech." backgroundImage="/images/industry-education.webp" revealClass="reveal-d4" />
        <IndustryCard title="Property" description="Real estate agencies, property developers, and listings platforms." backgroundImage="/images/industry-property.webp" revealClass="reveal-d5" />
        <IndustryCard title="Insurance" description="Insurance agents, brokerages, and financial advisory firms." backgroundImage="/images/industry-insurance.webp" revealClass="reveal-d5" />
      </div>
    </div>
  </section>

  <!-- ========== PROCESS ========== -->
  <section class="section" id="process" aria-label="Our process">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">How We Work</p>
        <h2>Simple, Transparent Process</h2>
        <p>From first call to launch in as fast as 2 weeks.</p>
      </div>
      <div class="process-grid">
        <div class="process-step reveal reveal-d1">
          <h3>Discovery</h3>
          <p>We learn about your business, goals, and audience to define the project scope.</p>
        </div>
        <div class="process-step reveal reveal-d2">
          <h3>Design</h3>
          <p>We create mockups and prototypes for your review. Iterate until it's perfect.</p>
        </div>
        <div class="process-step reveal reveal-d3">
          <h3>Build</h3>
          <p>We develop and test your site with clean code, fast performance, and mobile responsiveness.</p>
        </div>
        <div class="process-step reveal reveal-d4">
          <h3>Launch</h3>
          <p>We deploy, set up analytics, and provide a handover with training and support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT ========== -->
  <section class="section contact-section" id="contact" aria-label="Contact us">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info reveal">
          <p class="section-label">Get In Touch</p>
          <h2>Book a Free Consultation</h2>
          <p class="contact-desc">Tell us about your project and we'll get back to you within 24 hours. No obligations — just a conversation about how we can help.</p>
          <div class="contact-details">
            <div class="contact-detail">
              <span class="contact-detail-icon">&#128231;</span>
              <div>
                <strong>Email</strong>
                <a href="mailto:contact@jraftcreative.com">contact@jraftcreative.com</a>
              </div>
            </div>
            <div class="contact-detail">
              <span class="contact-detail-icon">&#128205;</span>
              <div>
                <strong>Location</strong>
                <span>60 Paya Lebar Road, Paya Lebar Square, S409051</span>
              </div>
            </div>
            <div class="contact-detail">
              <span class="contact-detail-icon">&#9201;&#65039;</span>
              <div>
                <strong>Response Time</strong>
                <span>Within 24 hours</span>
              </div>
            </div>
          </div>
        </div>
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- WhatsApp Button -->
  <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20services." class="whatsapp-btn" target="_blank" rel="noopener" aria-label="Chat on WhatsApp" slot="after-footer">
    <svg viewBox="0 0 32 32" width="28" height="28" fill="#fff" aria-hidden="true"><path d="M16.004 0h-.008C7.174 0 0 7.176 0 16.004c0 3.5 1.13 6.742 3.05 9.378L1.054 31.29l6.118-1.962A15.91 15.91 0 0 0 16.004 32C24.826 32 32 24.826 32 16.004S24.826 0 16.004 0zm9.302 22.602c-.39 1.1-2.276 2.106-3.156 2.17-.796.058-1.78.082-2.872-.278a26.3 26.3 0 0 1-2.6-1.074c-4.576-2.186-7.566-6.826-7.796-7.142-.222-.316-1.836-2.478-1.836-4.726 0-2.248 1.162-3.356 1.574-3.814.39-.434.858-.542 1.144-.542.286 0 .572.004.82.014.264.012.618-.1.966.738.39.938 1.294 3.224 1.408 3.458.112.234.19.508.038.82-.15.316-.226.512-.448.79-.222.278-.468.62-.668.832-.222.234-.454.49-.196.962.26.47 1.154 1.906 2.478 3.088 1.702 1.52 3.136 1.99 3.582 2.214.448.222.708.19.968-.114.26-.306 1.118-1.302 1.416-1.75.298-.448.596-.37.998-.222.404.148 2.566 1.21 3.006 1.432.44.222.734.334.844.518.112.186.112 1.074-.278 2.174z"/></svg>
  </a>

  <!-- Homepage-specific JS -->
  <script is:inline>
    // Service card expand — only one open at a time, with keyboard support
    var expandableCards = document.querySelectorAll('.service-expandable');
    function toggleCard(card) {
      var isExpanded = card.classList.contains('expanded');
      expandableCards.forEach(function (c) {
        c.classList.remove('expanded');
        c.setAttribute('aria-expanded', 'false');
      });
      if (!isExpanded) {
        card.classList.add('expanded');
        card.setAttribute('aria-expanded', 'true');
      }
    }
    expandableCards.forEach(function (card) {
      card.addEventListener('click', function (e) {
        if (e.target.closest('.pricing-card a, .pricing-card button')) return;
        toggleCard(card);
      });
      card.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          if (e.target.closest('.pricing-card a, .pricing-card button')) return;
          e.preventDefault();
          toggleCard(card);
        }
      });
    });

    // Pricing nav link — expand web dev card and scroll to pricing
    document.querySelectorAll('a[href="#pricing"]').forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        expandableCards.forEach(function (c) {
          c.classList.remove('expanded');
          c.setAttribute('aria-expanded', 'false');
        });
        var webDevCard = document.getElementById('serviceWebDev');
        webDevCard.classList.add('expanded');
        webDevCard.setAttribute('aria-expanded', 'true');
        setTimeout(function () {
          document.getElementById('pricing-webdev').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 350);
      });
    });

    // Client-side form validation
    function validateField(field, errorEl, rules) {
      var value = field.value.trim();
      for (var i = 0; i < rules.length; i++) {
        if (!rules[i].test(value)) {
          errorEl.textContent = rules[i].message;
          field.classList.add('form-input-error');
          field.setAttribute('aria-invalid', 'true');
          field.setAttribute('aria-describedby', errorEl.id);
          return false;
        }
      }
      errorEl.textContent = '';
      field.classList.remove('form-input-error');
      field.removeAttribute('aria-invalid');
      field.removeAttribute('aria-describedby');
      return true;
    }

    var nameField = document.getElementById('name');
    var emailField = document.getElementById('email');
    var messageField = document.getElementById('message');
    var nameError = document.getElementById('nameError');
    var emailError = document.getElementById('emailError');
    var messageError = document.getElementById('messageError');

    var nameRules = [
      { test: function(v) { return v.length > 0; }, message: 'Please enter your name.' },
      { test: function(v) { return v.length >= 2; }, message: 'Name must be at least 2 characters.' }
    ];
    var emailRules = [
      { test: function(v) { return v.length > 0; }, message: 'Please enter your email address.' },
      { test: function(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }, message: 'Please enter a valid email address (e.g. you@company.com).' }
    ];
    var messageRules = [
      { test: function(v) { return v.length > 0; }, message: 'Please tell us about your project.' },
      { test: function(v) { return v.length >= 10; }, message: 'Please provide more detail (at least 10 characters).' }
    ];

    // Live validation on blur
    nameField.addEventListener('blur', function() { validateField(nameField, nameError, nameRules); });
    emailField.addEventListener('blur', function() { validateField(emailField, emailError, emailRules); });
    messageField.addEventListener('blur', function() { validateField(messageField, messageError, messageRules); });

    // Clear error on input
    nameField.addEventListener('input', function() { if (nameField.classList.contains('form-input-error')) validateField(nameField, nameError, nameRules); });
    emailField.addEventListener('input', function() { if (emailField.classList.contains('form-input-error')) validateField(emailField, emailError, emailRules); });
    messageField.addEventListener('input', function() { if (messageField.classList.contains('form-input-error')) validateField(messageField, messageError, messageRules); });

    // Contact form submission
    var APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyyazRDsSx4C2NFFY1K1wJm6QH9v0cjZkDRcFKraSVrrg3nIjnaEe7UOyKCxhCe9TQWiQ/exec';

    document.getElementById('contactForm').addEventListener('submit', function (e) {
      e.preventDefault();
      var form = this;

      // Validate all fields
      var nameValid = validateField(nameField, nameError, nameRules);
      var emailValid = validateField(emailField, emailError, emailRules);
      var messageValid = validateField(messageField, messageError, messageRules);

      if (!nameValid || !emailValid || !messageValid) {
        // Focus the first invalid field
        if (!nameValid) nameField.focus();
        else if (!emailValid) emailField.focus();
        else messageField.focus();
        return;
      }

      var btn = document.getElementById('submitBtn');
      var name = nameField.value.trim();
      var company = document.getElementById('company').value.trim();
      var email = emailField.value.trim();
      var phone = document.getElementById('phone').value.trim();
      var message = messageField.value.trim();

      btn.textContent = 'Sending...';
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');

      var data = { name: name, company: company, email: email, phone: phone, message: message };

      var waText = 'Hi Jraft Creative, I just submitted an enquiry on your website.\n\nName: ' + name + (company ? '\nCompany: ' + company : '') + '\nProject: ' + message;
      document.getElementById('whatsappFollowUp').href = 'https://wa.me/6582234578?text=' + encodeURIComponent(waText);

      if (APPS_SCRIPT_URL !== 'PASTE_YOUR_APPS_SCRIPT_URL_HERE') {
        fetch(APPS_SCRIPT_URL, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        }).then(function () {
          form.querySelector('.form-fields').style.display = 'none';
          form.querySelector('.form-error-state').style.display = 'none';
          form.querySelector('.form-success').style.display = 'flex';
        }).catch(function () {
          btn.textContent = 'Send Your Message';
          btn.disabled = false;
          btn.removeAttribute('aria-busy');
          form.querySelector('.form-fields').style.display = 'none';
          form.querySelector('.form-error-state').style.display = 'flex';
        });
      } else {
        // Fallback when no script URL is configured
        form.querySelector('.form-fields').style.display = 'none';
        form.querySelector('.form-success').style.display = 'flex';
      }
    });

    // Retry button in error state
    var retryBtn = document.querySelector('.form-retry');
    if (retryBtn) {
      retryBtn.addEventListener('click', function () {
        var form = document.getElementById('contactForm');
        form.querySelector('.form-error-state').style.display = 'none';
        form.querySelector('.form-fields').style.display = 'block';
        document.getElementById('submitBtn').textContent = 'Send Your Message';
        document.getElementById('submitBtn').disabled = false;
        document.getElementById('submitBtn').removeAttribute('aria-busy');
      });
    }
  </script>
</BaseLayout>
