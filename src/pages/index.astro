---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import IndustryCard from '../components/IndustryCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Jraft Creative",
    "legalName": "Jraft Creative Pte. Ltd.",
    "description": "Full-service marketing agency in Singapore specialising in website development, SEO, paid performance marketing, and social media content creation.",
    "url": "https://jraftcreative.com/",
    "logo": "https://jraftcreative.com/images/logo.png",
    "email": "contact@jraftcreative.com",
    "telephone": "+6582234578",
    "foundingDate": "2025",
    "foundingLocation": {
      "@type": "Place",
      "name": "Singapore"
    },
    "numberOfEmployees": {
      "@type": "QuantitativeValue",
      "minValue": 1,
      "maxValue": 10
    },
    "areaServed": {
      "@type": "Country",
      "name": "Singapore"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Marketing Services",
      "itemListElement": [
        {
          "@type": "OfferCatalog",
          "name": "Website Development",
          "description": "Custom business websites, ecommerce stores, web applications, and landing pages. From SGD 2,500.",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Business Website", "description": "Custom-designed, mobile-responsive website up to 5 pages with contact form and basic SEO setup" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ecommerce Store", "description": "Full online store with product catalogue, secure checkout, and inventory management" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Web Application", "description": "Booking systems, client portals, dashboards, and custom operational tools" } }
          ]
        },
        {
          "@type": "OfferCatalog",
          "name": "SEO & Performance Optimisation",
          "description": "Technical SEO audits, on-page optimisation, local SEO, link building, and analytics. From SGD 800/month.",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Technical SEO Audit", "description": "Comprehensive site crawl, indexing fixes, schema markup, and site architecture improvements" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Local SEO", "description": "Google Business Profile optimisation, local citations, review management, and map pack rankings" } }
          ]
        },
        {
          "@type": "OfferCatalog",
          "name": "Paid Performance Marketing",
          "description": "Google Ads, Meta Ads, TikTok Ads, YouTube Ads, retargeting, and conversion tracking. From SGD 1,000/month.",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Google Ads Management", "description": "Search and display campaign setup, bid management, and Quality Score optimisation" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Meta Ads Management", "description": "Facebook and Instagram audience targeting, creative production, and A/B testing" } }
          ]
        },
        {
          "@type": "OfferCatalog",
          "name": "Social Media Content Creation",
          "description": "Content strategy, branded graphics, Reels, TikTok videos, captions, and community management. From SGD 2,000/month.",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Social Media Management", "description": "Monthly content calendars, graphic design, video production, and community management" } }
          ]
        }
      ]
    },
    "serviceType": [
      "Website Development",
      "SEO & Performance Optimisation",
      "Paid Performance Marketing",
      "Social Media Content Creation"
    ],
    "knowsAbout": [
      "Web Design",
      "Ecommerce",
      "Google Ads",
      "Meta Ads",
      "Search Engine Optimisation",
      "Social Media Marketing",
      "Digital Marketing Strategy",
      "Content Marketing",
      "Local SEO Singapore",
      "TikTok Marketing",
      "Landing Page Optimisation"
    ],
    "image": "https://jraftcreative.com/images/og-image.jpg",
    "priceRange": "$$",
    "currenciesAccepted": "SGD",
    "paymentAccepted": "Bank Transfer, PayNow",
    "founder": {
      "@type": "Person",
      "name": "Jeremy Cheong",
      "url": "https://jraftcreative.com/about/jeremy/"
    },
    "sameAs": [
      "https://www.instagram.com/jraftcreative",
      "https://www.linkedin.com/company/jraftcreative",
      "https://www.tiktok.com/@jraftcreative"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Jraft Creative",
    "alternateName": ["JRaft Creative", "Jraft"],
    "url": "https://jraftcreative.com/",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://jraftcreative.com/blog/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".section-header h2", ".section-content p", ".hero-subtitle"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Jraft Creative",
    "description": "Jraft Creative is a full-service digital marketing agency in Singapore offering website development, SEO, paid ads management, and social media content creation for small and medium businesses.",
    "url": "https://jraftcreative.com/",
    "telephone": "+6582234578",
    "priceRange": "$$",
    "areaServed": {
      "@type": "Country",
      "name": "Singapore"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Digital Marketing Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website Development", "description": "Custom websites from SGD 2,500" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Services", "description": "Search engine optimisation from SGD 800/month" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Paid Ads Management", "description": "Google Ads and Meta Ads from SGD 1,000/month" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Social Media Marketing", "description": "Content creation and management from SGD 2,000/month" } }
      ]
    }
  }
];

const webDevSubItems = [
  { title: "Business Websites", description: "Custom-designed, mobile-responsive sites that showcase your brand and convert visitors." },
  { title: "Ecommerce Stores", description: "Online stores with product catalogs, secure checkout, and inventory management." },
  { title: "Web Applications", description: "Booking systems, client portals, dashboards, and custom operational tools." },
  { title: "Landing Pages", description: "High-converting campaign pages for promotions and lead generation." },
  { title: "AI Integration", description: "Chatbots, automated workflows, and AI-powered features for smarter business." },
];

const seoSubItems = [
  { title: "Technical SEO Audit", description: "Comprehensive site crawl, indexing fixes, schema markup, and site architecture improvements." },
  { title: "On-Page Optimisation", description: "Keyword research, meta tags, content optimisation, and internal linking strategy." },
  { title: "Speed & Core Web Vitals", description: "Page speed optimisation, image compression, caching, and performance monitoring." },
  { title: "Analytics & Reporting", description: "Google Analytics 4 setup, Search Console, conversion tracking, and monthly performance reports." },
  { title: "Local SEO", description: "Google Business Profile optimisation, local citations, review management, and map pack rankings." },
];

const adsSubItems = [
  { title: "Google Ads (Search & Display)", description: "Keyword targeting, ad copywriting, bid management, and Quality Score optimisation." },
  { title: "Meta Ads (Facebook & Instagram)", description: "Audience targeting, creative production, A/B testing, and conversion campaigns." },
  { title: "TikTok & YouTube Ads", description: "Video ad campaigns, interest-based targeting, and brand awareness at scale." },
  { title: "Retargeting & Remarketing", description: "Pixel setup, custom audiences, lookalike targeting, and cross-platform retargeting funnels." },
  { title: "Campaign Analytics & Optimisation", description: "Conversion tracking, ROAS reporting, budget allocation, and continuous campaign refinement." },
];

const geoSubItems = [
  { title: "AI Visibility Audit", description: "Test 20-30 target prompts across ChatGPT, Gemini, Perplexity, and Copilot. Benchmark against competitors and identify gaps." },
  { title: "Schema & Entity Optimisation", description: "Advanced JSON-LD markup, Organization/Service/FAQ schemas, and llms.txt implementation so AI knows exactly who you are." },
  { title: "Citation-Ready Content", description: "Answer-first formatting, comparison tables, and FAQ sections that AI engines can extract and cite directly." },
  { title: "Authority & Reputation Building", description: "Build your presence on review platforms, directories, and authority sites that AI trusts and references." },
  { title: "AI Visibility Monitoring", description: "Monthly tracking of Brand Visibility Score, Citation Rate, and Share of Voice across all major AI platforms." },
];

const socialSubItems = [
  { title: "Content Strategy & Planning", description: "Monthly content calendars, pillar themes, and platform-specific strategies aligned to your goals." },
  { title: "Graphic Design & Visuals", description: "Branded carousels, infographics, quote cards, and on-brand static posts for all platforms." },
  { title: "Reels & Short-form Video", description: "Trending-format vertical videos for Instagram Reels, TikTok, and YouTube Shorts." },
  { title: "Copywriting & Captions", description: "Engaging captions, hashtag strategy, and platform-optimised copy that drives interaction." },
  { title: "Community Management", description: "Comment moderation, DM responses, engagement tracking, and audience growth tactics." },
];
---

<BaseLayout
  title="Marketing Agency Singapore — Jraft Creative"
  description="Singapore marketing agency building websites, SEO, paid ads, and social content for SMEs who want clear strategy and work that actually ships."
  canonical="https://jraftcreative.com/"
  ogTitle="Marketing Agency Singapore — Jraft Creative"
  ogDescription="Singapore marketing agency building websites, SEO, paid ads, and social content for SMEs who want clear strategy and work that actually ships."
  keywords="Jraft Creative, marketing agency Singapore, web design Singapore, SEO agency, paid ads management, social media marketing, website development, ecommerce"
  preloadImage="/images/hero.webp"
  schemaData={schemaData}
  hreflang={[
    { lang: "en-sg", href: "https://jraftcreative.com/" },
    { lang: "x-default", href: "https://jraftcreative.com/" }
  ]}
>

  <Hero
    title='Marketing Agency Singapore — We Help Brands <span class="highlight">Launch, Grow & Stand Out</span>'
    subtitle="Strategy, design, development, and marketing — all under one roof. We build brands that convert, campaigns that perform, and websites that leave a lasting impression."
    backgroundImage="/images/hero.webp"
    heroLabel="Full-Service Creative & Marketing Agency in Singapore"
    buttons={[
      { text: "Start Your Project", href: "/contact/", class: "btn btn-primary" },
      { text: "View Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
    ]}
  />

  <!-- ========== SERVICES ========== -->
  <section class="section" id="services" aria-label="Our services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Services</p>
        <h2>What We Do</h2>
      </div>
      <div class="section-content reveal">
        <p>End-to-end digital solutions tailored to your business needs. As a full-service digital marketing agency in Singapore, Jraft Creative helps brands build a powerful online presence through expert website development, SEO services, social media marketing, paid ads management, and <a href="/geo-agency-singapore/">Generative Engine Optimisation (GEO)</a>.</p>
        <p>Whether you need a high-converting <a href="/services/website-development/">web design</a>, an <a href="/ecommerce-website-singapore/">ecommerce store</a>, or a results-driven <a href="/digital-marketing-agency-singapore/">digital strategy</a>, our team delivers measurable business growth — from concept to launch and beyond. We also offer specialised <a href="/services/seo-performance/">SEO services</a>, <a href="/google-ads-agency-singapore/">Google Ads management</a>, <a href="/services/social-media/">social media marketing</a>, and <a href="/chatgpt-optimisation-singapore/">ChatGPT optimisation</a> to get your brand recommended by AI. Explore our full <a href="/services/ai-search-optimisation/">AI search optimisation</a> services.</p>
      </div>
      <div class="services-grid services-grid-5">
        <ServiceCard
          title="Website Development"
          description="Custom websites, stores, and web apps — designed to convert and built to scale."
          backgroundImage="/images/service-webdev.webp"
          id="serviceWebDev"
          revealClass="reveal-d1"
          expandable={true}
          subItems={webDevSubItems}
          pricing={{
            title: "Transparent Pricing",
            description: "No hidden fees. Choose the package that fits your needs.",
            id: "pricing-webdev",
            cards: [
              { name: "Starter", price: "$2,500", unit: "SGD", description: "Perfect for small businesses needing a professional online presence.", features: ["Up to 5 pages", "Mobile responsive design", "Contact form", "Basic SEO setup", "2 rounds of revisions", "1 month support"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-secondary" },
              { name: "Business", price: "$5,500", unit: "SGD", description: "For growing businesses that need more functionality and polish.", features: ["Up to 12 pages", "Custom design & animations", "CMS / blog integration", "Booking or enquiry system", "Advanced SEO & analytics", "3 months support"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-primary", featured: true },
              { name: "Premium", price: "$10,000+", unit: "SGD", description: "Full ecommerce, web apps, and complex custom builds.", features: ["Unlimited pages", "Ecommerce / web app", "Payment integration", "User accounts & dashboards", "API integrations", "6 months support"], cta: "Let's Talk", ctaHref: "/contact/", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="SEO & Performance"
          description="Search engine optimisation, speed optimisation, and analytics setup to maximise your online visibility and rankings."
          backgroundImage="/images/service-seo.webp"
          id="serviceSeo"
          revealClass="reveal-d2"
          expandable={true}
          subItems={seoSubItems}
          pricing={{
            title: "SEO Pricing",
            description: "Monthly retainer plans. Results-driven, no lock-in contracts.",
            cards: [
              { name: "Essential", price: "$800", unit: "SGD/mo", description: "For small businesses looking to build organic visibility.", features: ["Technical SEO audit", "On-page optimisation (10 pages)", "Google Analytics & Search Console", "Monthly keyword tracking", "Monthly performance report"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-secondary" },
              { name: "Growth", price: "$1,500", unit: "SGD/mo", description: "For businesses ready to dominate search rankings.", features: ["Everything in Essential", "Content strategy & blog SEO", "Link building (5 links/mo)", "Competitor analysis", "Local SEO & Google Business", "Bi-weekly reporting"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-primary", featured: true },
              { name: "Enterprise", price: "$3,000+", unit: "SGD/mo", description: "Full-service SEO for high-traffic sites and competitive industries.", features: ["Everything in Growth", "Dedicated SEO strategist", "Advanced link building (15+/mo)", "Content creation & publishing", "Core Web Vitals optimisation", "Weekly reporting & strategy calls"], cta: "Let's Talk", ctaHref: "/contact/", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="Paid Performance Marketing"
          description="Google Ads, Meta Ads, and data-driven paid campaigns that deliver measurable ROI and qualified leads."
          backgroundImage="/images/service-ads.webp"
          id="serviceAds"
          revealClass="reveal-d3"
          expandable={true}
          subItems={adsSubItems}
          pricing={{
            title: "Paid Ads Pricing",
            description: "Management fees are separate from ad spend. No minimum contract.",
            cards: [
              { name: "Starter", price: "$1,000", unit: "SGD/mo", description: "For businesses testing paid channels for the first time.", features: ["1 platform (Google or Meta)", "Campaign setup & strategy", "Ad copywriting & creatives", "Pixel & conversion tracking", "Monthly performance report"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-secondary" },
              { name: "Growth", price: "$2,500", unit: "SGD/mo", description: "For businesses scaling with multi-platform campaigns.", features: ["2 platforms (Google + Meta)", "A/B testing & creative iteration", "Retargeting & lookalike audiences", "Landing page recommendations", "Bi-weekly reporting & optimisation", "Dedicated account manager"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-primary", featured: true },
              { name: "Scale", price: "$5,000+", unit: "SGD/mo", description: "Full-funnel paid strategy across all major platforms.", features: ["All platforms (Google, Meta, TikTok, YouTube)", "Video ad production", "Advanced attribution modelling", "Real-time dashboard access", "Weekly strategy calls", "Dedicated strategist"], cta: "Let's Talk", ctaHref: "/contact/", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="Social Media Content Creation"
          description="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn that build your brand."
          backgroundImage="/images/service-social.webp"
          id="serviceSocial"
          revealClass="reveal-d4"
          expandable={true}
          subItems={socialSubItems}
          pricing={{
            title: "Social Media Pricing",
            description: "Monthly content packages. All content is yours to keep and reuse.",
            cards: [
              { name: "Essential", price: "$2,000", unit: "SGD/mo", description: "For brands starting their social media presence.", features: ["12 posts per month", "2 platforms", "Branded graphic design", "Captions & hashtags", "Monthly content calendar"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-secondary" },
              { name: "Professional", price: "$3,000", unit: "SGD/mo", description: "For brands ready to grow and engage consistently.", features: ["20 posts per month", "3 platforms", "4 Reels / short-form videos", "Stories & highlights design", "Captions, hashtags & scheduling", "Basic community management"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-primary", featured: true },
              { name: "Full-Service", price: "$5,000+", unit: "SGD/mo", description: "End-to-end social media management for serious brands.", features: ["30+ posts per month", "All platforms", "8+ Reels & video production", "Full community management", "Influencer coordination", "Monthly analytics & strategy review"], cta: "Let's Talk", ctaHref: "/contact/", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
        <ServiceCard
          title="AI Search Optimisation (GEO)"
          description="Get your brand recommended by ChatGPT, Gemini, and Perplexity. AI visibility audits, content optimisation, and citation monitoring."
          backgroundImage="/images/service-seo.webp"
          id="serviceGeo"
          revealClass="reveal-d1"
          expandable={true}
          subItems={geoSubItems}
          pricing={{
            title: "GEO Pricing",
            description: "Monthly retainer plans. No lock-in contracts.",
            cards: [
              { name: "Essentials", price: "$3,000", unit: "SGD/mo", description: "For businesses starting their AI visibility journey.", features: ["AI visibility audit & baseline", "Schema markup implementation", "Content optimisation (5 pages/mo)", "llms.txt setup & maintenance", "Monthly AI visibility report", "Quarterly strategy review"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-secondary" },
              { name: "Growth", price: "$5,000", unit: "SGD/mo", description: "For businesses ready to dominate AI recommendations.", features: ["Everything in Essentials", "Content optimisation (20 pages/mo)", "Authority building & directories", "Answer Engine content creation", "Bi-weekly reporting & benchmarks", "Dedicated GEO strategist", "Content freshness programme"], cta: "Get Started", ctaHref: "/contact/", ctaClass: "btn btn-primary", featured: true },
              { name: "Enterprise", price: "$10,000+", unit: "SGD/mo", description: "Full-service AI search domination across all platforms.", features: ["Everything in Growth", "Multi-platform defensive monitoring", "Wikipedia presence strategy", "Weekly calls & real-time dashboard", "50+ prompt monitoring daily", "Sentiment defence & crisis alerts"], cta: "Let's Talk", ctaHref: "/contact/", ctaClass: "btn btn-secondary" }
            ]
          }}
        />
      </div>

      <!-- Bundles subsection — packaged offer, distinct from individual services -->
      <div class="bundles-block" aria-labelledby="bundles-heading">
        <div class="bundles-header reveal">
          <p class="section-label">Bundles</p>
          <h3 id="bundles-heading">Or get it all in one package.</h3>
        </div>

        <article class="bundle-card reveal reveal-d1" aria-label="Growth Bundle">
          <div class="bundle-card-body">
            <div class="bundle-tag">
              <span class="bundle-tag-dot" aria-hidden="true"></span>
              Bundle
            </div>
            <h4 class="bundle-title">Growth Bundle</h4>
            <p class="bundle-desc">Paid ads + social media content — one team, one price. Built for Singapore startups and small businesses.</p>
            <ul class="bundle-list">
              <li>Meta + Google Ads management</li>
              <li>4–6 short videos + 4–6 static posts / month</li>
              <li>Monthly reporting + strategy call</li>
            </ul>
            <p class="bundle-savings">Save vs. buying Ads + Social separately.</p>
          </div>
          <div class="bundle-card-aside">
            <div class="bundle-price">
              <span class="bundle-price-amount">$2,999</span>
              <span class="bundle-price-unit">SGD / month</span>
            </div>
            <a href="/growth-bundle/" class="btn btn-primary bundle-cta">See the Growth Bundle</a>
            <p class="bundle-fine">No lock-in. Cancel anytime.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <style>
    /* Bundles subsection — packaged offer, distinct from standard ServiceCards */
    .bundles-block {
      margin-top: 80px;
    }
    .bundles-header {
      margin-bottom: 28px;
    }
    .bundles-header .section-label {
      margin-bottom: 8px;
    }
    .bundles-header h3 {
      font-family: 'Ripley Grotesque', 'Inter', sans-serif;
      font-size: clamp(1.6rem, 3vw, 2.25rem);
      font-weight: 500;
      line-height: 1.15;
      letter-spacing: -0.01em;
      color: var(--text, #f4f1ea);
      margin: 0;
    }

    .bundle-card {
      position: relative;
      display: grid;
      grid-template-columns: 1.45fr 1fr;
      gap: 0;
      background: var(--bg-card);
      border: 1px solid var(--accent);
      border-radius: var(--radius-sm, 8px);
      overflow: hidden;
      box-shadow: 0 0 0 1px rgba(73, 184, 137, 0.10), 0 24px 60px -28px rgba(73, 184, 137, 0.25);
    }
    .bundle-card::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(60% 80% at 100% 0%, rgba(73, 184, 137, 0.10), transparent 60%);
    }

    .bundle-card-body {
      padding: 40px 40px 36px;
      position: relative;
      z-index: 1;
    }
    .bundle-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border: 1px solid var(--accent);
      border-radius: 999px;
      background: var(--accent-dim);
      color: var(--accent);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .bundle-tag-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
    }
    .bundle-title {
      font-family: 'Ripley Grotesque', 'Inter', sans-serif;
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin: 0 0 12px;
      color: var(--text, #f4f1ea);
    }
    .bundle-desc {
      font-size: 1.02rem;
      line-height: 1.55;
      color: var(--text-muted, #b3b3b8);
      margin: 0 0 22px;
      max-width: 56ch;
    }
    .bundle-list {
      list-style: none;
      margin: 0 0 20px;
      padding: 0;
      display: grid;
      gap: 10px;
    }
    .bundle-list li {
      position: relative;
      padding-left: 22px;
      font-size: 0.95rem;
      color: var(--text, #f4f1ea);
      line-height: 1.5;
    }
    .bundle-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 10px;
      height: 2px;
      background: var(--accent);
    }
    .bundle-savings {
      margin: 0;
      font-size: 0.85rem;
      color: var(--accent);
      letter-spacing: 0.02em;
    }

    .bundle-card-aside {
      padding: 40px 40px 36px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 18px;
      background: linear-gradient(180deg, rgba(73, 184, 137, 0.06) 0%, rgba(73, 184, 137, 0.02) 100%);
      border-left: 1px solid rgba(73, 184, 137, 0.22);
      position: relative;
      z-index: 1;
    }
    .bundle-price {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .bundle-price-amount {
