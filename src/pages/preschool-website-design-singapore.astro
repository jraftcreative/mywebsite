---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Preschool Website Design Singapore",
    "description": "Custom website design for preschools in Singapore. Virtual tours, N1/N2/K1/K2 programme pages, online enrolment forms, ECDA compliance display, and parent portal links — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Preschool Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Preschool Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page preschool website with programme overview, enrolment form, photo gallery, contact page, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Preschool Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with virtual tour, teacher profiles, N1/N2/K1/K2 curriculum pages, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Preschool Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with parent portal integration, multi-branch pages, online registration and waitlist, ECDA compliance display, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a preschool website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professionally designed preschool website in Singapore ranges from $2,500 to $10,000+ SGD. Our Starter package at $2,500 covers a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages include virtual tours, parent portals, multi-branch support, and ECDA compliance pages." } },
      { "@type": "Question", "name": "Can parents register or join a waitlist through our preschool website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build online registration and waitlist forms directly into your preschool website. Parents can select the N1, N2, K1, or K2 programme, enter their child's date of birth, upload required documents, and receive an automated confirmation — all without your staff needing to process paper forms." } },
      { "@type": "Question", "name": "How do you display ECDA licensing and compliance information?", "acceptedAnswer": { "@type": "Answer", "text": "We create a dedicated section on your website that prominently shows your ECDA licence number, SPARK certification badge, teacher-to-child ratios, and any MOE kindergarten registration details. These trust signals are placed where parents naturally look during their shortlisting research." } },
      { "@type": "Question", "name": "Will my preschool appear on Google Maps and local search results?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We optimise your website for local SEO and set up or enhance your Google Business Profile so your preschool appears in Google Maps and 'preschool near me' search results. We also add location-specific schema markup to help Google connect your website with your physical centre." } },
      { "@type": "Question", "name": "How long does it take to build a preschool website?", "acceptedAnswer": { "@type": "Answer", "text": "Most preschool websites are completed within 2-3 weeks. A straightforward 5-page site can go live in under 2 weeks, while larger projects with parent portal integration, virtual tours, or multi-branch setups typically take 3-4 weeks. We provide a clear project timeline before we begin." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Preschool Website Design Singapore", "item": "https://jraftcreative.com/preschool-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Preschool Website Design Singapore — Early Childhood Web Design | Jraft Creative"
  description="Custom website design for preschools in Singapore. Virtual tours, N1/N2/K1/K2 programme pages, online enrolment forms, ECDA compliance display, and parent portal links — from S$2,500."
  canonical="https://jraftcreative.com/preschool-website-design-singapore/"
  ogTitle="Preschool Website Design Singapore — Jraft Creative"
  ogDescription="Website design for preschools in Singapore. Virtual tours, programme pages, enrolment forms, and ECDA compliance display — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="preschool website design singapore, preschool web design, nursery website singapore, childcare website design, early childhood centre website, ECDA preschool website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Preschool Website Design"
  heroTitle='Website Design for <span class="highlight">Preschools in Singapore</span>'
  heroSubtitle="Parents research 3 to 5 preschools online before scheduling a single visit. We design websites that give families the confidence to choose your centre — with virtual tours, N1/N2/K1/K2 programme pages, teacher profiles, and online enrolment forms built for how Singapore parents actually search."
  heroImage="/images/service-preschool.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my preschool in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Preschool Online"
  ctaDescription="Tell us about your preschool and we'll send you a tailored proposal within 24 hours. No obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20preschool%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why preschools need a professional website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Singapore Parents Compare Preschools Online Before Visiting Any of Them</h2>
      </div>
      <div class="section-content reveal">
        <p>The typical Singapore parent visits 3 to 5 preschool websites before booking a single centre tour. They compare programme structures, check ECDA licensing status, read parent reviews, and look through classroom photos — all from their phone during a lunch break or after the kids are asleep. If your preschool doesn't have a website, or if your site loads slowly and looks like it was built a decade ago, you've already lost that parent to a competitor who invested in their online presence.</p>
        <p>A listing on SgKindergartens or a Facebook page with sporadic updates isn't enough. Parents want to see structured programme breakdowns by level — Nursery 1, Nursery 2, Kindergarten 1, Kindergarten 2 — with clear information on learning outcomes, daily routines, teacher qualifications, and fee structures. They want to download registration forms or submit an enrolment inquiry online at midnight, not wait until Monday morning to call your office.</p>
        <p>Singapore has over 1,800 ECDA-licensed early childhood centres, and new ones open every quarter. Whether you run a single-centre preschool in Punggol or a growing chain with branches in Bukit Timah and Tanjong Pagar, your website is the first touchpoint that shapes parent perception. It needs to communicate warmth, professionalism, and transparency — the same qualities you deliver inside your classrooms every day.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Preschool website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Preschools</h2>
      </div>
      <div class="section-content reveal">
        <p>Every preschool website we deliver is designed specifically for Singapore's early childhood education landscape. We go beyond generic school templates — your site will feature virtual classroom tours, structured programme pages for each level, teacher profile sections, and online registration that parents can complete from any device.</p>
        <p>Your website is just the starting point. Pair it with our <a href="/services/seo-performance/">SEO services</a> to rank for "preschool near me" searches in your neighbourhood, <a href="/services/social-media/">social media marketing</a> to share classroom highlights and build a parent community, and <a href="/services/paid-ads/">paid ads management</a> to drive targeted enrolment inquiries during peak registration seasons.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Virtual Tours &amp; Photo Galleries</h3>
            <p>Interactive virtual walkthroughs and curated photo galleries of your classrooms, outdoor play areas, meal preparation spaces, and learning corners. Parents who can't visit in person — especially expat families relocating to Singapore — get a genuine feel for your preschool environment before making their shortlist.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>N1 / N2 / K1 / K2 Programme Pages</h3>
            <p>Dedicated pages for each programme level — Nursery 1, Nursery 2, Kindergarten 1, and Kindergarten 2. We lay out your curriculum approach, daily schedules, enrichment activities, learning milestones, and teacher-to-child ratios so parents can see exactly what their child will experience at every stage.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Online Enrolment &amp; Waitlist Forms</h3>
            <p>Custom registration forms that capture the child's date of birth, preferred programme level, start date, and any dietary or medical requirements. Parents receive automated confirmation emails upon submission, and your admin team gets organised entries instead of scattered WhatsApp messages and handwritten forms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Teacher Profiles &amp; ECDA Compliance</h3>
            <p>Dedicated sections for teacher qualifications, years of experience, and teaching philosophy — giving parents confidence in the people caring for their children. We also display your ECDA licence number, SPARK certification status, and subsidy eligibility details so families can verify your credentials at a glance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for preschool website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Preschool Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We build websites for education providers across Singapore. We understand how parents evaluate preschools online, what information drives enrolment decisions, and how to design every page to turn a browsing parent into a scheduled centre visit.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Built for the Singapore Preschool Market</h3>
            <p>We know the local early childhood landscape — ECDA regulations, SPARK accreditation requirements, MOE kindergarten programme alignment, CDA and AEIS subsidy displays. Your website is built around how preschools in Singapore actually operate and what local parents expect to see.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Live in 2 to 3 Weeks</h3>
            <p>We deliver fast because we know preschool timelines. Whether you're preparing for the January intake, opening a new branch mid-year, or replacing an outdated site before your next open house, your website will be ready when you need it.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First for On-the-Go Parents</h3>
            <p>Over 80% of preschool website traffic in Singapore comes from mobile devices. Every site we build is designed for parents scrolling on their phones — fast load times, tap-to-call buttons, thumb-friendly forms, and images optimised so nothing lags on a 4G connection during the MRT commute.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Website, SEO &amp; Marketing Under One Roof</h3>
            <p>Your preschool website is the foundation, but it works best paired with local SEO, social media content, and targeted ads. We handle your entire digital presence so you can focus on what you do best — running your centre and nurturing your students.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Preschool website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Preschool Website Pricing</p>
        <h2>Website Packages for Preschools</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For single-centre preschools launching their first website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme overview (N1–K2)</li>
              <li>Online enrolment form</li>
              <li>Photo gallery</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing preschools ready to increase enrolment.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Detailed N1/N2/K1/K2 pages</li>
              <li>Virtual tour integration</li>
              <li>Teacher profile sections</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-branch preschool groups and operators.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom design &amp; features</li>
              <li>Multi-branch location pages</li>
              <li>Parent portal integration</li>
              <li>Online waitlist &amp; registration</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about preschool website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Preschool Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a preschool website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professionally designed preschool website in Singapore ranges from $2,500 to $10,000+ SGD. Our Starter package at $2,500 covers a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages include virtual tours, teacher profiles, parent portals, and multi-branch support.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can parents register or join a waitlist through our preschool website?</summary>
          <div class="faq-answer"><p>Yes. We build online registration and waitlist forms directly into your website. Parents can select the N1, N2, K1, or K2 programme, enter their child's date of birth, upload required documents, and receive an automated confirmation — all without your staff needing to process paper forms or chase WhatsApp messages.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How do you display ECDA licensing and compliance information?</summary>
          <div class="faq-answer"><p>We create a dedicated section on your website that prominently shows your ECDA licence number, SPARK certification badge, teacher-to-child ratios, and any MOE kindergarten registration details. These trust signals are placed in high-visibility areas where parents naturally look when evaluating a preschool online.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will my preschool appear on Google Maps and local search results?</summary>
          <div class="faq-answer"><p>Yes. We optimise your website for local SEO and set up or enhance your Google Business Profile so your preschool ranks in Google Maps and "preschool near me" search results. We also add location-specific schema markup to connect your website with your physical centre and improve visibility in your neighbourhood.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a preschool website?</summary>
          <div class="faq-answer"><p>Most preschool websites are completed within 2 to 3 weeks. A straightforward 5-page site can go live in under 2 weeks, while larger projects with parent portal integration, virtual tours, or multi-branch setups typically take 3 to 4 weeks. We share a detailed project timeline before work begins.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
