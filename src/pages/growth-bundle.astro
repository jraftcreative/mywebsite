<style>
  /* ═══ GROWTH BUNDLE PAGE STYLES (typographic hero + v19 carved-arc photo) ═══ */

  /* ── HERO (typographic, DARK-MODE matched to live site) ─────────── */
  .gb-hero--typo {
    position: relative;
    overflow: hidden;
    padding: 180px 0 120px;
    background: var(--bg);
    isolation: isolate;
    width: 100%;
    max-width: 100vw;
    box-sizing: border-box;
    min-height: 100vh;        /* fallback for browsers without svh support */
    min-height: 100svh;       /* fill the viewport, mobile-chrome aware */
    display: flex;
    align-items: center;      /* vertically center foreground content */
  }
  .gb-hero--typo *,
  .gb-hero--typo *::before,
  .gb-hero--typo *::after {
    box-sizing: border-box;
  }

  /* Subtle accent glow at the bottom — mirrors the live .gb-hero::before treatment */
  .gb-hero--typo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 85%, var(--accent-glow) 0%, transparent 60%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Carved-arc photo region (desktop) ────────────────────────────────
     The hero rectangle's right edge is straight; ellipse() clips a concave
     "scoop" into the photo region's LEFT edge. Anchored at right:50% means
     the ellipse centre sits on the right edge of the photo region, so the
     photo is full-bleed to the right of the viewport and curves inward as
     it sweeps left. Horizontal radius 78%, vertical radius 95% — generous
     enough to read as an architectural sweep at 1440w. */
  .gb-hero-photo {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50vw;
    background-color: var(--bg);
    z-index: 1;
    /* The scoop — anchored to the right edge, vertically centered.
       Bigger horizontal radius = deeper concave sweep into the hero. */
    -webkit-clip-path: ellipse(92% 105% at 100% 50%);
    clip-path: ellipse(92% 105% at 100% 50%);
    overflow: hidden;          /* clip the Ken-Burns inner to the box bounds */
    pointer-events: none;
  }

  /* Ken-Burns inner — holds the background-image and the slow zoom + vertical
     drift. Sized 136% × 136% (inset:-18%) so the most-zoomed-out frame
     (scale 1.0 paired with translateY ±5%) still bleeds ≥10% past the clip
     ellipse on every edge → no mask edge ever visible. GPU-only transforms
     (scale + translateY). Vertical motion is orthogonal to the GROWTH
     wordmark's horizontal drift. */
  .gb-hero-photo-inner {
    position: absolute;
    inset: -18%;
    background-image: url('/hero-stock.jpg?v=10');
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    filter: brightness(0.88) saturate(1.05);
    transform-origin: 50% 50%;
    will-change: transform;
    animation: gb-hero-photo-kenburns 48s linear infinite;
  }

  /* Zoom (1.0 → 1.18) + vertical drift (+5% → -5%).
     linear timing for constant interpolation speed — no acceleration
     at the start of the zoom. Direction reversals at 0% / 50% / 100%
     produce a subtle pause at apex/nadir, which reads as less jarring
     than the ease-in-out's mid-cycle speed-up. */
  @keyframes gb-hero-photo-kenburns {
    0%   { transform: scale(1.0)  translate3d(0, 5%, 0); }
    50%  { transform: scale(1.18) translate3d(0, -5%, 0); }
    100% { transform: scale(1.0)  translate3d(0, 5%, 0); }
  }

  /* Soft dark overlay along the carved edge so the photo's left lip blends
     into the dark hero palette rather than crashing into the H1.
     Stays on the parent so it doesn't move with the Ken-Burns transform. */
  .gb-hero-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--bg) 0%,
      rgba(8, 8, 13, 0.55) 12%,
      rgba(8, 8, 13, 0.0) 38%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Massive outlined GROWTH lettering.
     CONSTRAINT: must not overlap the carved photo region. We pin it inside
     the LEFT half of the hero by clamping right to ~50vw and overflow:hidden
     on the typo container so any drift stays in-bounds. */
  .gb-hero-typo-bg {
    position: absolute;
    top: 50%;
    left: -4%;
    right: 50%;            /* hard stop at viewport midline */
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 0;
    line-height: 0.85;
    white-space: nowrap;
    overflow: hidden;
    will-change: transform;
  }
  .gb-hero-typo-word {
    display: block;
    font-family: 'Ripley Grotesque', 'Inter', system-ui, -apple-system, sans-serif;
    font-size: clamp(280px, 42vw, 620px);
    font-weight: 900;
    letter-spacing: -0.06em;
    color: transparent;
    -webkit-text-stroke: 2px rgba(240, 240, 242, 0.06);
    text-stroke: 2px rgba(240, 240, 242, 0.06);
    /* Ambient horizontal drift — barely perceptible. GPU transform only.
       Drift is now contained inside the left half. */
    animation: gb-hero-drift 42s ease-in-out infinite;
    will-change: transform;
  }

  /* Drift travels ~7vw left then back. Starts at 0 (no fade-in). */
  @keyframes gb-hero-drift {
    0%   { transform: translate3d(0, 0, 0); }
    50%  { transform: translate3d(-7vw, 0, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  /* Accessibility hard rule — disable for reduced-motion users.
     Covers both the GROWTH wordmark drift and the photo Ken-Burns. */
  @media (prefers-reduced-motion: reduce) {
    .gb-hero-typo-word,
    .gb-hero-photo-inner {
      animation: none;
    }
    /* Reset the inner to its neutral resting frame so no transient transform
       is left applied if the user toggles reduced-motion mid-session. */
    .gb-hero-photo-inner {
      transform: none;
    }
  }

  /* Container — foreground stack lives in the LEFT ~55% so it never collides
     with the carved-arc photo. The photo region is absolutely positioned, so
     this is a single-column layout for content. */
  .gb-hero-typo-container {
    position: relative;
    z-index: 2;
    width: 100%;
    display: block;
  }
  .gb-hero-typo-content {
    text-align: left;
    max-width: 600px;
    width: 55%;
    min-width: 0;
    padding-right: 32px;  /* keep text from drifting under the scoop */
  }

  /* Badge — mirror the live .gb-badge treatment (outlined, not filled) */
  .gb-hero--typo .gb-badge {
    display: inline-block;
    padding: 6px 16px;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--border-accent);
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: none;
    margin-bottom: 28px;
  }

  /* H1 */
  .gb-hero-typo-h1 {
    font-family: 'Ripley Grotesque', 'Inter', system-ui, -apple-system, sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--text);
    margin: 0 0 24px;
  }
  .gb-h1-line {
    display: block;
  }
  .gb-h1-accent {
    color: var(--accent);
  }

  /* Subhead */
  .gb-hero-typo-sub {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.55;
    margin: 0 0 28px;
  }

  /* CTAs — leave .btn-primary / .btn-secondary to cascade from global.css.
     Just lay them out here. */
  .gb-hero-typo-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }

  /* ── EXISTING PAGE STYLES (sections below hero) ─────────────── */

  /* Section labels & headings (used by all sections below hero) */
  .gb-section {
    padding: 100px 0;
  }
  .gb-section--alt {
    background: var(--bg-alt);
  }
  .gb-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
    text-align: center;
  }
  .gb-section h2 {
    text-align: center;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .gb-section-sub {
    text-align: center;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 48px;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  /* Problem Cards */
  .gb-problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 48px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .gb-problem-card {
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    transition: border-color 0.3s;
  }
  .gb-problem-card:hover {
    border-color: var(--border-accent);
  }
  .gb-problem-card svg {
    width: 28px;
    height: 28px;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .gb-problem-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .gb-problem-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Includes */
  .gb-includes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
  }
  .gb-includes-card {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }
  .gb-includes-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .gb-includes-header svg {
    width: 28px;
    height: 28px;
    color: var(--accent);
    flex-shrink: 0;
  }
  .gb-includes-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
  }
  .gb-includes-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .gb-includes-list li {
    font-size: 0.88rem;
    color: var(--text-secondary);
    padding-left: 24px;
    position: relative;
    line-height: 1.5;
  }
  .gb-includes-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }

  /* Who Tags */
  .gb-who-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    max-width: 700px;
    margin: 0 auto;
  }
  .gb-who-tag {
    padding: 10px 22px;
    border: 1px solid var(--border);
    border-radius: 50px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    cursor: default;
  }
  .gb-who-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Steps */
  .gb-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-top: 48px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  .gb-step {
    text-align: center;
    flex: 1;
    max-width: 260px;
    padding: 0 16px;
  }
  .gb-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg-dark);
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }
  .gb-step h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .gb-step p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .gb-step-arrow {
    display: flex;
    align-items: center;
    padding-top: 10px;
    color: var(--text-muted);
    opacity: 0.3;
  }
  .gb-step-arrow svg {
    width: 28px;
    height: 28px;
  }

  /* Pricing */
  .gb-pricing-wrap {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    max-width: 860px;
    margin: 48px auto 0;
    align-items: start;
  }
  .gb-pricing-card {
    padding: 40px;
    border: 2px solid var(--border-accent);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-align: center;
    position: relative;
  }
  .gb-pricing-tag {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--bg-dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 5px 20px;
    border-radius: 50px;
    letter-spacing: 0.04em;
  }
  .gb-pricing-amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text);
  }
  .gb-pricing-period {
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .gb-pricing-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 12px 0 24px;
    line-height: 1.5;
  }
  .gb-pricing-list {
    list-style: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }
  .gb-pricing-list li {
    font-size: 0.88rem;
    color: var(--text-secondary);
    padding-left: 24px;
    position: relative;
  }
  .gb-pricing-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .gb-pricing-btn {
    width: 100%;
    justify-content: center;
  }
  /* Compare */
  .gb-pricing-compare {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }
  .gb-pricing-compare h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 20px;
    color: var(--text-muted);
  }
  .gb-compare-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .gb-compare-price {
    color: var(--text-secondary);
    font-weight: 600;
  }
  .gb-compare-total {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: line-through;
    opacity: 0.5;
  }
  .gb-compare-savings {
    display: flex;
    justify-content: space-between;
    padding: 16px 0 0;
    font-size: 1rem;
    font-weight: 700;
  }
  .gb-savings-price {
    color: var(--accent);
    font-size: 1.1rem;
  }
  .gb-compare-note {
    margin-top: 16px;
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* FAQ */
  .gb-faq-list {
    max-width: 680px;
    margin: 40px auto 0;
  }
  .gb-faq {
    border-bottom: 1px solid var(--border);
    padding: 18px 0;
    cursor: pointer;
  }
  .gb-faq-q {
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .gb-faq-q svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--accent);
    transition: transform 0.3s;
  }
  .gb-faq.open .gb-faq-q svg {
    transform: rotate(180deg);
  }
  .gb-faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s;
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
  .gb-faq.open .gb-faq-a {
    max-height: 300px;
    padding-top: 12px;
  }

  /* CTA */
  .gb-cta {
    padding: 100px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .gb-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 50%, var(--accent-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .gb-cta h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    margin-bottom: 12px;
    position: relative;
  }
  .gb-cta p {
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto 28px;
    position: relative;
    font-size: 0.95rem;
  }
  .gb-cta .btn {
    position: relative;
  }
  .gb-cta-note {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 16px;
    position: relative;
  }

  /* ── MOBILE (≤768px) — FULL-BLEED PHOTO BACKGROUND ──────────────────
     New mobile composition (per Jeremy's directive):
       - The SG photo becomes the FULL-BLEED background of the mobile hero
         (no carved arc on mobile — clip-path:none).
       - A bottom-weighted dark gradient overlays the photo so the upper
         portion shows the skyline clearly and the lower portion fades
         into the dark hero color for text legibility.
       - Foreground stack (badge, H1, sub, CTAs) sits in the LOWER portion
         where the gradient is darkest — best contrast for body copy.
       - GROWTH wordmark is hidden on mobile to keep the composition clean
         against the photo background.
       - Ken Burns continues to run on the full-bleed image.
     Overflow safety: overflow-x:hidden on the hero, viewport-bounded
     widths, all foreground content respects the container's 20px gutters. */
  @media (max-width: 768px) {
    .gb-hero--typo {
      /* Flex-start + upper-third top padding positions the foreground text
         stack roughly in the UPPER THIRD of the mobile hero (well clear of
         the status bar). Bottom padding leaves breathing room above the
         home indicator / chrome. */
      padding: 25vh 0 56px;
      overflow-x: hidden;
      overflow-y: hidden;
      display: flex;
      align-items: flex-start;   /* foreground sits in upper third */
      /* Fill the FULL phone window. svh = static viewport (safe fallback for
         older browsers). dvh = dynamic viewport — grows to match the actual
         visible window when mobile browser chrome auto-hides on scroll.
         Modern browsers pick the dvh value, older fall back to svh. */
      min-height: 100svh;
      min-height: 100dvh;
      position: relative;
    }
    .gb-hero-typo-container {
      display: block;
      max-width: 100%;
      position: relative;
      z-index: 2;
    }
    .gb-hero-typo-content {
      max-width: 100%;
      min-width: 0;
      width: 100%;
      padding-right: 0;
    }
    .gb-hero-typo-h1 {
      font-size: clamp(2rem, 8.5vw, 2.8rem);
      letter-spacing: -0.03em;
    }
    .gb-hero-typo-sub {
      font-size: 0.95rem;
      max-width: 100%;
      width: 100%;
    }
    .gb-hero-typo-ctas {
      flex-direction: column;
      align-items: stretch;
      gap: 10px;
      width: 100%;
      /* Drop CTAs ~28px below the subhead so they sit a touch lower
         with breathing room — text stack overall still upper-portion. */
      margin-top: 28px;
    }
    .gb-hero-typo-ctas .gb-cta-primary,
    .gb-hero-typo-ctas .gb-cta-secondary {
      text-align: center;
      width: 100%;
      display: block;
      box-sizing: border-box;
      padding-left: 14px;
      padding-right: 14px;
      white-space: normal;
      word-break: keep-all;
    }

    /* Hide the GROWTH wordmark on mobile — would compete with the photo
       background and make the composition feel busy. */
    .gb-hero-typo-bg { display: none; }

    /* Photo region becomes the full-bleed background of the mobile hero.
       inset:0 covers the entire hero box. clip-path:none drops the desktop
       carved arc. z-index:0 sits BEHIND the foreground (z-index:2) AND
       behind the radial accent glow (::after, z-index:1). */
    .gb-hero-photo {
      position: absolute;
      inset: 0;
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100%;
      max-width: 100vw;
      height: auto;
      min-height: 0;
      -webkit-clip-path: none;
      clip-path: none;
      z-index: 0;
    }
    /* Ken-Burns inner stays as-is (inset:-18% bleed handles the scale 1.18
       extreme), but on mobile we re-bias the focal point so the skyline
       sits in the upper half of the hero where the gradient is lightest.
       Brightness filter dims the underlying photo uniformly so text reads
       crisp at every position in the upper-third stack. The skyline still
       registers — it's just supporting, not dominating. */
    .gb-hero-photo-inner {
      background-position: center 30%;
      filter: brightness(0.6);
    }
    /* Stronger, more uniform overlay: heavier at the top (where the badge,
       headline, subhead and CTAs all live in the upper third), still
       carrying enough darkness through the middle so the photo never
       reveals through brightly behind body copy, and deepest at the
       bottom for visual grounding and a clean transition into the next
       section. */
    .gb-hero-photo::after {
      background: linear-gradient(
        180deg,
        rgba(8, 8, 13, 0.75) 0%,
        rgba(8, 8, 13, 0.65) 35%,
        rgba(8, 8, 13, 0.60) 65%,
        rgba(8, 8, 13, 0.95) 100%
      );
      inset: 0;
    }

    /* The hero's radial accent glow (::after on .gb-hero--typo) should
       still sit BETWEEN the photo and the foreground content — it adds
       the brand accent tint near the bottom of the composition. */

    .gb-badge {
      max-width: 100%;
      white-space: normal;
    }

    .gb-section { padding: 64px 0; }
    .gb-problem-grid { grid-template-columns: 1fr; }
    .gb-includes-grid { grid-template-columns: 1fr; }
    .gb-steps { flex-direction: column; align-items: center; gap: 24px; }
    .gb-step-arrow { transform: rotate(90deg); }
    .gb-pricing-wrap { grid-template-columns: 1fr; }
    .gb-cta { padding: 64px 0; }
  }

  /* Short-viewport phones (~700px tall and under): tighten vertical rhythm
     and pull the upper-third stack slightly higher so the CTAs still clear
     the bottom safe area. */
  @media (max-width: 768px) and (max-height: 700px) {
    .gb-hero--typo { padding: 20vh 0 44px; }
    .gb-hero--typo .gb-badge { margin-bottom: 18px; }
    .gb-hero-typo-h1 { margin: 0 0 16px; }
    .gb-hero-typo-sub { margin: 0 0 20px; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     PER-SECTION AMBIENT ORBS (sections below hero)
     System: each section gets a scoped radial-gradient orb on a pseudo-
     element. Animations are GPU-only (transform + opacity). The .gb-orb
     class establishes the clipping container; per-section modifier
     classes (--problem, --included, --who, --how, --pricing, --faq,
     --cta) define orb shape, position, color, and motion so every
     adjacent section has distinct ambient motion.
     ═══════════════════════════════════════════════════════════════════ */

  .gb-orb {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .gb-orb > .container {
    position: relative;
    z-index: 1;
  }
  .gb-orb::before,
  .gb-orb::after {
    content: '';
    position: absolute;
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform, opacity;
  }

  /* ── 1. #problem — single large orb, top-left, diagonal drift ── */
  .gb-orb--problem::before {
    width: 60vw;
    height: 60vw;
    max-width: 900px;
    max-height: 900px;
    top: -22vw;
    left: -18vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.42) 0%, rgba(73, 184, 137, 0.18) 38%, transparent 70%);
    opacity: 0.55;
    animation: gb-orb-drift-diag 42s ease-in-out infinite;
  }

  /* ── 2. #whats-included — two medium orbs, counter-rotating ── */
  .gb-orb--included::before {
    width: 38vw;
    height: 38vw;
    max-width: 560px;
    max-height: 560px;
    top: -10vw;
    right: -8vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.32) 0%, rgba(73, 184, 137, 0.12) 40%, transparent 70%);
    opacity: 0.55;
    animation: gb-orb-counter-a 46s ease-in-out infinite;
  }
  .gb-orb--included::after {
    width: 36vw;
    height: 36vw;
    max-width: 520px;
    max-height: 520px;
    bottom: -12vw;
    left: -10vw;
    background: radial-gradient(circle, rgba(70, 90, 130, 0.30) 0%, rgba(70, 90, 130, 0.10) 42%, transparent 72%);
    opacity: 0.55;
    animation: gb-orb-counter-b 50s ease-in-out infinite;
  }

  /* ── 3. Who This Is For — wide low orb, horizontal sweep ── */
  .gb-orb--who::before {
    width: 90vw;
    height: 28vw;
    max-height: 380px;
    top: 5%;
    left: 5vw;
    background: radial-gradient(ellipse at center, rgba(73, 184, 137, 0.32) 0%, rgba(73, 184, 137, 0.10) 45%, transparent 75%);
    border-radius: 50%;
    opacity: 0.55;
    animation: gb-orb-sweep-h 44s ease-in-out infinite;
  }

  /* ── 4. How It Works — 3 small orbs in a row, breathing pulse ── */
  .gb-orb--how::before {
    width: 22vw;
    height: 22vw;
    max-width: 320px;
    max-height: 320px;
    top: 30%;
    left: 6vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.30) 0%, rgba(73, 184, 137, 0.10) 45%, transparent 72%);
    animation: gb-orb-breath-a 38s ease-in-out infinite;
  }
  .gb-orb--how::after {
    width: 22vw;
    height: 22vw;
    max-width: 320px;
    max-height: 320px;
    top: 30%;
    right: 6vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.26) 0%, rgba(73, 184, 137, 0.09) 45%, transparent 72%);
    animation: gb-orb-breath-b 44s ease-in-out infinite;
  }
  /* Centre third orb via a delegated keyframe — uses an inline-styled
     extra element isn't needed because the section's two pseudo-elements
     plus the existing alt-bg color rhythm already carry the cadence. */

  /* ── 5. #pricing — single large halo behind the price card ── */
  .gb-orb--pricing::before {
    width: 50vw;
    height: 50vw;
    max-width: 720px;
    max-height: 720px;
    top: 50%;
    left: 50%;
    margin-top: -25vw;
    margin-left: -25vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.40) 0%, rgba(73, 184, 137, 0.16) 38%, transparent 72%);
    opacity: 0.6;
    animation: gb-orb-halo 36s ease-in-out infinite;
  }

  /* ── 6. #faq — single medium orb, bottom-right, drifts up-left ── */
  .gb-orb--faq::before {
    width: 42vw;
    height: 42vw;
    max-width: 620px;
    max-height: 620px;
    bottom: -14vw;
    right: -12vw;
    background: radial-gradient(circle, rgba(60, 80, 130, 0.32) 0%, rgba(60, 80, 130, 0.12) 42%, transparent 72%);
    opacity: 0.6;
    animation: gb-orb-drift-up 48s ease-in-out infinite;
  }

  /* ── 7. .gb-cta — huge orb, radial pulse. Replaces the static
     ::before glow that was already there with an animated version. ── */
  .gb-cta.gb-orb--cta::before {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    top: 0;
    left: 0;
    border-radius: 0;
    filter: none;
    background: radial-gradient(ellipse at 50% 50%, var(--accent-glow) 0%, transparent 60%);
    opacity: 1;
    animation: none;
  }
  .gb-cta.gb-orb--cta::after {
    width: 70vw;
    height: 70vw;
    max-width: 1000px;
    max-height: 1000px;
    top: 50%;
    left: 50%;
    margin-top: -35vw;
    margin-left: -35vw;
    background: radial-gradient(circle, rgba(73, 184, 137, 0.50) 0%, rgba(73, 184, 137, 0.20) 38%, transparent 70%);
    opacity: 0.55;
    animation: gb-orb-pulse 32s ease-in-out infinite;
  }
  .gb-cta.gb-orb--cta .container {
    position: relative;
    z-index: 1;
  }

  /* ── Keyframes — GPU-only (transform + opacity). 30-50s loops. ── */
  @keyframes gb-orb-drift-diag {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50%      { transform: translate3d(10vw, 8vw, 0); }
  }
  @keyframes gb-orb-counter-a {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50%      { transform: translate3d(-6vw, 5vw, 0); }
  }
  @keyframes gb-orb-counter-b {
    0%, 100% { transform: translate3d(0, 0, 0); }
