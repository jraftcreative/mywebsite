---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaData = [{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Jraft Growth Bundle",
  "description": "Paid ads management + social media content creation for Singapore small businesses. $2,999/month.",
  "brand": { "@type": "Organization", "name": "Jraft Creative" },
  "offers": {
    "@type": "Offer",
    "price": "2999",
    "priceCurrency": "SGD",
    "availability": "https://schema.org/InStock"
  }
}];
---

<BaseLayout
  title="Growth Bundle — Ads + Content $2,999/mo | Jraft"
  description="Paid ads + social content in one bundle. 4-6 videos, 4-6 static posts, Meta + Google Ads — all $2,999/month. Built for Singapore startups and SMEs."
  canonical="https://jraftcreative.com/growth-bundle/"
  ogTitle="Growth Bundle — Ads + Content $2,999/mo | Jraft"
  ogDescription="Paid ads + social content in one bundle. 4-6 videos, 4-6 static posts, Meta + Google Ads — all $2,999/month. Built for Singapore startups and SMEs."
  keywords="singapore marketing agency, small business marketing, social media management singapore, meta ads singapore, google ads singapore"
  schemaData={schemaData}
>

<!-- ═══ HERO (TYPOGRAPHIC + CARVED-ARC PHOTO — v19) ═══ -->
<section class="gb-hero gb-hero--typo">
  <!-- Carved-out photo region: full-bleed right, concave-curve left edge.
       Position: absolute so the foreground container can sit beside/over it
       without the layout fighting itself.
       The clip-path lives on the parent. The image + Ken Burns transform live
       on the inner child so the two never fight each other. -->
  <div
    class="gb-hero-photo"
    role="img"
    aria-label="Singapore CBD skyline at blue hour — UOB Plaza, OCBC Centre and Marina Bay financial district towers lit up at dusk"
  >
    <div class="gb-hero-photo-inner" aria-hidden="true"></div>
  </div>

  <!-- Massive outlined typographic background, constrained to the left half so
       the wordmark never overlaps the photo region. -->
  <div class="gb-hero-typo-bg" aria-hidden="true">
    <span class="gb-hero-typo-word">GROWTH</span>
  </div>

  <div class="container gb-hero-typo-container">
    <div class="gb-hero-typo-content">
      <span class="gb-badge">Limited Slots Each Month</span>
      <h1 class="gb-hero-typo-h1">
        <span class="gb-h1-line">Stop guessing.</span>
        <span class="gb-h1-line">Start <span class="gb-h1-accent">growing.</span></span>
      </h1>
      <p class="gb-hero-typo-sub">Paid ads + social media content — one team, one price. Built for Singapore startups and small businesses.</p>

      <div class="gb-hero-typo-ctas">
        <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I'm%20interested%20in%20the%20Growth%20Bundle.%20Can%20we%20chat%3F" class="btn btn-primary gb-cta-primary" target="_blank" rel="noopener">Book a 15-Min Discovery Call</a>
        <a href="#whats-included" class="btn btn-secondary gb-cta-secondary">See What's Included</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══ PROBLEM ═══ -->
<section class="gb-section gb-orb gb-orb--problem" id="problem">
  <div class="container">
    <span class="gb-label">Sound Familiar?</span>
    <h2>You know you need marketing. But...</h2>
    <div class="gb-problem-grid">
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <h3>You don't have time</h3>
        <p>You're running the business. Who's going to plan content, write captions, shoot videos, and manage ads on top of everything else?</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        <h3>Individual services drain a small business</h3>
        <p>$2,000 for social media. $2,500 for ads. The pricing is normal — but it's built for businesses with marketing budgets, not founders running lean. Most SG SMEs can't sustain two retainers at once.</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <h3>Freelancers burned you</h3>
        <p>You hired someone cheap, got generic templates, inconsistent posting, and zero results. Now you're back to square one.</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <h3>You're posting randomly</h3>
        <p>You put up a post when you remember. No strategy, no consistency, no idea if it's working. Followers aren't growing and enquiries aren't coming.</p>
      </div>
