---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaData = [{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Jraft Growth Bundle",
  "description": "Paid ads management + social media content creation for Singapore small businesses. $2,999/month.",
  "brand": { "@type": "Organization", "name": "Jraft Creative" },
  "offers": {
    "@type": "Offer",
    "price": "2999",
    "priceCurrency": "SGD",
    "availability": "https://schema.org/InStock"
  }
}];
---

<BaseLayout
  title="Growth Bundle — Ads + Content for $2,999/mo | Jraft Creative"
  description="Paid ads + social media content creation in one bundle. 4-6 short-form videos, 4-6 static posts, Meta + Google Ads — all for $2,999/month. Built for Singapore startups and small businesses."
  canonical="https://jraftcreative.com/growth-bundle/"
  ogTitle="Growth Bundle — Ads + Content for $2,999/mo"
  ogDescription="Everything your business needs to grow online. Paid ads + social media content creation, $2,999/month. No fluff, no long contracts."
  keywords="singapore marketing agency, small business marketing, social media management singapore, meta ads singapore, google ads singapore"
  schemaData={schemaData}
>

<!-- ═══ HERO ═══ -->
<section class="gb-hero">
  <div class="container">
    <span class="gb-badge">Limited Slots Each Month</span>
    <h1>Stop guessing.<br/>Start growing.</h1>
    <p class="gb-hero-sub">Paid ads + social media content — one team, one price. Built for Singapore businesses that are ready to stop winging it.</p>
    <div class="gb-hero-price">
      <span class="gb-price">$2,999</span><span class="gb-price-period">/month</span>
    </div>
    <div class="gb-hero-ctas">
      <a href="https://wa.me/6582234578?text=Hi%20Jraft%2C%20I'm%20interested%20in%20the%20Growth%20Bundle.%20Can%20we%20chat%3F" class="btn btn-primary" target="_blank" rel="noopener">Book a 15-Min Discovery Call</a>
      <a href="#whats-included" class="btn btn-secondary">See What's Included</a>
    </div>
    <p class="gb-hero-note">3-month minimum &middot; Ad spend billed separately &middot; Cancel anytime after</p>
  </div>
</section>

<!-- ═══ PROBLEM ═══ -->
<section class="gb-section" id="problem">
  <div class="container">
    <span class="gb-label">Sound Familiar?</span>
    <h2>You know you need marketing. But...</h2>
    <div class="gb-problem-grid">
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <h3>You don't have time</h3>
        <p>You're running the business. Who's going to plan content, write captions, shoot videos, and manage ads on top of everything else?</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        <h3>Agencies are too expensive</h3>
        <p>You've gotten quotes. $2,000 for social media here, $2,500 for ads there. Suddenly you're looking at $5,000/month for two separate vendors.</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <h3>Freelancers burned you</h3>
        <p>You hired someone cheap, got generic templates, inconsistent posting, and zero results. Now you're back to square one.</p>
      </div>
      <div class="gb-problem-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        <h3>You're posting randomly</h3>
        <p>You put up a post when you remember. No strategy, no consistency, no idea if it's working. Followers aren't growing and enquiries aren't coming.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ WHAT'S INCLUDED ═══ -->
<section class="gb-section gb-section--alt" id="whats-included">
  <div class="container">
    <span class="gb-label">The Growth Bundle</span>
    <h2>Two services. One team. One price.</h2>
    <p class="gb-section-sub">Everything you'd pay two separate agencies for — combined into one bundle at $2,999/month.</p>

    <div class="gb-includes-grid">
      <div class="gb-includes-card">
        <div class="gb-includes-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <h3>Paid Ads Management</h3>
        </div>
        <ul class="gb-includes-list">
          <li>Meta Ads (Facebook + Instagram)</li>
          <li>Google Ads setup & management</li>
          <li>Audience targeting & lookalikes</li>
          <li>Ad creative design</li>
          <li>A/B testing & optimisation</li>
          <li>Pixel & conversion tracking setup</li>
          <li>Weekly performance monitoring</li>
          <li>Monthly reporting with recommendations</li>
        </ul>
      </div>
      <div class="gb-includes-card">
        <div class="gb-includes-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          <h3>Social Media Content</h3>
        </div>
        <ul class="gb-includes-list">
          <li>4–6 short-form videos/month (TikTok + Instagram Reels)</li>
          <li>4–6 static posts/month (Instagram or Facebook)</li>
          <li>Captions, hashtags & scheduling</li>
          <li>Content calendar planning</li>
          <li>Brand-consistent visual style</li>
          <li>Monthly content strategy call</li>
          <li>Revisions included</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══ WHO THIS IS FOR ═══ -->
<section class="gb-section">
  <div class="container">
    <span class="gb-label">Who This Is For</span>
    <h2>Built for businesses doing $10K–$100K/month</h2>
    <p class="gb-section-sub">You've got a real product or service. You've got customers. You just need the marketing engine to bring in more — consistently.</p>
    <div class="gb-who-grid">
      <div class="gb-who-tag">F&B & Restaurants</div>
      <div class="gb-who-tag">Clinics & Healthcare</div>
      <div class="gb-who-tag">Beauty & Aesthetics</div>
      <div class="gb-who-tag">Fitness & Gyms</div>
      <div class="gb-who-tag">Home Services</div>
      <div class="gb-who-tag">Education & Enrichment</div>
      <div class="gb-who-tag">Ecommerce & Retail</div>
      <div class="gb-who-tag">Professional Services</div>
    </div>
  </div>
</section>

<!-- ═══ HOW IT WORKS ═══ -->
<section class="gb-section gb-section--alt">
  <div class="container">
    <span class="gb-label">How It Works</span>
    <h2>Live in 7 days. Not 7 weeks.</h2>
    <div class="gb-steps">
      <div class="gb-step">
        <span class="gb-step-num">1</span>
        <h3>Discovery Call</h3>
        <p>15 minutes. We learn about your business, your goals, and whether this is the right fit. No pressure, no pitch deck.</p>
      </div>
      <div class="gb-step-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
      <div class="gb-step">
        <span class="gb-step-num">2</span>
        <h3>Onboarding</h3>
        <p>We set up your ad accounts, install tracking, plan your first month of content, and get creative assets ready. Done in 5–7 days.</p>
      </div>
      <div class="gb-step-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
      <div class="gb-step">
        <span class="gb-step-num">3</span>
        <h3>Ads + Content Go Live</h3>
        <p>Your ads start running, your content starts posting. You get a monthly report and strategy call. We handle everything.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ PRICING ═══ -->
<section class="gb-section" id="pricing">
  <div class="container">
    <span class="gb-label">Pricing</span>
    <h2>One price. No surprises.</h2>
    <div class="gb-pricing-wrap">
      <div class="gb-pricing-card">
        <span class="gb-pricing-tag">Growth Bundle</span>
        <div class="gb-pricing-price">
          <span class="gb-pricing-amount">$2,999</span>
          <span class="gb-pricing-period">/month</span>
        </div>
        <p class="gb-pricing-desc">Everything listed above. Paid ads + social media content. One invoice, one team.</p>
        <ul class="gb-pricing-list">
          <li>Meta Ads + Google Ads management</li>
          <li>4–6 short-form videos + 4–6 static posts/month</li>
          <li>Content calendar & scheduling</li>
          <li>Monthly performance report</li>
          <li>Monthly strategy call</li>
          <li>Pixel & tracking setup (one-time)</li>
        </ul>
        <a href="https://wa.me/6582234578?text=Hi%20Jraft%2C%20I'm%20interested%20in%20the%20Growth%20Bundle.%20Can%20we%20chat%3F" class="btn btn-primary gb-pricing-btn" target="_blank" rel="noopener">Book a 15-Min Call</a>
        <p class="gb-pricing-note">3-month minimum commitment</p>
      </div>

      <div class="gb-pricing-compare">
        <h3>What you'd pay separately</h3>
        <div class="gb-compare-row">
          <span>Social media agency</span>
          <span class="gb-compare-price">$2,000–$2,999/mo</span>
        </div>
        <div class="gb-compare-row">
          <span>Ads management agency</span>
          <span class="gb-compare-price">$1,500–$2,500/mo</span>
        </div>
        <div class="gb-compare-total">
          <span>Total (two vendors)</span>
          <span>$3,500–$5,500/mo</span>
        </div>
        <div class="gb-compare-savings">
          <span>With Jraft Growth Bundle</span>
          <span class="gb-savings-price">$2,999/mo</span>
        </div>
        <p class="gb-compare-note">Same work, one team, less coordination headaches.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FAQ ═══ -->
<section class="gb-section gb-section--alt" id="faq">
  <div class="container">
    <span class="gb-label">Questions</span>
    <h2>Frequently Asked</h2>
    <div class="gb-faq-list">
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">What's the minimum commitment?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">3 months. Marketing takes time to build momentum — one month isn't enough data to optimise anything. After 3 months, it's month-to-month and you can cancel with 30 days notice.</div>
      </div>
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">How much ad spend do I need on top?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">We recommend $1,000–$2,000/month for ad spend, paid directly to Meta and Google. This is separate from the $2,999 management fee. We'll advise on the right budget for your industry and goals.</div>
      </div>
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">Do I need to be on camera?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">No. We can create content using product shots, B-roll, text overlays, stock footage, and user-generated content styles. If you want to be on camera, great — but it's not required.</div>
      </div>
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">How fast will I see results?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">Ads can start generating leads within the first week. Social media growth is slower — expect meaningful traction by month 2–3. We set realistic expectations on the discovery call.</div>
      </div>
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">Can I choose just ads or just content?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">This bundle is designed to work together — ads without content is a leaky bucket, and content without ads is slow. If you only need one service, reach out and we'll discuss options.</div>
      </div>
      <div class="gb-faq" onclick="this.classList.toggle('open')">
        <div class="gb-faq-q">What industries do you work with?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="gb-faq-a">F&B, beauty, fitness, healthcare, education, home services, ecommerce, and professional services. If your business serves customers in Singapore and needs more of them, we can probably help.</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FINAL CTA ═══ -->
<section class="gb-cta">
  <div class="container">
    <h2>Ready to stop guessing?</h2>
    <p>Book a 15-minute call. We'll tell you honestly whether this bundle is right for your business.</p>
    <a href="https://wa.me/6582234578?text=Hi%20Jraft%2C%20I'm%20interested%20in%20the%20Growth%20Bundle.%20Can%20we%20chat%3F" class="btn btn-primary" target="_blank" rel="noopener">Book a 15-Min Discovery Call</a>
    <p class="gb-cta-note">Or WhatsApp us at +65 8223 4578</p>
  </div>
</section>

<style>
  /* ═══ GROWTH BUNDLE PAGE STYLES ═══ */

  /* Hero */
  .gb-hero {
    padding: 180px 0 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .gb-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, var(--accent-glow) 0%, transparent 60%);
    pointer-events: none;
  }
  .gb-badge {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid var(--border-accent);
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }
  .gb-hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .gb-hero-sub {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 580px;
    margin: 0 auto 32px;
    line-height: 1.65;
  }
  .gb-hero-price {
    margin-bottom: 32px;
  }
  .gb-price {
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .gb-price-period {
    font-size: 1.2rem;
    color: var(--text-muted);
    font-weight: 400;
  }
  .gb-hero-ctas {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .gb-hero-note {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* Sections */
  .gb-section {
    padding: 100px 0;
  }
  .gb-section--alt {
    background: var(--bg-alt);
  }
  .gb-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 10px;
    text-align: center;
  }
  .gb-section h2 {
    text-align: center;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .gb-section-sub {
    text-align: center;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto 48px;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  /* Problem Cards */
  .gb-problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 48px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .gb-problem-card {
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    transition: border-color 0.3s;
  }
  .gb-problem-card:hover {
    border-color: var(--border-accent);
  }
  .gb-problem-card svg {
    width: 28px;
    height: 28px;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .gb-problem-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .gb-problem-card p {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Includes */
  .gb-includes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
  }
  .gb-includes-card {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }
  .gb-includes-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .gb-includes-header svg {
    width: 28px;
    height: 28px;
    color: var(--accent);
    flex-shrink: 0;
  }
  .gb-includes-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
  }
  .gb-includes-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .gb-includes-list li {
    font-size: 0.88rem;
    color: var(--text-secondary);
    padding-left: 24px;
    position: relative;
    line-height: 1.5;
  }
  .gb-includes-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }

  /* Who Tags */
  .gb-who-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    max-width: 700px;
    margin: 0 auto;
  }
  .gb-who-tag {
    padding: 10px 22px;
    border: 1px solid var(--border);
    border-radius: 50px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.2s;
    cursor: default;
  }
  .gb-who-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Steps */
  .gb-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-top: 48px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  .gb-step {
    text-align: center;
    flex: 1;
    max-width: 260px;
    padding: 0 16px;
  }
  .gb-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg-dark);
    font-weight: 800;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }
  .gb-step h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .gb-step p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .gb-step-arrow {
    display: flex;
    align-items: center;
    padding-top: 10px;
    color: var(--text-muted);
    opacity: 0.3;
  }
  .gb-step-arrow svg {
    width: 28px;
    height: 28px;
  }

  /* Pricing */
  .gb-pricing-wrap {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    max-width: 860px;
    margin: 48px auto 0;
    align-items: start;
  }
  .gb-pricing-card {
    padding: 40px;
    border: 2px solid var(--border-accent);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-align: center;
    position: relative;
  }
  .gb-pricing-tag {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--bg-dark);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 5px 20px;
    border-radius: 50px;
    letter-spacing: 0.04em;
  }
  .gb-pricing-amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text);
  }
  .gb-pricing-period {
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .gb-pricing-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 12px 0 24px;
    line-height: 1.5;
  }
  .gb-pricing-list {
    list-style: none;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }
  .gb-pricing-list li {
    font-size: 0.88rem;
    color: var(--text-secondary);
    padding-left: 24px;
    position: relative;
  }
  .gb-pricing-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .gb-pricing-btn {
    width: 100%;
    justify-content: center;
  }
  .gb-pricing-note {
    margin-top: 12px;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Compare */
  .gb-pricing-compare {
    padding: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }
  .gb-pricing-compare h3 {
    font-size: 0.95rem;
