---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Social Media Marketing Singapore",
    "description": "Professional social media marketing services in Singapore. Content strategy, graphic design, Reels & video production, copywriting, and community management for brands that want to grow online.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Social Media Marketing",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2500", "priceCurrency": "SGD", "description": "8 posts per month across 2 platforms, content calendar, graphic design, copywriting, and monthly reporting" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3500", "priceCurrency": "SGD", "description": "12 posts per month across 3 platforms, 4 Reels/month, content strategy, community management, and bi-weekly reporting" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "20 posts per month across all platforms, 8+ Reels/month, dedicated creative team, influencer coordination, and weekly reporting" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does social media marketing cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Social media marketing in Singapore typically ranges from $2,500 to $5,000+ per month depending on scope. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, while our Professional and Full-Service plans include more content, Reels, and platform coverage." } },
      { "@type": "Question", "name": "Which social media platforms do you manage?", "acceptedAnswer": { "@type": "Answer", "text": "We manage all major platforms including Instagram, Facebook, TikTok, LinkedIn, and YouTube. Our team selects the best platforms for your business based on your target audience, industry, and goals. Most Singapore businesses see the strongest results on Instagram and TikTok." } },
      { "@type": "Question", "name": "Do I get to approve content before it goes live?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Every piece of content goes through our structured approval workflow before publishing. You receive a content calendar in advance with all post designs, captions, and hashtags for your review. Nothing goes live without your sign-off." } },
      { "@type": "Question", "name": "Do your plans include video and Reels production?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Professional plan includes 4 Reels per month and our Full-Service plan includes 8+ Reels per month. All video content is produced, edited, and optimised for each platform. Short-form video is the highest-performing format on Instagram and TikTok in Singapore." } },
      { "@type": "Question", "name": "How do you measure the success of social media marketing?", "acceptedAnswer": { "@type": "Answer", "text": "We track metrics that matter — reach, engagement rate, follower growth, website traffic from social, and conversions. Every plan includes regular reporting with clear insights and recommendations. We focus on business outcomes, not vanity metrics." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Social Media Marketing Singapore", "item": "https://jraftcreative.com/social-media-marketing-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Social Media Marketing Singapore — Social Media Agency | Jraft Creative"
  description="Professional social media marketing in Singapore — content strategy, graphic design, Reels & video, copywriting, and community management. Monthly plans from S$2,500. Free consultation."
  canonical="https://jraftcreative.com/social-media-marketing-singapore/"
  ogTitle="Social Media Marketing Singapore — Jraft Creative"
  ogDescription="Social media agency in Singapore. Content creation, Reels & video, community management, and growth strategy. Plans from $2,500 SGD/month."
  ogImage="https://jraftcreative.com/images/og-social.jpg"
  keywords="social media marketing singapore, social media agency singapore, social media management singapore, instagram marketing singapore, tiktok marketing singapore, content creation singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Social Media Agency Singapore"
  heroTitle='Social Media Marketing <span class="highlight">in Singapore</span>'
  heroSubtitle="Strategic content creation, Reels & video production, and community management that grows your audience and turns followers into customers. Built for brands that take social media seriously."
  heroImage="/images/service-social.webp"
  heroButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "View Our Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'm interested in your social media marketing services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Brand on Social Media"
  ctaDescription="Book a free consultation and tell us about your brand. We'll get back to you within 24 hours with a tailored social media strategy."
  ctaButtons={[
    { text: "Get a Free Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27m%20interested%20in%20your%20social%20media%20marketing%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="Social media challenges for Singapore businesses">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Struggling to Grow on Social Media?</h2>
      </div>
      <div class="section-content reveal">
        <p>Most businesses in Singapore know they need to be on social media — but knowing and executing are two different things. Inconsistent posting, recycled stock images, and captions that read like afterthoughts don't build an audience. They just fill a feed.</p>
        <p>Without a clear content strategy, you're posting into the void. No engagement, no growth, no leads. Meanwhile, your competitors are investing in professional content that builds trust, drives traffic, and converts followers into paying customers. Social media in Singapore moves fast, and falling behind is expensive.</p>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Social media marketing services we offer">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Social Media Services for Singapore Brands</h2>
      </div>
      <div class="section-content reveal">
        <p>We handle your entire social media presence — from strategy and content creation to publishing and community management. Every post is designed with purpose: to grow your brand, engage your audience, and drive measurable business results.</p>
        <p>Our team covers content strategy, original graphic design, short-form video production, professional copywriting, and active community management across Instagram, TikTok, Facebook, LinkedIn, and more.</p>
        <p>Want a complete digital presence? Combine social media with a professionally built <a href="/services/website-development/">website</a>, <a href="/services/seo-performance/">SEO</a> for organic search visibility, or <a href="/services/paid-ads/">paid advertising</a> to scale faster.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-content-strategy.webp">
          <div class="service-detail-card__content">
            <h3>Content Strategy</h3>
            <p>Data-driven content calendars tailored to your brand, audience, and platform. We plan every post around your business goals — not random trends.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Graphic Design</h3>
            <p>Scroll-stopping visuals created from scratch — branded post designs, carousel graphics, story templates, and platform-optimised imagery.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Reels &amp; Video Production</h3>
            <p>Short-form video content for Instagram Reels and TikTok — scripted, filmed, edited, and optimised to maximise reach and engagement.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-copywriting.webp">
          <div class="service-detail-card__content">
            <h3>Copywriting</h3>
            <p>Captions and copy that sound like your brand and speak to your audience. Clear calls-to-action, relevant hashtags, and SEO-conscious writing for every post.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Community Management</h3>
            <p>Active engagement with your audience — responding to comments, managing DMs, and building genuine connections that turn followers into loyal customers.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for social media marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>What Sets Our Social Media Agency Apart</h2>
      </div>
      <div class="section-content reveal">
        <p>We're not freelancers juggling dozens of accounts or a bot-driven agency pumping out generic templates. Every client gets a dedicated creative team that understands their brand and audience. Here's why Singapore businesses choose us:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Creative Team</h3>
            <p>Strategist, designer, copywriter, and video editor — all working on your brand. No one-person-does-everything compromises.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Platform Expertise</h3>
            <p>We know what works on each platform in Singapore. Instagram carousels, TikTok trends, LinkedIn thought leadership — every format optimised for its channel.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Approval Workflow</h3>
            <p>You see every post before it goes live. Full content calendar with designs, captions, and hashtags sent for your review and approval — no surprises.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>Month-to-month plans. Stay because the content and results speak for themselves, not because of a binding agreement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Social media marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Plans for Every Stage of Growth</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For brands building a consistent social presence.</p>
            <ul class="pricing-features">
              <li>8 posts per month</li>
              <li>2 platforms</li>
              <li>Content calendar &amp; strategy</li>
              <li>Graphic design</li>
              <li>Copywriting &amp; hashtags</li>
              <li>Monthly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For growing brands ready to scale their reach.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Content strategy &amp; design</li>
              <li>Community management</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">For brands that want a complete social media team.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels / short-form videos</li>
              <li>Dedicated creative team</li>
              <li>Influencer coordination</li>
              <li>Weekly reporting &amp; strategy</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>Full service details on our <a href="/services/social-media/" class="inline-link">social media marketing</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about social media marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Social Media Marketing — Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does social media marketing cost in Singapore?</summary>
          <div class="faq-answer"><p>Social media marketing in Singapore typically ranges from $2,500 to $5,000+ per month depending on scope. Our Essential plan starts at $2,500 SGD/month for 8 posts across 2 platforms, while our Professional and Full-Service plans include more content, Reels, and platform coverage.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which social media platforms do you manage?</summary>
          <div class="faq-answer"><p>We manage all major platforms including Instagram, Facebook, TikTok, LinkedIn, and YouTube. Our team selects the best platforms for your business based on your target audience, industry, and goals. Most Singapore businesses see the strongest results on Instagram and TikTok.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do I get to approve content before it goes live?</summary>
          <div class="faq-answer"><p>Absolutely. Every piece of content goes through our structured approval workflow before publishing. You receive a content calendar in advance with all post designs, captions, and hashtags for your review. Nothing goes live without your sign-off.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do your plans include video and Reels production?</summary>
          <div class="faq-answer"><p>Yes. Our Professional plan includes 4 Reels per month and our Full-Service plan includes 8+ Reels per month. All video content is produced, edited, and optimised for each platform. Short-form video is the highest-performing format on Instagram and TikTok in Singapore.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you measure the success of social media marketing?</summary>
          <div class="faq-answer"><p>We track metrics that matter — reach, engagement rate, follower growth, website traffic from social, and conversions. Every plan includes regular reporting with clear insights and recommendations. We focus on business outcomes, not vanity metrics.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
