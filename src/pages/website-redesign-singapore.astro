---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Website Redesign Singapore",
    "description": "Professional website redesign services in Singapore. Revamp outdated websites with modern UX, SEO migration, mobile-first development, and speed optimisation. From S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Website Redesign",
    "offers": [
      { "@type": "Offer", "name": "Starter Redesign", "price": "2500", "priceCurrency": "SGD", "description": "Redesign of up to 5 pages with updated visuals, mobile-responsive layout, basic SEO migration, and 2-week delivery" },
      { "@type": "Offer", "name": "Business Redesign", "price": "5500", "priceCurrency": "SGD", "description": "Full redesign of up to 10 pages with UX overhaul, SEO migration and URL mapping, CMS integration, speed optimisation, and analytics setup" },
      { "@type": "Offer", "name": "Premium Redesign", "price": "10000", "priceCurrency": "SGD", "description": "Complete website overhaul with unlimited pages, custom UX/UI, full SEO migration with 301 redirects, performance tuning, third-party integrations, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a website redesign cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "Website redesign in Singapore typically ranges from $2,500 to $10,000+ SGD depending on the number of pages, complexity, and features required. Our Starter redesign package begins at $2,500 for up to 5 pages, while our Business and Premium packages cover larger sites with advanced SEO migration and custom functionality." } },
      { "@type": "Question", "name": "Will I lose my Google rankings during a website redesign?", "acceptedAnswer": { "@type": "Answer", "text": "Not with proper SEO migration. We map every existing URL, set up 301 redirects for any changed paths, preserve meta tags and heading structures, and submit the updated sitemap to Google Search Console. Our goal is to maintain — and improve — your existing rankings throughout the transition." } },
      { "@type": "Question", "name": "How long does a website redesign take?", "acceptedAnswer": { "@type": "Answer", "text": "Most website redesigns take 2–4 weeks from kickoff to launch. Simpler redesigns with fewer pages can be completed in 2 weeks, while larger sites requiring content migration, custom features, or ecommerce functionality may take 4–6 weeks. We provide a clear timeline during the discovery phase." } },
      { "@type": "Question", "name": "Can you migrate my existing content to the new website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle full content migration — text, images, blog posts, and downloadable files. We audit your existing content, identify what to keep, update, or remove, and ensure everything is properly formatted and optimised on the new site. No content gets left behind unless you want it gone." } },
      { "@type": "Question", "name": "Will there be any downtime during the redesign?", "acceptedAnswer": { "@type": "Answer", "text": "No. We build your redesigned website on a staging environment while your current site stays live. Once the new site is tested and approved, we perform a seamless switchover — typically during off-peak hours. Your visitors will never see an under construction page." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Website Redesign Singapore", "item": "https://jraftcreative.com/website-redesign-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Website Redesign Singapore — Revamp Your Website | Jraft Creative"
  description="Professional website redesign in Singapore — modernise your site with improved UX, SEO migration, mobile-first design, and speed optimisation. From S$2,500. Free consultation."
  canonical="https://jraftcreative.com/website-redesign-singapore/"
  ogTitle="Website Redesign Singapore — Jraft Creative"
  ogDescription="Revamp your outdated website with a modern redesign. SEO migration, mobile-responsive design, and speed optimisation for Singapore businesses. From $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="website redesign singapore, website revamp singapore, website makeover singapore, redesign website singapore, website overhaul singapore, site redesign, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Website Redesign Singapore"
  heroTitle='Professional <span class="highlight">Website Redesign in Singapore</span>'
  heroSubtitle="Your website should be your hardest-working salesperson — not your biggest liability. We redesign outdated sites into fast, mobile-friendly, SEO-optimised websites that convert visitors into customers."
  heroImage="/images/service-redesign.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need to redesign my website in Singapore."
  ctaLabel="Ready to Revamp?"
  ctaTitle="Give Your Website the Redesign It Deserves"
  ctaDescription="Book a free consultation and we will audit your current site, identify what needs to change, and deliver a tailored proposal within 24 hours."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20to%20redesign%20my%20website%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why outdated websites lose customers in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>An Outdated Website Is Costing You Customers</h2>
      </div>
      <div class="section-content reveal">
        <p>If your website looks like it was built five years ago, visitors notice. Outdated design, slow load times, and clunky mobile experiences don't just hurt your brand image — they actively push potential customers toward competitors with better websites.</p>
        <p>In Singapore, over 70% of users browse on mobile. If your site isn't mobile-friendly, you're invisible to the majority of your audience. Add poor SEO, broken links, and confusing navigation to the mix, and you have a website that works against you instead of for you.</p>
        <p>A website redesign isn't just a facelift. It's a strategic overhaul that addresses the root causes of poor performance — from user experience and site architecture to technical SEO and page speed. The result is a website that ranks higher, loads faster, and converts more visitors into paying customers.</p>
      </div>
    </div>
  </section>

  <!-- ========== SUB-SERVICES ========== -->
  <section class="section" id="sub-services" aria-label="Website redesign services overview">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Do</p>
        <h2>Website Redesign Services for Singapore Businesses</h2>
      </div>
      <div class="section-content reveal">
        <p>We don't just reskin your website — we rebuild it from the ground up with a clear strategy behind every design decision. Every redesign project covers UX improvements, SEO preservation, mobile responsiveness, and performance tuning so your new site outperforms the old one in every measurable way.</p>
        <p>Need more than a redesign? Pair your revamped site with our <a href="/services/seo-performance/">SEO services</a> to climb Google rankings, <a href="/services/paid-ads/">paid advertising</a> to drive traffic from day one, or <a href="/services/social-media/">social media marketing</a> to grow your audience across platforms.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>UX &amp; Design Overhaul</h3>
            <p>Modern layouts, intuitive navigation, and conversion-focused design that transforms your website from an afterthought into a competitive advantage.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>SEO Migration &amp; URL Mapping</h3>
            <p>Preserve your Google rankings with proper 301 redirects, URL mapping, meta tag migration, and sitemap resubmission — so you don't lose the authority you've built.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Mobile-First Rebuild</h3>
            <p>Every redesigned page is built mobile-first and tested across devices. Your site will look and perform flawlessly on smartphones, tablets, and desktops.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Performance Upgrade</h3>
            <p>Lightweight code, optimised images, lazy loading, and Core Web Vitals tuning — because a fast website isn't a bonus, it's a baseline requirement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY JRAFT ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for website redesign">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>What Sets Our Website Redesigns Apart</h2>
      </div>
      <div class="section-content reveal">
        <p>Redesigning a website is more than swapping colours and fonts. It requires a deep understanding of your business goals, your audience, and the technical foundations that make a website perform. Here's why Singapore businesses trust us with their redesigns:</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Zero Downtime Launches</h3>
            <p>We build on a staging environment and switch over seamlessly. Your current site stays live until the new one is tested, approved, and ready to go.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>SEO Rankings Protected</h3>
            <p>Full URL mapping, 301 redirects, and structured data migration ensure you keep the search authority you've earned — not start from scratch.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>No Lock-in Contracts</h3>
            <p>You own your redesigned website and all its code from day one. No monthly hosting fees, no proprietary platforms — just a clean handover.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Singapore-Focused Strategy</h3>
            <p>We understand the local market, optimise for local SEO, design for SGD payments, and build sites that resonate with Singapore audiences.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Website redesign pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Redesign Pricing</p>
        <h2>Website Redesign Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For small sites that need a visual refresh.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages redesigned</li>
              <li>Modern responsive layout</li>
              <li>Basic SEO migration</li>
              <li>Content migration</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established businesses upgrading their site.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages redesigned</li>
              <li>Full UX &amp; design overhaul</li>
              <li>SEO migration &amp; URL mapping</li>
              <li>CMS / blog integration</li>
              <li>Speed optimisation</li>
              <li>Google Analytics setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For complex sites with advanced requirements.</p>
            <ul class="pricing-features">
              <li>Unlimited pages redesigned</li>
              <li>Fully custom UX/UI design</li>
              <li>Full SEO migration &amp; 301 redirects</li>
              <li>Ecommerce / booking systems</li>
              <li>Third-party integrations</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about website redesign in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Website Redesign Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a website redesign cost in Singapore?</summary>
          <div class="faq-answer"><p>Website redesign in Singapore typically ranges from $2,500 to $10,000+ SGD depending on the number of pages, complexity, and features required. Our Starter redesign package begins at $2,500 for up to 5 pages, while our Business and Premium packages cover larger sites with advanced SEO migration and custom functionality.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will I lose my Google rankings during a website redesign?</summary>
          <div class="faq-answer"><p>Not with proper SEO migration. We map every existing URL, set up 301 redirects for any changed paths, preserve meta tags and heading structures, and submit the updated sitemap to Google Search Console. Our goal is to maintain — and improve — your existing rankings throughout the transition.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How long does a website redesign take?</summary>
          <div class="faq-answer"><p>Most website redesigns take 2-4 weeks from kickoff to launch. Simpler redesigns with fewer pages can be completed in 2 weeks, while larger sites requiring content migration, custom features, or ecommerce functionality may take 4-6 weeks. We provide a clear timeline during the discovery phase.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you migrate my existing content to the new website?</summary>
          <div class="faq-answer"><p>Yes. We handle full content migration — text, images, blog posts, and downloadable files. We audit your existing content, identify what to keep, update, or remove, and ensure everything is properly formatted and optimised on the new site. No content gets left behind unless you want it gone.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Will there be any downtime during the redesign?</summary>
          <div class="faq-answer"><p>No. We build your redesigned website on a staging environment while your current site stays live. Once the new site is tested and approved, we perform a seamless switchover — typically during off-peak hours. Your visitors will never see an under construction page.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
