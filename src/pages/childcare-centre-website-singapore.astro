---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Childcare Centre Website Design Singapore",
    "description": "Professional website design for childcare centres in Singapore. Online enrolment forms, programme pages for infant to K2, fee schedules, ECDA licence display, and virtual tours — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Childcare Centre Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Childcare Centre Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page childcare centre website with programme overview, online enrolment form, photo gallery, fee schedule page, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Childcare Centre Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with virtual tour, daily schedule pages, parent testimonials, blog, ECDA licence display, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium Childcare Centre Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with parent communication portal, multi-centre support, online waitlist management, fee payment integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a childcare centre website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional childcare centre website in Singapore costs between $2,500 and $10,000+ depending on the features you need. Our Starter package at $2,500 SGD includes a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages add virtual tours, parent portals, daily schedule pages, and online fee payment." } },
      { "@type": "Question", "name": "Can parents submit enrolment and waitlist applications online?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build online enrolment and waitlist forms directly into your website. Parents can select their preferred programme level — infant care, toddler, playgroup, nursery, or kindergarten — submit their child's details, and receive automated confirmation emails. This reduces phone calls and walk-in admin work for your front desk staff." } },
      { "@type": "Question", "name": "Can you display our ECDA licence and SPARK certification on the website?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We prominently display your ECDA licence number, SPARK certification rating, and any subsidy eligibility details on your website. Parents actively check for these credentials when shortlisting childcare centres, so visible compliance builds immediate trust and sets you apart from unlicensed operators." } },
      { "@type": "Question", "name": "Will our childcare centre appear in 'childcare near me' searches?", "acceptedAnswer": { "@type": "Answer", "text": "We build every site with local SEO fundamentals — location-specific keywords, Google Business Profile optimisation, structured data markup, and neighbourhood targeting. This helps your centre rank for searches like 'childcare near Tampines' or 'infant care Bishan' so nearby parents find you first." } },
      { "@type": "Question", "name": "How long does it take to build a childcare centre website?", "acceptedAnswer": { "@type": "Answer", "text": "Most childcare centre websites go live within 2-3 weeks. A 5-page Starter site is typically ready in 2 weeks, while Business and Premium projects with virtual tours, parent portals, or multi-centre setups take 3-4 weeks. We provide a clear timeline before work begins." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Childcare Centre Website Design Singapore", "item": "https://jraftcreative.com/childcare-centre-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Childcare Centre Website Design Singapore — Childcare Web Design | Jraft Creative"
  description="Professional website design for childcare centres in Singapore. Online enrolment forms, programme pages for infant to K2, fee schedules, ECDA licence display, and virtual tours — from S$2,500."
  canonical="https://jraftcreative.com/childcare-centre-website-singapore/"
  ogTitle="Childcare Centre Website Design Singapore — Jraft Creative"
  ogDescription="Website design for childcare centres in Singapore. Enrolment forms, programme pages, ECDA compliance display — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="childcare centre website design singapore, childcare website singapore, childcare centre web design, infant care website singapore, childcare centre website, daycare website design singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Childcare Centre Website Design"
  heroTitle='Website Design for <span class="highlight">Childcare Centres</span> in Singapore'
  heroSubtitle="Parents research childcare options online long before they schedule a tour. We build trustworthy, mobile-friendly websites for childcare centres — with online enrolment forms, programme pages from infant care to K2, fee schedules, and ECDA licence display that gives families confidence in your centre."
  heroImage="/images/service-childcare.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my childcare centre in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Childcare Centre Online"
  ctaDescription="Book a free consultation and tell us about your centre. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20childcare%20centre%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why childcare centres need a professional website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Parents Are Choosing Childcare Centres Before They Ever Walk Through Your Door</h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore parents start their childcare search months — sometimes a full year — before their child needs a place. They search "infant care near me" or "childcare centre Punggol" from their phones during lunch breaks, compare fee schedules across tabs, and check whether your ECDA licence is current. If your centre doesn't show up on Google, or your online presence is a bare-bones Facebook page with outdated photos, you've already lost that family to the centre down the road that made it easy to find information.</p>
        <p>A listing on the ECDA portal or a mention in a parenting forum isn't enough anymore. Parents want structured, reliable information they can review at their own pace: your programme levels from infant care through K2, daily schedules, teacher-to-child ratios, fee breakdowns including government subsidies, and real photos of your classrooms and outdoor areas. They want to submit an enrolment inquiry or join your waitlist at 10pm — not wait until Monday morning to call your front desk.</p>
        <p>With over 1,500 licensed childcare centres across Singapore and new operators entering the market regularly, the competition for enrolments is real. Whether you run a single-centre operation in Bedok or a growing chain across the heartlands, your website is often the first — and most influential — touchpoint parents have with your brand. It needs to communicate safety, professionalism, and warmth in equal measure.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Childcare centre website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Childcare Centres</h2>
      </div>
      <div class="section-content reveal">
        <p>Every childcare centre website we deliver is purpose-built for the early childhood sector. We go beyond generic templates — your site will feature programme breakdowns by age group, daily schedule pages, fee schedule displays with subsidy information, ECDA licensing details, and local SEO so families searching "childcare near me" find your centre first.</p>
        <p>We also offer a full digital package beyond your website: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for neighbourhood childcare searches, <a href="/services/social-media/">social media marketing</a> to share classroom activities and build parent communities, and <a href="/services/paid-ads/">paid ads management</a> to drive enrolment inquiries from Google and Facebook.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Programme &amp; Daily Schedule Pages</h3>
            <p>Dedicated pages for every programme level your centre offers — infant care, toddler, playgroup, nursery, K1, and K2. Each page outlines the curriculum approach, daily schedule with meal and nap times, learning goals, and enrichment activities so parents understand exactly what their child's day looks like at your centre.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Online Enrolment &amp; Waitlist Forms</h3>
            <p>Let parents register interest, submit enrolment applications, or join your waitlist directly from your website — any time, any day. Custom forms capture the child's age, preferred programme level, and start date, with automated confirmation emails that keep parents informed and reduce your admin team's manual workload.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>ECDA Licence &amp; Fee Schedule Display</h3>
            <p>We prominently showcase your ECDA licence number, SPARK certification rating, and government subsidy eligibility details alongside a clear fee schedule breakdown. Parents actively verify these credentials when shortlisting centres, and transparent pricing eliminates the back-and-forth that delays enrolment decisions.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Virtual Tours &amp; Parent Testimonials</h3>
            <p>Photo galleries, embedded video walkthroughs, and curated parent testimonials that showcase your learning spaces, outdoor play areas, and classroom activities. For busy parents who can't visit during working hours, a virtual tour gives them the visual confidence to commit to scheduling a physical visit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for childcare centre website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Childcare Centre Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for education and childcare businesses across Singapore. We know what makes parents trust a centre online — and we design every element of your website to convert browsing families into scheduled tours and submitted enrolment forms.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Childcare Sector Expertise</h3>
            <p>We understand Singapore's early childhood landscape — ECDA licensing requirements, SPARK quality ratings, CDA and AICCS subsidy frameworks, and the parent decision-making journey from online research to centre visit. Your website will be built around how childcare centres actually operate and what parents need to see before they enrol.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most childcare centre websites go live within 2 weeks of kickoff. Whether you're opening a new centre, rebranding, or replacing an outdated site, we work efficiently so you're online before your next enrolment cycle begins.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First for On-the-Go Parents</h3>
            <p>Over 80% of parent searches happen on mobile. Every site we build is designed for phone-first browsing — fast load times, thumb-friendly navigation, tap-to-call buttons, and enrolment forms that are easy to complete without a laptop.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Marketing Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can manage your entire online presence — from ranking for "childcare near Jurong" to running Facebook enrolment campaigns — so you can focus on caring for your children and growing your team.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Childcare centre website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Childcare Centre Website Pricing</p>
        <h2>Website Packages for Childcare Centres</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For single-centre operators and new childcare centres.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Programme overview pages</li>
              <li>Online enrolment form</li>
              <li>Photo gallery</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing centres ready to increase enrolments.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Daily schedule &amp; curriculum pages</li>
              <li>Virtual tour integration</li>
              <li>Parent testimonials section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-centre childcare groups and chains.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-centre support</li>
              <li>Parent communication portal</li>
              <li>Online fee payment setup</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about childcare centre website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Childcare Centre Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a childcare centre website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional childcare centre website in Singapore costs between $2,500 and $10,000+ depending on the features you need. Our Starter package at $2,500 SGD includes a 5-page site with programme overview, enrolment form, and photo gallery. Business and Premium packages add virtual tours, daily schedule pages, parent portals, and online fee payment integration.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can parents submit enrolment and waitlist applications through the website?</summary>
          <div class="faq-answer"><p>Yes. We build online enrolment and waitlist forms directly into your website. Parents can select their preferred programme level — infant care, toddler, playgroup, nursery, or kindergarten — submit their child's details and preferred start date, and receive automated confirmation emails. This reduces phone calls and walk-in inquiries for your front desk staff.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Can you display our ECDA licence and SPARK certification on the website?</summary>
          <div class="faq-answer"><p>Absolutely. We prominently display your ECDA licence number, SPARK certification rating, and any government subsidy eligibility details (CDA, AICCS) on your website. Parents actively check for these credentials when shortlisting childcare centres, and visible compliance builds immediate trust and differentiates you from unlicensed operators.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will our centre appear in "childcare near me" searches on Google?</summary>
          <div class="faq-answer"><p>We build every site with local SEO fundamentals — location-specific keywords, Google Business Profile optimisation, structured data markup, and neighbourhood targeting. This helps your centre rank for searches like "childcare near Tampines," "infant care Bishan," or "childcare centre Woodlands" so nearby parents find you before your competitors.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a childcare centre website?</summary>
          <div class="faq-answer"><p>Most childcare centre websites go live within 2-3 weeks. A 5-page Starter site is typically ready in 2 weeks, while Business and Premium projects with virtual tours, parent portals, or multi-centre setups take 3-4 weeks. We provide a clear timeline before work begins so you can plan around your enrolment cycle.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
