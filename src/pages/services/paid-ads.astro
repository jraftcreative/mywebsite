---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Paid Performance Marketing",
    "description": "Paid advertising management services in Singapore including Google Ads, Meta Ads, TikTok & YouTube Ads, retargeting, and campaign analytics.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Paid Advertising Management",
    "offers": [
      { "@type": "Offer", "name": "Starter Ads Management", "price": "1000", "priceCurrency": "SGD", "description": "1 platform (Google or Meta), campaign setup & strategy, ad copywriting & creatives, pixel & conversion tracking" },
      { "@type": "Offer", "name": "Growth Ads Management", "price": "2500", "priceCurrency": "SGD", "description": "2 platforms (Google + Meta), A/B testing, retargeting & lookalike audiences, dedicated account manager" },
      { "@type": "Offer", "name": "Scale Ads Management", "price": "5000", "priceCurrency": "SGD", "description": "All platforms, video ad production, advanced attribution modelling, real-time dashboard, dedicated strategist" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much should I spend on ads?", "acceptedAnswer": { "@type": "Answer", "text": "For Singapore SMEs, we recommend starting with S$1,000–S$3,000 per month in ad spend (separate from management fees). This allows enough data to optimise campaigns effectively. We help you set the right budget based on your goals and industry." } },
      { "@type": "Question", "name": "Which ad platform is best for my business?", "acceptedAnswer": { "@type": "Answer", "text": "Google Ads works best for capturing high-intent search traffic. Meta Ads (Facebook and Instagram) are ideal for brand awareness and visual products. TikTok suits younger audiences. We recommend the best mix during our free strategy session." } },
      { "@type": "Question", "name": "How quickly will I see results from paid ads?", "acceptedAnswer": { "@type": "Answer", "text": "Unlike SEO, paid ads can drive traffic immediately. However, campaigns typically need 2–4 weeks of data collection and optimisation before reaching peak performance. Most clients see meaningful results within the first month." } },
      { "@type": "Question", "name": "Do management fees include the ad spend?", "acceptedAnswer": { "@type": "Answer", "text": "No. Management fees cover strategy, campaign setup, creative production, optimisation, and reporting. Ad spend is paid directly to the platforms (Google, Meta, TikTok) and is a separate budget that you control." } },
      { "@type": "Question", "name": "Can I pause or cancel my campaign?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We have no lock-in contracts. You can pause or cancel campaigns at any time. We recommend running campaigns for at least 3 months to gather enough data for meaningful optimisation and results." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services" },
      { "@type": "ListItem", "position": 3, "name": "Paid Ads", "item": "https://jraftcreative.com/services/paid-ads/" }
    ]
  }
];
---

<ServiceLayout
  title="Paid Ads Management Singapore | Jraft Creative"
  description="Paid ad campaign management in Singapore — Google Ads, Meta Ads, TikTok Ads, retargeting, and optimisation. From S$1,000/month."
  canonical="https://jraftcreative.com/services/paid-ads/"
  ogTitle="Paid Ads Agency Singapore — Jraft Creative"
  ogDescription="Google Ads, Meta Ads, and data-driven paid campaigns that deliver measurable ROI. Management fees from $1,000 SGD/month."
  ogImage="https://jraftcreative.com/images/og-ads.jpg"
  keywords="paid ads agency singapore, google ads management singapore, meta ads, facebook ads, instagram ads, PPC agency, performance marketing, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Paid Ads Agency Singapore"
  heroTitle='Paid Performance Marketing &amp; <span class="highlight">Ads Management in Singapore</span>'
  heroSubtitle="Google Ads, Meta Ads, and data-driven paid campaigns that deliver measurable ROI, qualified leads, and real business growth."
  heroImage="/images/service-ads.webp"
  heroButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your paid ads management services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Launch Your Ad Campaigns"
  ctaDescription="Book a free consultation and get a complimentary ad strategy. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free Ad Strategy", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20paid%20ads%20management%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="The paid ads challenge businesses face">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Wasting Ad Budget Without Clear Results?</h2>
      </div>
      <div class="section-content reveal">
        <p>Many businesses in Singapore waste thousands on paid ads with no clear strategy, poor targeting, and no way to measure what is actually working. Boosting posts on Instagram or running Google Ads without proper conversion tracking burns budget without delivering real leads.</p>
        <p>Without expert campaign management, you are likely paying too much per click, targeting the wrong audiences, and missing out on the retargeting and optimisation that separates profitable campaigns from money pits.</p>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTION (SUB-SERVICES) ========== -->
  <section class="section" id="sub-services" aria-label="Our paid ads solutions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Solution</p>
        <h2>Our Paid Advertising Services</h2>
      </div>
      <div class="section-content reveal">
        <p>Full-funnel ad campaigns across all major platforms. As a paid ads agency in Singapore, we plan, launch, and optimise campaigns on Google Ads, Meta, TikTok, and LinkedIn — targeting the right audiences to maximise your return on ad spend.</p>
        <p>From audience research and ad creative to bid strategy and conversion tracking, we manage every detail so your advertising budget delivers measurable business results.</p>
        <p>Drive even more results by combining ads with <a href="/services/seo-performance">SEO &amp; performance optimisation</a>, building a strong brand through <a href="/services/social-media">social media content</a>, or launching a high-converting <a href="/services/website-development">website</a>.</p>
        <p>See our dedicated <a href="/google-ads-agency-singapore/">Google Ads management</a> page, or explore our full <a href="/digital-marketing-agency-singapore/">digital marketing</a> packages.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-google-ads.webp">
          <div class="service-detail-card__content">
            <h3>Google Ads (Search &amp; Display)</h3>
            <p>Keyword targeting, ad copywriting, bid management, and Quality Score optimisation to capture high-intent search traffic.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-meta-ads.webp">
          <div class="service-detail-card__content">
            <h3>Meta Ads (Facebook &amp; Instagram)</h3>
            <p>Audience targeting, creative production, A/B testing, and conversion campaigns that reach your ideal customers on social.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-tiktok-ads.webp">
          <div class="service-detail-card__content">
            <h3>TikTok &amp; YouTube Ads</h3>
            <p>Video ad campaigns, interest-based targeting, and brand awareness at scale on the fastest-growing video platforms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-retargeting.jpg">
          <div class="service-detail-card__content">
            <h3>Retargeting &amp; Remarketing</h3>
            <p>Pixel setup, custom audiences, lookalike targeting, and cross-platform retargeting funnels to recapture warm leads.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-campaign-analytics.webp">
          <div class="service-detail-card__content">
            <h3>Campaign Analytics &amp; Optimisation</h3>
            <p>Conversion tracking, ROAS reporting, budget allocation, and continuous campaign refinement for maximum performance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROOF ========== -->
  <section class="section" id="proof" style="background: var(--bg-alt);" aria-label="Paid ads results and proof">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Results</p>
        <h2>Campaigns That Deliver Measurable ROI</h2>
      </div>
      <div class="section-content reveal">
        <p>Our ad campaigns are built around data, not guesswork. We track every conversion, optimise bids in real time, and provide transparent reporting so you know exactly where your ad spend goes and what it delivers.</p>
        <p>From lead generation campaigns that consistently deliver qualified enquiries to ecommerce campaigns that scale profitably, our clients see real business impact. <a href="/services/website-development/#portfolio" class="inline-link">See how we have helped businesses grow</a>.</p>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Paid ads pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Paid Ads Pricing</p>
        <h2>Ads Management Plans</h2>
        <p>Management fees are separate from ad spend. No minimum contract.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$1,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses testing paid channels for the first time.</p>
            <ul class="pricing-features">
              <li>1 platform (Google or Meta)</li>
              <li>Campaign setup &amp; strategy</li>
              <li>Ad copywriting &amp; creatives</li>
              <li>Pixel &amp; conversion tracking</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$2,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses scaling with multi-platform campaigns.</p>
            <ul class="pricing-features">
              <li>2 platforms (Google + Meta)</li>
              <li>A/B testing &amp; creative iteration</li>
              <li>Retargeting &amp; lookalike audiences</li>
              <li>Landing page recommendations</li>
              <li>Bi-weekly reporting &amp; optimisation</li>
              <li>Dedicated account manager</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Scale</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-funnel paid strategy across all major platforms.</p>
            <ul class="pricing-features">
              <li>All platforms (Google, Meta, TikTok, YouTube)</li>
              <li>Video ad production</li>
              <li>Advanced attribution modelling</li>
              <li>Real-time dashboard access</li>
              <li>Weekly strategy calls</li>
              <li>Dedicated strategist</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much should I spend on ads?</summary>
          <div class="faq-answer"><p>For Singapore SMEs, we recommend starting with S$1,000–S$3,000 per month in ad spend (separate from management fees). This allows enough data to optimise campaigns effectively. We help you set the right budget based on your goals and industry.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Which ad platform is best for my business?</summary>
          <div class="faq-answer"><p>Google Ads works best for capturing high-intent search traffic. Meta Ads (Facebook and Instagram) are ideal for brand awareness and visual products. TikTok suits younger audiences. We recommend the best mix during our free strategy session.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How quickly will I see results from paid ads?</summary>
          <div class="faq-answer"><p>Unlike SEO, paid ads can drive traffic immediately. However, campaigns typically need 2–4 weeks of data collection and optimisation before reaching peak performance. Most clients see meaningful results within the first month.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do management fees include the ad spend?</summary>
          <div class="faq-answer"><p>No. Management fees cover strategy, campaign setup, creative production, optimisation, and reporting. Ad spend is paid directly to the platforms (Google, Meta, TikTok) and is a separate budget that you control.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can I pause or cancel my campaign?</summary>
          <div class="faq-answer"><p>Yes. We have no lock-in contracts. You can pause or cancel campaigns at any time. We recommend running campaigns for at least 3 months to gather enough data for meaningful optimisation and results.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
