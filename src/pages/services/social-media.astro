---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Social Media Content Creation",
    "description": "Social media marketing and content creation services in Singapore including content strategy, graphic design, reels & short-form video, copywriting, and community management.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Social Media Content Creation"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How many posts will I get per month?", "acceptedAnswer": { "@type": "Answer", "text": "Output volume is scoped on the discovery call. Most engagements run 8–20 posts per month plus a mix of Stories, Reels, and short-form video — sized to your platform mix, audience, and growth stage." } },
      { "@type": "Question", "name": "Can I approve posts before they go live?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We share a content calendar with all posts, captions, and visuals for your approval before scheduling. You can request revisions at any time before publishing." } },
      { "@type": "Question", "name": "Do you create video content like Reels?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We produce Reels and short-form video for Instagram, TikTok, and YouTube Shorts as part of most engagements — scripting, filming guidance, and editing all handled in-house. Reel volume is scoped to your content calendar on the discovery call." } },
      { "@type": "Question", "name": "Which social media platforms do you manage?", "acceptedAnswer": { "@type": "Answer", "text": "We manage Instagram, Facebook, TikTok, LinkedIn, and YouTube. Most engagements cover 2–4 platforms, with the exact mix scoped to where your buyers actually scroll and discover brands like yours." } },
      { "@type": "Question", "name": "How do you measure social media success?", "acceptedAnswer": { "@type": "Answer", "text": "We track engagement rate, reach, follower growth, website clicks, and enquiries generated from social media. Monthly reports show what content performs best and how social media contributes to your business goals." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services" },
      { "@type": "ListItem", "position": 3, "name": "Social Media", "item": "https://jraftcreative.com/services/social-media/" }
    ]
  }
];
---

<ServiceLayout
  title="Social Media Content Creation Singapore — Jraft Creative"
  description="Social media marketing and content creation in Singapore — strategy, graphic design, Reels, copywriting, and community management."
  canonical="https://jraftcreative.com/services/social-media/"
  ogTitle="Social Media Content Creation Singapore — Jraft Creative"
  ogDescription="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn. Built for Singapore brands."
  ogImage="https://jraftcreative.com/images/og-social.jpg"
  keywords="social media marketing singapore, social media content creation, instagram marketing, tiktok content, social media agency, content strategy, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Social Media Marketing Singapore"
  heroTitle='Social Media Content Creation &amp; <span class="highlight">Marketing in Singapore</span>'
  heroSubtitle="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn that build your brand and grow your audience."
  heroImage="/images/service-social.webp"
  heroButtons={[
    { text: "Start Creating Content", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20social%20media%20content%20creation%20services.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your social media content creation services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Social Media Presence"
  ctaDescription="Book a free consultation and tell us about your brand. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Start Creating Content", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20social%20media%20content%20creation%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="The social media challenge businesses face">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Struggling to Stay Consistent on Social Media?</h2>
      </div>
      <div class="section-content reveal">
        <p>Most businesses know they need a social media presence but lack the time, resources, or expertise to do it well. Inconsistent posting, low-quality visuals, and generic content lead to stagnant follower growth and minimal engagement.</p>
        <p>Without a clear strategy and professional content, your brand blends into the noise instead of standing out — missing the chance to build trust, attract new customers, and stay top of mind with your audience.</p>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTION (SUB-SERVICES) ========== -->
  <section class="section" id="sub-services" aria-label="Our social media solutions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Solution</p>
        <h2>Our Social Media Services</h2>
      </div>
      <div class="section-content reveal">
        <p>End-to-end content creation and social media management. As a social media agency in Singapore, we craft scroll-stopping content and manage your presence across Instagram, Facebook, TikTok, and LinkedIn — growing your brand awareness and community engagement.</p>
        <p>From content calendars and copywriting to graphic design and performance analytics, we handle the day-to-day so you can focus on running your business while your social channels thrive.</p>
        <p>Maximise your social presence with <a href="/services/paid-ads">paid ads</a> to boost reach, <a href="/services/seo-performance">SEO services</a> to grow organic traffic, or a professionally built <a href="/services/website-development">website</a> to convert followers into customers.</p>
        <p>Explore industry-specific social media: <a href="/tiktok-marketing-agency-singapore/">TikTok marketing agency</a>, <a href="/aesthetics-clinic-social-media-singapore/">aesthetics clinic social</a>, <a href="/restaurant-social-media-singapore/">restaurant social</a>, or see how we work as a full-service <a href="/digital-marketing-agency-singapore/">digital marketing agency</a>.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-content-strategy.webp">
          <div class="service-detail-card__content">
            <h3>Content Strategy &amp; Planning</h3>
            <p>Monthly content calendars, pillar themes, and platform-specific strategies aligned to your business goals and audience behaviour.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Graphic Design &amp; Visuals</h3>
            <p>Branded carousels, infographics, quote cards, and on-brand static posts designed to stand out in the feed across all platforms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Reels &amp; Short-form Video</h3>
            <p>Trending-format vertical videos for Instagram Reels, TikTok, and YouTube Shorts that capture attention and drive engagement.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-copywriting.webp">
          <div class="service-detail-card__content">
            <h3>Copywriting &amp; Captions</h3>
            <p>Engaging captions, hashtag strategy, and platform-optimised copy that drives interaction, saves, and shares.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Community Management</h3>
            <p>Comment moderation, DM responses, engagement tracking, and audience growth tactics to build a loyal community around your brand.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROOF ========== -->
  <section class="section" id="proof" style="background: var(--bg-alt);" aria-label="Social media results and proof">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Social Media Matters in Singapore</p>
        <h2>5.4 Million Singaporeans Are <span class="highlight">Active on Social Media</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Singapore has a social media penetration rate of 92% — one of the highest in Southeast Asia. 5.4 million Singaporeans actively use social media, spending an average of 2 hours and 14 minutes per day scrolling Instagram, TikTok, Facebook, and LinkedIn. For businesses, this is the single largest audience you can reach consistently without paying for ads.</p>
        <p>Instagram Reels and TikTok videos generate 2x the engagement of static image posts, and carousel posts outperform single images by 3.1x on Instagram. Yet most Singapore businesses post inconsistently with low-quality visuals and generic captions — blending into the noise instead of building a recognisable brand.</p>
        <p>Our content strategies help brands build engaged audiences, increase reach, and turn followers into customers. Every post is purposeful and aligned with your business goals. <a href="/services/website-development/#portfolio" class="inline-link">View our portfolio</a> to see how we help brands stand out.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How many posts will I get per month?</summary>
          <div class="faq-answer"><p>Output volume is scoped on the discovery call. Most engagements run 8–20 posts per month plus a mix of Stories, Reels, and short-form video — sized to your platform mix, audience, and growth stage.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can I approve posts before they go live?</summary>
          <div class="faq-answer"><p>Absolutely. We share a content calendar with all posts, captions, and visuals for your approval before scheduling. You can request revisions at any time before publishing.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you create video content like Reels?</summary>
          <div class="faq-answer"><p>Yes. We produce Reels and short-form video for Instagram, TikTok, and YouTube Shorts as part of most engagements — scripting, filming guidance, and editing all handled in-house. Reel volume is scoped to your content calendar on the discovery call.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Which social media platforms do you manage?</summary>
          <div class="faq-answer"><p>We manage Instagram, Facebook, TikTok, LinkedIn, and YouTube. Most engagements cover 2–4 platforms, with the exact mix scoped to where your buyers actually scroll and discover brands like yours.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How do you measure social media success?</summary>
          <div class="faq-answer"><p>We track engagement rate, reach, follower growth, website clicks, and enquiries generated from social media. Monthly reports show what content performs best and how social media contributes to your business goals.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- ========== RELATED SERVICES ========== -->
  <section class="section" id="related-services" aria-label="Related social media services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>Social Media Services by Industry</h2>
      </div>
      <div class="related-services-grid reveal">
        <a href="/aesthetics-clinic-social-media-singapore/" class="related-service-link">Aesthetics Clinic Social</a>
        <a href="/tiktok-marketing-agency-singapore/" class="related-service-link">TikTok Marketing Agency</a>
        <a href="/content-marketing-agency-singapore/" class="related-service-link">Content Marketing Agency</a>
        <a href="/beauty-salon-social-media-singapore/" class="related-service-link">Beauty Salon Social Media</a>
        <a href="/restaurant-social-media-singapore/" class="related-service-link">Restaurant Social Media</a>
        <a href="/fnb-social-media-singapore/" class="related-service-link">F&B Social Media</a>
        <a href="/cafe-social-media-singapore/" class="related-service-link">Cafe Social Media</a>
        <a href="/gym-social-media-singapore/" class="related-service-link">Gym Social Media</a>
        <a href="/spa-social-media-singapore/" class="related-service-link">Spa Social Media</a>
        <a href="/education-social-media-marketing-singapore/" class="related-service-link">Education Social Media</a>
        <a href="/tuition-centre-social-media-singapore/" class="related-service-link">Tuition Centre Social Media</a>
        <a href="/yoga-studio-social-media-singapore/" class="related-service-link">Yoga Studio Social Media</a>
      </div>
    </div>
  </section>

</ServiceLayout>
