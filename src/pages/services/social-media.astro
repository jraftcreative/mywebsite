---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Social Media Content Creation",
    "description": "Social media marketing and content creation services in Singapore including content strategy, graphic design, reels & short-form video, copywriting, and community management.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Social Media Content Creation",
    "offers": [
      { "@type": "Offer", "name": "Essential Social Media", "price": "2000", "priceCurrency": "SGD", "description": "12 posts per month, 2 platforms, branded graphic design, captions & hashtags, monthly content calendar" },
      { "@type": "Offer", "name": "Professional Social Media", "price": "3000", "priceCurrency": "SGD", "description": "20 posts per month, 3 platforms, 4 Reels / short-form videos, stories & highlights design, community management" },
      { "@type": "Offer", "name": "Full-Service Social Media", "price": "5000", "priceCurrency": "SGD", "description": "30+ posts per month, all platforms, 8+ Reels & video production, full community management, influencer coordination" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services" },
      { "@type": "ListItem", "position": 3, "name": "Social Media", "item": "https://jraftcreative.com/services/social-media/" }
    ]
  }
];
---

<ServiceLayout
  title="Social Media Singapore | Content Creation - Jraft Creative"
  description="Social media marketing and content creation agency in Singapore. Strategy, graphic design, reels, copywriting, and community management from $2,000 SGD/month."
  canonical="https://jraftcreative.com/services/social-media/"
  ogTitle="Social Media Marketing Singapore — Jraft Creative"
  ogDescription="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn. Content packages from $2,000 SGD/month."
  keywords="social media marketing singapore, social media content creation, instagram marketing, tiktok content, social media agency, content strategy, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Social Media Marketing Singapore"
  heroTitle='Social Media Content Creation &amp; <span class="highlight">Marketing in Singapore</span>'
  heroSubtitle="Scroll-stopping visuals, reels, and copy for Instagram, TikTok, Facebook, and LinkedIn that build your brand and grow your audience."
  heroImage="/images/service-social.webp"
  heroButtons={[
    { text: "Start Creating Content", href: "/#contact", class: "btn btn-primary" },
    { text: "View Packages", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your social media content creation services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Grow Your Social Media Presence"
  ctaDescription="Book a free consultation and tell us about your brand. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Start Creating Content", href: "/#contact", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20social%20media%20content%20creation%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="The social media challenge businesses face">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Struggling to Stay Consistent on Social Media?</h2>
      </div>
      <div class="section-content reveal">
        <p>Most businesses know they need a social media presence but lack the time, resources, or expertise to do it well. Inconsistent posting, low-quality visuals, and generic content lead to stagnant follower growth and minimal engagement.</p>
        <p>Without a clear strategy and professional content, your brand blends into the noise instead of standing out — missing the chance to build trust, attract new customers, and stay top of mind with your audience.</p>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTION (SUB-SERVICES) ========== -->
  <section class="section" id="sub-services" aria-label="Our social media solutions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Solution</p>
        <h2>Our Social Media Services</h2>
      </div>
      <div class="section-content reveal">
        <p>End-to-end content creation and social media management. As a social media agency in Singapore, we craft scroll-stopping content and manage your presence across Instagram, Facebook, TikTok, and LinkedIn — growing your brand awareness and community engagement.</p>
        <p>From content calendars and copywriting to graphic design and performance analytics, we handle the day-to-day so you can focus on running your business while your social channels thrive.</p>
        <p>Maximise your social presence with <a href="/services/paid-ads">paid ads</a> to boost reach, <a href="/services/seo-performance">SEO services</a> to grow organic traffic, or a professionally built <a href="/services/website-development">website</a> to convert followers into customers.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-content-strategy.webp">
          <div class="service-detail-card__content">
            <h3>Content Strategy &amp; Planning</h3>
            <p>Monthly content calendars, pillar themes, and platform-specific strategies aligned to your business goals and audience behaviour.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Graphic Design &amp; Visuals</h3>
            <p>Branded carousels, infographics, quote cards, and on-brand static posts designed to stand out in the feed across all platforms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-reels-video.webp">
          <div class="service-detail-card__content">
            <h3>Reels &amp; Short-form Video</h3>
            <p>Trending-format vertical videos for Instagram Reels, TikTok, and YouTube Shorts that capture attention and drive engagement.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-copywriting.webp">
          <div class="service-detail-card__content">
            <h3>Copywriting &amp; Captions</h3>
            <p>Engaging captions, hashtag strategy, and platform-optimised copy that drives interaction, saves, and shares.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Community Management</h3>
            <p>Comment moderation, DM responses, engagement tracking, and audience growth tactics to build a loyal community around your brand.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROOF ========== -->
  <section class="section" id="proof" style="background: var(--bg-alt);" aria-label="Social media results and proof">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Results</p>
        <h2>Content That Builds Real Engagement</h2>
      </div>
      <div class="section-content reveal">
        <p>Our content strategies help brands build engaged audiences, increase reach, and turn followers into customers. We focus on quality over quantity — every post is purposeful and aligned with your business goals.</p>
        <p>From growing Instagram followings to driving real enquiries through social media, our clients see tangible results from consistent, professional content. <a href="/#work" class="inline-link">View our portfolio</a> to see how we help brands stand out.</p>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Social media pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Social Media Pricing</p>
        <h2>Content Packages</h2>
        <p>Monthly content packages. All content is yours to keep and reuse.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$2,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For brands starting their social media presence.</p>
            <ul class="pricing-features">
              <li>12 posts per month</li>
              <li>2 platforms</li>
              <li>Branded graphic design</li>
              <li>Captions &amp; hashtags</li>
              <li>Monthly content calendar</li>
            </ul>
            <a href="/#contact" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Professional</h3>
            <div class="price">$3,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For brands ready to grow and engage consistently.</p>
            <ul class="pricing-features">
              <li>20 posts per month</li>
              <li>3 platforms</li>
              <li>4 Reels / short-form videos</li>
              <li>Stories &amp; highlights design</li>
              <li>Captions, hashtags &amp; scheduling</li>
              <li>Basic community management</li>
            </ul>
            <a href="/#contact" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Full-Service</h3>
            <div class="price">$5,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">End-to-end social media management for serious brands.</p>
            <ul class="pricing-features">
              <li>30+ posts per month</li>
              <li>All platforms</li>
              <li>8+ Reels &amp; video production</li>
              <li>Full community management</li>
              <li>Influencer coordination</li>
              <li>Monthly analytics &amp; strategy review</li>
            </ul>
            <a href="/#contact" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</ServiceLayout>
