---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "SEO & Performance Optimisation",
    "description": "Professional SEO services in Singapore including technical SEO audits, on-page optimisation, speed and Core Web Vitals, analytics and reporting, and local SEO.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Search Engine Optimisation",
    "offers": [
      { "@type": "Offer", "name": "Essential SEO", "price": "800", "priceCurrency": "SGD", "description": "Technical SEO audit, on-page optimisation (10 pages), Google Analytics & Search Console, monthly reporting" },
      { "@type": "Offer", "name": "Growth SEO", "price": "1500", "priceCurrency": "SGD", "description": "Everything in Essential plus content strategy, link building, competitor analysis, local SEO" },
      { "@type": "Offer", "name": "Enterprise SEO", "price": "3000", "priceCurrency": "SGD", "description": "Full-service SEO with dedicated strategist, advanced link building, content creation, Core Web Vitals optimisation" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How long does SEO take to show results?", "acceptedAnswer": { "@type": "Answer", "text": "SEO is a long-term strategy. Most businesses start seeing noticeable improvements in organic traffic within 3–6 months. Competitive keywords may take longer, but quick wins like fixing technical issues can show results within weeks." } },
      { "@type": "Question", "name": "Can you guarantee first page rankings?", "acceptedAnswer": { "@type": "Answer", "text": "No legitimate SEO agency can guarantee specific rankings — Google's algorithm considers hundreds of factors. What we guarantee is a data-driven approach, transparent reporting, and continuous optimisation to improve your search visibility over time." } },
      { "@type": "Question", "name": "What's included in the monthly SEO report?", "acceptedAnswer": { "@type": "Answer", "text": "Our reports cover keyword rankings, organic traffic trends, top-performing pages, backlink profile, Core Web Vitals scores, and actionable recommendations. Growth and Enterprise plans include more frequent reporting and strategy calls." } },
      { "@type": "Question", "name": "How is SEO different from paid ads?", "acceptedAnswer": { "@type": "Answer", "text": "SEO drives free organic traffic by improving your site's visibility in search results — results compound over time. Paid ads deliver immediate traffic but stop the moment you pause spending. Most businesses benefit from combining both strategies." } },
      { "@type": "Question", "name": "Do I need a new website before starting SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Not necessarily. We can optimise most existing websites. However, if your site has serious technical issues, slow performance, or an outdated design, we may recommend improvements first. Our technical audit will identify exactly what needs fixing." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services" },
      { "@type": "ListItem", "position": 3, "name": "SEO & Performance", "item": "https://jraftcreative.com/services/seo-performance/" }
    ]
  }
];
---

<ServiceLayout
  title="Jraft Creative | SEO & Performance Optimisation Singapore"
  description="Professional SEO services in Singapore — technical audits, on-page optimisation, local SEO, and Core Web Vitals. Plans from S$800/month."
  canonical="https://jraftcreative.com/services/seo-performance/"
  ogTitle="SEO Services Singapore — Jraft Creative"
  ogDescription="Technical SEO, on-page optimisation, local SEO, and performance monitoring. Results-driven SEO plans from $800 SGD/month."
  ogImage="https://jraftcreative.com/images/og-seo.jpg"
  keywords="SEO agency singapore, SEO services singapore, technical SEO, on-page optimisation, local SEO, Google Business Profile, search engine optimisation, Jraft Creative"
  schemaData={schemaData}
  heroLabel="SEO Agency Singapore"
  heroTitle='SEO &amp; Performance Optimisation <span class="highlight">Services in Singapore</span>'
  heroSubtitle="Dominate search rankings with data-driven SEO strategies. Technical audits, on-page optimisation, local SEO, and performance monitoring that deliver measurable results."
  heroImage="/images/service-seo.webp"
  heroButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "View SEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your SEO services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Boost Your Search Rankings"
  ctaDescription="Book a free SEO consultation and get a complimentary site audit. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free SEO Audit", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20SEO%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="The SEO challenge businesses face">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Invisible on Google Means Invisible to Customers</h2>
      </div>
      <div class="section-content reveal">
        <p>Most businesses in Singapore invest in a website but never see it appear on the first page of Google. Without proper SEO, your site is effectively invisible — losing potential customers to competitors who rank higher every single day.</p>
        <p>Slow page speeds, missing meta data, poor site structure, and lack of local optimisation are common issues that keep businesses buried in search results and missing out on qualified organic traffic.</p>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTION (SUB-SERVICES) ========== -->
  <section class="section" id="sub-services" aria-label="Our SEO solutions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Solution</p>
        <h2>Our SEO &amp; Performance Services</h2>
      </div>
      <div class="section-content reveal">
        <p>Comprehensive search engine optimisation to grow your organic traffic. As an SEO agency in Singapore, we help businesses rank higher on Google through technical audits, on-page optimisation, and strategic link building — driving qualified organic traffic that converts.</p>
        <p>From keyword research and content strategy to site speed and Core Web Vitals, our data-driven approach ensures your website performs at its best across every search engine results page.</p>
        <p>Need a fast, SEO-ready website? Explore our <a href="/services/website-development">website development</a> services. Amplify your reach with <a href="/services/paid-ads">paid ads</a> or build brand awareness through <a href="/services/social-media">social media marketing</a>.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>Technical SEO Audit</h3>
            <p>Comprehensive site crawl, indexing fixes, schema markup, and site architecture improvements to ensure search engines can find and rank your content.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>On-Page Optimisation</h3>
            <p>Keyword research, meta tags, content optimisation, and internal linking strategy to maximise relevance for your target search terms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Core Web Vitals</h3>
            <p>Page speed optimisation, image compression, caching, and performance monitoring to meet Google's Core Web Vitals benchmarks.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-analytics-reporting.webp">
          <div class="service-detail-card__content">
            <h3>Analytics &amp; Reporting</h3>
            <p>Google Analytics 4 setup, Search Console configuration, conversion tracking, and monthly performance reports with actionable insights.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO</h3>
            <p>Google Business Profile optimisation, local citations, review management, and map pack rankings to capture local search traffic in Singapore.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROOF ========== -->
  <section class="section" id="proof" style="background: var(--bg-alt);" aria-label="SEO results and proof">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Results</p>
        <h2>Data-Driven Results You Can Measure</h2>
      </div>
      <div class="section-content reveal">
        <p>Our SEO strategies deliver measurable improvements in organic traffic, keyword rankings, and lead generation. We provide transparent monthly reporting so you can see exactly how your investment is performing.</p>
        <p>From local businesses ranking in Google's map pack to ecommerce sites doubling their organic traffic, our results speak for themselves. <a href="/services/website-development/#portfolio" class="inline-link">See our case studies</a> for real examples.</p>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="SEO pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">SEO Pricing</p>
        <h2>Results-Driven SEO Plans</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For small businesses looking to build organic visibility.</p>
            <ul class="pricing-features">
              <li>Technical SEO audit</li>
              <li>On-page optimisation (10 pages)</li>
              <li>Google Analytics &amp; Search Console</li>
              <li>Monthly keyword tracking</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$1,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses ready to dominate search rankings.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Content strategy &amp; blog SEO</li>
              <li>Link building (5 links/mo)</li>
              <li>Competitor analysis</li>
              <li>Local SEO &amp; Google Business</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$3,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service SEO for high-traffic sites and competitive industries.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Dedicated SEO strategist</li>
              <li>Advanced link building (15+/mo)</li>
              <li>Content creation &amp; publishing</li>
              <li>Core Web Vitals optimisation</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How long does SEO take to show results?</summary>
          <div class="faq-answer"><p>SEO is a long-term strategy. Most businesses start seeing noticeable improvements in organic traffic within 3–6 months. Competitive keywords may take longer, but quick wins like fixing technical issues can show results within weeks.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you guarantee first page rankings?</summary>
          <div class="faq-answer"><p>No legitimate SEO agency can guarantee specific rankings — Google's algorithm considers hundreds of factors. What we guarantee is a data-driven approach, transparent reporting, and continuous optimisation to improve your search visibility over time.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What's included in the monthly SEO report?</summary>
          <div class="faq-answer"><p>Our reports cover keyword rankings, organic traffic trends, top-performing pages, backlink profile, Core Web Vitals scores, and actionable recommendations. Growth and Enterprise plans include more frequent reporting and strategy calls.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>How is SEO different from paid ads?</summary>
          <div class="faq-answer"><p>SEO drives free organic traffic by improving your site's visibility in search results — results compound over time. Paid ads deliver immediate traffic but stop the moment you pause spending. Most businesses benefit from combining both strategies.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do I need a new website before starting SEO?</summary>
          <div class="faq-answer"><p>Not necessarily. We can optimise most existing websites. However, if your site has serious technical issues, slow performance, or an outdated design, we may recommend improvements first. Our technical audit will identify exactly what needs fixing.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
