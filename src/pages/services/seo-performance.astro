---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "SEO & Performance Optimisation",
  "description": "Professional SEO services in Singapore including technical SEO audits, on-page optimisation, speed and Core Web Vitals, analytics and reporting, and local SEO.",
  "provider": {
    "@type": "MarketingAgency",
    "name": "Jraft Creative",
    "url": "https://jraftcreative.com/",
    "logo": "https://jraftcreative.com/images/logo.png",
    "telephone": "+6582234578",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
      "postalCode": "409051",
      "addressLocality": "Singapore",
      "addressCountry": "SG"
    }
  },
  "areaServed": { "@type": "Country", "name": "Singapore" },
  "serviceType": "Search Engine Optimisation",
  "offers": [
    { "@type": "Offer", "name": "Essential SEO", "price": "800", "priceCurrency": "SGD", "description": "Technical SEO audit, on-page optimisation (10 pages), Google Analytics & Search Console, monthly reporting" },
    { "@type": "Offer", "name": "Growth SEO", "price": "1500", "priceCurrency": "SGD", "description": "Everything in Essential plus content strategy, link building, competitor analysis, local SEO" },
    { "@type": "Offer", "name": "Enterprise SEO", "price": "3000", "priceCurrency": "SGD", "description": "Full-service SEO with dedicated strategist, advanced link building, content creation, Core Web Vitals optimisation" }
  ]
};
---

<ServiceLayout
  title="SEO Services Singapore | SEO Agency &amp; Performance Optimisation — Jraft Creative"
  description="Professional SEO services in Singapore. Technical SEO audits, on-page optimisation, local SEO, speed optimisation, and monthly reporting. Plans from $800 SGD/month."
  canonical="https://jraftcreative.com/services/seo-performance"
  ogTitle="SEO Services Singapore — Jraft Creative"
  ogDescription="Technical SEO, on-page optimisation, local SEO, and performance monitoring. Results-driven SEO plans from $800 SGD/month."
  keywords="SEO agency singapore, SEO services singapore, technical SEO, on-page optimisation, local SEO, Google Business Profile, search engine optimisation, Jraft Creative"
  schemaData={schemaData}
  heroLabel="SEO Agency Singapore"
  heroTitle='SEO &amp; Performance Optimisation <span class="highlight">Services in Singapore</span>'
  heroSubtitle="Dominate search rankings with data-driven SEO strategies. Technical audits, on-page optimisation, local SEO, and performance monitoring that deliver measurable results."
  heroImage="/images/service-seo.webp"
  heroButtons={[
    { text: "Get a Free SEO Audit", href: "/#contact", class: "btn btn-primary" },
    { text: "View SEO Plans", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your SEO services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Boost Your Search Rankings"
  ctaDescription="Book a free SEO consultation and get a complimentary site audit. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Get a Free SEO Audit", href: "/#contact", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20SEO%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== SUB-SERVICES ========== -->
  <section class="section" id="sub-services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What's Included</p>
        <h2>Our SEO &amp; Performance Services</h2>
      </div>
      <div class="section-content reveal">
        <p>Comprehensive search engine optimisation to grow your organic traffic. As an SEO agency in Singapore, we help businesses rank higher on Google through technical audits, on-page optimisation, and strategic link building — driving qualified organic traffic that converts.</p>
        <p>From keyword research and content strategy to site speed and Core Web Vitals, our data-driven approach ensures your website performs at its best across every search engine results page.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-seo-audit.webp">
          <div class="service-detail-card__content">
            <h3>Technical SEO Audit</h3>
            <p>Comprehensive site crawl, indexing fixes, schema markup, and site architecture improvements to ensure search engines can find and rank your content.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>On-Page Optimisation</h3>
            <p>Keyword research, meta tags, content optimisation, and internal linking strategy to maximise relevance for your target search terms.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Speed &amp; Core Web Vitals</h3>
            <p>Page speed optimisation, image compression, caching, and performance monitoring to meet Google's Core Web Vitals benchmarks.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-analytics-reporting.webp">
          <div class="service-detail-card__content">
            <h3>Analytics &amp; Reporting</h3>
            <p>Google Analytics 4 setup, Search Console configuration, conversion tracking, and monthly performance reports with actionable insights.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO</h3>
            <p>Google Business Profile optimisation, local citations, review management, and map pack rankings to capture local search traffic in Singapore.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" style="background: var(--bg-alt);">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">SEO Pricing</p>
        <h2>Results-Driven SEO Plans</h2>
        <p>Monthly retainer plans. No lock-in contracts.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Essential</h3>
            <div class="price">$800 <span>SGD/mo</span></div>
            <p class="pricing-desc">For small businesses looking to build organic visibility.</p>
            <ul class="pricing-features">
              <li>Technical SEO audit</li>
              <li>On-page optimisation (10 pages)</li>
              <li>Google Analytics &amp; Search Console</li>
              <li>Monthly keyword tracking</li>
              <li>Monthly performance report</li>
            </ul>
            <a href="/#contact" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$1,500 <span>SGD/mo</span></div>
            <p class="pricing-desc">For businesses ready to dominate search rankings.</p>
            <ul class="pricing-features">
              <li>Everything in Essential</li>
              <li>Content strategy &amp; blog SEO</li>
              <li>Link building (5 links/mo)</li>
              <li>Competitor analysis</li>
              <li>Local SEO &amp; Google Business</li>
              <li>Bi-weekly reporting</li>
            </ul>
            <a href="/#contact" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Enterprise</h3>
            <div class="price">$3,000+ <span>SGD/mo</span></div>
            <p class="pricing-desc">Full-service SEO for high-traffic sites and competitive industries.</p>
            <ul class="pricing-features">
              <li>Everything in Growth</li>
              <li>Dedicated SEO strategist</li>
              <li>Advanced link building (15+/mo)</li>
              <li>Content creation &amp; publishing</li>
              <li>Core Web Vitals optimisation</li>
              <li>Weekly reporting &amp; strategy calls</li>
            </ul>
            <a href="/#contact" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</ServiceLayout>
