---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Website Development",
    "description": "Professional website development services in Singapore including custom business websites, ecommerce stores, web applications, landing pages, and AI integration.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": {
      "@type": "Country",
      "name": "Singapore"
    },
    "serviceType": "Website Development",
    "offers": [
      { "@type": "Offer", "name": "Starter Website", "price": "2500", "priceCurrency": "SGD", "description": "Up to 5 pages, mobile responsive design, contact form, basic SEO setup" },
      { "@type": "Offer", "name": "Business Website", "price": "5500", "priceCurrency": "SGD", "description": "Up to 12 pages, custom design & animations, CMS / blog integration, booking or enquiry system" },
      { "@type": "Offer", "name": "Premium Website", "price": "10000", "priceCurrency": "SGD", "description": "Unlimited pages, ecommerce / web app, payment integration, user accounts & dashboards" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How long does it take to build a website?", "acceptedAnswer": { "@type": "Answer", "text": "A typical business website takes 4–6 weeks from kickoff to launch. Ecommerce stores and web applications may take 8–12 weeks depending on complexity. We provide a detailed timeline during our free consultation." } },
      { "@type": "Question", "name": "Can I update the website content myself?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build most websites with a content management system (CMS) so you can edit text, images, and blog posts without any coding knowledge. We also provide a training session after launch." } },
      { "@type": "Question", "name": "Do you offer website maintenance after launch?", "acceptedAnswer": { "@type": "Answer", "text": "All packages include post-launch support (1–6 months depending on your plan). After that, we offer monthly maintenance plans starting from S$200/month covering updates, backups, security, and minor changes." } },
      { "@type": "Question", "name": "What platforms do you build websites on?", "acceptedAnswer": { "@type": "Answer", "text": "We use modern frameworks like Astro, Next.js, and WordPress depending on your needs. For ecommerce, we work with Shopify and WooCommerce. We recommend the best platform for your specific requirements during the consultation." } },
      { "@type": "Question", "name": "Do you provide hosting?", "acceptedAnswer": { "@type": "Answer", "text": "We help set up hosting on reliable platforms like Cloudflare, Vercel, or managed WordPress hosting with Singapore-based servers for fast load times. Hosting costs are separate and typically range from S$10–S$50 per month." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services" },
      { "@type": "ListItem", "position": 3, "name": "Website Development", "item": "https://jraftcreative.com/services/website-development/" }
    ]
  }
];
---

<ServiceLayout
  title="Jraft Creative | Web Design & Website Development Singapore"
  description="Jraft Creative builds custom websites in Singapore — business sites, ecommerce stores, web apps, and landing pages. Starting from $2,500 SGD."
  canonical="https://jraftcreative.com/services/website-development/"
  ogTitle="Website Development Singapore — Jraft Creative"
  ogDescription="Custom websites, ecommerce stores, and web applications designed to convert and built to scale. Starting from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="website development singapore, web design agency singapore, custom website singapore, ecommerce development, web application, landing page design, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Website Development Singapore"
  heroTitle='Custom Website Development &amp; <span class="highlight">Web Design in Singapore</span>'
  heroSubtitle="From business websites to full ecommerce stores and web applications — we design and build digital experiences that convert visitors into customers."
  heroImage="/images/service-webdev.webp"
  heroButtons={[
    { text: "Start Your Project", href: "/contact/", class: "btn btn-primary" },
    { text: "View Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I'd like to enquire about your website development services."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Let's Build Your Website"
  ctaDescription="Book a free consultation and tell us about your project. We'll get back to you within 24 hours."
  ctaButtons={[
    { text: "Start Your Project", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%27d%20like%20to%20enquire%20about%20your%20website%20development%20services.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== PROBLEM ========== -->
  <section class="section" id="challenge" aria-label="The challenge businesses face">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your <span class="highlight">Website</span> Should Be Your Best <span class="highlight">Salesperson</span></h2>
        <p>Most businesses in Singapore lose customers to these common website problems.</p>
      </div>
      <div class="challenge-grid">
        <div class="challenge-card challenge-card--overlay reveal reveal-d1" data-bg="/images/challenge-outdated.webp">
          <div class="challenge-card__content">
            <h3>Outdated Design</h3>
            <p>A dated website signals an outdated business. Visitors judge your credibility within 0.05 seconds — and leave if it looks unprofessional.</p>
          </div>
        </div>
        <div class="challenge-card challenge-card--overlay reveal reveal-d2" data-bg="/images/challenge-mobile.webp">
          <div class="challenge-card__content">
            <h3>Not Mobile-Friendly</h3>
            <p>Over 72% of Singapore web traffic is mobile. If your site isn't responsive, you're invisible to most of your potential customers.</p>
          </div>
        </div>
        <div class="challenge-card challenge-card--overlay reveal reveal-d3" data-bg="/images/challenge-slow.webp">
          <div class="challenge-card__content">
            <h3>Painfully Slow</h3>
            <p>53% of visitors leave if a page takes longer than 3 seconds to load. Slow sites kill conversions and hurt your Google rankings.</p>
          </div>
        </div>
        <div class="challenge-card challenge-card--overlay reveal reveal-d1" data-bg="/images/challenge-cta.webp">
          <div class="challenge-card__content">
            <h3>No Clear CTA</h3>
            <p>Visitors land on your site but don't know what to do next. Without clear calls-to-action, traffic doesn't convert into enquiries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTION (SUB-SERVICES) ========== -->
  <section class="section" id="sub-services" aria-label="Our website development solutions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Solution</p>
        <h2>Our <span class="highlight">Website Development</span> Services</h2>
      </div>
      <div class="section-content reveal">
        <p>Everything you need to establish a powerful online presence. As a website development agency in Singapore, we build custom websites that are fast, mobile-friendly, and designed to convert. From corporate sites and ecommerce stores to web applications, every project is crafted around user experience and business growth.</p>
        <p>Our web design approach pairs responsive design with SEO-ready structure and conversion-focused layouts — so your site looks great on every device and drives real results for your online presence.</p>
        <p>Pair your new website with our <a href="/services/seo-performance">SEO &amp; performance optimisation</a> services to rank higher on Google, drive traffic with <a href="/services/paid-ads">paid ads management</a>, or grow your brand through <a href="/services/social-media">social media content creation</a>.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Business Websites</h3>
            <p>Custom-designed, mobile-responsive sites that showcase your brand and convert visitors into leads and customers.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-ecommerce.webp">
          <div class="service-detail-card__content">
            <h3>Ecommerce Stores</h3>
            <p>Online stores with product catalogs, secure checkout, inventory management, and seamless payment integration.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-web-app.webp">
          <div class="service-detail-card__content">
            <h3>Web Applications</h3>
            <p>Booking systems, client portals, dashboards, and custom operational tools tailored to your business workflows.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Landing Pages</h3>
            <p>High-converting campaign pages optimised for promotions, product launches, and lead generation.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-ai.webp">
          <div class="service-detail-card__content">
            <h3>AI Integration</h3>
            <p>Chatbots, automated workflows, and AI-powered features that make your business smarter and more efficient.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PORTFOLIO CAROUSEL ========== -->
  <section class="section" id="portfolio" style="background: var(--bg-alt);" aria-label="Our portfolio">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Portfolio</p>
        <h2>Real Websites, Real Results</h2>
        <p>15+ websites delivered for businesses across Singapore.</p>
      </div>
    </div>
    <div class="carousel-wrapper reveal">
      <div class="carousel-track" id="portfolioCarousel">
        <a href="https://www.musicwithpat.com" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-music.webp" alt="Music with Pat" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">Music &middot; Website</span>
            <h3>Music with Pat</h3>
            <p>Portfolio and booking website for a piano teacher with consultation calendar and lead capture.</p>
          </div>
        </a>
        <a href="https://kairos-advisorygroup.com/" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-kairos.webp" alt="Kairos Advisory Group" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">Finance &middot; Website Revamp</span>
            <h3>Kairos Advisory Group</h3>
            <p>Website revamp for a financial advisory firm with service pages and team profiles.</p>
          </div>
        </a>
        <a href="https://jraftcreative.github.io/portfolio-restaurant/" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-restaurant.webp" alt="Sakura Kitchen" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">F&amp;B &middot; Website</span>
            <h3>Sakura Kitchen</h3>
            <p>Modern restaurant website with online menu, reservation system, and gallery.</p>
          </div>
        </a>
        <a href="https://jraftcreative.github.io/portfolio-tutor/" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-tutor.webp" alt="BrightPath Tutors" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">Education &middot; Platform</span>
            <h3>BrightPath Tutors</h3>
            <p>Tutor discovery and booking platform with subject filtering and enquiry flow.</p>
          </div>
        </a>
        <a href="https://jraftcreative.github.io/portfolio-ecommerce/" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-ecommerce.webp" alt="MŌDA Fashion &amp; Lifestyle" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">Retail &middot; Ecommerce</span>
            <h3>MŌDA</h3>
            <p>Premium ecommerce storefront with product collections and editorial layouts.</p>
          </div>
        </a>
        <a href="https://jraftcreative.github.io/pawhaus/" class="carousel-slide" target="_blank" rel="noopener">
          <div class="carousel-image"><img src="/images/preview-pawhaus.webp" alt="PawHaus Pet Store" width="600" height="400" loading="lazy"></div>
          <div class="carousel-info">
            <span class="carousel-type">Pets &middot; Ecommerce</span>
            <h3>PawHaus</h3>
            <p>Pet supplies ecommerce store with Snipcart checkout and product pages.</p>
          </div>
        </a>
      </div>
      <div class="carousel-controls">
        <button class="carousel-btn carousel-prev" id="carouselPrev" aria-label="Previous project"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
        <div class="carousel-dots" id="carouselDots"></div>
        <button class="carousel-btn carousel-next" id="carouselNext" aria-label="Next project"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Pricing plans">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Transparent Website Pricing</h2>
        <p>No hidden fees. Choose the package that fits your needs.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">Perfect for small businesses needing a professional online presence.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Mobile responsive design</li>
              <li>Contact form</li>
              <li>Basic SEO setup</li>
              <li>2 rounds of revisions</li>
              <li>1 month support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For growing businesses that need more functionality and polish.</p>
            <ul class="pricing-features">
              <li>Up to 12 pages</li>
              <li>Custom design &amp; animations</li>
              <li>CMS / blog integration</li>
              <li>Booking or enquiry system</li>
              <li>Advanced SEO &amp; analytics</li>
              <li>3 months support</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">Full ecommerce, web apps, and complex custom builds.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Ecommerce / web app</li>
              <li>Payment integration</li>
              <li>User accounts &amp; dashboards</li>
              <li>API integrations</li>
              <li>6 months support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How long does it take to build a website?</summary>
          <div class="faq-answer"><p>A typical business website takes 4–6 weeks from kickoff to launch. Ecommerce stores and web applications may take 8–12 weeks depending on complexity. We provide a detailed timeline during our free consultation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can I update the website content myself?</summary>
          <div class="faq-answer"><p>Yes. We build most websites with a content management system (CMS) so you can edit text, images, and blog posts without any coding knowledge. We also provide a training session after launch.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you offer website maintenance after launch?</summary>
          <div class="faq-answer"><p>All packages include post-launch support (1–6 months depending on your plan). After that, we offer monthly maintenance plans starting from S$200/month covering updates, backups, security, and minor changes.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>What platforms do you build websites on?</summary>
          <div class="faq-answer"><p>We use modern frameworks like Astro, Next.js, and WordPress depending on your needs. For ecommerce, we work with Shopify and WooCommerce. We recommend the best platform for your specific requirements during the consultation.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Do you provide hosting?</summary>
          <div class="faq-answer"><p>We help set up hosting on reliable platforms like Cloudflare, Vercel, or managed WordPress hosting with Singapore-based servers for fast load times. Hosting costs are separate and typically range from S$10–S$50 per month.</p></div>
        </details>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var track = document.getElementById('portfolioCarousel');
      var slides = track.querySelectorAll('.carousel-slide');
      var prevBtn = document.getElementById('carouselPrev');
      var nextBtn = document.getElementById('carouselNext');
      var dotsWrap = document.getElementById('carouselDots');
      var current = 0;
      var total = slides.length;
      var interval;

      // Create dots
      for (var i = 0; i < total; i++) {
        var dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to project ' + (i + 1));
        dot.dataset.index = i;
        dotsWrap.appendChild(dot);
      }
      var dots = dotsWrap.querySelectorAll('.carousel-dot');

      function goTo(index) {
        current = ((index % total) + total) % total;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, j) { d.classList.toggle('active', j === current); });
      }

      prevBtn.addEventListener('click', function() { goTo(current - 1); resetAuto(); });
      nextBtn.addEventListener('click', function() { goTo(current + 1); resetAuto(); });
      dotsWrap.addEventListener('click', function(e) {
        if (e.target.classList.contains('carousel-dot')) {
          goTo(parseInt(e.target.dataset.index));
          resetAuto();
        }
      });

      function startAuto() { interval = setInterval(function() { goTo(current + 1); }, 6000); }
      function resetAuto() { clearInterval(interval); startAuto(); }

      // Pause on hover
      var wrapper = track.parentElement;
      wrapper.addEventListener('mouseenter', function() { clearInterval(interval); });
      wrapper.addEventListener('mouseleave', function() { startAuto(); });

      // Touch swipe
      var startX = 0;
      track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; clearInterval(interval); }, { passive: true });
      track.addEventListener('touchend', function(e) {
        var diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) { goTo(current + (diff > 0 ? 1 : -1)); }
        startAuto();
      });

      startAuto();
    })();
  </script>

</ServiceLayout>
