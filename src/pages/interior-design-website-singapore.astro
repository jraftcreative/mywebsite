---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Interior Design Website Singapore",
    "description": "Professional website design for interior designers and renovation firms in Singapore. Portfolio galleries, project showcases, and consultation booking — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Interior Design Website",
    "offers": [
      { "@type": "Offer", "name": "Starter Interior Design Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page portfolio website with project gallery, services page, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Interior Design Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with before/after galleries, blog, advanced SEO, Google Business Profile, and consultation booking" },
      { "@type": "Offer", "name": "Premium Interior Design Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with 3D gallery integration, client portal, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an interior design website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional interior design website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page portfolio site with project gallery and contact form. Business and Premium packages add before/after showcases, blog, consultation booking, and client portals." } },
      { "@type": "Question", "name": "Can you build a portfolio website that showcases our projects?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Portfolio presentation is the core of every interior design website we build. We create filterable project galleries with high-resolution images, room-by-room breakdowns, and before/after comparisons that let potential clients see the quality of your work before they enquire." } },
      { "@type": "Question", "name": "Do you include before and after galleries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include interactive before/after galleries with slider comparisons. These are one of the most effective conversion tools for interior design firms — homeowners want to see the transformation you can deliver." } },
      { "@type": "Question", "name": "Can clients book consultations through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We can integrate consultation booking directly into your website. Potential clients can select a date and time, describe their project, and book a site visit or virtual consultation — reducing the back-and-forth of scheduling via email or WhatsApp." } },
      { "@type": "Question", "name": "How long does it take to build an interior design website?", "acceptedAnswer": { "@type": "Answer", "text": "Most interior design websites go live within 2–3 weeks. A simple portfolio site can be ready in 2 weeks, while larger projects with 3D galleries or client portals may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Interior Design Website Singapore", "item": "https://jraftcreative.com/interior-design-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Interior Design Website Singapore — Portfolio & Renovation Web Design | Jraft Creative"
  description="Professional website design for interior designers and renovation firms in Singapore. Portfolio galleries, project showcases, and consultation booking — from S$2,500."
  canonical="https://jraftcreative.com/interior-design-website-singapore/"
  ogTitle="Interior Design Website Singapore — Jraft Creative"
  ogDescription="Website design for interior designers in Singapore. Portfolio galleries, before/after showcases, consultation booking — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="interior design website singapore, renovation website design, interior designer portfolio website, id firm website singapore, renovation company website, home design web design singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Interior Design Websites"
  heroTitle='Website Design for <span class="highlight">Interior Designers in Singapore</span>'
  heroSubtitle="Your portfolio deserves a website that does your work justice. We build visually stunning, mobile-friendly websites for interior designers and renovation firms — with project galleries, before/after showcases, and consultation booking built in."
  heroImage="/images/service-interior.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my interior design firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Showcase Your Design Portfolio Online"
  ctaDescription="Book a free consultation and tell us about your interior design firm. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20interior%20design%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why interior designers need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Homeowners Browse Qanvast — But They Want to See Your Portfolio</h2>
      </div>
      <div class="section-content reveal">
        <p>Homeowners in Singapore start their renovation research on platforms like Qanvast and Houzz. They browse through dozens of firms, shortlist a few, and then do what every serious buyer does — they Google your company name. If you don't have a professional website with a strong portfolio, you lose the enquiry to an ID firm that does.</p>
        <p>A website without proper project galleries is a missed opportunity. Potential clients want to see your completed projects in detail — room-by-room walkthroughs, material choices, layout transformations. A generic site with stock photos and a contact form doesn't give them the confidence to reach out. Your work needs to be front and centre, presented in a way that reflects the quality you deliver.</p>
        <p>Singapore's HDB and condo renovation market is fiercely competitive. Hundreds of ID firms are fighting for the same pool of homeowners. Your online presence needs to stand out — not just on listing platforms, but on Google search results, on your own domain, and on social media. A purpose-built website is the foundation that ties all of that together.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Interior design website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Interior Designers</h2>
      </div>
      <div class="section-content reveal">
        <p>Every interior design website we deliver is purpose-built for the renovation industry. We go beyond a generic template — your site will feature high-impact project galleries, interactive before/after showcases, consultation booking, and structured service pages that convert visitors into enquiries.</p>
        <p>We understand that ID firms in Singapore need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/" class="inline-link">SEO services</a> to rank for renovation searches in your area, <a href="/services/social-media/" class="inline-link">social media marketing</a> to showcase your latest projects on Instagram and Facebook, and <a href="/services/paid-ads/" class="inline-link">paid ads management</a> for targeted campaigns on Google and Meta.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Project Portfolio Galleries</h3>
            <p>Filterable project galleries with high-resolution images, room-by-room breakdowns, and project descriptions. Organised by property type — HDB, condo, landed — so homeowners can find projects that match their own home.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Before &amp; After Showcases</h3>
            <p>Interactive before/after sliders that let visitors drag to reveal the transformation. Nothing sells interior design work better than showing the raw space alongside the finished result — it builds trust and drives enquiries.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Consultation Booking</h3>
            <p>Built-in booking forms that let potential clients select a date, describe their renovation project, and schedule a site visit or virtual consultation — reducing the back-and-forth of arranging meetings through WhatsApp or email.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Design Process &amp; Services Pages</h3>
            <p>Structured pages that walk homeowners through your design process — from initial consultation to handover. Clear service descriptions, package breakdowns, and pricing transparency that set expectations before the first meeting.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for interior design website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Interior Design Web Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've built websites for design-driven businesses across Singapore. We know how to present visual work online in a way that converts browsers into booked consultations — and we design every element of your website around that goal.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Design Industry Experience</h3>
            <p>We understand the unique needs of interior design firms — from portfolio layouts and project categorisation to gallery UX and lead capture flows that turn website visitors into consultation bookings.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most interior design websites go live within 2 weeks of kickoff. We know time matters when you're launching a new firm, rebranding, or simply losing enquiries to competitors with better websites.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Homeowners research renovations on their phones during commutes, lunch breaks, and late-night scrolling sessions. Every site we build is designed mobile-first with fast load times and thumb-friendly navigation.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on designing beautiful spaces for your clients.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Interior design website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Interior Design Website Pricing</p>
        <h2>Website Packages for Interior Designers &amp; Renovation Firms</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new ID firms and renovation contractors getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Project portfolio gallery</li>
              <li>Services &amp; contact pages</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For ID firms ready to grow enquiries online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Before/after galleries</li>
              <li>Consultation booking</li>
              <li>Blog / news section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For established firms and premium design studios.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>3D gallery integration</li>
              <li>Client portal</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about interior design website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Interior Design Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an interior design website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional interior design website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page portfolio site with project gallery and contact form. Business and Premium packages add before/after showcases, blog, consultation booking, and client portals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build a portfolio website that showcases our projects?</summary>
          <div class="faq-answer"><p>Absolutely. Portfolio presentation is the core of every interior design website we build. We create filterable project galleries with high-resolution images, room-by-room breakdowns, and before/after comparisons that let potential clients see the quality of your work before they enquire.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you include before and after galleries?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include interactive before/after galleries with slider comparisons. These are one of the most effective conversion tools for interior design firms — homeowners want to see the transformation you can deliver.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can clients book consultations through the website?</summary>
          <div class="faq-answer"><p>Yes. We can integrate consultation booking directly into your website. Potential clients can select a date and time, describe their project, and book a site visit or virtual consultation — reducing the back-and-forth of scheduling via email or WhatsApp.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an interior design website?</summary>
          <div class="faq-answer"><p>Most interior design websites go live within 2-3 weeks. A simple portfolio site can be ready in 2 weeks, while larger projects with 3D galleries or client portals may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
