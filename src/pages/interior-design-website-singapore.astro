---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Interior Design Website Singapore",
    "description": "Professional website design for interior designers and renovation firms in Singapore. Portfolio galleries, project showcases, and consultation booking — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Interior Design Website",
    "offers": [
      { "@type": "Offer", "name": "Starter Interior Design Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page portfolio website with project gallery, services page, contact form, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Interior Design Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with before/after galleries, blog, advanced SEO, Google Business Profile, and consultation booking" },
      { "@type": "Offer", "name": "Premium Interior Design Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with 3D gallery integration, client portal, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an interior design website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional interior design website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page portfolio site with project gallery and contact form. Business and Premium packages add before/after showcases, blog, consultation booking, and client portals." } },
      { "@type": "Question", "name": "Can you build a portfolio website that showcases our projects?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Portfolio presentation is the core of every interior design website we build. We create filterable project galleries with high-resolution images, room-by-room breakdowns, and before/after comparisons that let potential clients see the quality of your work before they enquire." } },
      { "@type": "Question", "name": "Do you include before and after galleries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include interactive before/after galleries with slider comparisons. These are one of the most effective conversion tools for interior design firms — homeowners want to see the transformation you can deliver." } },
      { "@type": "Question", "name": "Can clients book consultations through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We can integrate consultation booking directly into your website. Potential clients can select a date and time, describe their project, and book a site visit or virtual consultation — reducing the back-and-forth of scheduling via email or WhatsApp." } },
      { "@type": "Question", "name": "How long does it take to build an interior design website?", "acceptedAnswer": { "@type": "Answer", "text": "Most interior design websites go live within 2–3 weeks. A simple portfolio site can be ready in 2 weeks, while larger projects with 3D galleries or client portals may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Interior Design Website Singapore", "item": "https://jraftcreative.com/interior-design-website-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Force 3x2 grid on desktop for the deliver section per locked landing-page pattern */
  #sub-services .deliver-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  #sub-services {
    padding-top: 72px;
    padding-bottom: 72px;
  }
  @media (max-width: 900px) {
    #sub-services .deliver-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    #sub-services .deliver-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Renovation Buyer Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Interior Design Website Singapore — Jraft Creative"
  description="Website design for interior designers and renovation firms in Singapore. Portfolio galleries, project showcases, and consultation booking — from S$2,500."
  canonical="https://jraftcreative.com/interior-design-website-singapore/"
  ogTitle="Interior Design Website Singapore — Jraft Creative"
  ogDescription="Website design for interior designers in Singapore. Portfolio galleries, before/after showcases, consultation booking — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="interior design website singapore, renovation website design, interior designer portfolio website, id firm website singapore, renovation company website, home design web design singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Interior Design Websites"
  heroTitle='Website Design for <span class="highlight">Interior Designers in Singapore</span>'
  heroSubtitle="Your portfolio deserves a website that does your work justice. We build visually stunning, mobile-friendly websites for interior designers and renovation firms — with project galleries, before/after showcases, and consultation booking built in."
  heroImage="/images/service-interior.webp"
  heroImageAlt="Website design for interior designers in Singapore — portfolio galleries, before-after showcases, consultation booking"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20interior%20design%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my interior design firm in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle='Showcase Your <span class="highlight">Design Portfolio</span> Online'
  ctaDescription="Book a free consultation and tell us about your interior design firm. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20interior%20design%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why interior designers need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Homeowners Browse <span class="highlight">Qanvast</span> — Then They <span class="highlight">Google You</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Renovation buyers shortlist on aggregator platforms, then do what every serious buyer does — they Google your firm's name. If your site does not back up the listing, you lose the enquiry to an ID firm whose site does.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Aggregator-to-Google Handoff</h3>
            <p>Homeowners discover you on Qanvast or Houzz, then Google your firm to vet you. A generic site with stock photos and a contact form does not give them the confidence to enquire — they bounce back to the listing and pick a firm whose site closed the loop.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Portfolio-as-Hard-Drive Trap</h3>
            <p>Most ID-firm sites treat the portfolio as an afterthought — uncategorised image grids, no project context, no filtering by HDB or condo or landed. Buyers want room-by-room walkthroughs, material choices, and layout transformations they can imagine in their own home.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The Mobile-Last Mistake</h3>
            <p>Renovation buyers research on their phones during commutes, lunch breaks, and late-night scrolls. A desktop-first site with slow images, tiny tap targets, and broken galleries on mobile loses enquiries the firm never sees.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Interior design website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>Six <span class="highlight">Conversion Features</span> Every ID Firm Site <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Every interior design website we deliver is purpose-built for the renovation industry — high-impact project galleries, interactive before-after showcases, consultation booking, and structured service pages that convert visitors into enquiries.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3>Portfolio Galleries</h3>
            <p>Filterable project galleries with high-resolution images, room-by-room breakdowns, and project descriptions. Organised by property type — HDB, condo, landed — so homeowners can find projects that match their own home.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-landing-page.webp');">
          <div class="service-detail-card__content">
            <h3>Before &amp; After Showcases</h3>
            <p>Interactive before-after sliders that let visitors drag to reveal the transformation. Nothing sells interior design work better than showing the raw space alongside the finished result — it builds trust and drives enquiries.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3>Consultation Booking</h3>
            <p>Built-in booking forms that let potential clients select a date, describe their renovation project, and schedule a site visit or virtual consultation — reducing the back-and-forth of arranging meetings through WhatsApp or email.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3>Services &amp; Process</h3>
            <p>Structured pages that walk homeowners through your design process — from initial consultation to handover. Clear service descriptions, package breakdowns, and pricing transparency that set expectations before the first meeting.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-onpage-seo.webp');">
          <div class="service-detail-card__content">
            <h3>SEO &amp; Catchment Pages</h3>
            <p>Built on a structure Google can index — clean schema, sitemap, fast mobile loads, and optional catchment landing pages for Punggol, Sengkang, Tampines, and other HDB BTO clusters where your firm wants to rank.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-speed-vitals.webp');">
          <div class="service-detail-card__content">
            <h3>Mobile Speed &amp; Core Web Vitals</h3>
            <p>Every site we build is mobile-first with fast load times, thumb-friendly navigation, and image optimisation. Renovation buyers research on their phones — a site that lags on a phone loses the enquiry before it lands.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for interior design website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Websites</span> Built for How <span class="highlight">Renovation Buyers</span> Actually Shop</h2>
      </div>
      <div class="section-content reveal">
        <p>We have built websites for design-driven businesses across Singapore. We know how to present visual work online in a way that converts browsers into booked consultations — and we design every element of your site around that goal.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Design-Industry Experience</h3>
            <p>We understand the unique needs of interior design firms — from portfolio layouts and project categorisation to gallery UX and lead-capture flows that turn website visitors into consultation bookings.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — Two Weeks</h3>
            <p>Most interior design websites go live within two weeks of kickoff. We know time matters when you are launching a new firm, rebranding, or losing enquiries to competitors with better sites today.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on designing beautiful spaces for your clients — not coordinating three vendors.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== RENOVATION BUYER FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Renovation Buyer Funnel — how Singapore homeowners decide on an ID firm">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Buyer Funnel</p>
        <h2>How <span class="highlight">Renovation Buyers</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From BTO key collection to a signed contract, every HDB and condo renovation buyer in Singapore moves through the same five stages. Your portfolio site is the asset that closes the visit at every one of them.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Inspiration</h3>
          <p>Pinterest, IG Reels, TikTok walkthroughs</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Qanvast, Renonation, Google, AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Quote</h3>
          <p>3–5 firm consultations</p>
        </li>
        <li class="funnel-stage">
          <h3>Site Visit</h3>
          <p>Walkthroughs with shortlisted firms</p>
        </li>
        <li class="funnel-stage">
          <h3>Sign</h3>
          <p>Contract awarded</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about interior design website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2><span class="highlight">Interior Design Website</span> — Questions <span class="highlight">Answered</span></h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an interior design website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional interior design website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page portfolio site with project gallery and contact form. Business and Premium packages add before/after showcases, blog, consultation booking, and client portals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build a portfolio website that showcases our projects?</summary>
          <div class="faq-answer"><p>Absolutely. Portfolio presentation is the core of every interior design website we build. We create filterable project galleries with high-resolution images, room-by-room breakdowns, and before/after comparisons that let potential clients see the quality of your work before they enquire.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you include before and after galleries?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include interactive before/after galleries with slider comparisons. These are one of the most effective conversion tools for interior design firms — homeowners want to see the transformation you can deliver.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can clients book consultations through the website?</summary>
          <div class="faq-answer"><p>Yes. We can integrate consultation booking directly into your website. Potential clients can select a date and time, describe their project, and book a site visit or virtual consultation — reducing the back-and-forth of scheduling via email or WhatsApp.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an interior design website?</summary>
          <div class="faq-answer"><p>Most interior design websites go live within 2-3 weeks. A simple portfolio site can be ready in 2 weeks, while larger projects with 3D galleries or client portals may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More <span class="highlight">Interior Designer</span> Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/interior-designer-marketing-singapore/" class="related-service-link">Marketing for Interior Designers</a>
          <a href="/interior-designer-seo-singapore/" class="related-service-link">SEO for Interior Designers</a>
          <a href="/interior-designer-google-ads-singapore/" class="related-service-link">Google Ads for ID Firms</a>
          <a href="/interior-designer-social-media-singapore/" class="related-service-link">Social Media for ID Firms</a>
          <a href="/interior-designer-branding-singapore/" class="related-service-link">ID Firm Branding</a>
          <a href="/geo-agency-singapore/" class="related-service-link">GEO / AI Search Optimisation</a>
      </div>
    </div>
  </section>
</ServiceLayout>
