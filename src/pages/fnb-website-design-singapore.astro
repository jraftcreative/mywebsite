---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "F&B Website Design Singapore",
    "description": "Professional website design for restaurants, cafes, and F&B businesses in Singapore. Menu integration, online ordering, and Google Maps — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Restaurant Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter F&B Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page restaurant website with menu pages, contact form, Google Maps, and basic SEO setup" },
      { "@type": "Offer", "name": "Business F&B Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with online ordering integration, blog, advanced SEO, and Google Business Profile optimisation" },
      { "@type": "Offer", "name": "Premium F&B Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with multi-location support, delivery platform integration, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a restaurant website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional restaurant website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with menu pages, contact form, and Google Maps integration. Business and Premium packages add online ordering, multi-location support, and delivery platform integration." } },
      { "@type": "Question", "name": "Can you add online ordering to my restaurant website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include online ordering integration. We can connect your website to platforms like GrabFood and Deliveroo, or build a standalone ordering system directly on your site so you keep more of each sale." } },
      { "@type": "Question", "name": "Do you help with food photography for the website?", "acceptedAnswer": { "@type": "Answer", "text": "We partner with professional food photographers in Singapore and can coordinate a shoot as part of your project. Great food photography is critical for F&B websites — stock photos don't cut it when customers want to see your actual dishes before visiting." } },
      { "@type": "Question", "name": "Will my restaurant show up on Google Maps after the website is built?", "acceptedAnswer": { "@type": "Answer", "text": "We optimise your website for local SEO and integrate Google Maps on your contact page. We also help set up and optimise your Google Business Profile so your restaurant appears in Google Maps and local search results when people search for restaurants near them." } },
      { "@type": "Question", "name": "How long does it take to build a restaurant website?", "acceptedAnswer": { "@type": "Answer", "text": "Most restaurant websites go live within 2–3 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with online ordering or multi-location features may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "F&B Website Design Singapore", "item": "https://jraftcreative.com/fnb-website-design-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="F&B Website Design Singapore — Restaurant & Cafe Websites | Jraft Creative"
  description="Professional website design for restaurants, cafes, and F&B businesses in Singapore. Menu integration, online ordering, and Google Maps — from S$2,500."
  canonical="https://jraftcreative.com/fnb-website-design-singapore/"
  ogTitle="F&B Website Design Singapore — Jraft Creative"
  ogDescription="Website design for restaurants, cafes, and F&B businesses in Singapore. Menu integration, online ordering, Google Maps — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="fnb website design singapore, restaurant website singapore, cafe website design singapore, food and beverage website, restaurant web design, f&b digital marketing singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="F&B Website Design"
  heroTitle='Website Design for Restaurants &amp; <span class="highlight">F&amp;B in Singapore</span>'
  heroSubtitle="Your food deserves a website that does it justice. We build fast, mobile-friendly websites for restaurants, cafes, and F&B businesses — with menu integration, online ordering, and local SEO built in."
  heroImage="/images/service-fnb.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my F&B business in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your F&B Business Online"
  ctaDescription="Book a free consultation and tell us about your restaurant, cafe, or F&B concept. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20F%26B%20business%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why F&B businesses need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Your Menu Deserves More Than a PDF</h2>
      </div>
      <div class="section-content reveal">
        <p>Too many restaurants and cafes in Singapore are losing customers before they even walk through the door. An outdated website with a PDF menu, no mobile ordering option, and missing Google Maps listing tells potential diners that your business isn't keeping up.</p>
        <p>Customers searching for "restaurants near me" or "best cafe in Singapore" expect to see your menu, photos, location, and opening hours in seconds — on their phone. If your site loads slowly, looks broken on mobile, or doesn't show up on Google Maps, they'll pick the next place that does.</p>
        <p>Singapore's F&B scene is fiercely competitive. Whether you run a hawker concept, a fine-dining restaurant, or a neighbourhood cafe, your website is the digital front door to your business — and it needs to work as hard as your kitchen does.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="F&B website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for F&amp;B Businesses</h2>
      </div>
      <div class="section-content reveal">
        <p>Every F&B website we deliver is purpose-built for the food and beverage industry. We go beyond a generic template — your site will feature proper menu layouts, appetising food photography, online ordering capability, and local SEO so customers can find you on Google Maps.</p>
        <p>We understand that F&B businesses in Singapore need more than just a website. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/">SEO services</a> to rank for local food searches, <a href="/services/social-media/">social media marketing</a> for food photography content that drives foot traffic, and <a href="/services/paid-ads/">paid ads management</a> for food delivery and restaurant promotion campaigns.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Menu &amp; Ordering Integration</h3>
            <p>Beautiful, browsable menu pages with dish descriptions, pricing, and photos — plus online ordering integration so customers can order directly from your site.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Mobile-First Design</h3>
            <p>Over 80% of diners check restaurant websites on their phone. Every F&B site we build is designed mobile-first so your menu, location, and booking flow work perfectly on any device.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Local SEO &amp; Google Maps</h3>
            <p>We optimise your site for local search so you appear when customers search "restaurants near me." Google Business Profile setup, schema markup, and maps integration included.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-graphic-design.webp">
          <div class="service-detail-card__content">
            <h3>Food Photography Showcase</h3>
            <p>High-quality image galleries, full-bleed hero shots, and optimised food photography that makes your dishes look as good on screen as they taste in person.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for F&B website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for F&amp;B Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We've worked with restaurants, cafes, and food brands across Singapore. We know what drives diners to book a table, place an order, or walk through the door — and we design every element of your website around that.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>F&amp;B Industry Experience</h3>
            <p>We understand the unique needs of food businesses — from menu layouts and reservation systems to delivery integrations and peak-hour traffic handling.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most F&B websites go live within 2 weeks of kickoff. We know time matters when you're opening a new outlet or refreshing your brand.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Every site is designed for the phone-first diner. Fast load times, thumb-friendly navigation, and tap-to-call buttons so customers can reach you instantly.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can handle your entire online presence so you can focus on running your kitchen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="F&B website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">F&B Website Pricing</p>
        <h2>Website Packages for Restaurants &amp; Cafes</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For new restaurants and cafes getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Menu pages with pricing</li>
              <li>Contact page &amp; Google Maps</li>
              <li>Mobile-responsive design</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For F&B businesses ready to grow online.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Online ordering integration</li>
              <li>Blog / news section</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Business Profile setup</li>
              <li>Food photography gallery</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For multi-location or high-volume F&B brands.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Multi-location support</li>
              <li>Delivery platform integration</li>
              <li>Reservation / booking system</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about F&B website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>F&amp;B Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a restaurant website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional restaurant website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with menu pages, contact form, and Google Maps integration. Business and Premium packages add online ordering, multi-location support, and delivery platform integration.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you add online ordering to my restaurant website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include online ordering integration. We can connect your website to platforms like GrabFood and Deliveroo, or build a standalone ordering system directly on your site so you keep more of each sale.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you help with food photography for the website?</summary>
          <div class="faq-answer"><p>We partner with professional food photographers in Singapore and can coordinate a shoot as part of your project. Great food photography is critical for F&B websites — stock photos don't cut it when customers want to see your actual dishes before visiting.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Will my restaurant show up on Google Maps after the website is built?</summary>
          <div class="faq-answer"><p>We optimise your website for local SEO and integrate Google Maps on your contact page. We also help set up and optimise your Google Business Profile so your restaurant appears in Google Maps and local search results when people search for restaurants near them.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build a restaurant website?</summary>
          <div class="faq-answer"><p>Most restaurant websites go live within 2–3 weeks. A simple 5-page site can be ready in as little as 2 weeks, while larger projects with online ordering or multi-location features may take 3–4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>


  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore More</p>
        <h2>More F&B Services</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/fnb-seo-singapore/" class="related-service-link">F&B SEO</a>
          <a href="/fnb-marketing-agency-singapore/" class="related-service-link">F&B Marketing</a>
          <a href="/fnb-social-media-singapore/" class="related-service-link">F&B Social Media</a>
          <a href="/fnb-google-ads-singapore/" class="related-service-link">F&B Google Ads</a>
          <a href="/fnb-branding-singapore/" class="related-service-link">F&B Branding</a>
          <a href="/fnb-content-marketing-singapore/" class="related-service-link">F&B Content Marketing</a>
      </div>
    </div>
  </section>
</ServiceLayout>
