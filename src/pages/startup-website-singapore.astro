---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Startup Website Design Singapore",
    "description": "Website design for startups in Singapore — launch in 2 weeks with a fast, conversion-focused site. Fixed-price packages from S$2,500. No monthly lock-ins.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Startup Web Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page responsive website with contact form, basic SEO, and 2-week delivery for startups" },
      { "@type": "Offer", "name": "Business Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page custom website with CMS, blog, advanced SEO, Google Analytics, and pitch deck integration for growing startups" },
      { "@type": "Offer", "name": "Premium Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom website with unlimited pages, API integrations, investor portal, and priority support for funded startups" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a startup website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional startup website in Singapore typically costs between $2,500 and $10,000+ SGD depending on the number of pages and features. Our Starter package at $2,500 includes a 5-page responsive website with a lead capture form and basic SEO — everything an early-stage startup needs to establish credibility online." } },
      { "@type": "Question", "name": "Can you build an MVP landing page for my startup?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build focused MVP landing pages designed to validate your idea, capture early sign-ups, and impress potential investors. A single-page MVP site can be delivered in as little as one week, with room to expand as your startup grows." } },
      { "@type": "Question", "name": "How fast can you launch my startup website?", "acceptedAnswer": { "@type": "Answer", "text": "Most startup websites go live within 2 weeks of kickoff. If you need a simple MVP landing page, we can deliver in as little as one week. We move fast because we know speed matters when you're launching — every day without a website is a missed opportunity." } },
      { "@type": "Question", "name": "Do you work with pre-revenue startups?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Many of our clients are pre-revenue founders building their first product. Our Starter package at $2,500 is designed specifically for early-stage startups that need a professional web presence without enterprise-level costs. No monthly retainers or hidden fees." } },
      { "@type": "Question", "name": "What happens after my startup website launches?", "acceptedAnswer": { "@type": "Answer", "text": "You own your website and all its code outright — no lock-ins. We offer optional maintenance plans, and as your startup grows, we can scale your site with additional pages, features, blog content, SEO, and paid advertising. Many startups come back to us for ongoing digital marketing as they gain traction." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Startup Website Singapore", "item": "https://jraftcreative.com/startup-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Startup Website Singapore — Launch Fast, Look Professional | Jraft Creative"
  description="Website design for startups in Singapore — launch in 2 weeks with a fast, conversion-focused site. Fixed-price packages from S$2,500. No monthly lock-ins."
  canonical="https://jraftcreative.com/startup-website-singapore/"
  ogTitle="Startup Website Singapore — Jraft Creative"
  ogDescription="Website design for startups in Singapore. Fast, conversion-focused sites from $2,500 SGD. Launch in 2 weeks with no lock-in contracts."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="startup website singapore, startup web design singapore, startup landing page singapore, mvp website singapore, tech startup website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Startup Websites"
  heroTitle='Website Design for <span class="highlight">Startups in Singapore</span>'
  heroSubtitle="Your startup deserves more than a half-finished template. Get a fast, conversion-focused website that impresses investors and converts customers — from S$2,500 with 2-week delivery and no monthly lock-ins."
  heroImage="/images/service-web-dev.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Pricing", href: "#pricing", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my startup in Singapore."
  ctaLabel="Ready to Launch?"
  ctaTitle="Launch Your Startup Website"
  ctaDescription="Tell us about your startup and we'll recommend the right website package. Free consultation — no obligations, no pressure."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20startup%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why startups need a professional website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>First Impressions Matter — Especially for Startups</h2>
      </div>
      <div class="section-content reveal">
        <p>Investors, customers, and partners check your website first. A generic template or no website at all signals that you're not serious — and in Singapore's competitive startup ecosystem, that first impression can make or break a deal.</p>
        <p>But startups also can't afford to spend $20,000 on a website. You need something that looks professional, loads fast, and converts visitors — without draining the runway you should be spending on product development and growth.</p>
        <p>That's where we come in. We build sharp, conversion-focused websites specifically for startups — fast enough to keep pace with your launch timeline and affordable enough to fit a seed-stage budget.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD FOR STARTUPS ========== -->
  <section class="section" id="sub-services" aria-label="What we build for startups">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Startups</h2>
      </div>
      <div class="section-content reveal">
        <p>Every startup website we build is designed to do one thing well — get your business taken seriously. Whether you're pitching to VCs, launching a product, or capturing early leads, your site should work as hard as you do.</p>
        <p>Startups get the best results when they combine a great website with <a href="/services/seo-performance/">SEO services</a> for organic growth, <a href="/services/paid-ads/">paid advertising</a> for user acquisition, and <a href="/services/social-media/">social media marketing</a> for brand building. See our <a href="/digital-marketing-agency-singapore/">full-service digital marketing packages</a> for bundled options.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-responsive-web.webp">
          <div class="service-detail-card__content">
            <h3>Investor-Ready Landing Pages</h3>
            <p>Clean, compelling pages that communicate your value proposition in seconds. Designed to give investors confidence in your brand before they even take the meeting.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-ui-ux.webp">
          <div class="service-detail-card__content">
            <h3>Product Showcase</h3>
            <p>Highlight your product's features, benefits, and use cases with structured layouts, demo sections, and clear calls to action that move visitors toward sign-up or purchase.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-analytics-reporting.webp">
          <div class="service-detail-card__content">
            <h3>Lead Generation</h3>
            <p>Integrated contact forms, email capture, and WhatsApp links designed to convert visitors into early adopters, beta testers, or paying customers from day one.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-onpage-seo.webp">
          <div class="service-detail-card__content">
            <h3>SEO Foundation</h3>
            <p>Proper heading structure, meta tags, schema markup, and a crawlable architecture so Google can index your startup from launch — giving you organic visibility while you build traction.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-speed-vitals.webp">
          <div class="service-detail-card__content">
            <h3>Scalable Architecture</h3>
            <p>Built on a lightweight, modern tech stack that scales with your business. Add pages, features, a blog, or an API layer as your startup grows — without rebuilding from scratch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY STARTUPS CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why startups choose Jraft Creative">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Startups Choose Us</p>
        <h2>Built for Speed, Priced for Startups</h2>
      </div>
      <div class="section-content reveal">
        <p>We work with founders across Singapore who need to move fast and stay lean. No bloated proposals, no unnecessary features — just a professional website that helps you launch, raise, and grow.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Speed to Market</h3>
            <p>Most startup websites go live within 2 weeks of kickoff. MVP landing pages can be ready in as little as one week. We match your pace because we know launch timing is everything.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Startup-Friendly Pricing</h3>
            <p>Fixed-price packages from $2,500 with no hidden fees, no hourly billing, and no monthly retainers. You get a clear quote upfront and that's what you pay.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Scalable &amp; Future-Proof</h3>
            <p>Your website is built to grow with your business. Add new pages, features, integrations, or a blog as you scale — without starting over or switching platforms.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Support</h3>
            <p>Web, SEO, paid ads, and social media all under one roof. As your startup gains traction, we can layer on marketing services without you needing to manage multiple agencies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Startup website pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Pricing</p>
        <h2>Startup Website Packages</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For early-stage startups getting online.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Responsive design</li>
              <li>Contact / lead form</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For startups ready to scale.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Custom branding</li>
              <li>CMS / blog integration</li>
              <li>Advanced SEO &amp; schema</li>
              <li>Google Analytics setup</li>
              <li>Pitch deck integration</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For funded startups with advanced needs.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features</li>
              <li>API integrations</li>
              <li>Investor portal</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about startup websites in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Startup Website Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does a startup website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional startup website in Singapore typically costs between $2,500 and $10,000+ SGD depending on the number of pages and features. Our Starter package at $2,500 includes a 5-page responsive website with a lead capture form and basic SEO — everything an early-stage startup needs to establish credibility online.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can you build an MVP landing page for my startup?</summary>
          <div class="faq-answer"><p>Yes. We build focused MVP landing pages designed to validate your idea, capture early sign-ups, and impress potential investors. A single-page MVP site can be delivered in as little as one week, with room to expand as your startup grows.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>How fast can you launch my startup website?</summary>
          <div class="faq-answer"><p>Most startup websites go live within 2 weeks of kickoff. If you need a simple MVP landing page, we can deliver in as little as one week. We move fast because we know speed matters when you're launching — every day without a website is a missed opportunity.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Do you work with pre-revenue startups?</summary>
          <div class="faq-answer"><p>Absolutely. Many of our clients are pre-revenue founders building their first product. Our Starter package at $2,500 is designed specifically for early-stage startups that need a professional web presence without enterprise-level costs. No monthly retainers or hidden fees.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>What happens after my startup website launches?</summary>
          <div class="faq-answer"><p>You own your website and all its code outright — no lock-ins. We offer optional maintenance plans, and as your startup grows, we can scale your site with additional pages, features, blog content, SEO, and paid advertising. Many startups come back to us for ongoing digital marketing as they gain traction.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
