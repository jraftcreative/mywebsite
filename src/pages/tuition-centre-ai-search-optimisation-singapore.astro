      { "@type": "Question", "name": "How long before my tuition centre appears in AI recommendations?", "acceptedAnswer": { "@type": "Answer", "text": "Most tuition centres see measurable changes in AI citation rates within 30 to 90 days. Technical implementations like schema markup and llms.txt can improve visibility within weeks. Building parent reviews and authority signals produces compounding results over time." } },
      { "@type": "Question", "name": "How much does tuition centre AI search optimisation cost?", "acceptedAnswer": { "@type": "Answer", "text": "Our GEO plans for tuition centres start at $3,000 SGD/month for the Essentials package. Growth plans at $5,000/month add authority building, answer engine content, and a dedicated strategist. Enterprise plans from $10,000/month deliver full-service AI search domination across all platforms." } }
