      { "@type": "Offer", "name": "GEO Enterprise", "price": "10000", "priceCurrency": "SGD", "description": "Full-service AI search domination with defensive monitoring, Wikipedia strategy, weekly calls, 50+ prompt monitoring, sentiment defence" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Why does my tuition centre need AI search optimisation?", "acceptedAnswer": { "@type": "Answer", "text": "Parents in Singapore increasingly ask ChatGPT and Gemini for tuition centre recommendations before enrolling their children. These are extremely high-intent queries — a parent asking AI for the best PSLE maths tutor is ready to act. If your centre isn't in the AI answer, you lose that enrolment." } },
