---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Law Firm Marketing Singapore",
    "description": "Full-service marketing for law firms and lawyers in Singapore. Practice-area websites with enquiry capture, Google + Meta ads on high-intent legal searches, and explainer and thought-leadership content that builds authority. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015 before publish.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Law Firm Marketing Services",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Law Firm Marketing Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Law Firm Website Design",
            "description": "Practice-area websites for Singapore law firms — clear pages per practice area, enquiry capture, mobile-first, lawyer profiles, and content reviewed against the Legal Profession (Professional Conduct) Rules 2015."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Paid Ads for Law Firms (Google + Meta)",
            "description": "High-intent legal search ads — 'divorce lawyer Singapore', 'conveyancing lawyer Singapore', 'corporate lawyer Singapore' — practice-area targeting, retargeting recent visitors, and a Publicity-Rules review on every ad."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Social Media & Content for Law Firms",
            "description": "Legal explainer content and thought-leadership that builds authority within the Legal Profession (Professional Conduct) Rules 2015 — articles, short-form video and posts on a consistent cadence."
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your ads follow the Legal Profession (Professional Conduct) Rules 2015?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, page, caption and content piece is checked against the Legal Profession (Professional Conduct) Rules 2015 before it goes live. That means nothing false, misleading, deceptive or inaccurate; no advertising of success rates; no claims of expertise we can't justify; no comparisons that disparage other lawyers' fees or service; no client information that would breach confidentiality; and nothing that amounts to touting or improper soliciting. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "I get most of my work from referrals — why do I need marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Referrals are excellent, but they're capped by the size of your network and you don't control the timing. When someone is referred to you, they almost always search your name and your firm before they call — and increasingly people search the practice area first ('divorce lawyer Singapore', 'employment lawyer Singapore') and shortlist whoever they find and trust. A clear website, a presence on the searches that matter, and consistent content mean referrals land somewhere credible and that you also pick up enquiries your network was never going to send you." } },
      { "@type": "Question", "name": "What does law firm marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on which mix you start with. A solo practitioner or very small firm kicking off with a practice-area website and a starter Google + Meta budget typically sits between $2,500 and $4,000/month all-in. Firms adding consistent content, thought-leadership and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you." } },
      { "@type": "Question", "name": "Can you target by practice area?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is where most of the leverage sits. We build a page per practice area and run search ads against the exact intent: 'divorce lawyer Singapore', 'conveyancing lawyer Singapore', 'corporate lawyer Singapore', 'criminal lawyer Singapore', 'probate lawyer Singapore'. Someone typing those is actively looking for representation now. If you specialise in one or two areas, we concentrate the budget there rather than spreading it thin across everything." } },
      { "@type": "Question", "name": "I'm starting my own firm — can you handle the launch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a new-firm launch is one of the more common engagements we run. Firm name and logo lockup, a website with your practice-area pages and lawyer profiles, email and contact details, the right credential and admission details displayed correctly, ad accounts and tracking set up, and a launch content plan so your network knows where you've gone. We run the Publicity-Rules review across the launch assets before anything publishes. Most launches go live cleanly in 2–3 weeks." } },
      { "@type": "Question", "name": "Do you do content and thought-leadership for lawyers?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Plain-English explainers on the questions clients actually search ('what happens at the first divorce hearing', 'how conveyancing works for a HDB resale'), articles and short-form video, and thought-leadership that positions you as the lawyer who knows the area. Content is where authority is built within the Rules — we keep it accurate, avoid anything that reads as a guarantee of outcome, and don't use client matters in a way that breaches confidentiality. All scripts and drafts go through the same Publicity-Rules check as the ads." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Law Firm Marketing Singapore", "item": "https://jraftcreative.com/law-firm-marketing-singapore/" }
    ]
  }
];
---

<style is:global>
  /* Hide the global background grid pattern on this page only */
  .animated-bg__grid { display: none; }

  /* More-prominent related-service pills — match challenge-card-v2 green treatment */
  #related-services .related-service-link {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.35);
    color: var(--text);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  #related-services .related-service-link:hover {
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.22) 0%, rgba(73, 184, 137, 0.1) 100%), rgba(20, 28, 32, 0.7);
    border-color: rgba(73, 184, 137, 0.6);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(73, 184, 137, 0.3);
  }

  /* Separate the CTA section from related-services with bg-alt */
  .service-cta-section {
    background: var(--bg-alt) !important;
  }

  /* Gym Member Funnel — 5-stage horizontal flow with green accents */
  .renovation-funnel {
    list-style: none;
    padding: 0;
    margin: 56px 0 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    counter-reset: funnel;
  }
  .funnel-stage {
    position: relative;
    text-align: center;
    padding: 28px 20px;
    background: linear-gradient(135deg, rgba(73, 184, 137, 0.14) 0%, rgba(73, 184, 137, 0.06) 100%), rgba(20, 28, 32, 0.6);
    border: 1px solid rgba(73, 184, 137, 0.28);
    border-radius: 12px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .funnel-stage:hover {
    transform: translateY(-4px);
    border-color: rgba(73, 184, 137, 0.55);
    box-shadow: 0 16px 40px -16px rgba(73, 184, 137, 0.3);
  }
  .funnel-stage h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--accent);
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }
  .funnel-stage p {
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.5;
    margin: 0;
  }
  .funnel-stage:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -34px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.6rem;
    font-weight: 500;
    z-index: 2;
    line-height: 1;
    opacity: 0.7;
  }
  @media (max-width: 900px) {
    .renovation-funnel {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
    .funnel-stage:nth-child(2n)::after,
    .funnel-stage:last-child::after {
      display: none;
    }
    .funnel-stage:nth-child(2n-1)::after {
      right: -22px;
    }
  }
  @media (max-width: 600px) {
    .renovation-funnel {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .funnel-stage::after {
      display: none;
    }
  }
</style>

<ServiceLayout
  title="Marketing for Law Firms in Singapore — Publicity-Rules Reviewed"
  description="Full-service marketing for law firms and lawyers in SG — practice-area websites, Google + Meta ads, and content. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015."
  canonical="https://jraftcreative.com/law-firm-marketing-singapore/"
  ogTitle="Marketing for Law Firms in Singapore — Publicity-Rules Reviewed"
  ogDescription="Full-service marketing for law firms and lawyers in SG — practice-area websites, Google + Meta ads, and content. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="law firm marketing singapore, lawyer marketing singapore, legal marketing agency singapore, law firm website singapore, legal marketing, law firm advertising singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Law Firm Marketing"
  heroTitle='Marketing for <span class="highlight">Law Firms in Singapore</span>'
  heroSubtitle="Built for how SG legal clients actually find a lawyer — they search a practice area, read, then shortlist one firm. We run the website, the paid ads and the content that puts you in front of people looking for representation now. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015 before it goes live."
  heroImage="/law-firm-hero.jpg"
  heroImageAlt="Singapore lawyer in a client consultation — law firm marketing"
  heroButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my law firm in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at where your client enquiries are coming from"
  ctaDescription="Tell us your practice areas, whether you're solo, boutique or launching a new firm, and what your enquiry flow looks like today. We'll come back inside 24 hours with where we'd start — and what we'd review against the Publicity Rules first."
  ctaButtons={[
    { text: "Book Your Consultation", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why law firms need marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>The <span class="highlight">Best</span> Lawyers Are Still <span class="highlight">Losing Clients</span> to Firms with <span class="highlight">Better Marketing</span></h2>
      </div>
      <div class="section-content reveal">
        <p>When someone in Singapore needs a lawyer, they rarely start with a name — they start with a problem, search the practice area, read a few firms, and shortlist the one they can find, understand, and trust. The firms winning those enquiries aren't always the strongest advocates. They're the ones visible during that window.</p>
      </div>
      <div class="service-details-grid challenge-grid-v2" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>The Trust Test</h3>
            <p>Legal clients vet hard before they pick up the phone. They check your credentials, your practice-area pages, your reviews, and how clearly you explain their matter — often late at night, comparing several firms. If there's nothing to tell you apart from a directory line, the enquiry goes to whoever reads as more credible.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>The Compliance Line</h3>
            <p>"Best divorce lawyer in Singapore." "98% success rate." "We win more than [named firm]." Each of those can breach the Legal Profession (Professional Conduct) Rules 2015 — nothing false or misleading, no advertising of success rates, no disparaging comparisons. Generic agencies cross those lines without realising it. We review every asset against the Publicity Rules before it publishes.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>The High-Intent Window</h3>
            <p>"Corporate lawyer Singapore." "Divorce lawyer Jurong." "Conveyancing for HDB resale." Someone typing those is looking for representation now, on a matter that's worth real fees. Miss those searches and you're not in the running for the work that actually moves your billings — you're waiting on whatever referrals happen to arrive.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER ========== -->
  <section class="section" id="sub-services" style="background: var(--bg-alt);" aria-label="Marketing services for law firms in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Deliver</p>
        <h2>Six <span class="highlight">Marketing Channels</span> Every Law Firm <span class="highlight">Needs</span></h2>
      </div>
      <div class="section-content reveal">
        <p>We build marketing strategies specifically for law firms and lawyers — combining practice-area SEO, AI search optimisation, high-intent paid search, explainer content, branding, and conversion-focused web design. Every channel runs through a Legal Profession (Professional Conduct) Rules 2015 review before it goes live.</p>
      </div>
      <div class="service-details-grid deliver-grid">
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-local-seo.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/seo-performance/">SEO for Law Firms</a></h3>
            <p>Rank for the practice-area searches that signal real intent — "divorce lawyer Singapore", "conveyancing lawyer Singapore", "employment lawyer Bishan". A page per practice area, lawyer profile pages, and the long-tail explainer queries clients type before they shortlist.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-ai.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/law-firm-ai-search-optimisation-singapore/">GEO (AI Search)</a></h3>
            <p>Get cited when prospective clients ask ChatGPT, Gemini, Perplexity, or Google AI Mode for "best divorce lawyer Singapore" or "how does HDB conveyancing work". The same citation playbook we've used for our own agency, written to stay within the Publicity Rules.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-google-ads.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/paid-ads/">Google Ads for Law Firms</a></h3>
            <p>High-intent Google + Meta campaigns on the exact searches that convert — practice-area targeting, retargeting recent visitors, and a Publicity-Rules review on every ad. GCLID tracking ties each click back to a real enquiry, so budget concentrates where the matters are.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d1" style="background-image: url('/images/detail-reels-video.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/services/social-media/">Social Media for Law Firms</a></h3>
            <p>Plain-English explainers and short-form video on the questions clients actually search — "what happens at the first divorce hearing", "how a workplace injury claim works". Thought-leadership that builds authority within the Rules, never a guarantee of outcome.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d2" style="background-image: url('/images/detail-graphic-design.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/branding-agency-singapore/">Branding for Law Firms</a></h3>
            <p>The firm name and logo lockup, palette, and profile photography that make a boutique read as credible and established. Positioning that lets you out-specialise the big full-service firms instead of trying to out-spend them.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 deliver-card-with-bg reveal reveal-d3" style="background-image: url('/images/detail-business-website.webp');">
          <div class="service-detail-card__content">
            <h3><a href="/law-firm-website-singapore/">Websites for Law Firms</a></h3>
            <p>A practice-area site that turns search traffic into real enquiries — a clear page per practice area, lawyer profiles, the right credential and admission details displayed correctly, and enquiry capture that works on mobile. Reviewed against the Rules before launch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" aria-label="Why choose Jraft Creative for law firm marketing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2><span class="highlight">Marketing</span> Built for How <span class="highlight">Legal Clients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal">
        <p>Most agencies pitching law firms treat compliance as friction to route around, and treat a legal client like any other lead. We do the opposite — full-service, performance-led, and built around how Singaporeans actually choose a lawyer. We write to the Legal Profession (Professional Conduct) Rules 2015 as the spec, not as an afterthought, so campaigns ship instead of stalling in your principal's inbox.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card challenge-card-v2 reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Publicity-Rules Review on Everything</h3>
            <p>Every ad, page, caption and script is checked against the Legal Profession (Professional Conduct) Rules 2015 before it goes live — no success-rate claims, no disparaging comparisons, nothing that reads as touting. The compliance check sits inside your monthly report.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>One Agency, All Channels</h3>
            <p>SEO, GEO, Google Ads, Meta, social, branding, websites — under one roof. No coordinating between three vendors arguing about whose copy broke the Rules. Every channel delivers consistent positioning, design, and a single compliance thread.</p>
          </div>
        </div>
        <div class="service-detail-card challenge-card-v2 reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Enquiries, Not Vanity Metrics</h3>
            <p>We measure qualified enquiries and signed matters, not impressions. GCLID offline tracking and WhatsApp-routed enquiries prove which ad click became which consultation became which engaged client — the only numbers that move a firm's billings.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CLIENT FUNNEL ========== -->
  <section class="section" id="buyer-funnel" style="background: var(--bg-alt);" aria-label="The Client Funnel — how Singapore legal clients decide on a lawyer">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Client Funnel</p>
        <h2>How <span class="highlight">Legal Clients</span> Actually <span class="highlight">Decide</span></h2>
      </div>
      <div class="section-content reveal" style="margin-bottom: 24px;">
        <p>From the first "do I need a lawyer for this?" search to a signed engagement letter, every legal client in Singapore moves through the same five stages. We build marketing that shows up at each one — from research through to engagement.</p>
      </div>
      <ol class="renovation-funnel reveal">
        <li class="funnel-stage">
          <h3>Research</h3>
          <p>Practice-area search on Google &amp; AI tools</p>
        </li>
        <li class="funnel-stage">
          <h3>Shortlist</h3>
          <p>Comparing two to three firms they can find</p>
        </li>
        <li class="funnel-stage">
          <h3>Validate</h3>
          <p>Credentials, reviews, profile pages, content</p>
        </li>
        <li class="funnel-stage">
          <h3>Enquire</h3>
          <p>Form, call or WhatsApp to the firm</p>
        </li>
        <li class="funnel-stage">
          <h3>Engage</h3>
          <p>Consultation, engagement letter, matter opened</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Law firm marketing pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Law Firm Marketing Pricing</p>
        <h2><span class="highlight">Plans</span> for Firms of <span class="highlight">Every Size</span></h2>
        <p>Monthly retainer plans. No lock-in contracts. Scoped and quoted after a 30-minute call.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500–$4,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For solo practitioners and very small firms getting found.</p>
            <ul class="pricing-features">
              <li>Practice-area website</li>
              <li>Starter Google + Meta budget</li>
              <li>Conversion tracking setup</li>
              <li>Publicity-Rules review on every asset</li>
              <li>Monthly report with compliance check</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Growth</h3>
            <div class="price">$4,500–$8,000 <span>SGD/mo</span></div>
            <p class="pricing-desc">For firms adding content, thought-leadership and retargeting.</p>
            <ul class="pricing-features">
              <li>Everything in Starter</li>
              <li>Consistent content &amp; thought-leadership</li>
              <li>Retargeting recent visitors</li>
              <li>Multiple practice-area pages</li>
              <li>Monthly call &amp; reporting</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Custom</h3>
            <div class="price">Scoped <span>per firm</span></div>
            <p class="pricing-desc">For new-firm launches and multi-partner engagements.</p>
            <ul class="pricing-features">
              <li>New-firm launch — name, logo, full site</li>
              <li>Lawyer profiles &amp; credential display</li>
              <li>Ad accounts &amp; tracking from scratch</li>
              <li>Launch content plan</li>
              <li>Scoped and quoted after a 30-min call</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" style="background: var(--bg-alt);" aria-label="Frequently asked questions about law firm marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions lawyers actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your ads follow the Legal Profession (Professional Conduct) Rules 2015?</summary>
          <div class="faq-answer"><p>Yes. Every ad, page, caption and content piece is checked against the Legal Profession (Professional Conduct) Rules 2015 before it goes live. That means nothing false, misleading, deceptive or inaccurate; no advertising of success rates; no claims of expertise we can't justify; no comparisons that disparage other lawyers' fees or service; no client information that would breach confidentiality; and nothing that amounts to touting or improper soliciting. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I get most of my work from referrals — why do I need marketing?</summary>
          <div class="faq-answer"><p>Referrals are excellent, but they're capped by the size of your network and you don't control the timing. When someone is referred to you, they almost always search your name and your firm before they call — and increasingly people search the practice area first ("divorce lawyer Singapore", "employment lawyer Singapore") and shortlist whoever they find and trust. A clear website, a presence on the searches that matter, and consistent content mean referrals land somewhere credible and that you also pick up enquiries your network was never going to send you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What does law firm marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>It depends on which mix you start with. A solo practitioner or very small firm kicking off with a practice-area website and a starter Google + Meta budget typically sits between $2,500 and $4,000/month all-in. Firms adding consistent content, thought-leadership and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you target by practice area?</summary>
          <div class="faq-answer"><p>Yes — this is where most of the leverage sits. We build a page per practice area and run search ads against the exact intent: "divorce lawyer Singapore", "conveyancing lawyer Singapore", "corporate lawyer Singapore", "criminal lawyer Singapore", "probate lawyer Singapore". Someone typing those is actively looking for representation now. If you specialise in one or two areas, we concentrate the budget there rather than spreading it thin across everything.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I'm starting my own firm — can you handle the launch?</summary>
          <div class="faq-answer"><p>Yes — a new-firm launch is one of the more common engagements we run. Firm name and logo lockup, a website with your practice-area pages and lawyer profiles, email and contact details, the right credential and admission details displayed correctly, ad accounts and tracking set up, and a launch content plan so your network knows where you've gone. We run the Publicity-Rules review across the launch assets before anything publishes. Most launches go live cleanly in 2–3 weeks.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you do content and thought-leadership for lawyers?</summary>
          <div class="faq-answer"><p>Yes. Plain-English explainers on the questions clients actually search ("what happens at the first divorce hearing", "how conveyancing works for a HDB resale"), articles and short-form video, and thought-leadership that positions you as the lawyer who knows the area. Content is where authority is built within the Rules — we keep it accurate, avoid anything that reads as a guarantee of outcome, and don't use client matters in a way that breaches confidentiality. All scripts and drafts go through the same Publicity-Rules check as the ads.</p></div>
        </details>
      </div>
    </div>
