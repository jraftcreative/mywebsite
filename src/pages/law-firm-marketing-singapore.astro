---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Law Firm Marketing Singapore",
    "description": "Full-service marketing for law firms and lawyers in Singapore. Practice-area websites with enquiry capture, Google + Meta ads on high-intent legal searches, and explainer and thought-leadership content that builds authority. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015 before publish.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Law Firm Marketing Services",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Law Firm Marketing Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Law Firm Website Design",
            "description": "Practice-area websites for Singapore law firms — clear pages per practice area, enquiry capture, mobile-first, lawyer profiles, and content reviewed against the Legal Profession (Professional Conduct) Rules 2015."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Paid Ads for Law Firms (Google + Meta)",
            "description": "High-intent legal search ads — 'divorce lawyer Singapore', 'conveyancing lawyer Singapore', 'corporate lawyer Singapore' — practice-area targeting, retargeting recent visitors, and a Publicity-Rules review on every ad."
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Social Media & Content for Law Firms",
            "description": "Legal explainer content and thought-leadership that builds authority within the Legal Profession (Professional Conduct) Rules 2015 — articles, short-form video and posts on a consistent cadence."
          }
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do your ads follow the Legal Profession (Professional Conduct) Rules 2015?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every ad, page, caption and content piece is checked against the Legal Profession (Professional Conduct) Rules 2015 before it goes live. That means nothing false, misleading, deceptive or inaccurate; no advertising of success rates; no claims of expertise we can't justify; no comparisons that disparage other lawyers' fees or service; no client information that would breach confidentiality; and nothing that amounts to touting or improper soliciting. We share the compliance check inside the monthly report." } },
      { "@type": "Question", "name": "I get most of my work from referrals — why do I need marketing?", "acceptedAnswer": { "@type": "Answer", "text": "Referrals are excellent, but they're capped by the size of your network and you don't control the timing. When someone is referred to you, they almost always search your name and your firm before they call — and increasingly people search the practice area first ('divorce lawyer Singapore', 'employment lawyer Singapore') and shortlist whoever they find and trust. A clear website, a presence on the searches that matter, and consistent content mean referrals land somewhere credible and that you also pick up enquiries your network was never going to send you." } },
      { "@type": "Question", "name": "What does law firm marketing in Singapore actually cost?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on which mix you start with. A solo practitioner or very small firm kicking off with a practice-area website and a starter Google + Meta budget typically sits between $2,500 and $4,000/month all-in. Firms adding consistent content, thought-leadership and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you." } },
      { "@type": "Question", "name": "Can you target by practice area?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — this is where most of the leverage sits. We build a page per practice area and run search ads against the exact intent: 'divorce lawyer Singapore', 'conveyancing lawyer Singapore', 'corporate lawyer Singapore', 'criminal lawyer Singapore', 'probate lawyer Singapore'. Someone typing those is actively looking for representation now. If you specialise in one or two areas, we concentrate the budget there rather than spreading it thin across everything." } },
      { "@type": "Question", "name": "I'm starting my own firm — can you handle the launch?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a new-firm launch is one of the more common engagements we run. Firm name and logo lockup, a website with your practice-area pages and lawyer profiles, email and contact details, the right credential and admission details displayed correctly, ad accounts and tracking set up, and a launch content plan so your network knows where you've gone. We run the Publicity-Rules review across the launch assets before anything publishes. Most launches go live cleanly in 2–3 weeks." } },
      { "@type": "Question", "name": "Do you do content and thought-leadership for lawyers?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Plain-English explainers on the questions clients actually search ('what happens at the first divorce hearing', 'how conveyancing works for a HDB resale'), articles and short-form video, and thought-leadership that positions you as the lawyer who knows the area. Content is where authority is built within the Rules — we keep it accurate, avoid anything that reads as a guarantee of outcome, and don't use client matters in a way that breaches confidentiality. All scripts and drafts go through the same Publicity-Rules check as the ads." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Law Firm Marketing Singapore", "item": "https://jraftcreative.com/law-firm-marketing-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Marketing for Law Firms in Singapore — Publicity-Rules Reviewed"
  description="Full-service marketing for law firms and lawyers in SG — practice-area websites, Google + Meta ads, and content. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015."
  canonical="https://jraftcreative.com/law-firm-marketing-singapore/"
  ogTitle="Marketing for Law Firms in Singapore — Publicity-Rules Reviewed"
  ogDescription="Full-service marketing for law firms and lawyers in SG — practice-area websites, Google + Meta ads, and content. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015."
  ogImage="https://jraftcreative.com/images/og-webdev.jpg"
  keywords="law firm marketing singapore, lawyer marketing singapore, legal marketing agency singapore, law firm website singapore, legal marketing, law firm advertising singapore, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Law Firm Marketing"
  heroTitle='Marketing for <span class="highlight">Law Firms in Singapore</span>'
  heroSubtitle="Built for how SG legal clients actually find a lawyer — they search a practice area, read, then shortlist one firm. We run the website, the paid ads and the content that puts you in front of people looking for representation now. Every asset reviewed against the Legal Profession (Professional Conduct) Rules 2015 before it goes live."
  heroImage="/law-firm-hero.jpg"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need marketing for my law firm in Singapore."
  ctaLabel="Ready to talk?"
  ctaTitle="Let's look at where your client enquiries are coming from"
  ctaDescription="Tell us your practice areas, whether you're solo, boutique or launching a new firm, and what your enquiry flow looks like today. We'll come back inside 24 hours with where we'd start — and what we'd review against the Publicity Rules first."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20law%20firm%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
  hideDefaultCta={false}
>

  <!-- ========== THE PROBLEM ========== -->
  <section class="section" id="problem" aria-label="What law firms and lawyers in Singapore are up against">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Problem</p>
        <h2>Why a good lawyer can still be <span class="pillar-col__accent">invisible</span> online</h2>
      </div>
      <div class="section-content reveal">
        <p>When someone in Singapore needs a lawyer, they rarely start with a name — they start with a problem. "Divorce lawyer Singapore." "Conveyancing for HDB resale." "What to do after a workplace injury." They search, read a few firms, and shortlist the one that explains things clearly and feels trustworthy. The firms winning those enquiries aren't always the best advocates — they're the ones a client can actually find, understand, and trust before the first call.</p>
        <p>Here's what we usually find when we audit a solo practitioner or boutique firm's marketing:</p>
      </div>
      <div class="problem-grid">
        <article class="problem-card reveal reveal-d1">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <p class="problem-card__index">01</p>
            <h3 class="problem-card__title">Indistinguishable from <span class="problem-card__accent">every directory listing</span></h3>
            <p class="problem-card__copy">Your firm appears as one line in a legal directory or a search-portal list, next to a dozen others with the same template blurb. A client comparing firms tonight has nothing to tell you apart — no clear practice-area page, no plain-English explanation of how you'd handle their matter. The work that builds that distinction is exactly the work most firms never get to.</p>
          </div>
        </article>
        <article class="problem-card reveal reveal-d2">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <p class="problem-card__index">02</p>
            <h3 class="problem-card__title">Out-spent by the <span class="problem-card__accent">big full-service firms</span></h3>
            <p class="problem-card__copy">The large firms run firm-wide brand presence and sit at the top of broad searches. As a solo practitioner or boutique, you can't out-spend them — but you can out-specialise them. Tighter practice-area focus, sharper content, and ads aimed at the exact intent you actually want, where a generalist budget gets diluted.</p>
          </div>
        </article>
        <article class="problem-card reveal reveal-d3">
          <div class="problem-card__bar"></div>
          <div class="problem-card__body">
            <p class="problem-card__index">03</p>
            <h3 class="problem-card__title">Publicity-Rules breaches <span class="problem-card__accent">quietly creeping in</span></h3>
            <p class="problem-card__copy">"Best divorce lawyer in Singapore." "98% success rate." "We win more than [named firm]." Each of those can run into the Legal Profession (Professional Conduct) Rules 2015 — nothing false or misleading, no advertising of success rates, no disparaging comparisons with other lawyers. We've seen DIY legal ads where the headline alone is a problem. We review every asset before it publishes so it doesn't become one.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE DELIVER — 3 PILLARS ========== -->
  <section class="section" id="what-we-deliver" style="background: var(--bg-alt);" aria-label="What we deliver — three service pillars for law firms">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What we deliver</p>
        <h2>Your <span class="pillar-col__accent">marketing engine</span>, three pillars.</h2>
      </div>
      <div class="pillars-grid">
        <!--
          Image: Unsplash — empty courtroom with wooden panelling
          Source: https://unsplash.com/photos/an-empty-courtroom-with-wooden-paneling-and-columns-Bh6u25Qv9qA
          Photographer: Dragon White Munthe (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--website reveal reveal-d1" id="website">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <p class="pillar-col__label">Service 1</p>
            <h3 class="pillar-col__title">Website</h3>
            <p class="pillar-col__lede">A practice-area site that turns search traffic into real enquiries — a clear page per practice area, lawyer profiles, and enquiry capture that works on mobile.</p>
          </div>
        </article>

        <!--
          Image: Unsplash — wall of legal books / law library
          Source: https://unsplash.com/photos/book-lot-on-black-wooden-shelf-zeH-ljawHtg
          Photographer: Giammarco Boscaro (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--ads reveal reveal-d2" id="paid-ads">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <p class="pillar-col__label">Service 2</p>
            <h3 class="pillar-col__title">Paid Ads</h3>
            <p class="pillar-col__lede">Google + Meta on high-intent legal searches — "divorce lawyer Singapore", "conveyancing lawyer Singapore", "corporate lawyer Singapore" — every ad Publicity-Rules reviewed.</p>
          </div>
        </article>

        <!--
          Image: Unsplash — law office interior
          Source: https://unsplash.com/photos/hallway-between-glass-panel-doors-yWwob8kwOCk
          Photographer: Nastuh Abootalebi (Unsplash License — free commercial use)
        -->
        <article class="pillar-col pillar-col--image pillar-col--social reveal reveal-d3" id="social-media">
          <div class="pillar-col__overlay"></div>
          <div class="pillar-col__bar"></div>
          <div class="pillar-col__content">
            <p class="pillar-col__label">Service 3</p>
            <h3 class="pillar-col__title">Social & Content</h3>
            <p class="pillar-col__lede">Legal explainers and thought-leadership that build authority within the Rules — plain-English content that earns trust before the first call.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ========== WHO THIS IS FOR ========== -->
  <section class="section" id="who-this-is-for" aria-label="Who this is for">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Who this is for</p>
        <h2><span class="pillar-col__accent">Right fit</span> if you're one of these</h2>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Solo practitioner or very small firm</h3>
            <p>You run your own practice or a two-to-three-lawyer firm. You handle the matters and the business, and marketing is the thing that keeps getting pushed to next quarter. You want a steady flow of enquiries coming to your name and your firm — not whatever a directory sends you when you happen to be near the top.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Boutique firm in one practice area</h3>
            <p>You specialise — family, conveyancing, criminal, corporate, employment or IP — and you do it well. Generalist marketing wastes your budget. We aim everything at the exact intent your area attracts, with content that proves you actually know the work, so the right clients find the right specialist.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Lawyer going independent or a new firm launching</h3>
            <p>You're leaving a larger firm or starting fresh. New name, new website, new presence, and a network that needs to know where you've gone. We handle the launch end-to-end and run the Publicity-Rules review across every starter asset before it goes live.</p>
          </div>
        </div>
      </div>
      <div class="who-cta reveal">
        <p class="who-cta__text">Not sure which one is you? That's exactly what the first call is for.</p>
        <a href="/contact/" class="btn btn-primary">Get a Free Quote</a>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="section" id="how-it-works" style="background: var(--bg-alt);" aria-label="How law firm marketing engagement runs">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">How it works</p>
        <h2>Three steps. No 90-day onboarding theatre.</h2>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>1. 30-minute scoping call</h3>
            <p>You walk us through your practice areas, your firm's stage (solo, boutique or launching), where enquiries come from today, and the matters you most want more of. We tell you which of the three services to start with. No deck, no sales pressure.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>2. Week 1–2: setup</h3>
            <p>Website wireframes (if applicable), ad accounts, conversion tracking, content plan, and a Legal Profession (Professional Conduct) Rules 2015 review of every starter asset. Ads typically go live by day 10. Website usually goes live in 2–3 weeks.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>3. Month 2 onwards: run and report</h3>
            <p>Ads optimised weekly, content shipped on schedule, practice-area pages kept current, monthly call and monthly report with the compliance check included. No lock-in. Leave at the end of any month, no penalty.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about law firm marketing in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Questions lawyers actually ask us</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>Do your ads follow the Legal Profession (Professional Conduct) Rules 2015?</summary>
          <div class="faq-answer"><p>Yes. Every ad, page, caption and content piece is checked against the Legal Profession (Professional Conduct) Rules 2015 before it goes live. That means nothing false, misleading, deceptive or inaccurate; no advertising of success rates; no claims of expertise we can't justify; no comparisons that disparage other lawyers' fees or service; no client information that would breach confidentiality; and nothing that amounts to touting or improper soliciting. We share the compliance check inside the monthly report.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I get most of my work from referrals — why do I need marketing?</summary>
          <div class="faq-answer"><p>Referrals are excellent, but they're capped by the size of your network and you don't control the timing. When someone is referred to you, they almost always search your name and your firm before they call — and increasingly people search the practice area first ("divorce lawyer Singapore", "employment lawyer Singapore") and shortlist whoever they find and trust. A clear website, a presence on the searches that matter, and consistent content mean referrals land somewhere credible and that you also pick up enquiries your network was never going to send you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>What does law firm marketing in Singapore actually cost?</summary>
          <div class="faq-answer"><p>It depends on which mix you start with. A solo practitioner or very small firm kicking off with a practice-area website and a starter Google + Meta budget typically sits between $2,500 and $4,000/month all-in. Firms adding consistent content, thought-leadership and retargeting usually run between $4,500 and $8,000/month. We scope and quote each engagement after a 30-minute call — no fixed package pushed onto you.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can you target by practice area?</summary>
          <div class="faq-answer"><p>Yes — this is where most of the leverage sits. We build a page per practice area and run search ads against the exact intent: "divorce lawyer Singapore", "conveyancing lawyer Singapore", "corporate lawyer Singapore", "criminal lawyer Singapore", "probate lawyer Singapore". Someone typing those is actively looking for representation now. If you specialise in one or two areas, we concentrate the budget there rather than spreading it thin across everything.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>I'm starting my own firm — can you handle the launch?</summary>
          <div class="faq-answer"><p>Yes — a new-firm launch is one of the more common engagements we run. Firm name and logo lockup, a website with your practice-area pages and lawyer profiles, email and contact details, the right credential and admission details displayed correctly, ad accounts and tracking set up, and a launch content plan so your network knows where you've gone. We run the Publicity-Rules review across the launch assets before anything publishes. Most launches go live cleanly in 2–3 weeks.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you do content and thought-leadership for lawyers?</summary>
          <div class="faq-answer"><p>Yes. Plain-English explainers on the questions clients actually search ("what happens at the first divorce hearing", "how conveyancing works for a HDB resale"), articles and short-form video, and thought-leadership that positions you as the lawyer who knows the area. Content is where authority is built within the Rules — we keep it accurate, avoid anything that reads as a guarantee of outcome, and don't use client matters in a way that breaches confidentiality. All scripts and drafts go through the same Publicity-Rules check as the ads.</p></div>
        </details>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="section" id="final-cta" aria-label="Talk to us about your firm">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 0;">
        <p class="section-label">Next step</p>
        <h2>Tell us about your practice</h2>
        <p>30 minutes on the phone, no slide deck, no obligation. You'll leave with a clearer view of which of the three services to start with and whether we're the right team to run it.</p>
        <div class="hero-buttons" style="margin-top: 32px;">
          <a href="/contact/" class="btn btn-primary">Get a Free Quote</a>
          <a href="https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20marketing%20for%20my%20law%20firm%20in%20Singapore." class="btn btn-secondary" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="section" id="related-services" aria-label="Related services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Explore more</p>
        <h2>More for law firms</h2>
      </div>
      <div class="related-services-grid reveal">
          <a href="/law-firm-website-singapore/" class="related-service-link">Law Firm Website Design</a>
          <a href="/services/paid-ads/" class="related-service-link">Paid Ads Management</a>
          <a href="/services/social-media/" class="related-service-link">Social Media Marketing</a>
          <a href="/digital-marketing-agency-singapore/" class="related-service-link">Digital Marketing Agency</a>
      </div>
    </div>
  </section>
</ServiceLayout>

<style>
  /* ============================================================
     Section 2 — Problem cards
     3-column equal-width grid. All 3 cards same width and same
     height (align-items: stretch). Accent green top bar, mono
     "01 / 02 / 03" index, accent typographic highlight inside
     title. 5% accent-green gradient wash applied uniformly to
     all 3 cards. Bottom padding tight to the last line of copy.
     ============================================================ */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 32px;
    align-items: stretch;
  }

  .problem-card {
    position: relative;
    background: linear-gradient(150deg, rgba(73, 184, 137, 0.05) 0%, var(--bg-card) 55%);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 14px;
    padding: 36px 32px 28px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }

  .problem-card:hover {
    border-color: rgba(73, 184, 137, 0.35);
    background: var(--bg-card-hover);
    transform: translateY(-2px);
  }

  .problem-card__bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 3px;
    width: 64px;
    background: var(--accent);
    border-radius: 0 0 3px 0;
  }

  .problem-card__body {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .problem-card__index {
    font-family: var(--font-mono, "JetBrains Mono", ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
    line-height: 1;
  }

  .problem-card__title {
    font-size: 22px;
    line-height: 1.22;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .problem-card__accent {
    color: var(--accent);
    font-weight: 600;
  }

  .problem-card__copy {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.65;
    margin: 4px 0 0;
  }

  @media (max-width: 1024px) {
    .problem-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .problem-card {
      padding: 32px 24px 26px;
    }
  }

  /* ============================================================
     Section 3 — 3-pillar columns (image-backed)
     Side-by-side on desktop, stacks to 1 column on mobile.
     Uniform width and height (align-items: stretch). Each card
