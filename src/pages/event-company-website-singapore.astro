---
import ServiceLayout from '../layouts/ServiceLayout.astro';

const schemaData = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Event Company Website Design Singapore",
    "description": "Professional website design for event companies in Singapore. Event portfolio galleries, service package pages, enquiry and quote forms, testimonials, and venue partnership showcases — from S$2,500.",
    "provider": {
      "@type": "Organization",
      "name": "Jraft Creative",
      "url": "https://jraftcreative.com/",
      "logo": "https://jraftcreative.com/images/logo.png",
      "telephone": "+6582234578",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "60 Paya Lebar Road, Paya Lebar Square",
        "postalCode": "409051",
        "addressLocality": "Singapore",
        "addressCountry": "SG"
      }
    },
    "areaServed": { "@type": "Country", "name": "Singapore" },
    "serviceType": "Event Company Website Design",
    "offers": [
      { "@type": "Offer", "name": "Starter Event Website", "price": "2500", "priceCurrency": "SGD", "description": "5-page event company website with portfolio gallery, services overview, enquiry form, contact page, and basic SEO setup" },
      { "@type": "Offer", "name": "Business Event Website", "price": "5500", "priceCurrency": "SGD", "description": "10-page website with categorised event portfolio, service package pages, quote request form, testimonials section, blog, and advanced SEO with schema markup" },
      { "@type": "Offer", "name": "Premium Event Website", "price": "10000", "priceCurrency": "SGD", "description": "Fully custom event company website with venue partnership directory, client login portal, event calendar, multi-language support, and priority support" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an event company website cost in Singapore?", "acceptedAnswer": { "@type": "Answer", "text": "A professional event company website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with event portfolio, services page, and enquiry form. Business and Premium packages add quote request systems, testimonials, venue directories, and client portals." } },
      { "@type": "Question", "name": "Can clients request quotes directly through the website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Business package ($5,500) and above include a detailed quote request form where clients can specify their event type, guest count, venue preference, date, and budget range. You receive structured enquiries directly to your inbox — no more chasing details over WhatsApp." } },
      { "@type": "Question", "name": "Do you build event portfolio galleries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build categorised event portfolio galleries — corporate D&Ds, weddings, product launches, MICE events — with high-quality images, event descriptions, and optional video embeds. Each portfolio entry can include venue details, guest count, and services provided so prospects can see exactly what you deliver." } },
      { "@type": "Question", "name": "Can the website showcase venue partnerships?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build dedicated venue partnership pages or directories where you can highlight your preferred venues — hotels, convention centres, rooftop spaces, and outdoor locations across Singapore. Each listing can include venue photos, capacity details, and a direct link to enquire about that venue through your company." } },
      { "@type": "Question", "name": "How long does it take to build an event company website?", "acceptedAnswer": { "@type": "Answer", "text": "Most event company websites go live within 2–3 weeks. A 5-page portfolio site can be ready in 2 weeks, while larger projects with quote systems, venue directories, or client portals may take 3–4 weeks. We provide a clear timeline before starting." } }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jraftcreative.com/" },
      { "@type": "ListItem", "position": 2, "name": "Event Company Website Singapore", "item": "https://jraftcreative.com/event-company-website-singapore/" }
    ]
  }
];
---

<ServiceLayout
  title="Event Company Website Singapore — Event Web Design | Jraft Creative"
  description="Professional website design for event companies in Singapore. Event portfolio galleries, service package pages, enquiry and quote forms, testimonials, and venue partnership showcases — from S$2,500."
  canonical="https://jraftcreative.com/event-company-website-singapore/"
  ogTitle="Event Company Website Singapore — Jraft Creative"
  ogDescription="Website design for event companies in Singapore. Portfolio galleries, quote forms, venue showcases — from $2,500 SGD."
  ogImage="https://jraftcreative.com/images/og-web-dev.jpg"
  keywords="event company website singapore, event company website design singapore, event management website design, event planner website singapore, corporate event website, wedding event website singapore, AV rental website design, MICE event website, Jraft Creative"
  schemaData={schemaData}
  heroLabel="Event Company Websites"
  heroTitle='Website Design for <span class="highlight">Event Companies in Singapore</span>'
  heroSubtitle="From corporate D&amp;Ds at Marina Bay Sands to intimate weddings on Sentosa — your events deserve a website that does them justice. We build fast, conversion-focused websites for event management companies, AV rental firms, and corporate event planners across Singapore."
  heroImage="/images/service-event.webp"
  heroButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "See Our Work", href: "/services/website-development/#portfolio", class: "btn btn-secondary" }
  ]}
  whatsappText="Hi Jraft Creative, I need a website for my event company in Singapore."
  ctaLabel="Ready to Get Started?"
  ctaTitle="Get Your Event Company Online"
  ctaDescription="Book a free consultation and tell us about your event business. We'll get back to you within 24 hours with a tailored proposal."
  ctaButtons={[
    { text: "Get a Free Quote", href: "/contact/", class: "btn btn-primary" },
    { text: "Chat on WhatsApp", href: "https://wa.me/6582234578?text=Hi%20Jraft%20Creative%2C%20I%20need%20a%20website%20for%20my%20event%20company%20in%20Singapore.", class: "btn btn-secondary" }
  ]}
>

  <!-- ========== THE CHALLENGE ========== -->
  <section class="section" id="challenge" aria-label="Why event companies need a proper website">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">The Challenge</p>
        <h2>Event Companies Are Losing Bookings Without a Professional Website</h2>
      </div>
      <div class="section-content reveal">
        <p>Corporate HR teams planning annual D&amp;Ds, marketing managers sourcing launch event vendors, and couples searching for wedding planners all start with a Google search. If your event company relies on word-of-mouth referrals and a basic social media page, you are invisible to the majority of prospects actively looking for event services in Singapore. They will book the competitor with a polished website that showcases past events, outlines packages clearly, and makes it easy to request a quote.</p>
        <p>Singapore's event industry — from MICE conferences at Suntec to gala dinners at Raffles Hotel — is fiercely competitive. An Instagram grid cannot display your full portfolio by category, present detailed service packages with transparent pricing, collect structured enquiry data, or highlight your venue partnerships. Every lead that reaches you through a DM instead of a proper quote form means more manual back-and-forth, slower response times, and a higher chance of losing the booking to someone who made the process easier.</p>
        <p>Event planning is a high-trust purchase. Clients are committing thousands of dollars before they see any results. A professionally designed website with categorised portfolios, client testimonials, and detailed case studies builds the credibility needed to close those bookings — especially for corporate clients who need to justify vendor selection to their management team.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHAT WE BUILD ========== -->
  <section class="section" id="sub-services" aria-label="Event company website design services">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">What We Build</p>
        <h2>What We Build for Event Companies &amp; Planners</h2>
      </div>
      <div class="section-content reveal">
        <p>Every event company website we deliver is purpose-built for the events industry. We go beyond generic templates — your site will feature categorised event portfolios, structured quote request forms, testimonial showcases, and venue partnership directories designed to convert browsers into confirmed bookings.</p>
        <p>We understand that event companies in Singapore need more than just an online brochure. That's why we offer a full digital package: pair your new site with <a href="/services/seo-performance/" class="inline-link">SEO services</a> to rank for event-related searches, <a href="/services/social-media/" class="inline-link">social media marketing</a> to grow your brand presence, and <a href="/services/paid-ads/" class="inline-link">paid ads management</a> for targeted lead generation campaigns during peak booking seasons.</p>
      </div>
      <div class="service-details-grid">
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-business-website.webp">
          <div class="service-detail-card__content">
            <h3>Event Portfolio Galleries</h3>
            <p>Showcase your best events in categorised galleries — corporate D&amp;Ds, weddings, product launches, MICE conferences, and private parties. Each portfolio entry includes high-quality images, event descriptions, venue details, and guest count so prospects can see the scale and quality of your work at a glance.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d2" data-bg="/images/detail-landing-page.webp">
          <div class="service-detail-card__content">
            <h3>Service Packages &amp; Quote Forms</h3>
            <p>Dedicated pages for each service line — AV rental, decor, entertainment, full-service planning — with clear package breakdowns and pricing in SGD. Structured quote request forms capture event type, date, venue preference, guest count, and budget range so you receive qualified leads ready for a proposal.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d3" data-bg="/images/detail-community-mgmt.webp">
          <div class="service-detail-card__content">
            <h3>Testimonials &amp; Case Studies</h3>
            <p>Build trust with dedicated testimonial sections and detailed case studies from past events. Feature client quotes alongside event photos, highlight measurable outcomes — attendance numbers, client satisfaction ratings — and position your company as the proven choice for high-stakes events in Singapore.</p>
          </div>
        </div>
        <div class="service-detail-card service-detail-card--overlay reveal reveal-d1" data-bg="/images/detail-local-seo.webp">
          <div class="service-detail-card__content">
            <h3>Venue Partnerships &amp; Directory</h3>
            <p>Showcase your preferred venue partners — hotels like MBS and Shangri-La, convention centres like Suntec and MICE facilities at Resorts World Sentosa, rooftop bars, and outdoor event spaces. Each venue listing includes photos, capacity details, and a direct enquiry link so prospects can explore options without leaving your site.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY CHOOSE US ========== -->
  <section class="section" id="why-us" style="background: var(--bg-alt);" aria-label="Why choose Jraft Creative for event company website design">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Why Jraft Creative</p>
        <h2>Why Choose Us for Event Company Website Design</h2>
      </div>
      <div class="section-content reveal">
        <p>We have built websites for event management companies, AV rental firms, and corporate event planners across Singapore. We understand how prospects evaluate event vendors online and we build websites that turn that research into confirmed bookings.</p>
      </div>
      <div class="service-details-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Built for the Events Industry</h3>
            <p>We know the difference between a corporate gala, a product launch, and a wedding reception — and we build your website to speak to each audience. Service pages, portfolio categories, and quote forms are all structured around how event clients actually search and buy in Singapore.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d2">
          <div class="service-detail-card__content">
            <h3>Fast Turnaround — 2 Weeks</h3>
            <p>Most event company websites go live within 2 weeks of kickoff. Peak booking seasons like Q4 corporate events and the wedding season do not wait — we deliver quickly so you can start capturing leads before your competitors.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d3">
          <div class="service-detail-card__content">
            <h3>Mobile-First Always</h3>
            <p>Event planners and corporate buyers research vendors on their phones between meetings. Every site we build is designed for mobile first — fast load times, tap-to-call buttons, and quote forms that work perfectly on any screen size.</p>
          </div>
        </div>
        <div class="service-detail-card reveal reveal-d1">
          <div class="service-detail-card__content">
            <h3>Full Digital Package</h3>
            <p>Website, SEO, social media, and paid ads under one roof. We can manage your entire online presence — from ranking for "event company Singapore" on Google to running targeted ads during peak D&amp;D and wedding seasons — so you can focus on delivering great events.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" aria-label="Event company website design pricing">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">Event Website Pricing</p>
        <h2>Website Packages for Event Companies</h2>
        <p>One-time project fee. No monthly lock-ins.</p>
      </div>
      <div class="service-pricing">
        <div class="pricing-grid">
          <div class="pricing-card reveal reveal-d1">
            <h3>Starter</h3>
            <div class="price">$2,500 <span>SGD</span></div>
            <p class="pricing-desc">For event companies building their first professional website.</p>
            <ul class="pricing-features">
              <li>Up to 5 pages</li>
              <li>Event portfolio gallery (up to 3 categories)</li>
              <li>Services &amp; about page</li>
              <li>Enquiry form &amp; Google Maps</li>
              <li>Basic SEO setup</li>
              <li>2-week delivery</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Get Started</a>
          </div>
          <div class="pricing-card featured reveal reveal-d2">
            <h3>Business</h3>
            <div class="price">$5,500 <span>SGD</span></div>
            <p class="pricing-desc">For established event firms ready to scale their online presence.</p>
            <ul class="pricing-features">
              <li>Up to 10 pages</li>
              <li>Categorised event portfolio</li>
              <li>Quote request form with event details</li>
              <li>Testimonials &amp; case studies section</li>
              <li>Blog &amp; venue partnerships page</li>
              <li>Advanced SEO &amp; schema</li>
            </ul>
            <a href="/contact/" class="btn btn-primary">Get Started</a>
          </div>
          <div class="pricing-card reveal reveal-d3">
            <h3>Premium</h3>
            <div class="price">$10,000+ <span>SGD</span></div>
            <p class="pricing-desc">For large event management firms and multi-service agencies.</p>
            <ul class="pricing-features">
              <li>Unlimited pages</li>
              <li>Custom features &amp; design</li>
              <li>Client login portal &amp; event calendar</li>
              <li>Venue partnership directory</li>
              <li>Multi-language support</li>
              <li>Priority support</li>
            </ul>
            <a href="/contact/" class="btn btn-secondary">Let's Talk</a>
          </div>
        </div>
      </div>
      <div class="section-content reveal" style="margin-top: 2rem; text-align: center;">
        <p>See full service details on our <a href="/services/website-development/" class="inline-link">website development</a> page.</p>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section faq-section" id="faq" aria-label="Frequently asked questions about event company website design in Singapore">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-label">FAQ</p>
        <h2>Event Company Website Design Questions Answered</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item reveal reveal-d1">
          <summary>How much does an event company website cost in Singapore?</summary>
          <div class="faq-answer"><p>A professional event company website in Singapore typically costs between $2,500 and $10,000+ depending on features. Our Starter package at $2,500 SGD includes a 5-page site with event portfolio, services page, and enquiry form. Business and Premium packages add quote request systems, testimonials, venue directories, and client portals.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>Can clients request quotes directly through the website?</summary>
          <div class="faq-answer"><p>Yes. Our Business package ($5,500) and above include a detailed quote request form where clients can specify their event type, guest count, venue preference, date, and budget range. You receive structured enquiries directly to your inbox — no more chasing details over WhatsApp.</p></div>
        </details>
        <details class="faq-item reveal reveal-d3">
          <summary>Do you build event portfolio galleries?</summary>
          <div class="faq-answer"><p>Yes. We build categorised event portfolio galleries — corporate D&amp;Ds, weddings, product launches, MICE events — with high-quality images, event descriptions, and optional video embeds. Each portfolio entry can include venue details, guest count, and services provided so prospects can see exactly what you deliver.</p></div>
        </details>
        <details class="faq-item reveal reveal-d1">
          <summary>Can the website showcase venue partnerships?</summary>
          <div class="faq-answer"><p>Yes. We build dedicated venue partnership pages or directories where you can highlight your preferred venues — hotels, convention centres, rooftop spaces, and outdoor locations across Singapore. Each listing can include venue photos, capacity details, and a direct link to enquire about that venue through your company.</p></div>
        </details>
        <details class="faq-item reveal reveal-d2">
          <summary>How long does it take to build an event company website?</summary>
          <div class="faq-answer"><p>Most event company websites go live within 2-3 weeks. A 5-page portfolio site can be ready in 2 weeks, while larger projects with quote systems, venue directories, or client portals may take 3-4 weeks. We provide a clear timeline before starting.</p></div>
        </details>
      </div>
    </div>
  </section>

</ServiceLayout>
